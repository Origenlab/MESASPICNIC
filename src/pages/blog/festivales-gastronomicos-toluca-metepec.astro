        <img src="/img/mesa-picnic-comida-corporativa-empresas.webp" alt="Mesa de comida en festival" loading="lazy" width="400" height="270" />
        <img src="/img/corp-lanzamiento-1.avif" alt="Evento masivo en explanada" loading="lazy" width="400" height="270" />
      </div>
    </div>
