  <section class="art__section">
    <h2 class="art__h2">Costos típicos para festivales en zona Toluca</h2>
    <div class="art__table-wrap">
      <table class="art__table">
        <thead>
          <tr>
            <th>Tipo de festival</th>
            <th>Mesas</th>
            <th>Duración</th>
            <th>Costo mobiliario MESPIC</th>
