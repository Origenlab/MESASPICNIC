    { name: "Mesa Estándar", cap: "1.80m · 6 personas", href: "/catalogo/mesa-picnic-estandar/", img: "/img/mesa-picnic-area-verde-19.avif" },
  ]}
  sidebarArticles={[
    { title: "Cumpleaños infantiles Toluca y Zinacantepec", meta: "Infantiles · 7 min", href: "/blog/cumpleanos-infantiles-toluca-zinacantepec/", img: "/img/infantil-cumple-1.avif" },
    { title: "Decoración para fiestas infantiles", meta: "Decoración · 6 min", href: "/blog/decoracion-mesas-picnic-fiestas-infantiles/", img: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif" },
    { title: "Mesas picnic en Metepec, Esmeralda y Bosque Real", meta: "Edomex · 6 min", href: "/blog/mesas-picnic-fiestas-privadas-metepec-zona-esmeralda-bosque-real/", img: "/img/mesa-picnic-boda-hacienda-mexicana.webp" },
  ]}
  sidebarServices={[
    { name: "Fiestas Infantiles", desc: "Cumpleaños · Baby shower", href: "/servicios/fiestas-infantiles/" },
    { name: "Reuniones Familiares", desc: "Cumples adultos · Reencuentros", href: "/servicios/reuniones-familiares/" },
    { name: "Fiestas Temáticas", desc: "Conceptos originales", href: "/servicios/fiestas-tematicas/" },
    { name: "Picnic Romántico", desc: "Pedidas · Aniversarios", href: "/servicios/picnic-romantico/" },
  ]}
  sidebarCtaTitle="¿Cumpleaños en Metepec?"
