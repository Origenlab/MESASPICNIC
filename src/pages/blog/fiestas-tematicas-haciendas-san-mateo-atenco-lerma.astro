    { title: "Fiestas Temáticas en Toluca: venues urbanos", meta: "Temáticas Toluca · 8 min", href: "/blog/fiestas-tematicas-toluca-venues-urbanos/", img: "/img/tema-mexicana-1.avif" },
    { title: "10 Fiestas Temáticas con Mesas Picnic", meta: "Temáticas · 10 min", href: "/blog/fiestas-tematicas-conceptos-mesas-picnic/", img: "/img/tema-italiana-1.avif" },
    { title: "Bodas en Haciendas Calimaya y Tenango", meta: "Bodas · 10 min", href: "/blog/bodas-haciendas-calimaya-tenango-del-valle-toluca/", img: "/img/boda-hacienda-1.avif" },
  ]}
  sidebarServices={[
    { name: "Fiestas Temáticas", desc: "Conceptos originales", href: "/servicios/fiestas-tematicas/" },
    { name: "Reuniones Familiares", desc: "Cumples · Reencuentros", href: "/servicios/reuniones-familiares/" },
    { name: "Boda Rústica", desc: "Haciendas · Bosques", href: "/servicios/bodas/rustica/" },
    { name: "Eventos Corporativos", desc: "Cierres temáticos", href: "/servicios/eventos-corporativos/" },
