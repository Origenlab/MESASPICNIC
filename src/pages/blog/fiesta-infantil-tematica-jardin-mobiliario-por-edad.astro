        <ul class="art__coverage-list">
          <li>Metepec y Toluca</li>
          <li>Zinacantepec y Lerma</li>
          <li>Naucalpan y Atizapán</li>
          <li>Huixquilucan e Interlomas</li>
          <li>Tlalnepantla y Cuautitlán Izcalli</li>
        </ul>
      </div>
