---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const allPosts = [
  {
    title: "Ideas de Decoración para Mesas Picnic en Fiestas Infantiles",
    description: "Consejos profesionales para decorar mesas picnic infantiles con mejor estética, orden y funcionalidad.",
    image: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif",
    href: "/blog/ideas-decoracion-mesas-picnic-fiestas-infantiles/",
  },
  {
    title: "Cuántas Mesas Picnic Necesitas Según el Número de Invitados",
    description: "Guía práctica para calcular cuántas mesas picnic rentar según invitados, tipo de evento y espacio disponible.",
    image: "/img/mesa-picnic-grande-evento-16.avif",
    href: "/blog/cuantas-mesas-picnic-necesitas-segun-invitados/",
  },
  {
    title: "Renta de Mesas Picnic para Bodas en CDMX: Guía Completa",
    description: "Todo lo que necesitas saber sobre la renta de mesas picnic para bodas al aire libre en Ciudad de México y Estado de México.",
    image: "/img/mesa-picnic-boda-elegante-decoracion.avif",
    href: "/blog/renta-mesas-picnic-bodas-cdmx/",
  },
  {
    title: "Mesas Picnic para Eventos Corporativos: Guía para Empresas",
    description: "Cómo elegir mesas picnic para tu evento corporativo. Team buildings, conferencias y comidas empresariales al aire libre.",
    image: "/img/mesa-picnic-evento-corporativo-networking.avif",
    href: "/blog/mesas-picnic-eventos-corporativos/",
  },
  {
    title: "Decoración de Mesas Picnic para Fiestas Infantiles",
    description: "Ideas creativas para decorar mesas picnic en cumpleaños y fiestas infantiles. Temáticas, colores y consejos prácticos.",
    image: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif",
    href: "/blog/decoracion-mesas-picnic-fiestas-infantiles/",
  },
];
---

<BaseLayout
  title="Blog — MESPIC | Tips y Guías de Mesas Picnic"
  description="Artículos, guías y consejos sobre renta de mesas picnic para eventos. Bodas, corporativos, infantiles y más."
>

<Hero
  title="Blog MESPIC"
  description="Guías, consejos y tendencias sobre mesas picnic para eventos. Aprende a crear el evento perfecto."
  ctaPrimary={{ label: "Cotizar ahora →", href: "/cotizar/" }}
  ctaSecondary={{ label: "Servicios", href: "/servicios/" }}
  seoParagraph1="En el blog de MESPIC compartimos guías completas, consejos prácticos y tendencias sobre renta de mesas picnic para eventos. Desde cómo elegir la cantidad correcta de mesas para tu boda, hasta ideas de decoración para fiestas infantiles."
  seoParagraph2="Nuestros artículos están escritos con base en nuestra experiencia de más de 8 años organizando eventos con mesas picnic. Información real y práctica para que tu evento sea un éxito total."
/>

<section class="section">
  <div class="container">
    <div class="blog-grid">
      {allPosts.map((post) => (
        <a href={post.href} class="blog-card">
          <div class="blog-card-img">
            <img src={post.image} alt={post.title} loading="lazy" width="400" height="250" />
          </div>
          <div class="blog-card-body">
            <h2 class="blog-card-title">{post.title}</h2>
            <p class="blog-card-desc">{post.description}</p>
            <span class="blog-card-link">Leer artículo →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .blog-card {
    display: block;
    background: #fff;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
  }

  .blog-card-img {
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .blog-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }

  .blog-card:hover .blog-card-img img { transform: scale(1.05); }

  .blog-card-body { padding: 1.5rem; }

  .blog-card-title {
    font-size: 1.125rem;
    color: var(--c-primary);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .blog-card-desc {
    color: var(--c-text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .blog-card-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-accent);
  }

  @media (max-width: 768px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
