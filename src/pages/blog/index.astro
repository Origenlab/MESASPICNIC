<!-- ═══════════════════════════════════════════════════
     JAVASCRIPT — Filtros por categoría + Paginación
════════════════════════════════════════════════════ -->
<script>
(function () {
  const ITEMS_PER_PAGE = 6;

  const state = {
    cat: 'todos',
    page: 1,
  };

  const grid      = document.querySelector('.blog-grid');
  const paginEl   = document.getElementById('blog-pagination');
  const countEl   = document.getElementById('blog-count');

  function getAllCards() {
    return [...grid.querySelectorAll('.blog-card')];
  }

  // ── Render principal ─────────────────────────────
  function render() {
    const all      = getAllCards();
    const filtered = state.cat === 'todos'
      ? all
      : all.filter(c => c.dataset.cat === state.cat);
    const total  = filtered.length;
    const pages  = Math.max(1, Math.ceil(total / ITEMS_PER_PAGE));
    if (state.page > pages) state.page = 1;

    const start   = (state.page - 1) * ITEMS_PER_PAGE;
    const end     = start + ITEMS_PER_PAGE;
    const visible = new Set(filtered.slice(start, end).map(c => c.dataset.postId));

    all.forEach(card => {
      const show = visible.has(card.dataset.postId);
      card.style.display = show ? '' : 'none';
    });

    const totalAll = all.length;
    countEl.textContent = total === totalAll
      ? `${totalAll} artículos`
      : `${total} de ${totalAll} artículos`;

    renderPagination(pages, total, start + 1, Math.min(end, total));
  }

  // ── Paginación ───────────────────────────────────
  function renderPagination(totalPages, totalItems, rangeStart, rangeEnd) {
    if (totalPages <= 1 || totalItems === 0) { paginEl.innerHTML = ''; return; }

    const progress = Math.round((state.page / totalPages) * 100);
    const chevL = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>`;
    const chevR = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>`;

    let pageNums = '';
    const delta = 1;
    for (let i = 1; i <= totalPages; i++) {
      const near = Math.abs(i - state.page) <= delta || i === 1 || i === totalPages;
      const gap  = i === 2 && state.page > delta + 2;
      const gap2 = i === totalPages - 1 && state.page < totalPages - delta - 1;
      if (near) {
        const active = i === state.page;
        pageNums += `<button class="pag-page${active ? ' pag-page--active' : ''}" data-page="${i}" ${active ? 'aria-current="page"' : ''}>${i}</button>`;
      } else if (gap || gap2) {
        pageNums += `<span class="pag-dots">···</span>`;
      }
    }

    paginEl.innerHTML = `
      <div class="pag-card">
        <div class="pag-card__top">
          <div class="pag-card__info">
            <span class="pag-card__count">${totalItems} artículos</span>
            <span class="pag-card__range">Mostrando ${rangeStart}–${rangeEnd}</span>
          </div>
          <span class="pag-card__page-pill">Página ${state.page} de ${totalPages}</span>
        </div>
        <div class="pag-card__progress-track">
          <div class="pag-card__progress-bar" style="width:${progress}%"></div>
        </div>
        <div class="pag-card__controls">
          <button class="pag-ctrl" data-page="${state.page - 1}" aria-label="Página anterior" ${state.page === 1 ? 'disabled' : ''}>${chevL}<span>Anterior</span></button>
          <div class="pag-pages">${pageNums}</div>
          <button class="pag-ctrl" data-page="${state.page + 1}" aria-label="Página siguiente" ${state.page === totalPages ? 'disabled' : ''}><span>Siguiente</span>${chevR}</button>
        </div>
      </div>`;

    paginEl.querySelectorAll('[data-page]:not([disabled])').forEach(btn => {
      btn.addEventListener('click', () => {
        state.page = parseInt(btn.dataset.page);
        render();
        document.getElementById('articulos').scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  // ── Filtros de categoría ──────────────────────────
  document.querySelectorAll('.cat-filter[data-cat]').forEach(btn => {
    btn.addEventListener('click', () => {
      state.cat  = btn.dataset.cat;
      state.page = 1;
      document.querySelectorAll('.cat-filter[data-cat]').forEach(b => {
        b.classList.toggle('cat-filter--active', b === btn);
        b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
      });
      render();
    });
  });

  // Inicializar
  render();
})();
</script>

