            <td>Peonías, rosas blancas, hortensia</td>
          </tr>
          <tr>
            <td><strong>Moderno Minimalista</strong></td>
            <td class="td-accent">Madera expuesta, una sola flor, velas cilíndricas</td>
            <td>Negro, blanco, oro, madera natural</td>
            <td>Rosas negras, calla blanca, gypsophila</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

