            <th>Cuándo</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>1. Cotización</strong></td>
            <td class="td-accent">Nos escribes y te pasamos propuesta y precio final</td>
            <td>Tú y nosotros</td>
            <td>El mismo día</td>
          </tr>
          <tr>
