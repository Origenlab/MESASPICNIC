            <td class="td-accent">Apartas tu fecha con un anticipo</td>
            <td>Tú</td>
            <td>Al confirmar</td>
          </tr>
          <tr>
            <td><strong>3. Coordinación</strong></td>
            <td class="td-accent">Afinamos acceso, horario y detalles del venue</td>
            <td>Nosotros</td>
            <td>Días antes</td>
          </tr>
          <tr>
            <td><strong>4. Entrega y montaje</strong></td>
            <td class="td-accent">Llegamos, instalamos y nivelamos todo</td>
