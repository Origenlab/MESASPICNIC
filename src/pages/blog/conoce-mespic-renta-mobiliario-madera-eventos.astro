        </thead>
        <tbody>
          <tr>
            <td><strong>Montaje</strong></td>
            <td class="td-accent">Profesional, incluido en el precio</td>
            <td>Te dejan las piezas; tú las montas</td>
          </tr>
          <tr>
            <td><strong>Recolección</strong></td>
            <td class="td-accent">Incluida, sin límite de tiempo</td>
