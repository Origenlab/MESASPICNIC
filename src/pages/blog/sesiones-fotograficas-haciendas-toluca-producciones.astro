    { title: "Sesiones fotográficas en Valle de Bravo", meta: "Producciones · 8 min", href: "/blog/sesiones-fotograficas-valle-de-bravo-bosque-lago/", img: "/img/mesa-picnic-romantica-vinedo-champagne.webp" },
    { title: "Sesiones fotográficas con mesas picnic", meta: "Producciones · 9 min", href: "/blog/sesiones-fotograficas-mesas-picnic-producciones/", img: "/img/mesa-picnic-decoracion-elegante-champagne.webp" },
    { title: "Activaciones de marca con mesas picnic", meta: "Producciones · 9 min", href: "/blog/activaciones-marca-brand-experiences-mobiliario/", img: "/img/corp-lanzamiento-1.avif" },
