  sidebarCtaText="Tarifa especial productora destination. Equipo pernoctando, NDAs disponibles, facturación corporativa estándar."
  sidebarCtaWa="Hola%2C+quiero+cotizar+una+producci%C3%B3n+fotogr%C3%A1fica+en+Valle+de+Bravo."
  sidebarServicesTitle="Servicios para producciones"
