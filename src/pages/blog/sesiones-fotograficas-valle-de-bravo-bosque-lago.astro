    { name: "Mesa Estándar", cap: "1.80 m · Versátil", href: "/catalogo/mesa-picnic-estandar/", img: "/img/mesa-picnic-area-verde-19.avif" },
  ]}
  sidebarArticles={[
    { title: "Producciones en haciendas de Toluca", meta: "Producciones · 8 min", href: "/blog/sesiones-fotograficas-haciendas-toluca-producciones/", img: "/img/mesa-picnic-decoracion-elegante-champagne.webp" },
    { title: "Sesiones fotográficas con mesas picnic", meta: "Producciones · 9 min", href: "/blog/sesiones-fotograficas-mesas-picnic-producciones/", img: "/img/mesa-picnic-cena-gala-nocturna.webp" },
    { title: "Bodas en Valle de Bravo y Avándaro", meta: "Bodas VdB · 9 min", href: "/blog/bodas-valle-de-bravo-avandaro-mesas-picnic/", img: "/img/boda-vinedo-elegante-1.avif" },
  ]}
