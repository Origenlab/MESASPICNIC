    { name: "Mesa Grande 2.40m", cap: "10–12 personas", href: "/catalogo/mesa-picnic-grande/", img: "/img/mesa-picnic-grande-evento-16.avif" },
  ]}
  sidebarArticles={[
    { title: "Reuniones familiares Metepec y San Mateo Atenco", meta: "Familiar · 7 min", href: "/blog/reuniones-familiares-metepec-san-mateo-atenco/", img: "/img/reunion-familiar-mesas-picnic-coyoacan-01.avif" },
    { title: "Posadas Navideñas y Eventos Decembrinos", meta: "Decembrino · 8 min", href: "/blog/mesas-picnic-posadas-navidenas-eventos-decembrinos/", img: "/img/tema-navidad-1.avif" },
    { title: "Cumpleaños infantiles Toluca y Zinacantepec", meta: "Infantiles · 7 min", href: "/blog/cumpleanos-infantiles-toluca-zinacantepec/", img: "/img/infantil-cumple-1.avif" },
  ]}
  sidebarServices={[
    { name: "Reuniones Familiares", desc: "Posadas · Cumpleaños", href: "/servicios/reuniones-familiares/" },
    { name: "Fiestas Temáticas", desc: "Conceptos originales", href: "/servicios/fiestas-tematicas/" },
    { name: "Eventos Corporativos", desc: "Cierres de año empresariales", href: "/servicios/eventos-corporativos/" },
    { name: "Comidas Corporativas", desc: "Almuerzo · Cena fin de año", href: "/servicios/eventos-corporativos/comidas/" },
  ]}
  sidebarCtaTitle="¿Posada en mente?"
  sidebarCtaText="Reserva ya: diciembre se llena rápido. Cotizamos en menos de 30 minutos. Cobertura sin cargo extra en Toluca-Zinacantepec."
