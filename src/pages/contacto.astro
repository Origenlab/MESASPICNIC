<script is:inline>
  // Formulario de contacto → WhatsApp con datos del evento
  var form = document.getElementById('contactForm');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var name      = document.getElementById('cf-name').value.trim();
      var phone     = document.getElementById('cf-phone').value.trim();
      var email     = document.getElementById('cf-email').value.trim();
      var eventType = document.getElementById('cf-event').value;
      var date      = document.getElementById('cf-date').value;
      var guests    = document.getElementById('cf-guests').value;
      var zone      = document.getElementById('cf-zone').value.trim();
      var message   = document.getElementById('cf-message').value.trim();

      var text = 'Hola, me llamo ' + name + '.';
      if (eventType) text += ' Necesito mesas para: ' + eventType + '.';
      if (date)      text += ' Fecha: ' + date + '.';
      if (guests)    text += ' Personas: ' + guests + '.';
      if (zone)      text += ' Ubicación: ' + zone + '.';
      if (phone)     text += ' Mi teléfono: ' + phone + '.';
      if (email)     text += ' Correo: ' + email + '.';
      if (message)   text += ' Nota: ' + message;

      if (window.openMespicChat) { openMespicChat(); } else { window.open('https://wa.me/5215564328954?text=' + encodeURIComponent(text), '_blank', 'noopener'); }
    });
  }
</script>

