---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Hero from '../components/Hero.astro';
import CtaBar from '../components/CtaBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import FeatureCard from '../components/FeatureCard.astro';
import FaqSection from '../components/FaqSection.astro';
import NextStep from '../components/NextStep.astro';
import ExploreMore from '../components/ExploreMore.astro';
---

<BaseLayout
  title="Contacto — MESPIC | Escríbenos o Llámanos"
  description="Contáctanos por WhatsApp, teléfono o formulario. Respondemos en menos de 10 minutos para bodas, corporativos y todo tipo de eventos en CDMX y Edomex."
>

<!-- Breadcrumbs -->
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Contacto" }
  ]} />
</Fragment>

<!-- ══════════════════════════════════════════════════════
     HERO — variante oscura homologada con el resto del sitio
══════════════════════════════════════════════════════ -->
<Hero
  badge="Atención personalizada"
  title="Hablemos de Tu Evento"
  description="Cuéntanos la fecha, el lugar y el número de personas. Te respondemos con disponibilidad y precio en menos de 10 minutos."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="Lo más rápido es el WhatsApp: normalmente respondemos en menos de 10 minutos dentro de nuestro horario. Si prefieres dejar todo por escrito, usa el formulario de contacto o mándanos un correo y te contestamos el mismo día. Operamos los 7 días de la semana de 8:00 a 20:00 hrs."
  seoParagraph2="Cuando nos escribas, es útil que nos digas la fecha, la zona y cuántas personas esperan. Con esa información te damos disponibilidad y precio en un solo mensaje, sin necesidad de ir y venir con preguntas. El precio que cotizamos es el precio final: sin cargos extra ni sorpresas."
  dark={true}
/>

<!-- CtaBar — barra de acceso rápido a servicios -->
<CtaBar />

<!-- ══════════════════════════════════════════════════════
     CANALES DE CONTACTO + FORMULARIO
══════════════════════════════════════════════════════ -->
<section class="section" id="contacto">
  <SectionHeader
    tag="h2"
    badge="Canales de contacto"
    title="Elige Cómo Prefières Contactarnos"
    paragraph1="Tenemos varios canales disponibles según tu preferencia. WhatsApp es el más rápido; el formulario es ideal si quieres dejarnos todos los detalles por escrito."
    paragraph2="En cualquier caso, recibirás una respuesta con disponibilidad de fechas, inventario y precio final —todo en un solo mensaje."
    stats={[
      { value: "< 10 min", label: "respuesta por WhatsApp" },
      { value: "mismo día", label: "por correo o formulario" },
      { value: "precio final", label: "sin cargos adicionales" },
    ]}
  />

  <div class="container">
    <div class="contact-layout">

      <!-- ═══ COLUMNA IZQUIERDA: Canales ═══ -->
      <div class="contact-channels">

        <!-- Tarjeta WhatsApp -->
        <a
          href="https://wa.me/5215564328954?text=Hola%2C%20quiero%20cotizar%20mesas%20picnic%20para%20mi%20evento."
          onclick="if(window.openMespicChat){event.preventDefault();openMespicChat();}"
          target="_blank"
          rel="noopener"
          class="channel-card channel-card--wa"
          aria-label="Contactar por WhatsApp"
        >
          <div class="channel-card__icon channel-card__icon--wa">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div class="channel-card__body">
            <span class="channel-card__badge">Más rápido</span>
            <h3 class="channel-card__title">WhatsApp</h3>
            <p class="channel-card__value">+52 55 6432 8954</p>
            <p class="channel-card__desc">Respondemos en menos de 10 min. Envíanos fecha, zona y número de personas.</p>
          </div>
          <svg class="channel-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <!-- Tarjeta Teléfono -->
        <a
          href="tel:+525564328954"
          class="channel-card"
          aria-label="Llamar por teléfono"
        >
          <div class="channel-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div class="channel-card__body">
            <h3 class="channel-card__title">Teléfono</h3>
            <p class="channel-card__value">55 6432 8954</p>
            <p class="channel-card__desc">Lunes a domingo de 8:00 a 20:00 hrs. Atención directa sin menús automatizados.</p>
          </div>
          <svg class="channel-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <!-- Tarjeta Email -->
        <a
          href="mailto:mesaspicnick@gmail.com"
          class="channel-card"
          aria-label="Enviar correo electrónico"
        >
          <div class="channel-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div class="channel-card__body">
            <h3 class="channel-card__title">Correo electrónico</h3>
            <p class="channel-card__value">mesaspicnick@gmail.com</p>
            <p class="channel-card__desc">Ideal para cotizaciones detalladas. Respondemos el mismo día hábil.</p>
          </div>
          <svg class="channel-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <!-- Info operativa -->
        <div class="contact-ops">
          <div class="contact-ops__row">
            <div class="contact-ops__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <span class="contact-ops__label">Horario de atención</span>
              <p class="contact-ops__value">Lun–Dom · 8:00 a 20:00 hrs</p>
            </div>
          </div>
          <div class="contact-ops__divider"></div>
          <div class="contact-ops__row">
            <div class="contact-ops__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <span class="contact-ops__label">Cobertura de servicio</span>
              <p class="contact-ops__value">CDMX · Naucalpan · Huixquilucan · Atizapán y más municipios del Edomex</p>
            </div>
          </div>
        </div>

      </div>

      <!-- ═══ COLUMNA DERECHA: Formulario ═══ -->
      <div class="contact-form-col">
        <div class="contact-form-card">
          <div class="contact-form-card__header">
            <h2 class="contact-form-card__title">Envíanos los Detalles de Tu Evento</h2>
            <p class="contact-form-card__sub">Completa el formulario y te respondemos con precio y disponibilidad el mismo día.</p>
          </div>

          <form class="cform" id="contactForm" novalidate>

            <div class="cform__row">
              <div class="cform__group">
                <label for="cf-name" class="cform__label">Nombre completo <span class="cform__req">*</span></label>
                <input type="text" id="cf-name" name="name" required placeholder="Tu nombre completo" class="cform__input" />
              </div>
              <div class="cform__group">
                <label for="cf-phone" class="cform__label">WhatsApp / Teléfono <span class="cform__req">*</span></label>
                <input type="tel" id="cf-phone" name="phone" required placeholder="55 1234 5678" class="cform__input" />
              </div>
            </div>

            <div class="cform__group">
              <label for="cf-email" class="cform__label">Correo electrónico</label>
              <input type="email" id="cf-email" name="email" placeholder="tu@correo.com" class="cform__input" />
            </div>

            <div class="cform__row">
              <div class="cform__group">
                <label for="cf-event" class="cform__label">Tipo de evento <span class="cform__req">*</span></label>
                <select id="cf-event" name="event_type" required class="cform__input cform__select">
                  <option value="" disabled selected>Selecciona uno...</option>
                  <option value="Boda">Boda</option>
                  <option value="Evento corporativo">Evento corporativo</option>
                  <option value="Fiesta infantil">Fiesta infantil</option>
                  <option value="Picnic romántico">Picnic romántico</option>
                  <option value="Fiesta temática">Fiesta temática</option>
                  <option value="Reunión familiar">Reunión familiar</option>
                  <option value="Festival o feria">Festival o feria</option>
                  <option value="Sesión fotográfica">Sesión fotográfica</option>
                  <option value="Otro">Otro</option>
                </select>
              </div>
              <div class="cform__group">
                <label for="cf-date" class="cform__label">Fecha del evento</label>
                <input type="date" id="cf-date" name="event_date" class="cform__input" />
              </div>
            </div>

            <div class="cform__row">
              <div class="cform__group">
                <label for="cf-guests" class="cform__label">Número de personas</label>
                <select id="cf-guests" name="guests" class="cform__input cform__select">
                  <option value="" disabled selected>¿Cuántas personas?</option>
                  <option value="Menos de 20">Menos de 20</option>
                  <option value="20 a 50">20 a 50</option>
                  <option value="50 a 100">50 a 100</option>
                  <option value="100 a 200">100 a 200</option>
                  <option value="Más de 200">Más de 200</option>
                </select>
              </div>
              <div class="cform__group">
                <label for="cf-zone" class="cform__label">Alcaldía / Municipio</label>
                <input type="text" id="cf-zone" name="zone" placeholder="Ej: Coyoacán, Naucalpan…" class="cform__input" />
              </div>
            </div>

            <div class="cform__group">
              <label for="cf-message" class="cform__label">Mensaje adicional</label>
              <textarea id="cf-message" name="message" rows="4" class="cform__input cform__textarea" placeholder="Cuéntanos más sobre tu evento, el tipo de mobiliario que necesitas o cualquier duda que tengas…"></textarea>
            </div>

            <div class="cform__actions">
              <button type="submit" class="cform__btn-primary" id="btnSubmitForm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                Enviar mensaje
              </button>
              <a
                href="https://wa.me/5215564328954?text=Hola%2C%20quiero%20cotizar%20mesas%20picnic%20para%20mi%20evento."
                onclick="if(window.openMespicChat){event.preventDefault();openMespicChat();}"
                target="_blank"
                rel="noopener"
                class="cform__btn-wa"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                Preferir WhatsApp
              </a>
            </div>

            <p class="cform__note">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Tu información es privada. No compartimos datos con terceros.
            </p>

          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     POR QUÉ CONTACTARNOS — Feature Cards
══════════════════════════════════════════════════════ -->
<section class="section section-alt" id="por-que-contactarnos">
  <SectionHeader
    tag="h2"
    badge="Atención directa"
    title="Lo Que Pasa Cuando Nos Escribes"
    paragraph1="No tenemos bots ni formularios que se pierden. Cuando nos contactas, una persona real de nuestro equipo te responde con disponibilidad y precio en un solo mensaje."
    paragraph2="Trabajamos 7 días de la semana para que puedas organizar tu evento cuando lo necesites, sin esperar días hábiles ni respuestas genéricas."
    stats={[
      { value: "1 mensaje", label: "precio + disponibilidad" },
      { value: "sin bots", label: "atención humana real" },
      { value: "0 sorpresas", label: "precio final siempre" },
    ]}
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard
        index={0}
        title="Respuesta en Menos de 10 Minutos"
        description="Por WhatsApp respondemos en menos de 10 minutos durante nuestro horario (8:00–20:00 hrs, lunes a domingo). Sin esperar hasta el siguiente día hábil."
      />
      <FeatureCard
        index={1}
        title="Precio y Disponibilidad en un Solo Mensaje"
        description="No te hacemos ir y venir con preguntas. Si nos dices fecha, zona y número de personas, te respondemos con disponibilidad real y precio final en una sola respuesta."
      />
      <FeatureCard
        index={2}
        title="Sin Bots ni Respuestas Automáticas"
        description="Toda la comunicación es directa con nuestro equipo. Nadie te va a mandar respuestas genéricas ni va a pedirte que 'esperes a ser atendido'."
      />
      <FeatureCard
        index={3}
        title="Asesoría sin Compromiso de Compra"
        description="Puedes escribirnos con dudas, pedir una cotización o consultar disponibilidad sin ningún compromiso. Te ayudamos a decidir cuántas bancas necesitas y cómo distribuirlas."
      />
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════
     FAQ — Preguntas antes de contactar
══════════════════════════════════════════════════════ -->
<section class="section" id="faq-contacto">
  <SectionHeader
    tag="h2"
    badge="Preguntas frecuentes"
    title="Antes de Escribirnos, Quizás Esto Ayuda"
    paragraph1="Las preguntas más comunes que nos llegan antes de una cotización. Respondidas directamente, sin rodeos."
    paragraph2="Si tienes una duda que no está aquí, escríbenos por WhatsApp. Respondemos en minutos."
    stats={[
      { value: "6",       label: "respuestas inmediatas" },
      { value: "< 5 min", label: "respuesta por WhatsApp" },
      { value: "lun–dom", label: "8:00 a 20:00 hrs" },
    ]}
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    waMessage="Hola, tengo una pregunta sobre el servicio de mesas picnic para mi evento."
    schedule="Lun–Dom 8:00–20:00"
    items={[
      {
        question: "¿Cuánto tiempo antes debo contactarlos para reservar?",
        answer: "Recomendamos contactarnos con al menos 1 semana de anticipación para eventos pequeños (menos de 50 personas) y 2–3 semanas para eventos grandes o en temporada alta (noviembre–febrero). Dicho eso, si tu evento es en pocos días, escríbenos de todas formas: a veces tenemos disponibilidad de última hora."
      },
      {
        question: "¿Qué información necesitan para darme un precio?",
        answer: "Solo necesitamos tres datos: la fecha de tu evento, la ubicación (alcaldía o municipio) y el número aproximado de personas. Con eso te podemos dar disponibilidad y precio en un solo mensaje. No necesitas tener todo decidido para cotizar."
      },
      {
        question: "¿El precio que me dan por WhatsApp es el precio final?",
        answer: "Sí. El precio que cotizamos incluye entrega en tu ubicación, montaje profesional, uso sin límite de tiempo y recolección al terminar. No hay cargos extra por traslado, maniobras, tiempo adicional ni nada que no hayamos mencionado. Lo que cotizamos es lo que pagas."
      },
      {
        question: "¿Puedo pedir una cotización sin compromiso de contratación?",
        answer: "Claro que sí. Puedes escribirnos, pedir el precio, comparar con otras opciones y decidir después. No te vamos a presionar ni a cobrar por cotizar. La cotización no implica ningún compromiso de tu parte."
      },
      {
        question: "¿Responden los domingos y días festivos?",
        answer: "Sí. Operamos los 7 días de la semana de 8:00 a 20:00 hrs, incluyendo domingos y la mayoría de los días festivos. Si escribes fuera de ese horario, te respondemos en cuanto abramos al día siguiente."
      },
      {
        question: "¿Puedo contactarlos si no estoy seguro del tipo de evento que necesito?",
        answer: "Sí, con gusto te asesoramos. Dinos de qué se trata tu evento —una fiesta, una boda, un evento de empresa— y nosotros te recomendamos el modelo de banca, la cantidad adecuada y cómo distribuirlas. Sin costo y sin compromiso."
      }
    ]}
  />
</section>

<!-- Sigue explorando -->
<ExploreMore
  title="Sigue explorando MESPIC"
  subtitle="Todo lo que necesitas para tu evento en un solo lugar"
  items={[
    { href: '/servicios/', label: 'Todos los servicios', sub: 'Bodas, corporativos, infantiles y más', badge: 'Paso 1', isEmoji: true, icon: '🎪' },
    { href: '/catalogo/', label: 'Catálogo completo', sub: '20 modelos con fichas técnicas y fotos', badge: 'Paso 2', isEmoji: true, icon: '🪵' },
    { href: '/paquetes/', label: 'Nuestros paquetes', sub: 'Básico · Estándar · Premium', badge: 'Paso 3', isEmoji: true, icon: '📦' },
  ]}
/>

<!-- Siguiente paso -->
<NextStep
  titulo="¿Ya sabes qué tipo de evento tienes?"
  subtitulo="Explora todos nuestros servicios especializados: bodas, corporativos, fiestas infantiles, picnics románticos y más."
  href="/servicios/"
  btnLabel="Explorar servicios →"
  secondBtn={{ label: 'Ver catálogo', href: '/catalogo/' }}
/>

<!-- Schema.org LocalBusiness + ContactPage -->
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contacto — MESPIC",
    "description": "Contacta a MESPIC para cotizar renta de mesas picnic en CDMX y Edomex. WhatsApp, teléfono, correo y formulario disponibles.",
    "url": "https://mesaspicnic.com/contacto/",
    "mainEntity": {
      "@type": "LocalBusiness",
      "name": "MESPIC — Renta de Mesas Picnic",
      "telephone": "+52-55-6432-8954",
      "email": "mesaspicnick@gmail.com",
      "url": "https://mesaspicnic.com",
      "openingHours": "Mo,Tu,We,Th,Fr,Sa,Su 08:00-20:00",
      "areaServed": [
        { "@type": "City", "name": "Ciudad de México" },
        { "@type": "State", "name": "Estado de México" }
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+52-55-6432-8954",
        "contactType": "customer service",
        "availableLanguage": "Spanish",
        "hoursAvailable": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "08:00",
          "closes": "20:00"
        }
      }
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
