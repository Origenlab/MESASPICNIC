---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBar from '../components/CtaBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FaqSection from '../components/FaqSection.astro';
import CtaBarFinal from '../components/CtaBarFinal.astro';
import GallerySection from '../components/GallerySection.astro';

const galeriaIndex = [
  { src: "/img/boda-hacienda-1.avif", alt: "Mesa larga decorada con flores blancas para boda en hacienda mexicana" },
  { src: "/img/corp-rooftop-1.avif", alt: "Mobiliario corporativo en terraza con skyline de CDMX" },
  { src: "/img/infantil-cumple-1.avif", alt: "Banca decorada con globos y cupcakes para fiesta infantil" },
  { src: "/img/tema-mexicana-1.avif", alt: "Mesa con papel picado y decoración mexicana para fiesta temática" },
  { src: "/img/boda-boho-1.avif", alt: "Mesa bohemia con pampas y platos de terracota vista desde arriba" },
  { src: "/img/corp-teambuilding-1.avif", alt: "Bancas en parque verde para team building empresarial" },
  { src: "/img/infantil-teaparty-1.avif", alt: "Tea party infantil pastel sobre banca rústica en jardín" },
  { src: "/img/tema-tropical-1.avif", alt: "Mesa tropical con piñas y hojas monstera junto a la alberca" },
];
---

<BaseLayout
  title="Renta de Mesas Picnic para Eventos en CDMX | MESPIC"
  description="Renta de bancas de madera para bodas, corporativos y fiestas al aire libre. Entrega y montaje incluidos en CDMX y Edomex. Cotiza gratis."
>

<!-- Hero -->
<Hero
  badge="Mobiliario para eventos"
  title="Renta de Mesas Picnic para Eventos en CDMX"
  description="Bancas de madera natural para bodas, corporativos, fiestas infantiles y picnics al aire libre. Entrega, montaje y recolección incluidos en Ciudad de México y Estado de México."
  seoParagraph1="Desde 2017, MESPIC se dedica a la renta de mobiliario de madera para eventos al aire libre en la Ciudad de México y zona metropolitana. Hemos participado en más de 500 bodas, reuniones corporativas, cumpleaños y picnics románticos con bancas de pino natural lijadas y barnizadas a mano. Cada pieza mide 2.4 metros de largo y acomoda cómodamente de 6 a 8 personas."
  seoParagraph2="El servicio incluye entrega en tu ubicación, montaje profesional y recolección al terminar, sin cargos extra ni límite de tiempo. Operamos los 7 días de la semana y llegamos en un máximo de 3 horas a cualquier alcaldía de CDMX y municipios del Edomex como Naucalpan, Huixquilucan y Atizapán. El precio que cotizamos es el precio final: sin sorpresas."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar
  headline="¿Qué tipo de evento estás planeando?"
  items={[
    { label: "Bodas", href: "/servicios/bodas/", icon: "boda", desc: "Bancas de pino para jardines, haciendas y terrazas. Cualquier estilo de decoración." },
    { label: "Corporativo", href: "/servicios/eventos-corporativos/", icon: "corporativo", desc: "Team buildings, comidas y conferencias al aire libre para grupos de cualquier tamaño." },
    { label: "Fiestas infantiles", href: "/servicios/fiestas-infantiles/", icon: "fiesta", desc: "Bancas sin astillas, modelo infantil adaptado para niños de 3 a 10 años." },
    { label: "Picnic romántico", href: "/servicios/picnic-romantico/", icon: "picnic", desc: "Montaje íntimo con decoración, mantelería y ambientación para parejas." },
  ]}
/>

<!-- Servicios -->
<section class="section" id="servicios">
  <SectionHeader
    tag="h2"
    title="Servicios de Renta de Mobiliario"
    paragraph1="Cada tipo de evento tiene necesidades distintas. No es lo mismo montar una boda para 150 personas en un jardín que un cumpleaños infantil en una terraza. Por eso ofrecemos configuraciones específicas para cada ocasión."
    paragraph2="Todas las opciones incluyen entrega, montaje y recolección. Tú eliges el tipo de evento, nosotros nos encargamos de que el mobiliario llegue listo y a tiempo."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Bodas al Aire Libre" description="Bancas de pino barnizadas a mano para bodas en jardines, haciendas y terrazas. Combinan con cualquier estilo de decoración: rústico, boho, clásico o minimalista. Montaje incluido." image="/img/mesa-picnic-boda-elegante-decoracion.avif" href="/servicios/bodas/" btnLabel="Mesas para bodas" />
      <ServiceCard title="Eventos Corporativos" description="Mobiliario para team buildings, conferencias y comidas empresariales al aire libre. Configuramos el montaje según la cantidad de asistentes y el formato de tu evento." image="/img/mesa-picnic-evento-corporativo-networking.avif" href="/servicios/eventos-corporativos/" btnLabel="Mobiliario corporativo" />
      <ServiceCard title="Fiestas Infantiles" description="Bancas lijadas a grano fino, sin astillas ni bordes filosos. Modelo infantil con altura adaptada para niños. Para cumpleaños, baby showers y reuniones familiares." image="/img/mesa-picnic-fiesta-infantil-globos-colores.avif" href="/servicios/fiestas-infantiles/" btnLabel="Mesas para niños" />
      <ServiceCard title="Picnic Romántico" description="Montaje íntimo para dos personas con banca decorada, mantelería y ambientación. Ideal para pedidas de mano, aniversarios o una tarde especial en cualquier parque o jardín de la ciudad." image="/img/mesa-picnic-fiesta-tematica-20.avif" href="/servicios/picnic-romantico/" btnLabel="Picnic para parejas" />
      <ServiceCard title="Fiestas Temáticas" description="Montajes para fiestas mexicanas, XV años, ferias gastronómicas y celebraciones temáticas. La madera natural se adapta a cualquier ambientación que tengas en mente." image="/img/mesa-picnic-fiesta-tematica-20.avif" href="/servicios/fiestas-tematicas/" btnLabel="Mesas para fiestas" />
      <ServiceCard title="Reuniones Familiares" description="Mobiliario para cumpleaños de adultos, día de las madres, posadas y reuniones de fin de semana. Bancas amplias donde caben abuelos, papás y niños sin apretarse." image="/img/mesa-picnic-boda-elegante-decoracion.avif" href="/servicios/reuniones-familiares/" btnLabel="Mesas para familia" />
      <ServiceCard title="Festivales y Ferias" description="Bancas resistentes de alta capacidad para ferias gastronómicas, bazares, festivales culturales y eventos masivos al aire libre. Disponibles en volumen para 100+ personas." image="/img/mesa-picnic-evento-corporativo-networking.avif" href="/servicios/festivales/" btnLabel="Mobiliario para festivales" />
      <ServiceCard title="Sesiones Fotográficas" description="Bancas de madera como escenografía para sesiones de fotos profesionales, contenido para redes sociales, catálogos y producciones audiovisuales. Montaje por hora disponible." image="/img/mesa-picnic-fiesta-tematica-20.avif" href="/servicios/sesiones-fotograficas/" btnLabel="Renta para fotos" />
    </div>
  </div>
</section>

<!-- ¿Por qué MESPIC? -->
<section class="section" id="por-que">
  <SectionHeader
    tag="h2"
    title="¿Por qué elegir MESPIC?"
    paragraph1="Después de 8 años y más de 500 eventos, hay cosas que solo se aprenden con experiencia: cómo proteger la madera del clima, cuántas bancas necesitas según tus invitados, o cómo distribuir el mobiliario para que todos estén cómodos."
    paragraph2="Trabajamos con pino nacional seleccionado, lijado a grano fino y barnizado a mano. No subcontratamos: nuestro equipo se encarga desde la carga hasta el último detalle del montaje."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard index={0} title="Madera 100% Natural" description="Pino nacional seleccionado, lijado a grano fino y barnizado a mano. Sin plásticos ni materiales sintéticos. La textura y el color de la madera real no se pueden imitar." />
      <FeatureCard index={1} title="Entrega y Montaje Incluidos" description="Nuestro equipo lleva el mobiliario a tu ubicación, lo monta donde tú indiques y lo recoge al terminar. El precio que cotizamos es el precio final, sin cargos por traslado ni maniobras." />
      <FeatureCard index={2} title="Sin Límite de Tiempo" description="El mobiliario queda en tu evento hasta que termine. No cobramos por hora ni por tiempo extra. Si tu boda acaba a las 3 am, recogemos a las 3 am." />
      <FeatureCard index={3} title="+500 Eventos desde 2017" description="Bodas, corporativos, cumpleaños, posadas, XV años y festivales. Después de 8 años conocemos la logística y anticipamos lo que cada tipo de evento necesita." />
    </div>
  </div>
</section>

<!-- Testimonios -->
<section class="section section-alt" id="testimonios">
  <SectionHeader
    tag="h2"
    title="Lo que dicen nuestros clientes"
    paragraph1="No lo decimos nosotros. Estas son experiencias de personas que contrataron el servicio para bodas, cumpleaños y eventos corporativos en la Ciudad de México."
    paragraph2="Puedes verificar más opiniones en nuestro perfil de Google. Aquí publicamos las que nos parecen más representativas del servicio."
  />
  <div class="container">
    <div class="grid-4">
      <TestimonialCard name="Carolina Mendoza" event="Boda en jardín — Coyoacán" quote="Las bancas quedaron perfectas con la decoración de flores que teníamos pensada. El equipo llegó dos horas antes de la ceremonia y montó todo sin que yo tuviera que estar encima. Al final recogieron después de las 2 am sin ningún problema." stars={5} date="Feb 2026" />
      <TestimonialCard name="Roberto Sánchez" event="Team building — Polanco" quote="Contratamos 15 bancas para un evento de integración de 120 personas. Todo llegó puntual. Lo único que sugeriría es confirmar la hora de recolección con más anticipación porque tardaron un poco en recoger, pero el mobiliario estuvo impecable." stars={4} date="Ene 2026" />
      <TestimonialCard name="María José Torres" event="Cumpleaños infantil — Santa Fe" quote="Mi hija cumplió 7 años y las mesas infantiles fueron un acierto. Los niños comieron, pintaron y jugaron ahí toda la tarde. Me preocupaban las astillas pero la madera estaba perfectamente lijada. Repetiría sin duda." stars={5} date="Dic 2025" />
      <TestimonialCard name="Andrés Villarreal" event="Picnic romántico — Chapultepec" quote="Le hice una sorpresa a mi novia con el montaje de picnic romántico. La banca decorada con las flores y la mantelería se veía increíble. Ella no se lo esperaba. El único detalle es que la entrega fue 20 minutos tarde, pero valió la pena." stars={4} date="Feb 2026" />
      <TestimonialCard name="Lucía Herrera" event="Posada familiar — Naucalpan" quote="Rentamos 8 bancas para la posada de la familia. Cabíamos todos, incluidos los abuelos que pudieron sentarse cómodos. La madera es bonita y resistente. Ya las aparté también para el Día de las Madres." stars={5} date="Dic 2025" />
      <TestimonialCard name="Fernanda Ríos" event="Feria gastronómica — Roma Norte" quote="Usamos las bancas grandes para un bazar de comida con 8 puestos. Aguantaron todo el día con mucho movimiento de gente. Nos cobraron un poco más por ser evento de todo el día pero el servicio fue correcto y profesional." stars={4} date="Nov 2025" />
      <TestimonialCard name="Diego Paredes" event="Sesión de fotos — Condesa" quote="Soy fotógrafo y renté dos bancas como escenografía para un catálogo de ropa. La madera tiene una textura que se ve muy bien en cámara. El servicio por hora me pareció justo. Ya los tengo guardados para futuras producciones." stars={5} date="Ene 2026" />
      <TestimonialCard name="Patricia Gómez" event="XV años — Tlalpan" quote="Las mesas quedaron bien para el coctel antes de la fiesta. Tuvimos un malentendido con la cantidad (pedimos 10, llegaron 8) pero lo resolvieron rápido y mandaron las que faltaban en 40 minutos. Al final todo salió bien." stars={4} date="Oct 2025" />
    </div>
  </div>
</section>

<!-- Galería -->
<section class="section" id="galeria">
  <div class="container">
    <h2 class="gallery__heading">Nuestro Mobiliario en Acción</h2>
    <p class="gallery__sub">Bodas, corporativos, fiestas infantiles y eventos temáticos — la madera se adapta a cualquier ocasión.</p>
  </div>
  <GallerySection images={galeriaIndex} id="galeria-fotos" />
</section>

<!-- FAQ -->
<section class="section" id="faq">
  <SectionHeader
    tag="h2"
    title="Preguntas Frecuentes"
    paragraph1="Estas son las dudas más comunes que recibimos por WhatsApp antes de cada evento. Si no encuentras tu respuesta, usa el formulario de al lado y te respondemos en minutos."
    paragraph2="Toda la información de precios, tiempos de entrega, zonas de cobertura y especificaciones del mobiliario está en las respuestas."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿Qué incluye el servicio de renta?", answer: "Entrega en tu ubicación, montaje profesional, uso sin límite de tiempo y recolección al terminar. El precio que cotizamos es el precio final: sin cargos por traslado, maniobras ni tiempo extra." },
      { question: "¿Cuánto cuesta rentar una mesa picnic?", answer: "El precio depende del modelo y la cantidad. Cotizamos sin compromiso por WhatsApp con disponibilidad para tu fecha. Los paquetes arrancan desde 4 bancas estándar para 24 personas." },
      { question: "¿En qué zonas entregan?", answer: "Cubrimos todas las alcaldías de la Ciudad de México y municipios del Estado de México como Naucalpan, Huixquilucan, Atizapán, Tlalnepantla e Interlomas. El tiempo de entrega promedio es de 2 a 3 horas." },
      { question: "¿Con cuánta anticipación debo reservar?", answer: "Recomendamos al menos 1 semana de anticipación, especialmente en temporada alta (noviembre a febrero). Atendemos solicitudes de último momento según disponibilidad." },
      { question: "¿Las bancas son seguras para niños?", answer: "Sí. Todas las piezas están lijadas a grano fino, sin astillas ni bordes filosos. También tenemos un modelo infantil con altura y dimensiones adaptadas para niños de 3 a 10 años." },
      { question: "¿Puedo decorar las bancas?", answer: "La madera natural combina con todo: manteles, flores, velas, centros de mesa, telas o cualquier elemento. Muchos clientes nos mandan fotos de referencia y adaptamos el montaje a su estilo." },
      { question: "¿Qué pasa si llueve el día del evento?", answer: "Si tu evento se cancela por clima, puedes reagendar sin costo adicional. Si el evento es en un espacio techado o con carpa, no hay problema: las bancas funcionan igual en interiores." },
      { question: "¿Cuántas personas caben por banca?", answer: "La mesa estándar mide 1.80 × 1.50 m y acomoda 6 personas. La mesa grande mide 2.40 × 1.50 m para 10-12 personas. La infantil es de 1.20 × 1.00 m para 8-10 niños." }
    ]}
  />
</section>

<!-- CTA Final -->
<CtaBarFinal
  headline="¿Listo para tu evento?"
  subtext="Cotiza sin compromiso. Te respondemos en minutos."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero cotizar mesas picnic para mi evento."
  cotizarHref="/cotizar/"
/>

<!-- Schema.org -->
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "MESPIC — Renta de Mesas Picnic",
    "description": "Renta de mobiliario de madera para eventos al aire libre en Ciudad de México y Estado de México.",
    "url": "https://mesaspicnic.com",
    "telephone": "+52-55-6432-8954",
    "priceRange": "$$",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Ciudad de México",
      "addressRegion": "CDMX",
      "addressCountry": "MX"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "ratingCount": "500"
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué incluye el servicio de renta?", "acceptedAnswer": { "@type": "Answer", "text": "Entrega en tu ubicación, montaje profesional, uso sin límite de tiempo y recolección al terminar. El precio que cotizamos es el precio final." }},
      { "@type": "Question", "name": "¿Cuánto cuesta rentar una mesa picnic?", "acceptedAnswer": { "@type": "Answer", "text": "El precio depende del modelo y la cantidad. Cotizamos sin compromiso por WhatsApp. Los paquetes arrancan desde 4 bancas estándar para 24 personas." }},
      { "@type": "Question", "name": "¿En qué zonas entregan?", "acceptedAnswer": { "@type": "Answer", "text": "Cubrimos todas las alcaldías de CDMX y municipios del Edomex como Naucalpan, Huixquilucan, Atizapán y Tlalnepantla. Entrega en 2 a 3 horas." }},
      { "@type": "Question", "name": "¿Las bancas son seguras para niños?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Todas las piezas están lijadas a grano fino, sin astillas. También tenemos modelo infantil adaptado para niños de 3 a 10 años." }},
      { "@type": "Question", "name": "¿Cuántas personas caben por banca?", "acceptedAnswer": { "@type": "Answer", "text": "Mesa estándar: 6 personas (1.80 × 1.50 m). Mesa grande: 10-12 personas (2.40 × 1.50 m). Infantil: 8-10 niños (1.20 × 1.00 m)." }}
    ]
  })} />
</Fragment>

</BaseLayout>

<style>
  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 1024px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .grid-4 { grid-template-columns: 1fr; }
  }

  .gallery__heading {
    text-align: center;
    margin-bottom: 0.5rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--c-text, #1C1917);
    letter-spacing: -0.02em;
  }

  .gallery__sub {
    text-align: center;
    color: var(--c-text-muted, #78716C);
    font-size: 0.9375rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }
</style>
