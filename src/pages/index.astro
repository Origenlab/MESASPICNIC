---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBar from '../components/CtaBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import TestimonialCardEmpresa from '../components/TestimonialCardEmpresa.astro';
import FaqSection from '../components/FaqSection.astro';
import CtaBarFinal from '../components/CtaBarFinal.astro';
import GallerySection from '../components/GallerySection.astro';

const galeriaIndex = [
  { src: "/img/boda-hacienda-1.avif", alt: "Mesa larga decorada con flores blancas para boda en hacienda mexicana" },
  { src: "/img/corp-rooftop-1.avif", alt: "Mobiliario corporativo en terraza con skyline de CDMX" },
  { src: "/img/baby-shower-mesas-picnic-madera-cdmx-01.avif", alt: "Banca decorada con globos y cupcakes para fiesta infantil" },
  { src: "/img/mesa-picnic-madera-renta-cdmx-05.avif", alt: "Mesa con papel picado y decoración mexicana para fiesta temática" },
  { src: "/img/boda-boho-1.avif", alt: "Mesa bohemia con pampas y platos de terracota vista desde arriba" },
  { src: "/img/eventos-corporativos-ejecutivos-renta-mesas-picnic-02.avif", alt: "Bancas en parque verde para team building empresarial" },
  { src: "/img/infantil-teaparty-1.avif", alt: "Tea party infantil pastel sobre banca rústica en jardín" },
  { src: "/img/tema-tropical-1.avif", alt: "Mesa tropical con piñas y hojas monstera junto a la alberca" },
];
---

<BaseLayout
  title="Renta de Mesas Picnic para Eventos en CDMX | MESPIC"
  description="Renta de bancas de madera para bodas, corporativos y fiestas al aire libre. Entrega y montaje incluidos en CDMX y Edomex. Cotiza gratis."
>

<!-- Hero -->
<Hero
  badge="Mobiliario para eventos"
  title="Renta de Mesas Picnic para Eventos en CDMX"
  description="Bancas de madera natural para bodas, corporativos, fiestas infantiles y picnics al aire libre. Entrega, montaje y recolección incluidos en Ciudad de México y Estado de México."
  seoParagraph1="Desde 2017, MESPIC se dedica a la renta de mobiliario de madera para eventos al aire libre en la Ciudad de México y zona metropolitana. Hemos participado en más de 500 bodas, reuniones corporativas, cumpleaños y picnics románticos con bancas de pino natural lijadas y barnizadas a mano. Cada pieza mide 2.4 metros de largo y acomoda cómodamente de 6 a 8 personas."
  seoParagraph2="El servicio incluye entrega en tu ubicación, montaje profesional y recolección al terminar, sin cargos extra ni límite de tiempo. Operamos los 7 días de la semana y llegamos en un máximo de 3 horas a cualquier alcaldía de CDMX y municipios del Edomex como Naucalpan, Huixquilucan y Atizapán. El precio que cotizamos es el precio final: sin sorpresas."
  ctaPrimary={null}
  ctaSecondary={null}
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<!-- Servicios -->
<section class="section" id="servicios">
  <SectionHeader
    tag="h2"
    badge="Nuestros Servicios"
    title="Servicios de Renta de Mobiliario"
    paragraph1="Cada tipo de evento tiene necesidades distintas. No es lo mismo montar una boda para 150 personas en un jardín que un cumpleaños infantil en una terraza. Por eso ofrecemos configuraciones específicas para cada ocasión."
    paragraph2="Todas las opciones incluyen entrega, montaje y recolección. Tú eliges el tipo de evento, nosotros nos encargamos de que el mobiliario llegue listo y a tiempo."
    stats={[
      { value: '8+', label: 'tipos de eventos cubiertos' },
      { value: '500+', label: 'eventos realizados' },
      { value: '7 días', label: 'atención sin excepciones' },
    ]}
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Bodas al Aire Libre" description="Bancas de pino barnizadas a mano para bodas en jardines, haciendas y terrazas. Combinan con cualquier estilo de decoración: rústico, boho, clásico o minimalista. Montaje incluido." image="/img/boda-hacienda-1.avif" href="/servicios/bodas/" btnLabel="Mesas para bodas" badge="Bodas" icon="💍" />
      <ServiceCard title="Eventos Corporativos" description="Mobiliario para team buildings, conferencias y comidas empresariales al aire libre. Configuramos el montaje según la cantidad de asistentes y el formato de tu evento." image="/img/corp-teambuilding-1.avif" href="/servicios/eventos-corporativos/" btnLabel="Mobiliario corporativo" badge="Corporativo" icon="🏢" />
      <ServiceCard title="Fiestas Infantiles" description="Bancas lijadas a grano fino, sin astillas ni bordes filosos. Modelo infantil con altura adaptada para niños. Para cumpleaños, baby showers y reuniones familiares." image="/img/infantil-cumple-1.avif" href="/servicios/fiestas-infantiles/" btnLabel="Mesas para niños" badge="Infantil" icon="🎈" />
      <ServiceCard title="Picnic Romántico" description="Montaje íntimo para dos personas con banca decorada, mantelería y ambientación. Ideal para pedidas de mano, aniversarios o una tarde especial en cualquier parque o jardín de la ciudad." image="/img/picnic-romantico-bridal-shower-mesas-pino-01.avif" href="/servicios/picnic-romantico/" btnLabel="Picnic para parejas" badge="Romántico" icon="❤️" />
      <ServiceCard title="Fiestas Temáticas" description="Montajes para fiestas mexicanas, XV años, ferias gastronómicas y celebraciones temáticas. La madera natural se adapta a cualquier ambientación que tengas en mente." image="/img/tema-mexicana-1.avif" href="/servicios/fiestas-tematicas/" btnLabel="Mesas para fiestas" badge="Temático" icon="🎉" />
      <ServiceCard title="Reuniones Familiares" description="Mobiliario para cumpleaños de adultos, día de las madres, posadas y reuniones de fin de semana. Bancas amplias donde caben abuelos, papás y niños sin apretarse." image="/img/reunion-familiar-mesas-picnic-coyoacan-01.avif" href="/servicios/reuniones-familiares/" btnLabel="Mesas para familia" badge="Familiar" icon="🏡" />
      <ServiceCard title="Festivales y Ferias" description="Bancas resistentes de alta capacidad para ferias gastronómicas, bazares, festivales culturales y eventos masivos al aire libre. Disponibles en volumen para 100+ personas." image="/img/cine-aire-libre-mesas-picnic-festival-01.avif" href="/servicios/festivales/" btnLabel="Mobiliario para festivales" badge="Masivo" icon="🎪" />
      <ServiceCard title="Sesiones Fotográficas" description="Bancas de madera como escenografía para sesiones de fotos profesionales, contenido para redes sociales, catálogos y producciones audiovisuales. Montaje por hora disponible." image="/img/equipo-trabajo-mesas-picnic-showroom.avif" href="/servicios/sesiones-fotograficas/" btnLabel="Renta para fotos" badge="Foto & Video" icon="📷" />
    </div>
  </div>
</section>

<!-- Catálogo de Productos -->
<section class="section section-alt" id="catalogo">
  <SectionHeader
    tag="h2"
    badge="Catálogo de productos"
    title="6 Modelos de Mesa Picnic para Elegir"
    paragraph1="Cada modelo tiene un uso y capacidad distintos. Desde la estándar para bodas y reuniones hasta la infantil con acabado ultrafino, pasando por el Set Completo con decoración incluida. Elige el que se adapte a tu evento."
    paragraph2="¿Tienes dudas sobre cuál modelo rentar? Mándanos tu número de invitados por WhatsApp y te recomendamos la configuración ideal en minutos."
    stats={[
      { value: '6', label: 'modelos en catálogo' },
      { value: '6–12', label: 'personas por pieza' },
      { value: '+120 pzas', label: 'inventario disponible' },
    ]}
  />
  <div class="container">
    <div class="grid-3">
      <ServiceCard
        title="Mesa Picnic Estándar"
        description="El modelo más solicitado. 1.80 × 1.50 m para 6 personas. Pino lijado y barnizado a mano. Ideal para bodas, reuniones familiares y corporativos."
        image="/img/renta-mesa-picnic-madera-pino-cdmx-03.avif"
        href="/catalogo/mesa-picnic-estandar/"
        btnLabel="Ver ficha técnica →"
        badge="6 personas"
        icon="🪵"
      />
      <ServiceCard
        title="Mesa Picnic Grande"
        description="2.40 × 1.50 m para 10 a 12 personas. Preferida para eventos corporativos, festivales y mesa principal de bodas. Resistencia estructural reforzada."
        image="/img/mesa-picnic-grande-evento-16.avif"
        href="/catalogo/mesa-picnic-grande/"
        btnLabel="Ver ficha técnica →"
        badge="10-12 personas"
        icon="🌳"
      />
      <ServiceCard
        title="Mesa Picnic Infantil"
        description="1.20 × 1.00 m con altura reducida, bordes redondeados y lijado ultrafino sin astillas. Para cumpleaños y baby showers con 8-10 niños."
        image="/img/infantil-cumple-1.avif"
        href="/catalogo/mesa-picnic-infantil/"
        btnLabel="Ver ficha técnica →"
        badge="3-10 años"
        icon="🧸"
      />
      <ServiceCard
        title="Mesa Picnic Premium"
        description="Pino seleccionado sin nudos, 4 manos de barniz de acabado fino. Para bodas de alto perfil, eventos VIP y sesiones fotográficas profesionales."
        image="/img/mesa-picnic-lujo-madera-exterior-renta-01.avif"
        href="/catalogo/mesa-picnic-premium/"
        btnLabel="Ver ficha técnica →"
        badge="Bodas VIP"
        icon="✨"
      />
      <ServiceCard
        title="Set Picnic Completo"
        description="Mesa estándar con mantelería, cojines, centro decorativo y ambientación incluida. Llave en mano para picnics románticos y pedidas de mano."
        image="/img/picnic-romantico-bridal-shower-mesas-pino-01.avif"
        href="/catalogo/set-picnic-completo/"
        btnLabel="Ver ficha técnica →"
        badge="Todo incluido"
        icon="🎁"
      />
      <ServiceCard
        title="Mesa Picnic Rústica"
        description="Acabado campestre con barniz que resalta la veta y los nudos naturales. Estilo boho, vintage y rústico-chic para bodas en bosques y haciendas."
        image="/img/boda-rustica-intima-1.avif"
        href="/catalogo/mesa-picnic-rustica/"
        btnLabel="Ver ficha técnica →"
        badge="Boho & Vintage"
        icon="🌿"
      />
    </div>
    <div class="catalog-cta-wrap">
      <a href="/catalogo/" class="btn btn-secondary">Ver catálogo completo con tabla comparativa →</a>
    </div>
  </div>
</section>

<!-- ¿Por qué MESPIC? -->
<section class="section" id="por-que">
  <SectionHeader
    tag="h2"
    badge="Por qué elegirnos"
    title="¿Por qué elegir MESPIC?"
    paragraph1="Después de 8 años y más de 500 eventos, hay cosas que solo se aprenden con experiencia: cómo proteger la madera del clima, cuántas bancas necesitas según tus invitados, o cómo distribuir el mobiliario para que todos estén cómodos."
    paragraph2="Trabajamos con pino nacional seleccionado, lijado a grano fino y barnizado a mano. No subcontratamos: nuestro equipo se encarga desde la carga hasta el último detalle del montaje."
    stats={[
      { value: '8 años', label: 'de experiencia operativa' },
      { value: '100%', label: 'madera de pino natural' },
      { value: 'equipo propio', label: 'sin subcontratistas' },
    ]}
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard index={0} title="Madera 100% Natural" description="Pino nacional seleccionado, lijado a grano fino y barnizado a mano. Sin plásticos ni materiales sintéticos. La textura y el color de la madera real no se pueden imitar." />
      <FeatureCard index={1} title="Entrega y Montaje Incluidos" description="Nuestro equipo lleva el mobiliario a tu ubicación, lo monta donde tú indiques y lo recoge al terminar. El precio que cotizamos es el precio final, sin cargos por traslado ni maniobras." />
      <FeatureCard index={2} title="Sin Límite de Tiempo" description="El mobiliario queda en tu evento hasta que termine. No cobramos por hora ni por tiempo extra. Si tu boda acaba a las 3 am, recogemos a las 3 am." />
      <FeatureCard index={3} title="+500 Eventos desde 2017" description="Bodas, corporativos, cumpleaños, posadas, XV años y festivales. Después de 8 años conocemos la logística y anticipamos lo que cada tipo de evento necesita." />
    </div>
  </div>
</section>

<!-- Testimonios -->
<section class="section section-alt" id="testimonios">
  <SectionHeader
    tag="h2"
    badge="Empresas que confían en nosotros"
    title="Lo que dicen nuestros aliados"
    paragraph1="Empresas del sector eventos que trabajan junto a MESPIC en cada producción — desde corporativos de gran formato hasta festivales y fiestas infantiles en la Ciudad de México."
    paragraph2="Estas alianzas nos permiten ser parte de eventos integrales donde el mobiliario se combina con iluminación, sonido, pantallas y producción profesional."
    stats={[
      { value: '8', label: 'empresas aliadas' },
      { value: '5★', label: 'calificación unánime' },
      { value: 'CDMX + Edomex', label: 'zona de cobertura' },
    ]}
  />
  <div class="container">
    <div class="grid-4">
      <TestimonialCardEmpresa
        name="Eventech MX"
        sector="Tecnología para Eventos"
        url="https://eventech.mx/"
        initials="ET"
        quote="Llevamos más de dos años trabajando con MESPIC en nuestros eventos corporativos. La puntualidad, la calidad del mobiliario y el profesionalismo del equipo son consistentes en cada servicio. Para nosotros es un proveedor de confianza que seguimos recomendando sin dudarlo."
      />
      <TestimonialCardEmpresa
        name="Renta de Iluminación"
        sector="Iluminación para Eventos"
        url="https://rentadeiluminacion.com/"
        initials="RI"
        quote="Trabajamos con MESPIC en varios eventos donde combinamos iluminación y mobiliario. La coordinación es fluida, siempre llegan a tiempo y el mobiliario está en perfectas condiciones. Es una alianza natural que ya recomendamos a nuestros propios clientes."
      />
      <TestimonialCardEmpresa
        name="Avant Expo"
        sector="Stands y Exposiciones"
        url="https://avantexpo.com.mx/"
        initials="AE"
        quote="Integramos el mobiliario de MESPIC en varios de nuestros montajes para exposiciones y eventos corporativos. La madera natural encaja perfecto con stands de diseño y el servicio logístico es impecable. Un proveedor confiable que nos facilita el trabajo."
      />
      <TestimonialCardEmpresa
        name="Podiumex"
        sector="Producción de Eventos"
        url="https://podiumex.com/"
        initials="PX"
        quote="En Podiumex hemos contado con MESPIC como proveedor de mobiliario en producciones de eventos de gran formato. Su capacidad de respuesta, la calidad de las piezas y la seriedad del equipo los hacen un aliado indispensable en cualquier producción."
      />
      <TestimonialCardEmpresa
        name="Pantalla LED"
        sector="Renta de Pantallas LED"
        url="https://pantalla-led.com/"
        initials="PL"
        quote="Combinamos nuestras pantallas LED con el mobiliario de MESPIC en eventos al aire libre y el resultado visual es muy impactante. Son puntuales, organizados y el estado de las piezas siempre es excelente. Los recomendamos como parte de nuestro ecosistema de proveedores."
      />
      <TestimonialCardEmpresa
        name="Inflables para Fiestas"
        sector="Entretenimiento Infantil"
        url="https://inflablesparafiestas.com.mx/"
        initials="IF"
        quote="Llevamos eventos infantiles donde nuestros inflables y el mobiliario de MESPIC se complementan de maravilla. Los niños tienen dónde jugar y dónde sentarse a comer, todo en el mismo espacio. El equipo de MESPIC siempre coordinado y sin complicaciones."
      />
      <TestimonialCardEmpresa
        name="Sonido para Eventos"
        sector="Audio y Sonido para Eventos"
        url="https://sonidoparaeventos.com.mx/"
        initials="SE"
        quote="Hemos coincidido con MESPIC en eventos al aire libre donde nosotros ponemos el sonido y ellos el mobiliario. La logística de su equipo es ágil y no interfiere con nuestros montajes. Una empresa seria con la que es fácil trabajar en paralelo."
      />
      <TestimonialCardEmpresa
        name="Renta de Sonido e Iluminación"
        sector="Sonido e Iluminación"
        url="https://rentadesonidoeiluminacion.com.mx/"
        initials="RS"
        quote="Cuando ofrecemos paquetes integrales de sonido e iluminación, MESPIC es nuestra primera opción para el mobiliario. Su servicio cierra el círculo: el cliente recibe todo resuelto en un solo evento. Profesionales de principio a fin."
      />
    </div>
  </div>
</section>

<!-- Galería -->
<section class="section" id="galeria">
  <SectionHeader
    tag="h2"
    badge="Galería de eventos"
    title="Nuestro Mobiliario en Acción"
    paragraph1="Bodas, corporativos, fiestas infantiles y eventos temáticos — la madera se adapta a cualquier ocasión y estilo de decoración."
    stats={[
      { value: '3 modelos', label: 'estándar, grande e infantil' },
      { value: 'pino natural', label: 'lijado y barnizado a mano' },
      { value: 'cualquier estilo', label: 'rústico, boho, minimalista…' },
    ]}
  />
  <GallerySection images={galeriaIndex} id="galeria-fotos" />
</section>

<!-- FAQ -->
<section class="section" id="faq">
  <SectionHeader
    tag="h2"
    badge="Preguntas frecuentes"
    title="Preguntas Frecuentes"
    paragraph1="Estas son las dudas más comunes que recibimos por WhatsApp antes de cada evento. Si no encuentras tu respuesta, usa el formulario de al lado y te respondemos en minutos."
    paragraph2="Toda la información de precios, tiempos de entrega, zonas de cobertura y especificaciones del mobiliario está en las respuestas."
    stats={[
      { value: '8', label: 'preguntas con respuesta inmediata' },
      { value: '< 5 min', label: 'tiempo de respuesta por WhatsApp' },
      { value: 'lun–dom', label: '8:00 a 20:00 hrs' },
    ]}
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿Qué incluye el servicio de renta?", answer: "Entrega en tu ubicación, montaje profesional, uso sin límite de tiempo y recolección al terminar. El precio que cotizamos es el precio final: sin cargos por traslado, maniobras ni tiempo extra." },
      { question: "¿Cuánto cuesta rentar una mesa picnic?", answer: "El precio depende del modelo y la cantidad. Cotizamos sin compromiso por WhatsApp con disponibilidad para tu fecha. Los paquetes arrancan desde 4 bancas estándar para 24 personas." },
      { question: "¿En qué zonas entregan?", answer: "Cubrimos todas las alcaldías de la Ciudad de México y municipios del Estado de México como Naucalpan, Huixquilucan, Atizapán, Tlalnepantla e Interlomas. El tiempo de entrega promedio es de 2 a 3 horas." },
      { question: "¿Con cuánta anticipación debo reservar?", answer: "Recomendamos al menos 1 semana de anticipación, especialmente en temporada alta (noviembre a febrero). Atendemos solicitudes de último momento según disponibilidad." },
      { question: "¿Las bancas son seguras para niños?", answer: "Sí. Todas las piezas están lijadas a grano fino, sin astillas ni bordes filosos. También tenemos un modelo infantil con altura y dimensiones adaptadas para niños de 3 a 10 años." },
      { question: "¿Puedo decorar las bancas?", answer: "La madera natural combina con todo: manteles, flores, velas, centros de mesa, telas o cualquier elemento. Muchos clientes nos mandan fotos de referencia y adaptamos el montaje a su estilo." },
      { question: "¿Qué pasa si llueve el día del evento?", answer: "Si tu evento se cancela por clima, puedes reagendar sin costo adicional. Si el evento es en un espacio techado o con carpa, no hay problema: las bancas funcionan igual en interiores." },
      { question: "¿Cuántas personas caben por banca?", answer: "La mesa estándar mide 1.80 × 1.50 m y acomoda 6 personas. La mesa grande mide 2.40 × 1.50 m para 10-12 personas. La infantil es de 1.20 × 1.00 m para 8-10 niños." }
    ]}
  />
</section>

<!-- CTA Final -->
<CtaBarFinal
  headline="¿Listo para tu evento?"
  subtext="Cotiza sin compromiso. Te respondemos en minutos."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero cotizar mesas picnic para mi evento."
  cotizarHref="/cotizar/"
/>

<!-- Schema.org -->
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "MESPIC — Renta de Mesas Picnic",
    "description": "Renta de mobiliario de madera para eventos al aire libre en Ciudad de México y Estado de México.",
    "url": "https://mesaspicnic.com",
    "telephone": "+52-55-6432-8954",
    "priceRange": "$$",
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle Gob. García Conde 34, Col. San Miguel Chapultepec I Secc",
      "addressLocality": "Ciudad de México",
      "addressRegion": "Miguel Hidalgo, CDMX",
      "postalCode": "11800",
      "addressCountry": "MX"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "ratingCount": "500"
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué incluye el servicio de renta?", "acceptedAnswer": { "@type": "Answer", "text": "Entrega en tu ubicación, montaje profesional, uso sin límite de tiempo y recolección al terminar. El precio que cotizamos es el precio final." }},
      { "@type": "Question", "name": "¿Cuánto cuesta rentar una mesa picnic?", "acceptedAnswer": { "@type": "Answer", "text": "El precio depende del modelo y la cantidad. Cotizamos sin compromiso por WhatsApp. Los paquetes arrancan desde 4 bancas estándar para 24 personas." }},
      { "@type": "Question", "name": "¿En qué zonas entregan?", "acceptedAnswer": { "@type": "Answer", "text": "Cubrimos todas las alcaldías de CDMX y municipios del Edomex como Naucalpan, Huixquilucan, Atizapán y Tlalnepantla. Entrega en 2 a 3 horas." }},
      { "@type": "Question", "name": "¿Las bancas son seguras para niños?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Todas las piezas están lijadas a grano fino, sin astillas. También tenemos modelo infantil adaptado para niños de 3 a 10 años." }},
      { "@type": "Question", "name": "¿Cuántas personas caben por banca?", "acceptedAnswer": { "@type": "Answer", "text": "Mesa estándar: 6 personas (1.80 × 1.50 m). Mesa grande: 10-12 personas (2.40 × 1.50 m). Infantil: 8-10 niños (1.20 × 1.00 m)." }}
    ]
  })} />
</Fragment>

</BaseLayout>

<style>
  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .catalog-cta-wrap {
    text-align: center;
    margin-top: 2.5rem;
  }

  @media (max-width: 1024px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
    .grid-3 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .grid-4 { grid-template-columns: 1fr; }
    .grid-3 { grid-template-columns: 1fr; }
  }

</style>
