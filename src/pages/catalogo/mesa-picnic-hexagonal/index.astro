---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import NextStep from '../../../components/NextStep.astro';
import ExploreMore from '../../../components/ExploreMore.astro';
---

<BaseLayout
  title="Mesa Picnic Hexagonal para Renta — Ø 1.80 m · 6-8 Personas | MESPIC CDMX"
  description="Renta la Mesa Picnic Hexagonal de MESPIC: diseño poligonal de pino nacional barnizado, capacidad para 6-8 personas. Perfecta para bodas boho, eventos jardín, fiestas temáticas y sesiones fotográficas en CDMX y Edomex. Entrega y montaje incluidos."
  ogImage="/img/catalogo/mesa-picnic-hexagonal-madera-6-personas-jardin-01.webp"
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Catálogo", href: "/catalogo/" },
    { label: "Mesa Picnic Hexagonal" }
  ]} />
</Fragment>

<Hero
  badge="Mesa Hexagonal"
  title="Mesa Picnic Hexagonal — Ø 1.80 m para 6-8 Personas"
  description="El modelo más distintivo del catálogo. Forma hexagonal de pino nacional, barnizada a mano. Rompe el formato rectangular convencional y ordena la conversación en círculo: ideal para bodas boho, fiestas temáticas y eventos de jardín."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="La Mesa Picnic Hexagonal de MESPIC es la pieza favorita de los coordinadores de bodas y eventos que buscan ruptura visual con respecto al formato rectangular convencional. Su forma de seis lados permite que los comensales se distribuyan de manera natural alrededor de la mesa, facilitando la conversación en grupo y eliminando las posiciones de 'cabecera'. Con un diámetro inscrito de 1.80 metros, acomoda entre 6 y 8 personas con total comodidad."
  seoParagraph2="Disponible para renta en Ciudad de México y Estado de México, la Mesa Hexagonal se integra perfectamente a eventos de estética boho, rústica, campestre y vintage. Su pino nacional lijado y barnizado a tres manos presenta la veta natural de la madera, que actúa como decoración propia sin necesitar forros ni cubiertas adicionales. Cada mesa incluye 6 bancas sectoriales que se ajustan al perímetro hexagonal para un montaje visual impecable."
  dark={true}
/>

<CtaBar />

<!-- ═══════════════════════════════════════════════════════
     GALERÍA + SIDEBAR MODELOS
═══════════════════════════════════════════════════════ -->
<section class="section" id="galeria">
  <SectionHeader
    tag="h2"
    badge="Mesa Hexagonal en eventos"
    title="La Mesa Hexagonal en Bodas Boho, Jardines y Sesiones Fotográficas"
    paragraph1="El formato hexagonal crea composiciones visuales únicas que ninguna mesa rectangular puede replicar. Aquí, algunos de los eventos donde ha sido la pieza protagonista."
    paragraph2="¿Ya tienes fecha y locación? Consulta disponibilidad y configuración de layout por WhatsApp. Respondemos el mismo día."
  />
  <ProductGallery
    images={[
      { src: "/img/catalogo/mesa-picnic-hexagonal-madera-6-personas-jardin-01.webp", alt: "Mesa picnic hexagonal de pino natural decorada para boda boho en jardín al aire libre" },
      { src: "/img/catalogo/mesa-picnic-hexagonal-madera-6-personas-jardin-02.webp", alt: "Mesa hexagonal con bancas sectoriales en jardín privado para evento al atardecer" },
      { src: "/img/catalogo/mesa-picnic-hexagonal-madera-6-personas-jardin-03.webp", alt: "Varias mesas picnic hexagonales distribuidas en jardín verde para boda campestre" },
      { src: "/img/catalogo/mesa-picnic-hexagonal-madera-6-personas-jardin-04.webp", alt: "Mesa hexagonal con decoración floral boho para celebración en jardín privado CDMX" },
      { src: "/img/catalogo/mesa-picnic-hexagonal-madera-6-personas-jardin-05.webp", alt: "Mesa picnic hexagonal con luces cálidas en evento nocturno de jardín elegante" },
      { src: "/img/catalogo/mesa-picnic-hexagonal-ficha-dimensiones-01.webp",        alt: "Ficha de dimensiones de la mesa picnic hexagonal MESPIC — Ø 1.80 m" },
    ]}
    recommended={[
      { title: "Mesa Estándar",      description: "1.80 m · 6 personas",              href: "/catalogo/mesa-picnic-estandar/",     image: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" },
      { title: "Mesa Premium",       description: "Acabado sin nudos · Bodas VIP",    href: "/catalogo/mesa-picnic-premium/",      image: "/img/mesa-picnic-lujo-madera-exterior-renta-01.avif" },
      { title: "Mesa Rústica",       description: "Veta visible · Boho & vintage",    href: "/catalogo/mesa-picnic-rustica/",      image: "/img/mesa-picnic-madera-renta-cdmx-05.avif" },
      { title: "Set Picnic Completo",description: "Mesa + decoración premium",        href: "/catalogo/set-picnic-completo/",      image: "/img/picnic-romantico-bridal-shower-mesas-pino-02.avif" },
      { title: "Mesa Grande",        description: "2.40 m · 10–12 personas",          href: "/catalogo/mesa-picnic-grande/",       image: "/img/mesas-picnic-madera-renta-evento-cdmx-05.avif" },
    ]}
    sidebarTitle="Otros modelos del catálogo"
  />
</section>

<!-- ═══════════════════════════════════════════════════════
     ESPECIFICACIONES TÉCNICAS
═══════════════════════════════════════════════════════ -->
<section class="section section-alt" id="especificaciones">
  <SectionHeader
    tag="h2"
    badge="Ficha técnica"
    title="Especificaciones de la Mesa Hexagonal"
    paragraph1="Dimensiones exactas, material, acabado y capacidad. Todo lo que necesitas para planear el layout de tu evento con mesas de formato no convencional."
    paragraph2="Si necesitas croquis de distribución o medidas exactas para tu locación, escríbenos por WhatsApp y te enviamos la ficha técnica completa en PDF."
    stats={[
      { value: 'Ø 1.80 m', label: 'diámetro inscrito' },
      { value: '6 lados',  label: 'formato hexagonal' },
      { value: '6-8',      label: 'personas sentadas' },
    ]}
  />
  <div class="container">
    <div class="spec-grid">
      <div class="spec-card">
        <h3 class="spec-card__title">Ficha Técnica</h3>
        <ul class="spec-list" role="list">
          <li class="spec-list__item">
            <span class="spec-list__label">Forma</span>
            <span class="spec-list__value">Hexagonal (6 lados iguales)</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Diámetro inscrito</span>
            <span class="spec-list__value">Ø 1.80 m</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Alto de mesa</span>
            <span class="spec-list__value">75 cm</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Capacidad</span>
            <span class="spec-list__value">6–8 personas</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Material</span>
            <span class="spec-list__value">Pino nacional seleccionado</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Acabado</span>
            <span class="spec-list__value">Lijado fino + barniz exterior 3 manos</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Uso recomendado</span>
            <span class="spec-list__value">Exterior e interior ventilado</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Peso aproximado</span>
            <span class="spec-list__value">38 kg</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Disponibilidad</span>
            <span class="spec-list__value spec-list__value--ok">+40 piezas en bodega</span>
          </li>
        </ul>
        <a href="/cotizar/" class="spec-card__cta">Cotizar disponibilidad →</a>
      </div>

      <div class="spec-features">
        <FeatureCard
          index={0}
          title="Forma Hexagonal Premium"
          description="La geometría hexagonal crea un centro visual natural que ningún formato rectangular puede replicar. Cada comensal tiene la misma perspectiva de la mesa y de los demás, favoreciendo la conversación grupal y eliminando la jerarquía visual de 'cabecera'."
        />
        <FeatureCard
          index={1}
          title="Compatible con Estilos Boho, Rústico y Moderno"
          description="La veta natural del pino barnizado funciona como elemento decorativo propio. Combina con decoración boho (flores secas, macramé), rústica (follaje y velas) o minimalista (flores blancas y cristalería simple) sin necesidad de forros."
        />
        <FeatureCard
          index={2}
          title="Acceso desde 6 Ángulos — Servicio Más Fluido"
          description="El formato hexagonal permite al personal de servicio acercarse a cualquier comensal desde cualquiera de los 6 lados. Esto agiliza la presentación de platillos en banquetes y reduce la incomodidad de servir sobre los hombros de los invitados."
        />
        <FeatureCard
          index={3}
          title="Pino Nacional Barnizado a Mano"
          description="El mismo pino nacional seleccionado que utilizamos en todos los modelos del catálogo: lijado a grano progresivo 80-120-180 y sellado con barniz de poliuretano exterior en tres capas. Resistente a humedad moderada y exposición solar de eventos de 8 a 12 horas."
        />
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     USOS RECOMENDADOS
═══════════════════════════════════════════════════════ -->
