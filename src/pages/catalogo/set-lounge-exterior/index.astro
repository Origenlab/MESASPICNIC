---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import NextStep from '../../../components/NextStep.astro';
import WaBubble from '../../../components/WaBubble.astro';
import ExploreMore from '../../../components/ExploreMore.astro';
---
<BaseLayout
  title="Set Lounge Exterior para Renta — Zona VIP · Eventos Premium | MESPIC CDMX"
  description="Renta el Set Lounge Exterior de MESPIC: mesa baja de pino con aceite de teca + 4 módulos de asiento tapizados. Zona VIP lista para instalar en bodas, cócteles y eventos premium en CDMX y Edomex."
  ogImage="/img/catalogo/set-lounge-exterior-madera-vip-evento-01.webp"
>
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Catálogo", href: "/catalogo/" },
    { label: "Set Lounge Exterior" }
  ]} />
</Fragment>
<Hero
  badge="Zona VIP Premium"
  title="Set Lounge Exterior — Zona VIP Lista para Instalar"
  description="El conjunto más exclusivo del catálogo. Mesa baja de pino con aceite de teca y 4 módulos de asiento tapizados en lona impermeable. Una zona VIP completa en un solo set, lista en minutos. Ideal para bodas premium, picnics románticos y eventos de lujo al aire libre."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="El Set Lounge Exterior de MESPIC representa la evolución natural del mobiliario picnic hacia una experiencia de lujo completa al aire libre. A diferencia de las mesas y bancas convencionales, el Set Lounge crea un ambiente de descanso exclusivo con una mesa baja de 45 centímetros de altura en pino tratado con aceite de teca, rodeada de 4 módulos de asiento tapizados en lona impermeable de 600D. El resultado es una zona de lounge al nivel de los mejores resorts boutique de México."
  seoParagraph2="Disponible para renta en Ciudad de México y Estado de México, el Set Lounge Exterior es especialmente solicitado por coordinadores de bodas VIP, organizadores de picnics románticos y empresas que buscan crear áreas de hospitalidad premium en sus eventos corporativos. La combinación de madera natural con aceite de teca y tapizado en colores neutros (crudo, negro, beige o terracota) crea un mobiliario elegante que no requiere decoración adicional para impactar visualmente."
  dark={true}
/>
<CtaBar />
<section class="section" id="galeria">
  <SectionHeader tag="h2" badge="Lounge en eventos"
    title="El Set Lounge en Bodas VIP, Picnics Románticos y Galas"
    paragraph1="Zonas de hospitalidad y descanso que elevan la experiencia de cualquier evento al nivel de los mejores venues boutique. Así luce el Set Lounge en contextos reales."
    paragraph2="¿Necesitas combinar el Set Lounge con mesas de comedor para crear un evento completo? Te preparamos el layout integrado." />
  <ProductGallery
    images={[
      { src: "/img/catalogo/set-lounge-exterior-madera-vip-evento-01.webp", alt: "Set lounge exterior de madera con tapizado crudo en cena romántica al atardecer" },
      { src: "/img/catalogo/set-lounge-exterior-madera-vip-evento-02.webp", alt: "Zona lounge exterior con mesa baja de pino y velas para evento romántico VIP" },
      { src: "/img/catalogo/set-lounge-exterior-madera-vip-evento-03.webp", alt: "Set lounge premium en pedida de mano al aire libre con decoración de flores" },
      { src: "/img/catalogo/set-lounge-exterior-madera-vip-evento-04.webp", alt: "Lounge exterior con mesa baja de madera en viñedo al atardecer" },
      { src: "/img/catalogo/set-lounge-exterior-madera-vip-evento-05.webp", alt: "Mesa baja lounge con decoración elegante de champagne y flores para evento gala" },
      { src: "/img/mesa-picnic-decoracion-elegante-champagne.webp",         alt: "Detalle de decoración de mesa lounge exterior con champagne y arreglo floral" },
    ]}
    recommended={[
      { title: "Set Picnic Completo", description: "Mesa + decoración premium",        href: "/catalogo/set-picnic-completo/",     image: "/img/picnic-romantico-bridal-shower-mesas-pino-02.avif" },
      { title: "Mesa Premium",        description: "Acabado sin nudos · Bodas VIP",   href: "/catalogo/mesa-picnic-premium/",     image: "/img/mesa-picnic-lujo-madera-exterior-renta-01.avif" },
      { title: "Mesa Hexagonal",      description: "Ø 1.80 m · 6-8 personas",        href: "/catalogo/mesa-picnic-hexagonal/",   image: "/img/catalogo/mesa-picnic-hexagonal-madera-6-personas-jardin-01.webp" },
      { title: "Mesa de Parota",      description: "Madera premium maciza VIP",       href: "/catalogo/mesa-picnic-parota/",      image: "/img/catalogo/mesa-picnic-parota-madera-premium-vip-01.webp" },
      { title: "Mesa Alta Cocktail",  description: "Standing · networking premium",   href: "/catalogo/mesa-alta-cocktail/",      image: "/img/catalogo/mesa-alta-cocktail-madera-networking-01.webp" },
    ]}
    sidebarTitle="Otros modelos del catálogo"
  />
</section>
<section class="section section-alt" id="especificaciones">
  <SectionHeader tag="h2" badge="Ficha técnica" title="Especificaciones del Set Lounge Exterior"
    paragraph1="Componentes, materiales y dimensiones del set completo. Todo lo que necesitas para planear la zona VIP de tu evento."
    paragraph2="¿Necesitas múltiples sets o configuraciones personalizadas? Escríbenos con los detalles de tu evento y te preparamos una propuesta a medida."
    stats={[
      { value: '4-6',    label: 'personas por set' },
      { value: '45 cm',  label: 'altura mesa baja' },
      { value: 'VIP',    label: 'experiencia premium' },
    ]} />
  <div class="container">
    <div class="spec-grid">
      <div class="spec-card">
        <h3 class="spec-card__title">Ficha Técnica</h3>
        <ul class="spec-list" role="list">
          <li class="spec-list__item"><span class="spec-list__label">Componentes</span><span class="spec-list__value">1 mesa + 4 módulos asiento</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Medidas mesa</span><span class="spec-list__value">0.90 × 0.60 × 0.45 m</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Área total set</span><span class="spec-list__value">~2.50 × 2.50 m</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Capacidad</span><span class="spec-list__value">4–6 personas sentadas</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Material mesa</span><span class="spec-list__value">Pino natural + aceite de teca</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Tapizado</span><span class="spec-list__value">Lona impermeable 600D</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Colores disponibles</span><span class="spec-list__value">Crudo, negro, beige, terracota</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Uso</span><span class="spec-list__value">Exterior con humedad moderada</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Disponibilidad</span><span class="spec-list__value spec-list__value--ok">+25 sets completos en bodega</span></li>
        </ul>
        <a href="/cotizar/" class="spec-card__cta">Cotizar disponibilidad →</a>
      </div>
      <div class="spec-features">
        <FeatureCard index={0} title="Zona VIP Lista para Instalar en 15 Minutos"
          description="El Set Lounge Exterior llega completamente armado y listo para instalar. Nuestro equipo coloca la mesa central, distribuye los 4 módulos de asiento y alinea la configuración. En 15 minutos, la zona VIP está lista para recibir a los primeros invitados sin que el anfitrión haya movido un dedo." />
        <FeatureCard index={1} title="Tapizado Impermeable — Lona 600D Premium"
          description="Los módulos de asiento están tapizados en lona de poliéster de 600 denier, el mismo estándar impermeable usado en mobiliario de terrazas de hoteles boutique. Resiste salpicaduras, humedad ambiental y rocío de madrugada sin manchar ni decolorar el tapizado." />
        <FeatureCard index={2} title="Configuración Modular — Cuatro Posibles Layouts"
          description="Los 4 módulos de asiento se pueden distribuir en L, en U, enfrentados o alrededor de la mesa según el concepto del evento. Esta flexibilidad de configuración permite adaptar el Set Lounge a espacios y concepciones estéticas diferentes sin piezas adicionales." />
        <FeatureCard index={3} title="Madera de Pino con Aceite de Teca — Resistencia Superior"
          description="A diferencia de las mesas del catálogo con barniz de poliuretano, la mesa baja del Set Lounge está acabada con aceite de teca de penetración profunda. Este tratamiento impregna la fibra de la madera en lugar de crear una película superficial, ofreciendo mayor resistencia a la humedad y un aspecto más natural y mate." />
      </div>
    </div>
  </div>
</section>
<section class="section" id="usos">
  <SectionHeader tag="h2" badge="Usos recomendados" title="El Set Lounge: Para Eventos que Priorizan la Experiencia"
    paragraph1="El Set Lounge Exterior crea zonas de hospitalidad que transforman la percepción del evento. Estos son los contextos donde genera mayor impacto."
    paragraph2="¿Tu evento necesita una zona VIP diferente? Descríbenos tu concepto y lo adaptamos."
    stats={[
      { value: '4-6',    label: 'personas por set' },
      { value: '15 min', label: 'instalación completa' },
      { value: '4',      label: 'colores de tapizado' },
    ]} />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Bodas de Lujo y Ceremonias VIP" description="Las bodas premium en haciendas y jardines privados incorporan el Set Lounge como área de cóctel pre-ceremonia o como zona de descanso post-banquete donde los invitados más cercanos pueden continuar la celebración en un ambiente íntimo y elegante." image="/img/catalogo/set-lounge-exterior-madera-vip-evento-03.webp" href="/servicios/bodas/" btnLabel="Lounge para bodas" badge="Bodas VIP" />
      <ServiceCard title="Picnic Romántico Premium" description="Para pedidas de mano, aniversarios y escapadas románticas, el Set Lounge en una sola configuración para 2 personas crea un escenario de cinematografía pura: mesa baja con champagne, flores, frutos y cojines, en medio de un jardín o viñedo al atardecer." image="/img/catalogo/set-lounge-exterior-madera-vip-evento-04.webp" href="/servicios/picnic-romantico/" btnLabel="Lounge romántico" badge="Romántico" />
      <ServiceCard title="Eventos Corporativos de Alto Perfil" description="En presentaciones de producto, cenas de dirección y eventos de apreciación a clientes VIP, el Set Lounge crea áreas de conversación exclusivas que complementan las mesas de comedor sin competir con ellas. El formato lounge invita a conversaciones más largas y relajadas." image="/img/catalogo/set-lounge-exterior-madera-vip-evento-02.webp" href="/servicios/eventos-corporativos/" btnLabel="Lounge corporativo" badge="Corporativo" />
      <ServiceCard title="Fiestas Privadas y Celebraciones" description="Para cumpleaños de 40 o 50 años, graduaciones familiares y reuniones donde los anfitriones quieren crear diferentes zonas de experiencia dentro del mismo evento, el Set Lounge define visualmente el área premium de la celebración." image="/img/catalogo/set-lounge-exterior-madera-vip-evento-01.webp" href="/servicios/reuniones-familiares/" btnLabel="Lounge para fiestas" badge="Celebraciones" />
    </div>
  </div>
</section>
<section class="section section-alt" id="faq">
  <SectionHeader tag="h2" badge="Preguntas frecuentes" title="Preguntas sobre el Set Lounge Exterior"
    paragraph1="Dudas sobre materiales, configuración, resistencia al exterior y coordinación con el resto del evento."
    paragraph2="¿Tu evento tiene requerimientos específicos? Escríbenos con los detalles." />
  <FaqSection phone="55 6432 8954" whatsapp="5564328954" schedule="Lun–Dom 8:00–20:00"
    waMessage="Hola, quiero cotizar el Set Lounge Exterior para mi evento."
    items={[
      { question: "¿El tapizado es realmente impermeable?", answer: "Sí. La lona de 600 denier tiene tratamiento impermeabilizante que resiste salpicaduras y humedad ambiental. No está diseñada para lluvia directa e intensa; en ese caso recomendamos colocar el Set Lounge bajo carpa o toldo. Para eventos en temporada de lluvias, siempre sugerimos tener cobertura de protección disponible." },
      { question: "¿Qué colores de tapizado están disponibles?", answer: "Manejamos 4 colores de tapizado: crudo (blanco roto, el más solicitado para bodas), negro mate (para eventos corporativos y modernos), beige arena (neutro que combina con todo) y terracota (el color institucional de MESPIC, ideal para eventos con paleta cálida). La disponibilidad por color puede variar según la temporada; consulta al reservar." },
      { question: "¿El Set Lounge puede configurarse para 2 personas solamente?", answer: "Sí. Para picnics románticos y pedidas de mano, es habitual configurar el Set Lounge solo con la mesa central y 2 módulos de asiento enfrentados. Los 2 módulos adicionales se incluyen en el precio pero no es necesario instalarlos si no se van a usar. Simplemente indícanos la configuración al reservar." },
      { question: "¿Se puede combinar con mesas del catálogo en el mismo evento?", answer: "Sí, y es la combinación más habitual en eventos con zonas diferenciadas: mesas estándar o grandes para la zona de comida principal, y Sets Lounge para el área de cóctel o descanso VIP. La diferencia de altura entre la mesa baja del lounge (45 cm) y las mesas estándar (75 cm) crea una separación visual clara entre zonas." },
      { question: "¿El servicio incluye cojines o almohadillas adicionales?", answer: "El tapizado integrado de los módulos de asiento es el único elemento de asiento incluido. No incluimos cojines decorativos adicionales. Si quieres cojines extra de decoración para personalizar el look del lounge, te orientamos sobre proveedores de decoración que trabajan con MESPIC de forma complementaria." },
      { question: "¿Hay cargo adicional por el traslado del Set Lounge?", answer: "No. El Set Lounge Exterior está incluido en el servicio estándar de entrega, montaje y recolección de MESPIC para toda la CDMX y Estado de México. El precio cotizado incluye traslado, instalación en la configuración acordada y recolección al finalizar el evento, sin costos adicionales." }
    ]} />
</section>

<!-- Sigue explorando -->
<ExploreMore
  title="Sigue explorando MESPIC"
  subtitle="Todo lo que necesitas para tu evento en un solo lugar"
  items={[
    { href: '/servicios/', label: 'Todos los servicios', sub: 'Bodas, corporativos, infantiles y más', badge: 'Paso 1', isEmoji: true, icon: '🎪' },
    { href: '/catalogo/', label: 'Catálogo completo', sub: '20 modelos con fichas técnicas y fotos', badge: 'Paso 2', isEmoji: true, icon: '🪵' },
    { href: '/paquetes/', label: 'Nuestros paquetes', sub: 'Básico · Estándar · Premium', badge: 'Paso 3', isEmoji: true, icon: '📦' },
  ]}
/>

<!-- Siguiente paso -->
<NextStep
  titulo="¿Ya sabes qué tipo de evento tienes?"
  subtitulo="Explora todos nuestros servicios especializados: bodas, corporativos, fiestas infantiles, picnics románticos y más."
  href="/servicios/"
  btnLabel="Explorar servicios →"
  secondBtn={{ label: 'Ver catálogo', href: '/catalogo/' }}
/>
<WaBubble whatsapp="5564328954" message="Hola, me interesa rentar el Set Lounge Exterior." />
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@type": "Product", "name": "Set Lounge Exterior — Renta MESPIC", "description": "Set lounge exterior para renta. Incluye mesa baja de pino 0.90×0.60×0.45 m con aceite de teca + 4 módulos asiento tapizados en lona 600D impermeable. 4-6 personas. Disponible en crudo, negro, beige y terracota. CDMX y Edomex.", "brand": { "@type": "Brand", "name": "MESPIC" }, "category": "Mobiliario para eventos — Renta", "offers": { "@type": "Offer", "priceCurrency": "MXN", "availability": "https://schema.org/InStock" } })} />
</Fragment>
</BaseLayout>
<style>
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }
  .spec-grid { display: grid; grid-template-columns: 320px 1fr; gap: 2rem; align-items: start; }
  .spec-card { background: #fff; border: 1px solid var(--c-border, #E7E0D8); border-radius: var(--radius-md, 12px); padding: 1.75rem; position: sticky; top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2rem); }
  .spec-card__title { font-size: 1rem; font-weight: 700; color: var(--c-text, #1C1917); margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 2px solid var(--c-primary, #2C5530); }
  .spec-list { list-style: none; display: flex; flex-direction: column; gap: 0; margin-bottom: 1.5rem; }
  .spec-list__item { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.625rem 0; border-bottom: 1px solid var(--c-border, #E7E0D8); }
  .spec-list__item:last-child { border-bottom: none; }
  .spec-list__label { font-size: 0.8125rem; color: var(--c-text-muted, #78716C); font-weight: 500; flex-shrink: 0; }
  .spec-list__value { font-size: 0.8125rem; color: var(--c-text, #1C1917); font-weight: 600; text-align: right; }
  .spec-list__value--ok { color: var(--c-primary, #2C5530); }
  .spec-card__cta { display: flex; align-items: center; justify-content: center; background: var(--c-primary, #2C5530); color: #fff; padding: 0.75rem 1.25rem; border-radius: 8px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.18s ease; }
  .spec-card__cta:hover { background: #224228; }
  .spec-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  @media (max-width: 1024px) { .spec-grid { grid-template-columns: 1fr; } .spec-card { position: static; } }
  @media (max-width: 640px) { .spec-features { grid-template-columns: 1fr; } }
</style>
