---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import WaBubble from '../../../components/WaBubble.astro';
---

<BaseLayout
  title="Mesa Redonda de Madera para Renta — Ø 1.50m · 8-10 Personas | MESPIC CDMX"
  description="Renta la Mesa Redonda de Madera de MESPIC: diseño romántico de pino nacional barnizado, diámetro 1.50 m, capacidad para 8-10 personas. Perfecta para bodas íntimas, aniversarios, comuniones y cenas corporativas en CDMX y Edomex. Entrega y montaje incluidos."
  ogImage="/img/catalogo/mesa-redonda-madera-evento-boda-01.webp"
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Catálogo", href: "/catalogo/" },
    { label: "Mesa Redonda de Madera" }
  ]} />
</Fragment>

<Hero
  badge="Mesa Redonda"
  title="Mesa Redonda de Madera — Ø 1.50 m para 8-10 Personas"
  description="Diseño circular que elimina jerarquías. Pino nacional barnizado tres manos. Sin bancas integradas, compatible con sillas Tiffany, Crossback o de madera. Perfecta para bodas románticas, aniversarios y celebraciones íntimas."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="La Mesa Redonda de Madera de MESPIC es la elección de coordinadores que buscan crear atmosferas de intimidad e igualdad visual en bodas románticas, aniversarios y celebraciones emotivas. Su diámetro de 1.50 metros acomoda entre 8 y 10 personas alrededor de un círculo perfecto, eliminando la posición de 'cabecera' que las mesas rectangulares siempre presuponen. Todos los comensales se ven entre sí, favoreciendo la conversación fluida y la conexión emocional en momentos clave. La madera de pino nacional lijada y barnizada a tres manos presenta su veta natural, funcionando como elemento decorativo que complementa cualquier paleta floral o de color."
  seoParagraph2="Disponible para renta en toda la Ciudad de México y Estado de México, la Mesa Redonda de Madera es especialmente demandada en bodas íntimas de jardines privados en Coyoacán, Tlalpan y Xochimilco, así como en cenas corporativas en salones con vista y comuniones en capillas y haciendas. Sin bancas integradas, se combina libremente con sillas Tiffany blancas, Crossback naturales o de madera para crear composiciones visuales de alto impacto. Cada mesa incluye servicio completo de traslado, montaje profesional por nuestro equipo especializado y recolección al finalizar tu evento."
  dark={true}
/>

<CtaBar />

<!-- ═══════════════════════════════════════════════════════
     GALERÍA + SIDEBAR MODELOS
═══════════════════════════════════════════════════════ -->
<section class="section" id="galeria">
  <SectionHeader
    tag="h2"
    badge="Mesa Redonda en eventos"
    title="La Mesa Redonda de Madera en Bodas Románticas, Aniversarios y Celebraciones Íntimas"
    paragraph1="Su forma circular crea una energía diferente: sin cabecera, todos a la misma distancia. Aquí, algunos de los eventos donde ha sido la pieza central de momentos memorables."
    paragraph2="¿Quieres una mesa redonda para tu boda o celebración especial? Cotiza disponibilidad y estilo de decoración por WhatsApp. Respondemos el mismo día."
  />
  <ProductGallery
    images={[
      { src: "/img/catalogo/mesa-redonda-madera-evento-boda-01.webp", alt: "Mesa redonda de pino natural en jardín privado para boda romántica CDMX" },
      { src: "/img/catalogo/mesa-redonda-madera-jardin-exterior-02.webp", alt: "Mesa redonda con decoración floral en jardín exterior para celebración íntima" },
      { src: "/img/catalogo/mesa-redonda-madera-celebracion-03.webp", alt: "Mesa redonda con sillas tiffany blancas en jardín para aniversario elegante" },
      { src: "/img/catalogo/mesa-redonda-madera-cena-formal-04.webp", alt: "Mesa redonda con mantel redondo y centro de flores en cena corporativa formal" },
      { src: "/img/catalogo/mesa-redonda-madera-natural-pino-05.webp", alt: "Detalle veta de pino natural en mesa redonda MESPIC con acabado artesanal barnizado" },
      { src: "/img/catalogo/mesa-redonda-madera-evento-boda-01.webp", alt: "Ficha detalle mesa redonda — Ø 1.50 m" },
    ]}
    recommended={[
      { title: "Mesa Parota",          description: "Madera tropical exótica",        href: "/catalogo/mesa-picnic-parota/",     image: "/img/mesa-picnic-boda-elegante-decoracion.avif" },
      { title: "Mesa Premium",         description: "Acabado sin nudos · VIP",       href: "/catalogo/mesa-picnic-premium/",    image: "/img/mesa-picnic-boda-elegante-luces.avif" },
      { title: "Set Lounge Exterior",  description: "Mobiliario garden premium",    href: "/catalogo/set-lounge-exterior/",    image: "/img/tema-mexicana-1.avif" },
      { title: "Set Picnic Completo",  description: "Mesa + decoración premium",    href: "/catalogo/set-picnic-completo/",    image: "/img/mesa-picnic-pedida-mano-romantica.webp" },
      { title: "Mesa Hexagonal",       description: "Forma poligonal premium",      href: "/catalogo/mesa-picnic-hexagonal/",  image: "/img/mesa-picnic-evento-corporativo-networking.avif" },
    ]}
    sidebarTitle="Otros modelos del catálogo"
  />
</section>

<!-- ═══════════════════════════════════════════════════════
     ESPECIFICACIONES TÉCNICAS
═══════════════════════════════════════════════════════ -->
<section class="section section-alt" id="especificaciones">
  <SectionHeader
    tag="h2"
    badge="Ficha técnica"
    title="Especificaciones de la Mesa Redonda de Madera"
    paragraph1="Dimensiones exactas, material, acabado y capacidad. Diseño romántico que elimina jerarquías y favorece la conversación fluida."
    paragraph2="Si necesitas orientación sobre manteles redondos, distribución de centros de mesa o especificaciones para tu locación, escríbenos por WhatsApp y te enviamos la ficha técnica completa en PDF."
    stats={[
      { value: 'Ø 1.50 m', label: 'diámetro' },
      { value: '0 lados',  label: 'sin cabecera' },
      { value: '8-10',     label: 'personas sentadas' },
    ]}
  />
  <div class="container">
    <div class="spec-grid">
      <div class="spec-card">
        <h3 class="spec-card__title">Ficha Técnica</h3>
        <ul class="spec-list" role="list">
          <li class="spec-list__item">
            <span class="spec-list__label">Forma</span>
            <span class="spec-list__value">Circular (redonda)</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Diámetro</span>
            <span class="spec-list__value">Ø 1.50 m</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Alto de mesa</span>
            <span class="spec-list__value">0.76 m</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Capacidad</span>
            <span class="spec-list__value">8–10 personas</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Material</span>
            <span class="spec-list__value">Pino nacional seleccionado</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Acabado</span>
            <span class="spec-list__label">Lijado fino + barniz exterior 3 manos</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Uso recomendado</span>
            <span class="spec-list__value">Exterior e interior ventilado</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Peso aproximado</span>
            <span class="spec-list__value">35 kg</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Disponibilidad</span>
            <span class="spec-list__value spec-list__value--ok">+25 piezas en bodega</span>
          </li>
        </ul>
        <a href="/cotizar/" class="spec-card__cta">Cotizar disponibilidad →</a>
      </div>

      <div class="spec-features">
        <FeatureCard
          index={0}
          title="Sin Cabecera — Todos Iguales"
          description="El formato circular elimina la posición de 'cabecera' que siempre existe en mesas rectangulares. Todos los comensales comparten el mismo estatus visual, perfecto para celebraciones íntimas donde la igualdad emocional es importante."
        />
        <FeatureCard
          index={1}
          title="Conversación Fluida — Ø 1.50 m de Diámetro"
          description="Con un diámetro de 1.50 metros, todos los comensales se ven entre sí sin necesidad de girar la cabeza. La conversación fluye naturalmente de lado a lado, sin dominancia de posiciones como en mesas largas."
        />
        <FeatureCard
          index={2}
          title="Alta Estética con Mantel Redondo"
          description="La mesa redonda luce espectacular con manteles redondos que se ajustan perfectamente a su forma. Flores de centro, velas flotantes y arreglos circulares crean composiciones visuales que solo una mesa redonda puede lograr."
        />
        <FeatureCard
          index={3}
          title="Capacidad Sorprendente — 8-10 Personas"
          description="Aunque su diámetro es de 1.50 metros, acomoda hasta 10 personas alrededor del círculo con comodidad real. Cada comensal tiene espacio para plato, vaso y servilleta sin apreturas visuales o de movimiento."
        />
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     USOS RECOMENDADOS
═══════════════════════════════════════════════════════ -->
<section class="section" id="usos">
  <SectionHeader
