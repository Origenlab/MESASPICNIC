---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import WaBubble from '../../../components/WaBubble.astro';
---
<BaseLayout
  title="Set Picnic Infantil Temático para Renta — Mesa + Bancas de Colores | MESPIC CDMX"
  description="Renta el Set Picnic Infantil Temático de MESPIC: mesa 1.00 × 0.70 m con bancas en 5 colores para niños de 3-8 años. Pintura atóxica certificada. Ideal para cumpleaños temáticos, baby showers y fiestas infantiles en CDMX y Edomex."
  ogImage="/img/catalogo/set-picnic-infantil-tematico-colores-01.webp"
>
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Catálogo", href: "/catalogo/" },
    { label: "Set Infantil Temático" }
  ]} />
</Fragment>
<Hero
  badge="Set Infantil Temático"
  title="Set Picnic Infantil Temático — 5 Colores · Pintura Atóxica Certificada"
  description="El mobiliario infantil más completo del catálogo. Mesa de 1.00 × 0.70 m con altura ergonómica para niños de 3 a 8 años, 2 bancas laterales incluidas, pintura atóxica certificada en 5 colores temáticos. La zona de niños que todos los niños quieren y todos los padres aprueban."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="El Set Picnic Infantil Temático de MESPIC resuelve uno de los retos más frecuentes en los eventos familiares: ¿dónde sientan a los niños de manera cómoda, segura y visualmente integrada al concepto del evento? Con una altura de mesa de 52 centímetros —calibrada específicamente para niños de 3 a 8 años— y una superficie de 1.00 × 0.70 metros que permite dibujar, comer y jugar sin apreturas, el Set Infantil es la solución más completa del mercado de renta de mobiliario de madera para niños en México."
  seoParagraph2="Disponible para renta en Ciudad de México y Estado de México, el Set Infantil Temático se distingue por su pintura atóxica certificada —aprobada para superficies de contacto con niños— en 5 colores que se adaptan a cualquier temática de evento: blanco para bodas y baby showers, azul cielo para fiestas de niños, rosa palo para fiestas de niñas, verde menta para temáticas naturales y lila para unicornios y hadas. Cada color combina con globos, manteles y decoraciones temáticas de forma inmediata sin esfuerzo adicional."
  dark={true}
/>
<CtaBar />
<section class="section" id="galeria">
  <SectionHeader tag="h2" badge="Set Infantil en eventos"
    title="El Set Infantil en Cumpleaños Temáticos, Baby Showers y Fiestas de Niños"
    paragraph1="Una zona de niños bien equipada es la diferencia entre una fiesta donde los niños están contentos y una donde los padres están al borde. Así luce el Set Infantil en eventos reales."
    paragraph2="¿Necesitas varios colores en el mismo evento para diferenciar grupos de edades? Escríbenos y coordinamos la disponibilidad." />
  <ProductGallery
    images={[
      { src: "/img/catalogo/set-picnic-infantil-tematico-colores-01.webp", alt: "Set picnic infantil temático con colores para cumpleaños de niños en jardín CDMX" },
      { src: "/img/catalogo/set-picnic-infantil-tematico-colores-02.webp", alt: "Mesa infantil de madera con bancas de colores en fiesta de cumpleaños exterior" },
      { src: "/img/catalogo/set-picnic-infantil-tematico-colores-03.webp", alt: "Set infantil temático con decoración de unicornio para fiesta de niña" },
      { src: "/img/catalogo/set-picnic-infantil-tematico-colores-04.webp", alt: "Mesa infantil de colores en fiesta temática de princesas con decoración" },
      { src: "/img/catalogo/set-picnic-infantil-tematico-colores-05.webp", alt: "Set picnic infantil con tema dinosaurios para cumpleaños de niño en jardín" },
      { src: "/img/catalogo/set-picnic-infantil-tematico-fiesta-01.webp",  alt: "Mesa infantil temática con cupcakes y globos en fiesta de cumpleaños" },
    ]}
    recommended={[
      { title: "Mesa Infantil Estándar",description: "1.20 m · 8-10 niños · madera natural", href: "/catalogo/mesa-picnic-infantil/",          image: "/img/baby-shower-mesas-picnic-madera-cdmx-01.avif" },
      { title: "Set Picnic Completo",   description: "Mesa + decoración premium adultos",    href: "/catalogo/set-picnic-completo/",           image: "/img/picnic-romantico-bridal-shower-mesas-pino-02.avif" },
      { title: "Mesa Estándar",         description: "1.80 m · 6 personas adultos",          href: "/catalogo/mesa-picnic-estandar/",          image: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" },
      { title: "Mesa Plegable",         description: "Portátil · 4-6 personas",              href: "/catalogo/mesa-picnic-plegable/",          image: "/img/catalogo/mesa-picnic-plegable-portatil-evento-01.webp" },
      { title: "Mesa Hexagonal",        description: "Ø 1.80 m · boho & jardín",            href: "/catalogo/mesa-picnic-hexagonal/",         image: "/img/catalogo/mesa-picnic-hexagonal-madera-6-personas-jardin-01.webp" },
    ]}
    sidebarTitle="Otros modelos del catálogo"
  />
</section>
<section class="section section-alt" id="especificaciones">
  <SectionHeader tag="h2" badge="Ficha técnica" title="Especificaciones del Set Infantil Temático"
    paragraph1="Dimensiones ergonómicas para niños, certificación de la pintura y disponibilidad de colores. Todo lo que los papás quieren saber antes de reservar."
    paragraph2="¿Tienes una temática específica y necesitas confirmar qué color del set combina mejor? Escríbenos y te enviamos muestras de color."
    stats={[
      { value: '52 cm',  label: 'altura ergonómica' },
      { value: '5',      label: 'colores temáticos' },
      { value: '3-8',    label: 'años de edad' },
    ]} />
  <div class="container">
    <div class="spec-grid">
      <div class="spec-card">
        <h3 class="spec-card__title">Ficha Técnica</h3>
        <ul class="spec-list" role="list">
          <li class="spec-list__item"><span class="spec-list__label">Medidas mesa</span><span class="spec-list__value">1.00 × 0.70 m</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Altura mesa</span><span class="spec-list__value">52 cm (para niños 3-8 años)</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Capacidad</span><span class="spec-list__value">6–8 niños</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Material</span><span class="spec-list__value">Pino nacional + pintura atóxica certificada</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Acabado</span><span class="spec-list__value">Pintura satinada atóxica + sellador</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Colores</span><span class="spec-list__value">Blanco, azul cielo, rosa palo, verde menta, lila</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Componentes</span><span class="spec-list__value">1 mesa + 2 bancas laterales</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Peso</span><span class="spec-list__value">12 kg (ligero y manejable)</span></li>
          <li class="spec-list__item"><span class="spec-list__label">Disponibilidad</span><span class="spec-list__value spec-list__value--ok">+80 sets en bodega (varios colores)</span></li>
        </ul>
        <a href="/cotizar/" class="spec-card__cta">Cotizar disponibilidad →</a>
      </div>
      <div class="spec-features">
        <FeatureCard index={0} title="Pintura Atóxica Certificada para Niños"
          description="La pintura del Set Infantil Temático cumple con los estándares de no toxicidad para superficies de contacto con niños. A diferencia de los barnices industriales estándar, la pintura satinada atóxica no libera compuestos orgánicos volátiles (COV) en condiciones normales de uso, lo que la hace segura para el contacto directo de manos y cara de los niños durante el evento." />
        <FeatureCard index={1} title="Altura Ergonómica de 52 cm para 3-8 Años"
          description="La altura de 52 centímetros es el resultado de calibrar el set para que un niño de 3 años pueda sentarse con los pies tocando el suelo y un niño de 8 años pueda apoyar los codos cómodamente sobre la mesa. Esta horquilla de edad cubre el 90% de los eventos donde se requiere zona de niños en fiestas familiares mexicanas." />
        <FeatureCard index={2} title="5 Colores que Combinan con Cualquier Temática"
          description="Blanco para bodas y baby showers de estética limpia; azul cielo para transportes, océano, dinosaurios y superhéroes; rosa palo para princesas, unicornios y jardines de hadas; verde menta para temáticas naturales y tropicales; lila para hadas, mariposas y temáticas fantásticas. Los 5 colores están seleccionados para combinar directamente con las paletas de decoración más comunes en el mercado mexicano de fiestas infantiles." />
        <FeatureCard index={3} title="Ligero y Fácil — Solo 12 kg por Set Completo"
          description="Con 12 kilogramos por set completo (mesa + 2 bancas), el Set Infantil es el más manejable del catálogo. Nuestro equipo puede instalar 10 sets infantiles en el mismo tiempo que 5 mesas estándar. Esta agilidad de montaje es especialmente valiosa en eventos donde el espacio infantil es un área secundaria que se monta después del área principal." />
      </div>
    </div>
  </div>
</section>
<section class="section" id="usos">
  <SectionHeader tag="h2" badge="Usos recomendados" title="Para Qué Tipo de Evento es el Set Infantil Temático"
    paragraph1="El Set Infantil Temático es la solución específica para crear zonas de niños que integran el concepto visual del evento con las necesidades funcionales de los más pequeños."
    paragraph2="¿Tienes niños de diferentes rangos de edad en tu evento? Escríbenos y te orientamos sobre combinar el Set Infantil Temático con la Mesa Infantil Estándar."
    stats={[
      { value: '+80',    label: 'sets disponibles' },
      { value: '5',      label: 'colores temáticos' },
      { value: '3-8',    label: 'años objetivo' },
    ]} />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Cumpleaños Temáticos" description="Para fiestas con temática definida —unicornios, dinosaurios, princesas, superhéroes— el Set Infantil en el color que corresponde a la paleta temática integra la zona de niños al concepto visual de forma inmediata, sin necesitar mantelería adicional." image="/img/catalogo/set-picnic-infantil-tematico-colores-05.webp" href="/servicios/fiestas-infantiles/" btnLabel="Para cumpleaños" badge="Cumpleaños" />
      <ServiceCard title="Baby Showers" description="Para baby showers con zona interactiva de niños hermanos o primos, el Set Infantil en blanco o en el color que coordina con la paleta del shower (azul o rosa) crea una mini área de actividades infantiles que libera a los padres para disfrutar la celebración." image="/img/catalogo/set-picnic-infantil-tematico-colores-03.webp" href="/servicios/fiestas-tematicas/" btnLabel="Para baby showers" badge="Baby Shower" />
      <ServiceCard title="Fiestas de Cumpleaños Adultos con Niños" description="En bodas, XV años y cumpleaños de adultos donde los niños también están invitados, el Set Infantil crea una zona exclusiva para ellos que evita que interrumpan las mesas de adultos y que ellos mismos se sientan cómodos con un espacio a su medida." image="/img/catalogo/set-picnic-infantil-tematico-colores-04.webp" href="/servicios/fiestas-infantiles/" btnLabel="Zona de niños" badge="Zona Kids" />
      <ServiceCard title="Fiestas Infantiles en Jardín" description="Para cumpleaños de niños en jardines privados o parques, el Set Infantil Temático en el color del festejado es la pieza principal del montaje: sencilla, colorida y perfectamente escalada al tamaño de los pequeños invitados." image="/img/catalogo/set-picnic-infantil-tematico-fiesta-01.webp" href="/servicios/fiestas-infantiles/" btnLabel="Fiestas en jardín" badge="Jardín" />
    </div>
  </div>
</section>
<section class="section section-alt" id="faq">
  <SectionHeader tag="h2" badge="Preguntas frecuentes" title="Preguntas sobre el Set Picnic Infantil Temático"
    paragraph1="Las dudas más frecuentes de papás y coordinadores antes de reservar el Set Infantil para un evento con niños."
    paragraph2="¿Tu pregunta no está aquí? Escríbenos y te respondemos de inmediato." />
  <FaqSection phone="55 6432 8954" whatsapp="5564328954" schedule="Lun–Dom 8:00–20:00"
    waMessage="Hola, quiero cotizar el Set Picnic Infantil Temático para mi evento."
    items={[
      { question: "¿Para qué edades está diseñado el Set Infantil Temático?", answer: "El Set Infantil Temático está calibrado para niños de 3 a 8 años. La altura de la mesa (52 cm) y de las bancas (32 cm de asiento) es la adecuada para este rango de edad. Para niños menores de 3 años la mesa puede resultar un poco alta; para niños de 9 años o más, el Set Infantil Estándar de 1.20 m puede ser más adecuado por su mayor superficie." },
      { question: "¿La pintura es realmente segura para niños?", answer: "Sí. Todos los sets infantiles del catálogo MESPIC están pintados con pintura satinada atóxica formulada para superficies de contacto con niños. No contiene plomo, cadmio ni ftalatos en concentraciones dañinas. En condiciones normales de uso —contacto de manos, apoyo de cara, lápices y crayones sobre la superficie— la pintura no representa ningún riesgo para los niños." },
      { question: "¿Puedo elegir el color específico del set?", answer: "Sí. Al cotizar, indícanos qué color necesitas de los 5 disponibles: blanco, azul cielo, rosa palo, verde menta o lila. Te confirmamos la disponibilidad del color para tu fecha. Si tu evento requiere varios colores diferentes (por ejemplo, azul y rosa para fiesta mixta), también podemos combinarlos siempre que tengamos stock disponible de cada color." },
      { question: "¿Cuántos niños caben en cada set?", answer: "Cada Set Infantil Temático incluye 1 mesa y 2 bancas, con capacidad para 6 a 8 niños: 3 o 4 por cada banca. Para eventos con más de 15 niños, recomendamos combinar el Set Infantil Temático (para los más pequeños, 3-5 años) con la Mesa Infantil Estándar de 1.20 m (para niños de 6-10 años), que tiene mayor superficie." },
      { question: "¿El set incluye sillas o solo bancas?", answer: "El Set Infantil Temático incluye 2 bancas laterales de madera del mismo color que la mesa. No incluye sillas individuales. Si prefieres sillas individuales para la zona de niños, te orientamos sobre opciones complementarias; escríbenos con los detalles de tu evento." },
      { question: "¿La entrega incluye el set infantil junto con el resto del mobiliario?", answer: "Sí. Cuando rentas el Set Infantil junto con mesas de adultos del catálogo, la entrega, montaje y recolección de todos los elementos se realiza en el mismo servicio sin costo adicional. El equipo de MESPIC instala la zona de niños simultáneamente con el área de adultos para que todo esté listo al mismo tiempo." }
    ]} />
</section>
<CtaBarFinal headline="¿Lista la Zona de Niños?" subtext="Cotiza el Set Infantil Temático para tu fecha. Respondemos el mismo día con disponibilidad de colores." phone="55 6432 8954" whatsapp="5564328954" waMessage="Hola, quiero cotizar el Set Picnic Infantil Temático para mi evento." cotizarHref="/cotizar/" />
<WaBubble whatsapp="5564328954" message="Hola, me interesa rentar el Set Picnic Infantil Temático." />
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@type": "Product", "name": "Set Picnic Infantil Temático — Renta MESPIC", "description": "Set picnic infantil temático para renta. Mesa 1.00×0.70×0.52 m + 2 bancas. Pintura atóxica certificada en 5 colores: blanco, azul cielo, rosa palo, verde menta y lila. Para niños de 3-8 años. +80 sets en bodega. CDMX y Edomex.", "brand": { "@type": "Brand", "name": "MESPIC" }, "category": "Mobiliario para eventos infantiles — Renta", "offers": { "@type": "Offer", "priceCurrency": "MXN", "availability": "https://schema.org/InStock" } })} />
</Fragment>
</BaseLayout>
<style>
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }
  .spec-grid { display: grid; grid-template-columns: 320px 1fr; gap: 2rem; align-items: start; }
  .spec-card { background: #fff; border: 1px solid var(--c-border, #E7E0D8); border-radius: var(--radius-md, 12px); padding: 1.75rem; position: sticky; top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2rem); }
  .spec-card__title { font-size: 1rem; font-weight: 700; color: var(--c-text, #1C1917); margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 2px solid var(--c-primary, #2C5530); }
  .spec-list { list-style: none; display: flex; flex-direction: column; gap: 0; margin-bottom: 1.5rem; }
  .spec-list__item { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.625rem 0; border-bottom: 1px solid var(--c-border, #E7E0D8); }
  .spec-list__item:last-child { border-bottom: none; }
  .spec-list__label { font-size: 0.8125rem; color: var(--c-text-muted, #78716C); font-weight: 500; flex-shrink: 0; }
  .spec-list__value { font-size: 0.8125rem; color: var(--c-text, #1C1917); font-weight: 600; text-align: right; }
  .spec-list__value--ok { color: var(--c-primary, #2C5530); }
  .spec-card__cta { display: flex; align-items: center; justify-content: center; background: var(--c-primary, #2C5530); color: #fff; padding: 0.75rem 1.25rem; border-radius: 8px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.18s ease; }
  .spec-card__cta:hover { background: #224228; }
  .spec-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  @media (max-width: 1024px) { .spec-grid { grid-template-columns: 1fr; } .spec-card { position: static; } }
  @media (max-width: 640px) { .spec-features { grid-template-columns: 1fr; } }
</style>
