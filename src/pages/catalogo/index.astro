<style>
  /* ══════════════════════════════════════════
     CATALOG GRID — Layout editorial 3 columnas
  ══════════════════════════════════════════ */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  /* ══════════════════════════════════════════
     CATALOG CARD
  ══════════════════════════════════════════ */
  .cat-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--c-border, #E7E0D8);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.22s ease, transform 0.22s ease;
    position: relative;
  }

  .cat-card:hover {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    transform: translateY(-3px);
  }

  /* ── Imagen ── */
  .cat-card__img-link {
    display: block;
    text-decoration: none;
  }

  .cat-card__img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--c-bg-alt, #FAF8F5);
  }

  .cat-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .cat-card:hover .cat-card__img {
    transform: scale(1.04);
  }

  /* ── Badge flotante (esquina sup-izq) ── */
  .cat-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(255, 255, 255, 0.96);
    color: var(--c-primary, #2C5530);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 50px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    pointer-events: none;
  }

  /* Premium badge en dorado */
  .cat-card--premium .cat-card__badge {
    background: var(--c-accent, #D4A574);
    color: #fff;
  }

  /* ── Capacidad (esquina inf-der) ── */
  .cat-card__cap {
    position: absolute;
    bottom: 12px;
    right: 12px;
    background: var(--c-primary, #2C5530);
