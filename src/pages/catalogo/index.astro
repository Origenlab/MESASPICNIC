<!-- ═══════════════════════════════════════════════════════════════════════
     JAVASCRIPT — Filtros, Paginación, Vista, Sort
═══════════════════════════════════════════════════════════════════════ -->
<script>
(function () {
  const ITEMS_PER_PAGE = 9;

  // Estado de la aplicación
  const state = {
    categoria: 'todos',
    usos: new Set(),
    capacidad: 'todos',
    search: '',
    sort: 'default',
    page: 1,
    view: 'grid',
  };

  // DOM refs
  const grid       = document.getElementById('cat-grid');
  const noResults  = document.getElementById('no-results');
  const countEl    = document.getElementById('results-count');
  const paginEl    = document.getElementById('pagination');
  const filterChips= document.getElementById('active-filters');
  const sidebar    = document.getElementById('catalog-sidebar');
  const overlay    = document.getElementById('sidebar-overlay');

  function getAllCards() {
    return [...grid.querySelectorAll('.cat-card')];
  }

  // ── Lógica de filtrado ──────────────────────────────────────────────
  function matchCard(card) {
    const cat    = card.dataset.categoria;
    const usos   = card.dataset.usos.split(',');
    const cap    = parseInt(card.dataset.cap);
    const nombre = card.dataset.nombre;

    if (state.categoria !== 'todos' && cat !== state.categoria) return false;
    if (state.usos.size > 0 && ![...state.usos].some(u => usos.includes(u))) return false;
    if (state.capacidad === 'small'  && cap > 6)           return false;
    if (state.capacidad === 'medium' && (cap < 6 || cap > 10)) return false;
    if (state.capacidad === 'large'  && cap <= 10)         return false;
    if (state.search && !nombre.includes(state.search))    return false;
    return true;
  }

  function sortCards(cards) {
    const arr = [...cards];
    if (state.sort === 'cap-asc')  return arr.sort((a,b) => +a.dataset.cap - +b.dataset.cap);
    if (state.sort === 'cap-desc') return arr.sort((a,b) => +b.dataset.cap - +a.dataset.cap);
    if (state.sort === 'nombre')   return arr.sort((a,b) => a.dataset.nombre.localeCompare(b.dataset.nombre));
    return arr; // default: DOM order = insert order = curated
  }

  // ── Render principal ────────────────────────────────────────────────
  function render() {
    const all      = getAllCards();
    const filtered = sortCards(all.filter(matchCard));
    const total    = filtered.length;
    const pages    = Math.max(1, Math.ceil(total / ITEMS_PER_PAGE));
    if (state.page > pages) state.page = 1;

    const start  = (state.page - 1) * ITEMS_PER_PAGE;
    const end    = start + ITEMS_PER_PAGE;
    const visible = new Set(filtered.slice(start, end).map(c => c.dataset.id));

    all.forEach(card => {
      const show = visible.has(card.dataset.id);
      card.style.display = show ? '' : 'none';
      card.style.opacity = show ? '1' : '0';
    });

    countEl.textContent = total === 20
      ? '20 modelos'
      : `${total} de 20 modelos`;

    noResults.hidden = total > 0;
    grid.style.display = total === 0 ? 'none' : '';

    renderPagination(pages, total);
    renderChips();
  }

  // ── Paginación ──────────────────────────────────────────────────────
  function renderPagination(totalPages, totalItems) {
    if (totalPages <= 1 || totalItems === 0) { paginEl.innerHTML = ''; return; }

    const start    = (state.page - 1) * ITEMS_PER_PAGE + 1;
    const end      = Math.min(state.page * ITEMS_PER_PAGE, totalItems);
    const progress = Math.round((state.page / totalPages) * 100);

    const chevL = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>`;
    const chevR = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>`;

    let pageNums = '';
    const delta = 1;
    for (let i = 1; i <= totalPages; i++) {
      const near = Math.abs(i - state.page) <= delta || i === 1 || i === totalPages;
      const gap  = i === 2 && state.page > delta + 2;
      const gap2 = i === totalPages - 1 && state.page < totalPages - delta - 1;
      if (near) {
        const active = i === state.page;
        pageNums += `<button class="pag-page${active ? ' pag-page--active' : ''}" data-page="${i}" ${active ? 'aria-current="page"' : ''}>${i}</button>`;
      } else if (gap || gap2) {
        pageNums += `<span class="pag-dots">···</span>`;
      }
    }

    paginEl.innerHTML = `
      <div class="pag-card">
        <div class="pag-card__top">
          <div class="pag-card__info">
            <span class="pag-card__count">${totalItems} modelos</span>
            <span class="pag-card__range">Mostrando ${start}–${end}</span>
          </div>
          <span class="pag-card__page-pill">Página ${state.page} de ${totalPages}</span>
        </div>
        <div class="pag-card__progress-track">
          <div class="pag-card__progress-bar" style="width:${progress}%"></div>
        </div>
        <div class="pag-card__controls">
          <button class="pag-ctrl" data-page="${state.page - 1}" aria-label="Página anterior" ${state.page === 1 ? 'disabled' : ''}>${chevL}<span>Anterior</span></button>
          <div class="pag-pages">${pageNums}</div>
          <button class="pag-ctrl" data-page="${state.page + 1}" aria-label="Página siguiente" ${state.page === totalPages ? 'disabled' : ''}><span>Siguiente</span>${chevR}</button>
        </div>
      </div>`;

    paginEl.querySelectorAll('[data-page]:not([disabled])').forEach(btn => {
      btn.addEventListener('click', () => {
        state.page = parseInt(btn.dataset.page);
        render();
        document.getElementById('catalogo').scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  // ── Chips de filtros activos ────────────────────────────────────────
  const catLabels = { clasica: 'Mesas Picnic', especial: 'Mesas Especiales', complemento: 'Sets y Complementos', ninos: 'Para Niños' };
  const capLabels = { small: 'Hasta 6 personas', medium: '6–10 personas', large: 'Más de 10' };
  const usoLabels = { bodas: 'Bodas', corporativo: 'Corporativo', festivales: 'Festivales', familiar: 'Familiar', premium: 'Premium', infantil: 'Infantil' };

  function renderChips() {
    const chips = [];

    if (state.categoria !== 'todos') {
      chips.push(`<button class="filter-chip" data-remove="cat">${catLabels[state.categoria]} <span class="chip-x">×</span></button>`);
    }
    state.usos.forEach(uso => {
      chips.push(`<button class="filter-chip" data-remove="uso:${uso}">${usoLabels[uso] || uso} <span class="chip-x">×</span></button>`);
    });
    if (state.capacidad !== 'todos') {
      chips.push(`<button class="filter-chip" data-remove="cap">${capLabels[state.capacidad]} <span class="chip-x">×</span></button>`);
    }
    if (state.search) {
      chips.push(`<button class="filter-chip" data-remove="search">"${state.search}" <span class="chip-x">×</span></button>`);
    }
    if (chips.length > 0) {
      chips.push(`<button class="filter-chip filter-chip--reset" data-remove="all">Limpiar todo ×</button>`);
    }

    filterChips.innerHTML = chips.join('');
    filterChips.querySelectorAll('[data-remove]').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.remove;
        if (key === 'all')           clearAll();
        else if (key === 'cat')      { state.categoria = 'todos'; syncCatUI(); }
        else if (key.startsWith('uso:')) { state.usos.delete(key.slice(4)); syncCheckboxes(); }
        else if (key === 'cap')      { state.capacidad = 'todos'; syncCapUI(); }
        else if (key === 'search')   { state.search = ''; document.getElementById('catalog-search').value = ''; }
        state.page = 1;
        render();
      });
    });
  }

  // ── Sync UI helpers ──────────────────────────────────────────────────
  function syncCatUI() {
    document.querySelectorAll('[data-cat]').forEach(b => b.classList.toggle('active', b.dataset.cat === state.categoria));
    document.querySelectorAll('[data-tab]').forEach(b => {
      b.classList.toggle('active', b.dataset.tab === state.categoria);
      b.setAttribute('aria-selected', b.dataset.tab === state.categoria ? 'true' : 'false');
    });
  }

  function syncCheckboxes() {
    document.querySelectorAll('input[name="uso"]').forEach(cb => { cb.checked = state.usos.has(cb.value); });
  }

  function syncCapUI() {
    document.querySelectorAll('[data-cap]').forEach(b => b.classList.toggle('active', b.dataset.cap === state.capacidad));
  }

  function clearAll() {
    state.categoria = 'todos';
    state.usos.clear();
    state.capacidad = 'todos';
    state.search = '';
    state.page = 1;
    document.getElementById('catalog-search').value = '';
    syncCatUI();
    syncCheckboxes();
    syncCapUI();
  }

  // ── Event listeners ──────────────────────────────────────────────────
  // Sidebar category nav
  document.querySelectorAll('[data-cat]').forEach(btn => {
    btn.addEventListener('click', () => {
      state.categoria = btn.dataset.cat;
      state.page = 1;
      syncCatUI();
      render();
      if (window.innerWidth < 900) closeSidebar();
    });
  });

  // Section tabs (horizontal)
  document.querySelectorAll('[data-tab]').forEach(btn => {
    btn.addEventListener('click', () => {
      state.categoria = btn.dataset.tab;
      state.page = 1;
      syncCatUI();
      render();
    });
  });

  // Uso checkboxes
  document.querySelectorAll('input[name="uso"]').forEach(cb => {
    cb.addEventListener('change', () => {
      if (cb.checked) state.usos.add(cb.value);
      else state.usos.delete(cb.value);
      state.page = 1;
      render();
    });
  });

  // Capacidad
  document.querySelectorAll('[data-cap]').forEach(btn => {
    btn.addEventListener('click', () => {
      state.capacidad = btn.dataset.cap;
      state.page = 1;
      syncCapUI();
      render();
    });
  });

  // Búsqueda con debounce
  let searchTimer;
  document.getElementById('catalog-search').addEventListener('input', e => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
      state.search = e.target.value.trim().toLowerCase();
      state.page = 1;
      render();
    }, 200);
  });

  // Sort
  document.getElementById('sort-select').addEventListener('change', e => {
    state.sort = e.target.value;
    state.page = 1;
    render();
  });

  // Vista grid / lista
  document.getElementById('view-grid-btn').addEventListener('click', () => {
    state.view = 'grid';
    grid.className = 'cat-grid cat-grid--grid';
    document.getElementById('view-grid-btn').classList.add('active');
    document.getElementById('view-list-btn').classList.remove('active');
  });
  document.getElementById('view-list-btn').addEventListener('click', () => {
    state.view = 'list';
    grid.className = 'cat-grid cat-grid--list';
    document.getElementById('view-list-btn').classList.add('active');
    document.getElementById('view-grid-btn').classList.remove('active');
  });

  // Mobile sidebar
  function openSidebar() {
    sidebar.classList.add('sidebar--open');
    overlay.classList.add('overlay--active');
    document.body.style.overflow = 'hidden';
    document.getElementById('filter-toggle-btn').setAttribute('aria-expanded', 'true');
  }
  function closeSidebar() {
    sidebar.classList.remove('sidebar--open');
    overlay.classList.remove('overlay--active');
    document.body.style.overflow = '';
    document.getElementById('filter-toggle-btn').setAttribute('aria-expanded', 'false');
  }
  document.getElementById('filter-toggle-btn').addEventListener('click', openSidebar);
  document.getElementById('sidebar-close').addEventListener('click', closeSidebar);
  overlay.addEventListener('click', closeSidebar);
  document.getElementById('clear-filters-btn')?.addEventListener('click', () => { clearAll(); render(); });

  // Render inicial
  render();
})();
</script>

