<BaseLayout
  title="Catálogo de Mesas Picnic — 20 Modelos para Renta | MESPIC CDMX"
  description="Catálogo completo con 20 modelos de mesas picnic y mobiliario de madera para renta en CDMX y Edomex. Filtra por tipo de evento, capacidad o categoría. Estándar, grande, XL, farm americana, biergarten, redonda, teka, parota, barra, set comedor, lounge VIP e infantil. Entrega y montaje incluidos."
  ogImage="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif"
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Catálogo" }
  ]} />
</Fragment>

<Hero
  badge="20 modelos disponibles"
  title="Catálogo Completo de Mesas Picnic y Mobiliario"
  description="Filtra por tipo de evento, capacidad o categoría. Desde la Banca Individual hasta la Barra de Coctelería — el catálogo más completo de mobiliario de madera para eventos en México."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="MESPIC cuenta con 20 modelos de mesas picnic, sets, barras y mobiliario complementario disponibles para renta en la Ciudad de México y el Estado de México. Todos los modelos están fabricados en pino nacional seleccionado, lijado a grano fino y barnizado tres manos para resistencia al exterior."
  seoParagraph2="Usa los filtros para encontrar el modelo exacto para tu evento: tipo de celebración, capacidad de invitados o categoría de producto. Combinaciones de modelos en una sola cotización y entrega. Traslado, montaje profesional y recolección incluidos sin costo adicional."
  dark={true}
/>

<CtaBar />

<!-- ═══════════════════════════════════════════════════════════════════════
     CATÁLOGO INTERACTIVO — Sidebar + Grid
═══════════════════════════════════════════════════════════════════════ -->
<section class="catalog-section" id="catalogo">
  <div class="catalog-wrap">

    <!-- Overlay para mobile sidebar -->
    <div id="sidebar-overlay" class="sidebar-overlay" aria-hidden="true"></div>

    <!-- ── SIDEBAR ──────────────────────────────────────────────────────── -->
    <aside class="catalog-sidebar" id="catalog-sidebar" aria-label="Filtros del catálogo">

      <div class="sidebar-header">
        <span class="sidebar-header__title">Filtros</span>
        <button class="sidebar-close-btn" id="sidebar-close" aria-label="Cerrar filtros">✕</button>
      </div>

      <!-- Búsqueda -->
      <div class="sidebar-block">
        <label class="sidebar-block__label" for="catalog-search">Buscar modelo</label>
        <div class="sidebar-search-wrap">
          <svg class="sidebar-search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="search" id="catalog-search" class="sidebar-search" placeholder="Ej: hexagonal, farm…" autocomplete="off" />
        </div>
      </div>

      <!-- Categorías -->
      <div class="sidebar-block">
        <span class="sidebar-block__label">Categoría</span>
        <nav class="sidebar-cats" role="list">
          <button class="sidebar-cat active" data-cat="todos" role="listitem">
            <span class="sidebar-cat__label">Todos los modelos</span>
            <span class="sidebar-cat__count">20</span>
          </button>
          {categorias.map(c => (
            <button class="sidebar-cat" data-cat={c.id} role="listitem">
              <span class="sidebar-cat__label">{c.label}</span>
              <span class="sidebar-cat__count">{c.count}</span>
            </button>
          ))}
        </nav>
      </div>

      <!-- Tipo de evento -->
      <div class="sidebar-block">
        <span class="sidebar-block__label">Tipo de evento</span>
        <div class="sidebar-checks">
          <label class="sidebar-check"><input type="checkbox" name="uso" value="bodas"><span>Bodas al aire libre</span></label>
          <label class="sidebar-check"><input type="checkbox" name="uso" value="corporativo"><span>Corporativo</span></label>
          <label class="sidebar-check"><input type="checkbox" name="uso" value="festivales"><span>Festivales y ferias</span></label>
          <label class="sidebar-check"><input type="checkbox" name="uso" value="familiar"><span>Reuniones familiares</span></label>
          <label class="sidebar-check"><input type="checkbox" name="uso" value="premium"><span>Premium / VIP</span></label>
          <label class="sidebar-check"><input type="checkbox" name="uso" value="infantil"><span>Fiestas infantiles</span></label>
        </div>
      </div>

      <!-- Capacidad -->
      <div class="sidebar-block">
