---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import NextStep from '../../components/NextStep.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import WaBubble from '../../../components/WaBubble.astro';
---

<BaseLayout
  title="Mesa Biergarten de Madera para Renta — 2.20m · 8-10 Personas | MESPIC CDMX"
  description="Renta la Mesa Biergarten de Madera de MESPIC: formato cervecería alemana de pino nacional con 2.20 m de largo, bancas desmontables incluidas, capacidad para 8-10 personas. Perfecta para festivales, food markets, fiestas y team buildings en CDMX y Edomex. Entrega y montaje incluidos."
  ogImage="/img/catalogo/mesa-biergarten-madera-festival-01.webp"
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Catálogo", href: "/catalogo/" },
    { label: "Mesa Biergarten" }
  ]} />
</Fragment>

<Hero
  badge="Mesa Biergarten"
  title="Mesa Biergarten de Madera — 2.20 m para 8-10 Personas"
  description="Formato cervecería alemana con bancas desmontables. Pino nacional de 2.20 m de largo por 0.60 m de ancho estrecho. Incluye 2 bancas removibles de 2.20 × 0.35 m. Perfecta para festivales, mercados, fiestas y eventos informales."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="La Mesa Biergarten de Madera de MESPIC es el formato estándar internacional para festivales, mercados de comida, fiestas al aire libre y eventos con alta densidad de personas. Su configuración tipo cervecería alemana incluye una mesa más estrecha (0.60 metros de ancho versus 1.10 metros de las farm) y dos bancas desmontables que no están integradas a la estructura. Esto permite máxima flexibilidad: configura las bancas de frente (como cervecería tradicional), de lado, o retíralas completamente para acceso lateral. Con 2.20 metros de largo, acomoda 8-10 personas (4-5 por lado) en un formato lineal compacto, permitiendo mayor densidad de mesas en el espacio."
  seoParagraph2="Disponible para renta en toda la Ciudad de México y Estado de México, la Mesa Biergarten es especialmente demandada en festivales de comida y bebida, food markets, ferias gastronómicas en parques públicos de la CDMX, tianguis corporativos, team buildings con picnic y eventos informales que priorizan el flujo de personas. El pino nacional tratado y barnizado resiste la intemperie, sol directo y uso intensivo. Cada mesa incluye 2 bancas desmontables de la misma madera, plus servicio completo de traslado, montaje profesional y recolección al finalizar tu evento."
  dark={true}
/>

<CtaBar />

<!-- ═══════════════════════════════════════════════════════
     GALERÍA + SIDEBAR MODELOS
═══════════════════════════════════════════════════════ -->
<section class="section" id="galeria">
  <SectionHeader
    tag="h2"
    badge="Mesa Biergarten en eventos"
    title="La Mesa Biergarten en Festivales, Mercados y Eventos Masivos"
    paragraph1="Su formato estrecho y bancas desmontables la hacen ideal para festivales, food courts y eventos con mucho flujo de personas. Aquí, algunos de los eventos donde es la pieza principal."
    paragraph2="¿Organizas un festival o mercado? Cotiza tus mesas Biergarten por WhatsApp. Ofrecemos descuentos por volumen. Respondemos el mismo día."
  />
  <ProductGallery
    images={[
      { src: "/img/catalogo/mesa-biergarten-madera-festival-01.webp", alt: "Mesa biergarten con bancas en festival de comida al aire libre CDMX" },
      { src: "/img/catalogo/mesa-biergarten-madera-exterior-02.webp", alt: "Múltiples mesas biergarten distribuidas en parque para evento comunitario" },
      { src: "/img/catalogo/mesa-biergarten-evento-jardin-03.webp", alt: "Mesa biergarten con bancas removibles en evento de team building informal" },
      { src: "/img/catalogo/mesa-biergarten-cerveceria-pino-04.webp", alt: "Detalle de pino natural en mesa biergarten con bancos de cervecería alemana estilo vintage" },
      { src: "/img/catalogo/mesa-biergarten-reunion-exterior-05.webp", alt: "Mesas biergarten densamente distribuidas en festival de comida y bebida con personas disfrutando" },
      { src: "/img/cine-aire-libre-mesas-picnic-festival-04.avif", alt: "Ficha detalle mesa biergarten — 2.20 m x 0.60 m con bancas" },
    ]}
    recommended={[
      { title: "Mesa Picnic Estándar", description: "1.80 m · 6 personas",             href: "/catalogo/mesa-picnic-estandar/",   image: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" },
      { title: "Mesa Picnic XL",        description: "2.40 m · 10-12 personas",        href: "/catalogo/mesa-picnic-xl/",         image: "/img/mesa-picnic-lujo-madera-exterior-renta-01.avif" },
      { title: "Banca Individual",      description: "Para complementar mesas",       href: "/catalogo/banca-picnic-individual/",image: "/img/mesa-picnic-madera-renta-cdmx-05.avif" },
      { title: "Mesa Plegable",         description: "Transporte y almacenaje fácil", href: "/catalogo/mesa-picnic-plegable/",   image: "/img/picnic-romantico-bridal-shower-mesas-pino-02.avif" },
      { title: "Set Picnic Completo",   description: "Mesa + decoración premium",    href: "/catalogo/set-picnic-completo/",    image: "/img/mesas-picnic-madera-renta-evento-cdmx-05.avif" },
    ]}
    sidebarTitle="Otros modelos del catálogo"
  />
</section>

<!-- ═══════════════════════════════════════════════════════
     ESPECIFICACIONES TÉCNICAS
═══════════════════════════════════════════════════════ -->
<section class="section section-alt" id="especificaciones">
  <SectionHeader
    tag="h2"
    badge="Ficha técnica"
    title="Especificaciones de la Mesa Biergarten de Madera"
    paragraph1="Dimensiones exactas, material, acabado y capacidad. Formato probado internacionalmente para festivales y eventos masivos de alta densidad."
    paragraph2="Si necesitas croquis de distribución para tu festival o mercado, escríbenos por WhatsApp y te enviamos la ficha técnica completa con layout recommendations."
    stats={[
      { value: '2.20 m',   label: 'largo compacto' },
      { value: '0.60 m',   label: 'ancho festival' },
      { value: '8-10',     label: 'personas sentadas' },
    ]}
  />
  <div class="container">
    <div class="spec-grid">
      <div class="spec-card">
        <h3 class="spec-card__title">Ficha Técnica</h3>
        <ul class="spec-list" role="list">
          <li class="spec-list__item">
            <span class="spec-list__label">Largo</span>
            <span class="spec-list__value">2.20 m</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Ancho</span>
            <span class="spec-list__value">0.60 m (festival)</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Alto de mesa</span>
            <span class="spec-list__value">0.76 m</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Bancas incluidas</span>
            <span class="spec-list__value">2 bancas desmontables (2.20 × 0.35 m)</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Capacidad</span>
            <span class="spec-list__value">8–10 personas (4-5 por lado)</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Material</span>
            <span class="spec-list__value">Pino nacional tratado</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Acabado</span>
            <span class="spec-list__value">Barniz resistente a intemperie (3 manos)</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Peso aproximado</span>
            <span class="spec-list__value">45 kg (mesa + bancas)</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Disponibilidad</span>
            <span class="spec-list__value spec-list__value--ok">+50 piezas en bodega</span>
          </li>
        </ul>
        <a href="/cotizar/" class="spec-card__cta">Cotizar disponibilidad →</a>
      </div>

      <div class="spec-features">
        <FeatureCard
          index={0}
          title="Bancas Desmontables — Total Flexibilidad"
          description="Las 2 bancas no están integradas a la mesa. Se pueden posicionar de frente (cervecería tradicional), de lado, o retirarse completamente para permitir acceso lateral. Perfecto para eventos con flujo constante de personas y reconfiguración de espacios."
        />
        <FeatureCard
          index={1}
          title="Alta Densidad de Layout — 0.60 m de Ancho"
          description="Su formato estrecho (0.60 metros) versus las mesas estándar permite organizar más mesas en el mismo espacio. Ideal para festivales y mercados donde el aprovechamiento del área es crítico para rentabilidad y confort de invitados."
        />
        <FeatureCard
          index={2}
          title="Resistencia Outdoor Probada — Intemperie Directa"
          description="Pino nacional tratado y barniz de poliuretano exterior en tres capas resisten sol directo, lluvia, sombra y uso intensivo en festivales. Aguanta temporadas completas de eventos sin requerir mantenimiento especial entre usos."
        />
        <FeatureCard
          index={3}
          title="Formato Festival Estándar Internacional"
          description="La configuración biergarten es el estándar internacional probado en Oktoberfest, mercados de Berlín, y festivales de todo el mundo. Millones de personas han comido alrededor de este formato — es la opción de seguridad para eventos masivos."
        />
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     USOS RECOMENDADOS
═══════════════════════════════════════════════════════ -->
<section class="section" id="usos">
  <SectionHeader
    tag="h2"
    badge="Usos recomendados"
    title="Eventos Donde la Mesa Biergarten es Ideal"
    paragraph1="Su formato compacto, bancas desmontables y resistencia a intemperie la hacen perfecta para festivales, mercados, ferias y eventos informales. Estos son los contextos donde nuestros clientes la solicitan con mayor frecuencia."
    paragraph2="Si organizas un evento masivo, escríbenos por WhatsApp con el número de asistentes esperados. Ofrecemos descuentos por volumen y asesoramiento en layout optimizado."
    stats={[
      { value: '0.60 m',   label: 'ancho compacto' },
      { value: 'removibles',label: 'bancas' },
      { value: 'festivales',label: 'uso principal' },
    ]}
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard
        title="Festivales de Comida y Bebida"
        description="Formato estándar en food festivals y ferias gastronómicas. Su ancho compacto permite máxima densidad de mesas, mientras que las bancas removibles facilitan el acceso a puestos de comida. Disponible en parques públicos y plazas de CDMX."
        image="/img/catalogo/mesa-biergarten-madera-festival-01.webp"
        href="/servicios/eventos-corporativos/"
        btnLabel="Festivales y mercados"
        badge="Festival"
      />
      <ServiceCard
        title="Ferias, Bazares y Tianguis Comunitarios"
        description="Perfecta para tianguis corporativos, bazares escolares y ferias comunitarias donde el flujo de personas es constante. La configuración biergarten permite que los visitantes se sienten momentáneamente sin ocupar demasiado espacio."
        image="/img/catalogo/mesa-biergarten-madera-exterior-02.webp"
        href="/servicios/eventos-corporativos/"
        btnLabel="Bazares y tianguis"
        badge="Comunitario"
      />
      <ServiceCard
        title="Team Buildings y Fiestas Corporativas Informales"
        description="Para team buildings con comida al aire libre, la Mesa Biergarten crea una atmósfera relajada y de camaradería. Sus bancas compartidas favorecen la integración y conversación entre departamentos de forma natural."
        image="/img/catalogo/mesa-biergarten-evento-jardin-03.webp"
        href="/servicios/eventos-corporativos/"
        btnLabel="Team buildings"
        badge="Corporativo"
      />
      <ServiceCard
        title="Fiestas Informales y Reuniones al Aire Libre"
        description="Para cumpleaños, despedidas y celebraciones en parques y jardines comunitarios, la Mesa Biergarten acomoda a muchas personas con espíritu de fiesta y camaradería. Incluye bancas, no hay que rentarlas aparte."
        image="/img/catalogo/mesa-biergarten-reunion-exterior-05.webp"
        href="/servicios/reuniones-familiares/"
        btnLabel="Fiestas informales"
        badge="Celebración"
      />
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     FAQ
═══════════════════════════════════════════════════════ -->
<section class="section section-alt" id="faq">
  <SectionHeader
    tag="h2"
    badge="Preguntas frecuentes"
    title="Preguntas sobre la Mesa Biergarten"
    paragraph1="Las dudas más comunes antes de rentar Mesas Biergarten para festivales y eventos. Respondemos con detalle para que organices tu evento sin preocupaciones."
    paragraph2="¿Tu pregunta no está aquí? Escríbenos por WhatsApp — respondemos el mismo día."
  />
  <FaqSection
    phone="55 3128 1706"
    whatsapp="5531281706"
    schedule="Lun–Dom 8:00–20:00"
    waMessage="Hola, quiero cotizar Mesas Biergarten de Madera para mi festival."
    items={[
      {
        question: "¿Cuál es la diferencia entre la Mesa Biergarten y la Mesa Picnic estándar?",
        answer: "La Mesa Biergarten es más estrecha (0.60m vs 0.80-1.10m de la picnic estándar) y más corta (2.20m vs 2.40m), lo que permite mayor densidad de mesas en espacios reducidos. Además, incluye 2 bancas desmontables que no están integradas a la estructura, permitiendo reconfiguración del espacio. Es el formato estándar internacional para festivales, mientras la picnic es para bodas y eventos más formales."
      },
      {
        question: "¿Las bancas de la Mesa Biergarten son desmontables?",
        answer: "Sí, completamente desmontables. Las 2 bancas (2.20 × 0.35 m cada una) no están integradas a la mesa. Puedes posicionarlas de frente (cervecería tradicional), de lado, o retirarlas completamente para permitir acceso lateral en festival o mercado. Esta flexibilidad es lo que hace la Biergarten ideal para eventos con flujo variable de personas."
      },
      {
        question: "¿Cuántas mesas Biergarten necesito para un festival?",
        answer: "Depende del número de asistentes y la capacidad de comedores que planees. Cada mesa acomoda 8-10 personas, pero en festivales típicamente los comensales rotan rápidamente. Para 200 personas con rotación media, 15-20 mesas suelen ser suficientes. Enviamos croquis de distribución optimizado para tu espacio — escríbenos con medidas del área disponible."
      },
      {
        question: "¿La Mesa Biergarten resiste la lluvia y el sol directo?",
        answer: "Sí. El pino nacional está tratado y barnizado con protección exterior en tres capas de poliuretano. Resiste lluvia moderada, sol directo, humedad y uso intensivo en festivales. No es impermeable al 100% (es madera natural), pero aguanta perfectamente eventos de 8-12 horas bajo clima variable de CDMX y Edomex."
      },
      {
        question: "¿Se puede usar la Mesa Biergarten en espacios techados o salones?",
        answer: "Absolutamente sí. Funciona perfectamente en salones, carpas cerradas y espacios techados. El barniz exterior no interfiere con interiores. De hecho, muchos salones de eventos corporativos la usan para cenas buffet informales por su flexibilidad de bancas. Solo asegúrate de ventilación adecuada para el confort de los comensales."
      },
      {
        question: "¿Puedo mezclar Mesas Biergarten con otros modelos en el mismo evento?",
        answer: "Sí, es frecuente combinar Biergarten con mesas estándar o grandes dependiendo de la atmósfera que quieras crear. Las Biergarten sirven para zonas informales, comedores, o cocktail areas, mientras mesas picnic estándar pueden usarse para zonas más formales. Escríbenos con la configuración que imaginas y te asesoramos sobre la mejor mezcla."
      }
    ]}
  />
</section>

