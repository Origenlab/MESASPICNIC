---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import WaBubble from '../../../components/WaBubble.astro';
---

<BaseLayout
  title="Mesa Picnic Rústica para Renta — Estilo Boho y Vintage | MESPIC CDMX"
  description="Mesa Picnic Rústica de MESPIC: barniz que resalta la veta y los nudos naturales del pino. Estilo boho, vintage y rústico-chic. Ideal para bodas en bosques y haciendas en CDMX y Edomex. Entrega y montaje incluidos."
  ogImage="/img/tema-mexicana-1.avif"
>

<!-- Breadcrumbs -->
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Catálogo", href: "/catalogo/" },
    { label: "Mesa Picnic Rústica" }
  ]} />
</Fragment>

<!-- Hero -->
<Hero
  badge="Mesa Picnic Rústica"
  title="Mesa Picnic Rústica — Veta Natural para Estilos Boho y Vintage"
  description="El acabado rústico de MESPIC no es un defecto: es una elección estética. Barniz campestre que resalta la veta, los nudos y el carácter natural de la madera de pino. La mesa que se convierte en el elemento decorativo principal del evento."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="La Mesa Picnic Rústica usa exactamente la misma madera de pino nacional que los modelos estándar, pero el proceso de barnizado es diferente. En lugar de buscar una superficie uniforme, el barniz rústico está formulado para resaltar la veta, los nudos y las variaciones de tono natural de la madera. El resultado es una pieza con carácter orgánico y visual que encaja perfectamente con decoraciones boho, vintage, campestre y rústico-chic."
  seoParagraph2="Para bodas en bosques, haciendas y viñedos, la Mesa Rústica se convierte en parte integral del escenario: la veta de la madera dialoga con la vegetación del entorno, con las flores silvestres y con los elementos naturales de la decoración boho. No necesita mantel para verse bien — de hecho, muchas parejas prefieren dejarla al natural con solo un camino de flores o ramas de eucalipto. Mismas dimensiones y capacidad que la estándar: 1.80 × 1.50 m, 6 personas, entrega y montaje incluidos."
  dark={true}
  metrics={[
    { value: "veta",      label: "natural resaltada" },
    { value: "boho",      label: "vintage & rústico" },
    { value: "6 pax",     label: "capacidad estándar" },
  ]}
/>

<!-- CtaBar -->
<CtaBar />

<!-- GALERÍA -->
<section class="section" id="galeria">
  <SectionHeader
    tag="h2"
    badge="Mesa Rústica en eventos"
    title="La Mesa Rústica en Bodas Boho, Haciendas y Festivales"
    paragraph1="El acabado rústico funciona como decoración en sí misma: veta visible, nudos naturales y un tono cálido que complementa flores silvestres, pampas, telas de lino y decoración orgánica."
    paragraph2="¿Tu boda es en una hacienda o bosque? La Rústica es el modelo más solicitado para ese contexto. Cotiza por WhatsApp con tu fecha y el número de piezas."
  />
  <ProductGallery
    images={[
      { src: "/img/tema-mexicana-1.avif",                           alt: "Mesa picnic rústica con decoración temática y veta visible en jardín de hacienda" },
      { src: "/img/mesa-picnic-boda-elegante-decoracion.avif",      alt: "Mesas rústicas para boda boho al aire libre con flores silvestres y pampas" },
      { src: "/img/tema-mexicana-1.avif",                           alt: "Mesa rústica en feria gastronómica con ambiente campestre y decoración natural" },
      { src: "/img/mesa-picnic-boda-elegante-luces.avif",           alt: "Mesa rústica nocturna con luces cálidas para boda vintage en jardín privado" },
      { src: "/img/corp-teambuilding-1.avif",                       alt: "Mesas rústicas en parque verde para evento corporativo con estética natural" },
      { src: "/img/tema-mexicana-1.avif",                           alt: "Detalle de la veta y acabado rústico de la mesa picnic estilo boho de MESPIC" },
    ]}
    recommended={[
      { title: "Mesa Estándar",    description: "Acabado liso · 6 personas",   href: "/catalogo/mesa-picnic-estandar/",  image: "/img/mesa-picnic-boda-elegante-decoracion.avif" },
      { title: "Mesa Premium",     description: "Sin nudos · Lujo",            href: "/catalogo/mesa-picnic-premium/",   image: "/img/mesa-picnic-boda-elegante-luces.avif" },
      { title: "Set Completo",     description: "Mesa + decoración incluida",  href: "/catalogo/set-picnic-completo/",   image: "/img/mesa-picnic-pedida-mano-romantica.webp" },
      { title: "Bodas Rústicas",   description: "Servicio completo boda",      href: "/servicios/bodas/rustica/",        image: "/img/mesa-picnic-boda-elegante-decoracion.avif" },
      { title: "Bodas Boho",       description: "Pampas y macramé",            href: "/servicios/bodas/boho/",           image: "/img/mesa-picnic-boda-elegante-decoracion.avif" },
    ]}
    sidebarTitle="También te puede interesar"
  />
</section>

<!-- ESPECIFICACIONES -->
<section class="section section-alt" id="especificaciones">
  <SectionHeader
    tag="h2"
    badge="Ficha técnica · Rústica"
    title="Especificaciones de la Mesa Rústica"
    paragraph1="Mismas dimensiones y capacidad que la estándar, proceso de barnizado diferente para lograr el carácter rústico que caracteriza a este modelo."
    stats={[
      { value: '1.80 m',  label: 'largo' },
      { value: '6 pax',   label: 'capacidad' },
      { value: 'veta',    label: 'natural resaltada' },
    ]}
  />
  <div class="container">
    <div class="spec-grid">
      <div class="spec-card">
        <h3 class="spec-card__title">Ficha Técnica</h3>
        <ul class="spec-list" role="list">
          <li class="spec-list__item">
            <span class="spec-list__label">Medidas</span>
            <span class="spec-list__value">1.80 × 1.50 m</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Capacidad</span>
            <span class="spec-list__value">6 personas</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Material</span>
            <span class="spec-list__value">Pino nacional</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Acabado</span>
            <span class="spec-list__value">Barniz rústico que resalta veta</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Nudos</span>
            <span class="spec-list__value">Visibles y parte del diseño</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Estilo compatible</span>
            <span class="spec-list__value">Boho · Vintage · Campestre</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Disponibilidad</span>
            <span class="spec-list__value spec-list__value--ok">En bodega CDMX</span>
          </li>
        </ul>
        <a href="/cotizar/" class="spec-card__cta">Cotizar disponibilidad →</a>
      </div>

      <div class="spec-features">
        <FeatureCard
          index={0}
          title="Barniz Rústico — Veta y Nudos Visibles"
          description="El barniz rústico está formulado para penetrar la madera y resaltar su estructura natural en lugar de uniformizarla. La veta, los nudos y las variaciones de tono quedan visibles y se convierten en parte del diseño."
        />
        <FeatureCard
          index={1}
          title="Complemento Natural para Decoración Orgánica"
          description="La Mesa Rústica no necesita mantel para verse bien. Un camino de eucalipto, pampas, flores silvestres o ramas de olivo sobre la superficie de madera visible genera una composición de alta calidad estética con mínimos elementos."
        />
        <FeatureCard
          index={2}
          title="Perfecta para Interiores Rústicos y Exteriores Naturales"
          description="Ideal para haciendas, ranchos, fincas, viñedos y bosques. El carácter campestre de la mesa integra el mobiliario al entorno natural en lugar de contrastar con él."
        />
        <FeatureCard
          index={3}
          title="Misma Resistencia que el Modelo Estándar"
          description="El acabado rústico no compromete la resistencia de la madera. El barniz de exterior es el mismo en términos de protección — solo cambia la estética del acabado. La mesa aguanta el mismo uso intensivo que cualquier modelo del catálogo."
        />
      </div>
    </div>
  </div>
</section>

<!-- USOS -->
<section class="section" id="usos">
  <SectionHeader
    tag="h2"
    badge="Estilos y eventos compatibles"
    title="Cuándo Elegir la Mesa Rústica"
    paragraph1="La Mesa Rústica es la elección correcta cuando el estilo del evento requiere que el mobiliario tenga carácter visual propio, no que sea neutro."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard
        title="Bodas Rústicas y Boho"
        description="El modelo más solicitado para bodas con estilo orgánico. La veta visible de la mesa crea una continuidad visual con flores silvestres, pampas, macramé y telas de lino natural."
        image="/img/mesa-picnic-boda-elegante-decoracion.avif"
        href="/servicios/bodas/rustica/"
        btnLabel="Boda rústica"
        badge="Bodas"
      />
      <ServiceCard
        title="Fiestas Temáticas Mexicanas"
        description="Para fiestas con decoración mexicana tradicional, la textura rústica de la madera combina con papel picado, talavera, manteles bordados y elementos artesanales de manera natural y orgánica."
        image="/img/tema-mexicana-1.avif"
        href="/servicios/fiestas-tematicas/"
        btnLabel="Fiestas temáticas"
        badge="Temático"
      />
      <ServiceCard
        title="Ferias Gastronómicas"
        description="En food markets y ferias gastronómicas de nivel, la Mesa Rústica refuerza la identidad visual artesanal y orgánica que buscan muchos cocineros y productores de alimentos locales."
        image="/img/mesa-picnic-feria-gastronomica-multitud.avif"
        href="/servicios/festivales/"
        btnLabel="Food markets"
        badge="Festivales"
      />
      <ServiceCard
        title="Sesiones Fotográficas"
        description="Para fotógrafos y productores que buscan texturas naturales como fondo o prop. La veta visible y el tono rústico generan profundidad visual y calidez que el acabado liso no tiene."
        image="/img/mesa-picnic-boda-elegante-luces.avif"
        href="/servicios/sesiones-fotograficas/"
        btnLabel="Sesiones foto"
        badge="Foto & Video"
      />
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section section-alt" id="faq">
  <SectionHeader
    tag="h2"
    badge="Preguntas frecuentes"
    title="Preguntas sobre la Mesa Rústica"
    paragraph1="Las dudas más comunes sobre el acabado rústico, la compatibilidad con estilos de decoración y el uso en diferentes tipos de evento."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    waMessage="Hola, quiero cotizar la Mesa Picnic Rústica para mi evento."
    items={[
      {
        question: "¿La Mesa Rústica se ve descuidada o tiene mal acabado?",
        answer: "No. El acabado rústico es una decisión estética, no un acabado de menor calidad. El barniz está aplicado cuidadosamente para resaltar la veta y los nudos naturales del pino, no para dejar la madera desprotegida. La superficie es suave al tacto, sin astillas ni irregularidades. Si buscas una superficie visualmente impecable y uniforme, el modelo estándar o premium es la elección correcta."
      },
      {
        question: "¿La Mesa Rústica necesita mantel?",
        answer: "No necesita mantel para verse bien. De hecho, en muchos eventos el cliente elige dejarla al natural y agregar solo un camino de elementos decorativos (flores, ramas, velas) sobre la superficie de madera visible. Si prefieres poner mantel, funciona igualmente bien con cualquier tela."
      },
      {
        question: "¿Se puede usar la Rústica en bodas clásicas o formales?",
        answer: "Depende de la estética del evento. Para bodas con decoración formal (porcelana blanca, candelabros plateados, manteles de lino liso), el modelo estándar o premium genera una continuidad más coherente. Para bodas que mezclan elementos clásicos con toques rústicos u orgánicos, la Rústica funciona muy bien como contraste intencional."
      },
      {
        question: "¿Los nudos de la madera son defectos?",
        answer: "No. Los nudos son parte de la estructura natural del pino y en el modelo rústico se tratan como elemento decorativo, no como defecto. Antes de cada entrega, la mesa pasa por inspección para confirmar que los nudos no comprometen la integridad estructural. Los nudos que podrían generar irregularidades de superficie son trabajados para garantizar una mesa segura y estética."
      },
      {
        question: "¿Puedo combinar la Mesa Rústica con la Estándar en el mismo evento?",
        answer: "Sí. Algunos clientes combinan ambos modelos: rústicas para mesas de adultos y estándar para zonas de niños o mesas de servicio. El tono de la madera es muy similar; la diferencia está en la textura del acabado. En fotografía, la combinación genera variedad visual interesante."
      }
    ]}
  />
</section>

<CtaBarFinal
  headline="¿Tu boda o evento tiene estética boho o rústica?"
  subtext="La Mesa Rústica es la pieza que necesitas. Cotiza sin compromiso para tu fecha."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero cotizar la Mesa Picnic Rústica para mi boda o evento."
  cotizarHref="/cotizar/"
/>

<WaBubble whatsapp="5564328954" message="Hola, quiero cotizar la Mesa Picnic Rústica para mi evento." />

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Mesa Picnic Rústica — Renta MESPIC",
    "description": "Mesa picnic de pino con acabado rústico para renta en CDMX y Edomex. 1.80 × 1.50 m, 6 personas. Barniz que resalta veta y nudos naturales. Ideal para bodas boho, vintage y festivales gastronómicos.",
    "brand": { "@type": "Brand", "name": "MESPIC" },
    "offers": {
      "@type": "Offer",
      "priceCurrency": "MXN",
      "availability": "https://schema.org/InStock",
      "seller": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-6432-8954" }
    }
  })} />
</Fragment>

</BaseLayout>

<style>
  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }

  .spec-grid { display: grid; grid-template-columns: 320px 1fr; gap: 2rem; align-items: start; }
  .spec-card { background: #fff; border: 1px solid var(--c-border, #E7E0D8); border-radius: var(--radius-md, 12px); padding: 1.75rem; position: sticky; top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2rem); }
  .spec-card__title { font-size: 1rem; font-weight: 700; color: var(--c-text, #1C1917); margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 2px solid var(--c-primary, #2C5530); }
  .spec-list { list-style: none; display: flex; flex-direction: column; gap: 0; margin-bottom: 1.5rem; }
  .spec-list__item { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.625rem 0; border-bottom: 1px solid var(--c-border, #E7E0D8); }
  .spec-list__item:last-child { border-bottom: none; }
  .spec-list__label { font-size: 0.8125rem; color: var(--c-text-muted, #78716C); font-weight: 500; flex-shrink: 0; }
  .spec-list__value { font-size: 0.8125rem; color: var(--c-text, #1C1917); font-weight: 600; text-align: right; }
  .spec-list__value--ok { color: var(--c-primary, #2C5530); }
  .spec-card__cta { display: flex; align-items: center; justify-content: center; background: var(--c-primary, #2C5530); color: #fff; padding: 0.75rem 1.25rem; border-radius: 8px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.18s ease; }
  .spec-card__cta:hover { background: #224228; }
  .spec-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  @media (max-width: 1024px) { .spec-grid { grid-template-columns: 1fr; } .spec-card { position: static; } }
  @media (max-width: 640px) { .spec-features { grid-template-columns: 1fr; } }
</style>
