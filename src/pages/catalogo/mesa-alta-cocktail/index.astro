---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import NextStep from '../../../components/NextStep.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import WaBubble from '../../../components/WaBubble.astro';
---

<BaseLayout
  title="Mesa Alta Cocktail para Renta — Networking y Standing Events | MESPIC CDMX"
  description="Renta la Mesa Alta Cocktail de MESPIC: tablero circular Ø 70 cm × 110 cm de alto, perfecta para eventos standing, networking corporativo, cócteles y activaciones de marca en CDMX y Edomex."
  ogImage="/img/catalogo/mesa-alta-cocktail-madera-networking-01.webp"
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Catálogo", href: "/catalogo/" },
    { label: "Mesa Alta Cocktail" }
  ]} />
</Fragment>

<Hero
  badge="Mesa Cocktail"
  title="Mesa Alta Cocktail — Networking y Eventos Standing"
  description="La pieza definitiva para cócteles, networking corporativo y zonas de standing. Tablero circular de MDF con acabado pino, base de acero negro mate. Ø 70 cm × 110 cm de alto. Sin sillas necesarias."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="La Mesa Alta Cocktail de MESPIC cubre el segmento de eventos de pie que ningún otro modelo del catálogo atiende. Su altura de 110 centímetros está calculada para que adultos de talla promedio apoyen los brazos con comodidad mientras sostienen una copa o una tarjeta de presentación. El tablero circular de Ø 70 centímetros es suficiente para 4 a 5 personas de pie, creando una conversación natural sin que nadie dé la espalda a los demás."
  seoParagraph2="Disponible para renta en Ciudad de México y Estado de México, la Mesa Alta Cocktail es el elemento diferenciador en eventos corporativos de networking, presentaciones de producto, cócteles de gala y activaciones de marca en espacios abiertos. Su base de acero negro mate en acabado industrial aporta contraste visual con el tablero cálido de madera, resultando en un mobiliario que funciona igualmente bien en eventos modernos, rústicos o de estética industrial."
  dark={true}
/>

<CtaBar />

<section class="section" id="galeria">
  <SectionHeader
    tag="h2"
    badge="Mesa Cocktail en eventos"
    title="La Mesa Alta Cocktail en Networking, Cócteles y Activaciones"
    paragraph1="El mobiliario de pie transforma la dinámica social de los eventos: favorece la circulación, aumenta el número de interacciones y elimina la rigidez del formato mesa-silla. Así luce en contextos reales."
    paragraph2="¿Necesitas combinarla con mesas bajas o mesas estándar en el mismo evento? Escríbenos y te hacemos un layout integrado."
  />
  <ProductGallery
    images={[
      { src: "/img/catalogo/mesa-alta-cocktail-madera-networking-01.webp", alt: "Mesa alta cocktail de madera en evento corporativo afterwork con networking" },
      { src: "/img/catalogo/mesa-alta-cocktail-madera-networking-02.webp", alt: "Mesa cocktail alta en rooftop corporativo para evento standing de empresa" },
      { src: "/img/catalogo/mesa-alta-cocktail-madera-networking-03.webp", alt: "Varias mesas altas cocktail en lanzamiento de producto con invitados de pie" },
      { src: "/img/catalogo/mesa-alta-cocktail-madera-networking-04.webp", alt: "Mesa alta de madera en evento corporativo networking al aire libre CDMX" },
      { src: "/img/catalogo/mesa-alta-cocktail-madera-networking-05.webp", alt: "Mesa cocktail alta en celebración empresarial con decoración floral y cristalería" },
      { src: "/img/mesa-picnic-conferencia-empresarial-plantas.avif",      alt: "Mesa alta cocktail junto a elementos naturales en conferencia empresarial exterior" },
    ]}
    recommended={[
      { title: "Set Lounge Exterior", description: "Zona VIP · mesas bajas + asientos",  href: "/catalogo/set-lounge-exterior/",      image: "/img/catalogo/set-lounge-exterior-madera-vip-evento-01.webp" },
      { title: "Banca Individual",    description: "1.80 m · 3 personas",                href: "/catalogo/banca-picnic-individual/",  image: "/img/catalogo/banca-picnic-madera-pino-individual-01.webp" },
      { title: "Mesa Estándar",       description: "1.80 m · 6 personas",                href: "/catalogo/mesa-picnic-estandar/",     image: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" },
      { title: "Mesa Grande",         description: "2.40 m · 10–12 personas",            href: "/catalogo/mesa-picnic-grande/",       image: "/img/mesas-picnic-madera-renta-evento-cdmx-05.avif" },
      { title: "Set Completo",        description: "Mesa + decoración premium",           href: "/catalogo/set-picnic-completo/",      image: "/img/picnic-romantico-bridal-shower-mesas-pino-02.avif" },
    ]}
    sidebarTitle="Otros modelos del catálogo"
  />
</section>

<section class="section section-alt" id="especificaciones">
  <SectionHeader
    tag="h2"
    badge="Ficha técnica"
    title="Especificaciones de la Mesa Alta Cocktail"
    paragraph1="Dimensiones, materiales y capacidad. Todo lo que necesitas para planear la distribución de tu zona de standing."
    paragraph2="¿Necesitas saber cuántas mesas para tu número de invitados de pie? Escríbenos y te hacemos el cálculo en minutos."
    stats={[
      { value: 'Ø 70 cm',  label: 'tablero circular' },
      { value: '110 cm',   label: 'altura standing' },
      { value: '4-5',      label: 'personas de pie' },
    ]}
  />
  <div class="container">
    <div class="spec-grid">
      <div class="spec-card">
        <h3 class="spec-card__title">Ficha Técnica</h3>
        <ul class="spec-list" role="list">
          <li class="spec-list__item">
            <span class="spec-list__label">Forma tablero</span>
            <span class="spec-list__value">Circular</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Diámetro tablero</span>
            <span class="spec-list__value">Ø 70 cm</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Altura</span>
            <span class="spec-list__value">110 cm (standing)</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Capacidad</span>
            <span class="spec-list__value">4–5 personas de pie</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Material tablero</span>
            <span class="spec-list__value">MDF rechapado pino + laca mate</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Base</span>
            <span class="spec-list__value">Acero negro mate — 4 patas cruzadas</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Uso recomendado</span>
            <span class="spec-list__value">Interior y exterior protegido</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Peso</span>
            <span class="spec-list__value">12 kg</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Disponibilidad</span>
            <span class="spec-list__value spec-list__value--ok">+60 piezas en bodega</span>
          </li>
        </ul>
        <a href="/cotizar/" class="spec-card__cta">Cotizar disponibilidad →</a>
      </div>
      <div class="spec-features">
        <FeatureCard index={0} title="Standing — Sin Sillas Necesarias"
          description="La altura de 110 cm está calculada para eventos de pie: los invitados pueden apoyar los brazos, la copa y la tarjeta de presentación sin agacharse. Elimina la necesidad de rentar sillas adicionales y libera espacio para circulación, lo que aumenta la dinámica social del evento." />
        <FeatureCard index={1} title="Diseño Minimalista Versátil"
          description="El contraste entre el tablero cálido de madera y la base de acero negro mate crea un mobiliario que funciona en eventos modernos, industriales y rústicos por igual. No requiere mantel ni cubierta adicional; la combinación de materiales es decorativa por sí misma." />
        <FeatureCard index={2} title="Tablero de MDF Premium con Chapa de Pino"
          description="El tablero de MDF de alta densidad con chapa de pino natural garantiza una superficie plana, sin nudos ni irregularidades, ideal para apoyar cristalería fina, tabletas digitales o materiales de presentación. La laca mate anti-manchas facilita la limpieza entre usos." />
        <FeatureCard index={3} title="Base de Acero Negro Mate — Estabilidad Total"
          description="Las 4 patas cruzadas de acero en acabado negro mate ofrecen una base amplia que previene el volteo incluso en superficies ligeramente irregulares. Cada pata lleva niveladores de goma que protegen tanto el piso del venue como la estabilidad de la mesa en terrenos naturales." />
      </div>
    </div>
  </div>
</section>

<section class="section" id="usos">
  <SectionHeader tag="h2" badge="Usos recomendados"
    title="Eventos Donde la Mesa Cocktail es Indispensable"
    paragraph1="El formato de pie redefine la experiencia social: más interacciones, más circulación, más dinamismo. Estos son los contextos donde la Mesa Alta Cocktail tiene mayor impacto."
    paragraph2="¿Estás planeando un evento mixto con zonas de pie y zonas sentadas? Te asesoramos en la distribución sin costo."
    stats={[
      { value: '360°',  label: 'visibilidad desde la mesa' },
      { value: '4-5',   label: 'personas por mesa' },
      { value: 'pie',   label: 'formato standing premium' },
    ]} />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Networking Corporativo" description="La Mesa Cocktail es el estándar de los eventos de networking empresarial. Facilita que los invitados cambien de grupo durante la velada, aumenta el número de contactos realizados y elimina la incomodidad de buscar silla libre." image="/img/catalogo/mesa-alta-cocktail-madera-networking-04.webp" href="/servicios/eventos-corporativos/" btnLabel="Mesas corporativas" badge="Corporativo" />
      <ServiceCard title="Cócteles y Galas" description="Para recepciones de gala, cócteles de boda y presentaciones de colección, la Mesa Cocktail aporta elegancia de pie sin necesitar el espacio ni la logística de una mesa de banquete completa." image="/img/catalogo/mesa-alta-cocktail-madera-networking-05.webp" href="/servicios/bodas/" btnLabel="Mesas para cócteles" badge="Gala" />
      <ServiceCard title="Activaciones de Marca" description="En lanzamientos de producto y activaciones en centros comerciales o espacios públicos, la Mesa Cocktail crea puntos de encuentro que invitan a detenerse, probar y conversar con los representantes de la marca." image="/img/corp-lanzamiento-1.avif" href="/servicios/eventos-corporativos/" btnLabel="Para activaciones" badge="Marca" />
      <ServiceCard title="Team Building Exterior" description="Como complemento a las actividades de integración empresarial, las mesas cocktail crean zonas de descanso informales donde los equipos comparten resultados, bebidas y conversaciones sin la formalidad de una mesa de conferencias." image="/img/catalogo/mesa-alta-cocktail-madera-networking-02.webp" href="/servicios/eventos-corporativos/" btnLabel="Team building" badge="Team Building" />
    </div>
  </div>
</section>

<section class="section section-alt" id="faq">
  <SectionHeader tag="h2" badge="Preguntas frecuentes" title="Preguntas sobre la Mesa Alta Cocktail"
    paragraph1="Las dudas más comunes sobre el formato standing y la compatibilidad de la Mesa Cocktail con otros elementos del catálogo."
    paragraph2="¿Planeas combinar zonas de pie con zonas sentadas? Escríbenos y te hacemos el layout completo." />
  <FaqSection phone="55 6432 8954" whatsapp="5564328954" schedule="Lun–Dom 8:00–20:00"
    waMessage="Hola, quiero cotizar la Mesa Alta Cocktail para mi evento."
    items={[
      { question: "¿La Mesa Cocktail incluye bancos altos o sillas bar?", answer: "El modelo estándar de la Mesa Cocktail se renta sin asientos. Es una mesa de standing puro. Si tu evento requiere taburetes o bancos altos para ciertas zonas, podemos orientarte sobre opciones de complemento; escríbenos y buscamos la solución más adecuada para tu concepto." },
      { question: "¿Cuántas personas pueden estar de pie alrededor de la mesa?", answer: "La Mesa Cocktail está dimensionada para 4 a 5 personas de pie cómodamente distribuidas alrededor del tablero circular de Ø 70 cm. Para eventos de networking donde los grupos se forman y disuelven constantemente, calcula entre 3 y 4 personas por mesa como referencia para el número de mesas a contratar." },
      { question: "¿Funciona en exteriores bajo sol directo?", answer: "La Mesa Cocktail está diseñada principalmente para interiores y para exteriores cubiertos (bajo carpa, toldo o pérgola). La laca del tablero MDF no está formulada para exposición solar prolongada. Para exteriores sin cubierta o en eventos de más de 4 horas bajo sol, recomendamos combinarla con una carpa o colocarla en zonas con sombra natural." },
      { question: "¿Se puede combinar con mesas bajas de madera en el mismo evento?", answer: "Sí, y es una combinación muy solicitada en eventos mixtos: zona de pie con Mesas Cocktail para networking y zona sentada con Mesas Estándar, Premium o el Set Lounge para descanso y comida. Este diseño crea una experiencia de evento más dinámica y visualmente interesante." },
      { question: "¿Cuántas mesas cocktail necesito para un evento de 100 personas de pie?", answer: "Para 100 personas en un evento de networking o cóctel, recomendamos entre 20 y 25 mesas cocktail. Esto permite que no todas las personas estén en la mesa al mismo tiempo (muchos estarán circulando) y crea suficientes puntos de anclaje sin saturar el espacio de circulación." },
      { question: "¿La entrega y montaje están incluidos?", answer: "Sí. El precio de renta de la Mesa Alta Cocktail incluye traslado a tu venue en CDMX o Edomex, instalación por nuestro equipo y recolección al finalizar el evento. La mesa no requiere herramienta para instalar; el equipo de MESPIC la coloca y nivela en su posición definitiva." }
    ]} />
</section>


<!-- Siguiente paso: Ver paquetes -->
<NextStep
  titulo="¿Ya elegiste el mobiliario que necesitas?"
  subtitulo="Selecciona el paquete que mejor se adapta al número de invitados de tu evento. Precio final sin extras."
  href="/paquetes/"
  btnLabel="Ver paquetes disponibles →"
  step={2}
  secondBtn={{ label: 'Cotizar directamente', href: '/cotizar/' }}
/>

<CtaBarFinal headline="¿Lista tu Zona de Networking?" subtext="Cotiza disponibilidad de Mesas Cocktail para tu fecha. Respondemos el mismo día con precio y configuración." phone="55 6432 8954" whatsapp="5564328954" waMessage="Hola, quiero cotizar Mesas Alta Cocktail para mi evento." cotizarHref="/cotizar/" />
<WaBubble whatsapp="5564328954" message="Hola, me interesa rentar Mesas Altas Cocktail." />

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@type": "Product", "name": "Mesa Alta Cocktail — Renta MESPIC", "description": "Mesa alta cocktail de standing para renta. Tablero circular Ø 70 cm × 110 cm de alto. MDF rechapado pino + base acero negro mate. Para 4-5 personas de pie. Ideal para networking, cócteles y activaciones de marca en CDMX y Edomex.", "brand": { "@type": "Brand", "name": "MESPIC" }, "category": "Mobiliario para eventos — Renta", "offers": { "@type": "Offer", "priceCurrency": "MXN", "availability": "https://schema.org/InStock", "seller": { "@type": "LocalBusiness", "name": "MESPIC — Renta de Mesas Picnic", "telephone": "+52-55-6432-8954", "url": "https://mesaspicnic.com" } } })} />
</Fragment>
</BaseLayout>

<style>
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }
  .spec-grid { display: grid; grid-template-columns: 320px 1fr; gap: 2rem; align-items: start; }
  .spec-card { background: #fff; border: 1px solid var(--c-border, #E7E0D8); border-radius: var(--radius-md, 12px); padding: 1.75rem; position: sticky; top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2rem); }
  .spec-card__title { font-size: 1rem; font-weight: 700; color: var(--c-text, #1C1917); margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 2px solid var(--c-primary, #2C5530); }
  .spec-list { list-style: none; display: flex; flex-direction: column; gap: 0; margin-bottom: 1.5rem; }
  .spec-list__item { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.625rem 0; border-bottom: 1px solid var(--c-border, #E7E0D8); }
  .spec-list__item:last-child { border-bottom: none; }
  .spec-list__label { font-size: 0.8125rem; color: var(--c-text-muted, #78716C); font-weight: 500; flex-shrink: 0; }
  .spec-list__value { font-size: 0.8125rem; color: var(--c-text, #1C1917); font-weight: 600; text-align: right; }
  .spec-list__value--ok { color: var(--c-primary, #2C5530); }
  .spec-card__cta { display: flex; align-items: center; justify-content: center; background: var(--c-primary, #2C5530); color: #fff; padding: 0.75rem 1.25rem; border-radius: 8px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.18s ease; }
  .spec-card__cta:hover { background: #224228; }
  .spec-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  @media (max-width: 1024px) { .spec-grid { grid-template-columns: 1fr; } .spec-card { position: static; } }
  @media (max-width: 640px) { .spec-features { grid-template-columns: 1fr; } }
</style>
