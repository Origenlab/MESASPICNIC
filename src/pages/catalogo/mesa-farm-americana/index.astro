      </a>
      <a href="/blog/decoracion-mesas-picnic-fiestas-infantiles/" class="blog-card">
        <div class="blog-card__img-wrap">
          <img src="/img/mesa-picnic-fiesta-infantil-cupcakes.webp" alt="Decoración de mesas farm para eventos formales" loading="lazy" width="400" height="240" />
        </div>
        <div class="blog-card__body">
          <span class="blog-card__cat">Decoración</span>
          <h3 class="blog-card__title">Decoración de Mesas Farm para Eventos de Lujo</h3>
          <p class="blog-card__desc">Ideas profesionales para decorar mesas farm americana: flores elaboradas, paletas de color premium y centros de mesa impactantes.</p>
          <span class="blog-card__cta">Leer artículo →</span>
        </div>
      </a>
      <a href="/blog/picnic-lujo-experiencias-premium-cdmx/" class="blog-card">
        <div class="blog-card__img-wrap">
          <img src="/img/mesa-picnic-romantica-velas-rosas.webp" alt="Mesas farm para experiencias premium en CDMX" loading="lazy" width="400" height="240" />
        </div>
        <div class="blog-card__body">
          <span class="blog-card__cat">Premium</span>
          <h3 class="blog-card__title">Mesas Farm para Experiencias Premium en CDMX</h3>
          <p class="blog-card__desc">Cómo crear eventos de alto nivel: selección de mobiliario farm, catering compatible, decoración floral y detalles que marcan la diferencia.</p>
          <span class="blog-card__cta">Leer artículo →</span>
        </div>
      </a>
    </div>
  </div>
</section>


<!-- Siguiente paso: Ver paquetes -->
<NextStep
  titulo="¿Ya elegiste el mobiliario que necesitas?"
  subtitulo="Selecciona el paquete que mejor se adapta al número de invitados de tu evento. Precio final sin extras."
  href="/paquetes/"
  btnLabel="Ver paquetes disponibles →"
  step={2}
  secondBtn={{ label: 'Cotizar directamente', href: '/cotizar/' }}
/>

<CtaBarFinal
  headline="¿Lista tu Mesa Farm Americana?"
  subtext="Cotiza disponibilidad para tu fecha. Respondemos el mismo día con precio, distribución y confirmación de layout."
  phone="55 3128 1706"
  whatsapp="5531281706"
  waMessage="Hola, quiero cotizar la Mesa Farm Americana para mi evento."
  cotizarHref="/cotizar/"
/>

<WaBubble whatsapp="5531281706" message="Hola, me interesa rentar la Mesa Farm Americana." />

