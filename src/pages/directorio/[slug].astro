---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import FaqSection from '../../components/FaqSection.astro';
import NextStep from '../../components/NextStep.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import EspaciosSidebar from '../../components/EspaciosSidebar.astro';
import VenueCard from '../../components/VenueCard.astro';
import data from '../../data/espacios.json';

export async function getStaticPaths() {
  const d = (await import('../../data/espacios.json')).default;
  return d.espacios.map((e: any) => ({ params: { slug: e.slug }, props: { espacio: e } }));
}

const { espacio } = Astro.props as { espacio: any };
const tipos: Record<string, string> = data.tipos;
const tipoLabel = tipos[espacio.tipo];

const mismaAlcaldia = data.espacios.filter((e: any) => e.slug !== espacio.slug && e.alcaldia === espacio.alcaldia);
const otros = data.espacios.filter((e: any) => e.slug !== espacio.slug && e.alcaldia !== espacio.alcaldia);
const relacionados = [...mismaAlcaldia, ...otros].slice(0, 3);

const waMessage = `Hola, vi ${espacio.nombre} (${espacio.alcaldia}) en el directorio y quiero cotizar mobiliario para mi evento ahí.`;

const venueSchema: any = {
  "@context": "https://schema.org",
  "@type": "EventVenue",
  "name": espacio.nombre,
  "description": espacio.descripcion,
  "url": `https://mesaspicnic.com/directorio/${espacio.slug}/`,
  "image": `https://mesaspicnic.com${espacio.imagenPrincipal}`,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": espacio.alcaldia,
    "addressRegion": "Ciudad de México",
    "addressCountry": "MX"
  },
  "areaServed": { "@type": "City", "name": `${espacio.alcaldia}, Ciudad de México` }
};
if (espacio.capacidadNum) venueSchema.maximumAttendeeCapacity = espacio.capacidadNum;

// ── Contenido enriquecido (genérico, datos reales del catálogo MESPIC) ──
const modelos = [
  { modelo: 'Mesa Estándar', medidas: '1.80 × 1.50 m', capacidad: '6 personas', ideal: 'Bodas, reuniones y corporativos', href: '/catalogo/mesa-picnic-estandar/' },
  { modelo: 'Mesa Grande', medidas: '2.40 × 1.50 m', capacidad: '10–12 personas', ideal: 'Mesa principal y eventos masivos', href: '/catalogo/mesa-picnic-grande/' },
  { modelo: 'Mesa Infantil', medidas: '1.20 × 1.00 m', capacidad: '8–10 niños', ideal: 'Fiestas infantiles (3–10 años)', href: '/catalogo/mesa-picnic-infantil/' },
  { modelo: 'Mesa Premium', medidas: '1.80 × 1.50 m', capacidad: '6 personas', ideal: 'Bodas VIP y sesiones de fotos', href: '/catalogo/mesa-picnic-premium/' },
];

const calculoMesas = [
  { invitados: '30 invitados', estandar: '5 mesas', grandes: '3 mesas' },
  { invitados: '50 invitados', estandar: '8–9 mesas', grandes: '5 mesas' },
  { invitados: '100 invitados', estandar: '17–18 mesas', grandes: '9–10 mesas' },
  { invitados: '150 invitados', estandar: '25–26 mesas', grandes: '13–14 mesas' },
  { invitados: '200 invitados', estandar: '34 mesas', grandes: '17–18 mesas' },
];

const comparativa = [
  { c: 'Estética en jardín', madera: 'Cálida y natural, combina con el verde', plastico: 'Se ve promocional y frío', tablon: 'Neutro, depende del mantel' },
  { c: 'Asientos', madera: 'Bancas integradas (no rentas sillas)', plastico: 'Sillas por separado', tablon: 'Sillas por separado' },
  { c: 'Montaje', madera: 'Incluido por MESPIC', plastico: 'Por tu cuenta', tablon: 'Requiere vestir y montar' },
  { c: 'Para fotos', madera: 'Excelente, estilo rústico/boho', plastico: 'Regular', tablon: 'Bueno con mantelería' },
  { c: 'Logística', madera: 'Entrega, montaje y recolección', plastico: 'Variable', tablon: 'Variable' },
];

// Campos enriquecidos opcionales por venue (fallback si no existen)
const acerca: string[] = espacio.acerca && espacio.acerca.length ? espacio.acerca : [espacio.descripcion];
const puntosInteres: string[] = espacio.puntosInteres || [];
const comercialHook: string = espacio.comercialHook || `En ${espacio.nombre}, las mesas de madera de MESPIC le dan a tu evento la calidez que el plástico no logra.`;
// ── SEO: título y meta humanizados (fallback si el venue no los trae) ──
const seoTitle = espacio.seoTitle || `${espacio.nombre} en ${espacio.alcaldia} — Jardín de Eventos y Mesas Picnic | MESPIC`;
const seoDesc = espacio.seoDesc || `¿Tu evento es en ${espacio.nombre}, ${espacio.alcaldia}? MESPIC monta mesas picnic de madera en el jardín, con bancas incluidas y sin cargos extra. Cotiza fácil.`;

// ── FAQ (se usa para render y para schema FAQPage) ──
const faqItems = [
  { question: `¿${espacio.nombre} incluye mesas y mobiliario?`, answer: `Por lo general no. Como casi todos los jardines de eventos, ${espacio.nombre} se renta solo como espacio. Nosotros nos encargamos de esa parte: llevamos las mesas picnic de madera, las montamos en el jardín y las recogemos al final. Tú reservas el lugar y MESPIC pone el mobiliario.` },
  { question: `¿Cuántas mesas necesito para mi evento en ${espacio.nombre}?`, answer: `Depende de cuántos invitados sean. Una mesa estándar acomoda 6 personas y la grande de 10 a 12. Dinos tu número aproximado y te calculamos las mesas exactas sin costo, para que no te quedes corto ni pagues de más.` },
  { question: `¿MESPIC lleva y monta el mobiliario hasta ${espacio.alcaldia}?`, answer: `Sí. Cubrimos ${espacio.alcaldia} y todas las alcaldías de la Ciudad de México. Llegamos, montamos y al terminar recogemos, sin cobrarte extra por el traslado dentro de la cobertura.` },
  { question: `¿Cómo aparto la fecha en ${espacio.nombre}?`, answer: `La fecha del espacio se aparta directamente con el recinto. En cuanto la tengas confirmada, escríbenos con el número de invitados y te cotizamos el mobiliario de madera para ese día.` },
  { question: `¿Qué incluye la renta de mesas picnic de MESPIC?`, answer: `El precio incluye entrega, montaje y recolección. Las mesas vienen con bancas integradas, así que no rentas sillas aparte, y lo que cotizamos es el precio final: sin cargos ocultos ni cobros por tiempo extra.` },
];
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  ogImage={espacio.imagenPrincipal}
  schema={venueSchema}
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Directorio de Espacios", href: "/directorio/" },
    { label: espacio.nombre }
  ]} />
</Fragment>

<Hero
  badge={`${tipoLabel} · ${espacio.alcaldia}, CDMX`}
  title={`${espacio.nombre} — ${tipoLabel} en ${espacio.alcaldia}`}
  description={`${espacio.capacidad}. Ideal para ${espacio.eventos.slice(0, 3).join(', ').toLowerCase()}. Réntalo como locación y monta tu evento con mobiliario de madera MESPIC.`}
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1={espacio.descripcion}
  seoParagraph2={`La mayoría de los jardines y salones al aire libre como ${espacio.nombre} se rentan solo como locación, sin mobiliario. MESPIC complementa tu evento con mesas picnic y bancas de madera de pino, montadas directamente en el espacio que reserves. Cubrimos ${espacio.alcaldia} y toda la Ciudad de México con entrega, montaje y recolección incluidos.`}
  dark={true}
/>

<CtaBar />

<!-- ═══════════════════════════════════════════════════════
     SIDEBAR + CONTENIDO PRINCIPAL
═══════════════════════════════════════════════════════ -->
<section class="section" id="detalle">
  <div class="container">
    <div class="esp-layout">
      <!-- Main -->
      <div class="esp-main">
        <!-- Galería -->
        <div class="esp-galeria">
          {espacio.imagenes.map((img: any, i: number) => (
            <figure class:list={['esp-foto', { 'esp-foto--main': i === 0 }]}>
              <img src={img.src} alt={img.alt} loading={i === 0 ? 'eager' : 'lazy'} width="600" height="450" />
            </figure>
          ))}
        </div>

        <!-- Datos del espacio -->
        <div class="esp-datos">
          <div class="esp-datos__head">
            <h2 class="esp-datos__title">{espacio.nombre}</h2>
            {espacio.sinSitioWeb && <span class="esp-datos__badge">Google Business · sin sitio web</span>}
          </div>
          <div class="esp-datos__grid">
            <div class="esp-dato"><span class="esp-dato__k">Tipo</span><span class="esp-dato__v">{tipoLabel}</span></div>
            <div class="esp-dato"><span class="esp-dato__k">Alcaldía</span><span class="esp-dato__v">{espacio.alcaldia}, {espacio.estado}</span></div>
            <div class="esp-dato"><span class="esp-dato__k">Capacidad</span><span class="esp-dato__v">{espacio.capacidad}</span></div>
            <div class="esp-dato"><span class="esp-dato__k">Eventos</span><span class="esp-dato__v">{espacio.eventos.length} tipos</span></div>
          </div>
          <div class="esp-datos__tags">
            {espacio.eventos.map((ev: string) => (<span class="esp-tag">{ev}</span>))}
          </div>
          <a href="/cotizar/" class="esp-datos__cta">Cotizar mobiliario para este espacio →</a>
          <p class="esp-datos__nota">Reservas la locación con el recinto; MESPIC pone el mobiliario de madera y lo monta en tu evento.</p>
          <p class="esp-datos__ref">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            Información de referencia recopilada de fuentes públicas. Confirma disponibilidad, capacidad y datos de contacto directamente con el recinto.
          </p>
        </div>

        <!-- Acerca del espacio y la zona -->
        <header class="esp-h">
          <span class="esp-h__badge"><span class="esp-h__dot"></span>Acerca del espacio</span>
          <h2 class="esp-h__title">Sobre {espacio.nombre} en {espacio.alcaldia}</h2>
        </header>
        <div class="esp-prosa">
          {acerca.map((p: string) => (<p>{p}</p>))}
        </div>

        {puntosInteres.length > 0 && (
          <div class="esp-interes">
            <h3 class="esp-interes__title">Puntos de interés y qué considerar</h3>
            <ul class="esp-interes__list">
              {puntosInteres.map((p: string) => (<li>{p}</li>))}
            </ul>
          </div>
        )}

        <!-- COMERCIAL: Renta de mesas picnic en este espacio -->
        <div class="esp-comercial">
          <div class="esp-comercial__body">
            <span class="esp-comercial__eyebrow">Renta de mesas picnic con MESPIC</span>
            <h2 class="esp-comercial__title">Renta mesas picnic de madera para tu evento en {espacio.nombre}</h2>
            <p class="esp-comercial__hook">{comercialHook}</p>
            <p class="esp-comercial__text">
              ¿Vas a celebrar en {espacio.nombre}? El espacio te da el jardín; MESPIC te da el mobiliario. Llevamos
              <strong> mesas picnic de madera de pino natural</strong>, lijadas y barnizadas a mano, y las montamos
              directamente en el jardín antes de que llegues. Cada mesa incluye sus bancas integradas, así que
              <strong> no tienes que rentar sillas por separado</strong>. Al terminar tu evento, recogemos todo: tú solo disfrutas.
            </p>
            <ul class="esp-comercial__list">
              <li>Entrega, montaje y recolección incluidos en {espacio.alcaldia} y toda la CDMX</li>
              <li>Mesas con bancas integradas — sin rentar sillas aparte</li>
              <li>Madera natural que combina con el jardín (rústico, boho, clásico o minimalista)</li>
              <li>Precio final cerrado, sin cargos ocultos ni por tiempo extra</li>
              <li>Modelos para adultos, niños y mesa principal según tu evento</li>
            </ul>
            <div class="esp-comercial__cta">
              <a href="/cotizar/" class="btn btn-primary">Cotizar mesas picnic →</a>
              <a href="/catalogo/" class="btn btn-outline">Ver catálogo de mesas</a>
            </div>
          </div>
        </div>

        <!-- Incluye / pone MESPIC -->
        <header class="esp-h">
          <span class="esp-h__badge"><span class="esp-h__dot"></span>Qué incluye</span>
          <h2 class="esp-h__title">Qué Incluye y Qué Pone MESPIC</h2>
          <p class="esp-h__text">{espacio.tips ? `Tip MESPIC: ${espacio.tips}` : `Como la mayoría de los jardines de eventos, ${espacio.nombre} se renta como locación. MESPIC aporta el mobiliario.`}</p>
        </header>
        <div class="esp-incluye-grid">
          <div class="esp-col esp-col--si">
            <h3 class="esp-col__title">Incluye el espacio</h3>
            <ul class="esp-col__list" role="list">
              {espacio.incluye.map((x: string) => (<li class="esp-col__item esp-col__item--si">{x}</li>))}
            </ul>
          </div>
          <div class="esp-col esp-col--no">
            <h3 class="esp-col__title">Lo pone MESPIC</h3>
            <ul class="esp-col__list" role="list">
              {espacio.noIncluye.map((x: string) => (<li class="esp-col__item esp-col__item--mespic">{x}</li>))}
            </ul>
          </div>
        </div>

        <!-- Tabla: modelos de mesas picnic -->
        <header class="esp-h">
          <span class="esp-h__badge"><span class="esp-h__dot"></span>Catálogo</span>
          <h2 class="esp-h__title">Modelos de Mesas Picnic Disponibles</h2>
          <p class="esp-h__text">Estos son los modelos que MESPIC monta en {espacio.nombre}. Cada uno tiene una capacidad y un uso ideal según tu tipo de evento.</p>
        </header>
        <div class="esp-tabla-wrap">
          <table class="esp-tabla">
            <thead>
              <tr><th>Modelo</th><th>Medidas</th><th>Capacidad</th><th>Ideal para</th></tr>
            </thead>
            <tbody>
              {modelos.map((m) => (
                <tr>
                  <td><a href={m.href} class="esp-tabla__link">{m.modelo}</a></td>
                  <td>{m.medidas}</td>
                  <td>{m.capacidad}</td>
                  <td>{m.ideal}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Tabla: cuántas mesas necesitas -->
        <header class="esp-h">
          <span class="esp-h__badge"><span class="esp-h__dot"></span>Calculadora</span>
          <h2 class="esp-h__title">¿Cuántas Mesas Necesitas en {espacio.nombre}?</h2>
          <p class="esp-h__text">Referencia rápida según tu número de invitados. Combina modelos si quieres: por ejemplo, mesas grandes para la zona principal y estándar para el resto.</p>
        </header>
        <div class="esp-tabla-wrap">
          <table class="esp-tabla">
            <thead>
              <tr><th>Invitados</th><th>Con Mesa Estándar (6 pax)</th><th>Con Mesa Grande (10–12 pax)</th></tr>
            </thead>
            <tbody>
              {calculoMesas.map((r) => (
                <tr><td><strong>{r.invitados}</strong></td><td>{r.estandar}</td><td>{r.grandes}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="esp-tabla-nota">¿Aforo exacto? Escríbenos tu número de invitados y te calculamos las mesas sin costo.</p>

        <!-- Tabla comparativa: madera vs otras opciones -->
        <header class="esp-h">
          <span class="esp-h__badge"><span class="esp-h__dot"></span>Comparativa</span>
          <h2 class="esp-h__title">Mesas de Madera vs. Otras Opciones</h2>
          <p class="esp-h__text">Por qué las mesas picnic de madera son la mejor opción para un jardín como {espacio.nombre}, frente a sillas de plástico o tablones con mantel.</p>
        </header>
        <div class="esp-tabla-wrap">
          <table class="esp-tabla esp-tabla--comp">
            <thead>
              <tr><th>Característica</th><th>Mesa picnic madera</th><th>Sillas / plástico</th><th>Tablón + mantel</th></tr>
            </thead>
            <tbody>
              {comparativa.map((r) => (
                <tr><td><strong>{r.c}</strong></td><td class="esp-tabla__win">{r.madera}</td><td>{r.plastico}</td><td>{r.tablon}</td></tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Eventos ideales -->
        <header class="esp-h">
          <span class="esp-h__badge"><span class="esp-h__dot"></span>Eventos ideales</span>
          <h2 class="esp-h__title">Eventos que Funcionan en {espacio.nombre}</h2>
          <p class="esp-h__text">Por su tipo, capacidad y ubicación en {espacio.alcaldia}, este espacio funciona bien para estos eventos. MESPIC tiene la configuración de mobiliario para cada uno.</p>
        </header>
        <div class="esp-ev-grid">
          {espacio.eventos.map((ev: string) => (
            <FeatureCard title={ev} description={`MESPIC monta el mobiliario de madera ideal para ${ev.toLowerCase()} en ${espacio.nombre}: mesas y bancas de pino que combinan con el entorno y se adaptan a tu número de invitados.`} />
          ))}
        </div>
      </div>

      <!-- Sidebar (derecha) -->
      <EspaciosSidebar espacios={data.espacios} tipos={tipos} activeSlug={espacio.slug} />
    </div>
  </div>
</section>

<!-- FAQ (full width) -->
<section class="section section-alt" id="faq">
  <SectionHeader
    tag="h2"
    badge="Preguntas frecuentes"
    title={`Preguntas sobre Eventos en ${espacio.nombre}`}
    paragraph1="Dudas comunes sobre cómo montar tu evento en este espacio con mobiliario de MESPIC."
    paragraph2="¿No está tu pregunta aquí? Escríbenos por WhatsApp y te respondemos de inmediato."
  />
  <FaqSection
    phone="55 3068 2988"
    whatsapp="5530682988"
    schedule="Lun–Dom 8:00–20:00"
    waMessage={waMessage}
    items={faqItems}
  />
</section>

<!-- Otros espacios (full width) -->
<section class="section" id="otros-espacios">
  <SectionHeader
    tag="h2"
    badge="Más espacios"
    title="Otros Jardines y Salones del Directorio"
    paragraph1={`Explora más espacios al aire libre del directorio${mismaAlcaldia.length ? ` en ${espacio.alcaldia} y otras alcaldías` : ' en CDMX'} para comparar opciones según tu zona, número de invitados y estilo de evento.`}
  />
  <div class="container">
    <div class="dir-grid">
      {relacionados.map((e: any) => (
        <VenueCard e={e} tipos={tipos} />
      ))}
    </div>
    <div class="esp-cta-wrap">
      <a href="/directorio/" class="btn btn-outline">Ver todo el directorio de espacios →</a>
    </div>
  </div>
</section>

<ExploreMore
  title="Sigue explorando MESPIC"
  subtitle="Todo lo que necesitas para tu evento en un solo lugar"
  items={[
    { href: '/directorio/', label: 'Directorio de espacios', sub: 'Jardines y salones en CDMX', badge: 'Espacios', isEmoji: true, icon: '🌳' },
    { href: '/catalogo/', label: 'Catálogo completo', sub: '20 modelos con fichas técnicas', badge: 'Mobiliario', isEmoji: true, icon: '🪵' },
    { href: '/paquetes/', label: 'Nuestros paquetes', sub: 'Básico · Estándar · Premium', badge: 'Paquetes', isEmoji: true, icon: '📦' },
  ]}
/>

<NextStep
  titulo={`¿Tu evento es en ${espacio.nombre}?`}
  subtitulo="Escríbenos el espacio y tu número de invitados. Te decimos cuántas mesas necesitas y montamos el mobiliario directo en tu locación."
  href="/cotizar/"
  btnLabel="Cotizar mobiliario →"
  secondBtn={{ label: 'Ver más espacios', href: '/directorio/' }}
/>

</BaseLayout>

<style>
  /* ── Layout sidebar + main ── */
  .esp-layout { display: grid; grid-template-columns: 1fr 300px; gap: 2.5rem; align-items: start; }
  .esp-main { min-width: 0; }

  /* ── Galería ── */
  .esp-galeria { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.75rem; }
  .esp-foto { margin: 0; border-radius: var(--radius-md, 12px); overflow: hidden; aspect-ratio: 4 / 3; border: 1px solid var(--c-border, #E7E0D8); }
  .esp-foto--main { grid-column: 1 / -1; aspect-ratio: 16 / 9; }
  .esp-foto img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── Datos del espacio ── */
  .esp-datos { background: #fff; border: 1px solid var(--c-border, #E7E0D8); border-radius: var(--radius-md, 12px); padding: 1.6rem 1.75rem; margin-bottom: 2.5rem; }
  .esp-datos__head { display: flex; align-items: center; gap: 0.85rem; flex-wrap: wrap; margin-bottom: 1.25rem; padding-bottom: 1rem; border-bottom: 1px solid var(--c-border, #E7E0D8); }
  .esp-datos__title { font-size: 1.4rem; font-weight: 800; color: var(--c-text, #1C1917); line-height: 1.2; }
  .esp-datos__badge { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--c-secondary, #8B6F4E); background: var(--c-bg-alt, #F7F4F0); border: 1px solid var(--c-border, #E7E0D8); border-radius: 999px; padding: 0.3rem 0.75rem; }
  .esp-datos__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.25rem; }
  .esp-dato { display: flex; flex-direction: column; gap: 0.2rem; }
  .esp-dato__k { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: var(--c-text-muted, #78716C); }
  .esp-dato__v { font-size: 0.92rem; font-weight: 700; color: var(--c-text, #1C1917); }
  .esp-datos__tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.4rem; }
  .esp-tag { font-size: 0.7rem; font-weight: 600; color: var(--c-secondary, #8B6F4E); background: var(--c-bg-alt, #F7F4F0); border: 1px solid var(--c-border, #E7E0D8); border-radius: 999px; padding: 0.25rem 0.7rem; }
  .esp-datos__cta { display: inline-flex; align-items: center; justify-content: center; background: var(--c-primary, #2C5530); color: #fff; padding: 0.85rem 1.5rem; border-radius: 8px; font-size: 0.95rem; font-weight: 700; text-decoration: none; transition: background 0.18s ease; }
  .esp-datos__cta:hover { background: var(--c-primary-light, #3D7A45); }
  .esp-datos__nota { font-size: 0.78rem; color: var(--c-text-muted, #78716C); line-height: 1.5; margin-top: 0.85rem; }
