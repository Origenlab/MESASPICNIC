---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import FaqSection from '../../components/FaqSection.astro';
import CtaBarFinal from '../../components/CtaBarFinal.astro';
import WaBubble from '../../components/WaBubble.astro';
---

<BaseLayout
  title="Mesas para Fiestas Temáticas y XV Años en CDMX | MESPIC"
  description="Bancas de madera para fiestas mexicanas, XV años, garden party y brunch. La madera se adapta a tu concepto. CDMX y Edomex."
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios", href: "/servicios/" },
    { label: "Fiestas Temáticas" }
  ]} />
</Fragment>

<Hero
  badge="Fiestas con concepto"
  title="Mobiliario de Madera para Fiestas con Temática"
  description="La madera no tiene estilo propio — adopta el tuyo. Desde una fiesta mexicana con papel picado hasta un brunch provenzal con lavanda. Tú pones el concepto, nosotros ponemos las bancas."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="Las fiestas temáticas necesitan mobiliario que no compita con la decoración. La madera de pino natural funciona como lienzo en blanco: absorbe el color de una fiesta mexicana con cempasúchil, el minimalismo de un garden party escandinavo o la opulencia de unos XV años con centro de mesa alto. No necesitas forrar las bancas — la madera ya aporta textura y calidez."
  seoParagraph2="Hemos montado fiestas temáticas para 20 hasta 200 personas en jardines, haciendas, terrazas y salones con área exterior en CDMX y Edomex. Cada temática tiene su propia lógica de distribución: una fiesta mexicana no se monta igual que un brunch — y nosotros sabemos la diferencia porque lo hacemos cada semana."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<section class="section" id="montajes">
  <SectionHeader
    badge="Nuestras temáticas"
    tag="h2"
    title="La Madera se Adapta a tu Concepto"
    paragraph1="No importa si es una fiesta mexicana, un garden party, unos XV años o un brunch dominical. La madera natural complementa cualquier paleta de colores y estilo decorativo."
    paragraph2="Estos son montajes de referencia. Explora el mobiliario recomendado en la barra lateral."
  />
  <ProductGallery
    images={[
      { src: "/img/cumpleanos-lujo-mesas-picnic-decoracion-01.avif", alt: "Fiesta mexicana con papel picado y cempasúchil sobre bancas de madera" },
      { src: "/img/cumpleanos-lujo-mesas-picnic-decoracion-02.avif", alt: "XV años con centros de mesa altos y decoración rosa sobre pino" },
      { src: "/img/cumpleanos-lujo-mesas-picnic-decoracion-03.avif", alt: "Garden party con flores blancas y mantelería de lino" },
      { src: "/img/cumpleanos-lujo-mesas-picnic-decoracion-04.avif", alt: "Brunch dominical con fruta y pasteles sobre madera natural" },
      { src: "/img/mesas-picnic-decoracion-evento-al-aire-libre-05.avif", alt: "Fiesta tropical con hojas de palma y piñas decorativas" },
      { src: "/img/mesas-picnic-decoracion-evento-al-aire-libre-06.avif", alt: "Vendimia con uvas, quesos y copas de vino sobre banca rústica" },
      { src: "/img/mesas-picnic-decoracion-evento-al-aire-libre-07.avif", alt: "Fiesta vintage con vajilla antigua y flores secas" },
      { src: "/img/mesas-picnic-decoracion-evento-al-aire-libre-08.avif", alt: "Celebración de día de muertos con cempasúchil y velas" },
      { src: "/img/mesas-picnic-madera-renta-evento-cdmx-15.avif", alt: "Feria gastronómica con estaciones de comida sobre bancas" },
    ]}
    recommended={[
      { title: "Mesa Estándar", description: "Versátil, 6-8 personas", href: "/catalogo/mesa-picnic-estandar/" },
      { title: "Mesa Grande", description: "Mesa central, 10-12 personas", href: "/catalogo/mesa-picnic-grande/" },
      { title: "Mesa Rústica", description: "Acabado campestre", href: "/catalogo/mesa-picnic-rustica/" },
      { title: "Set Completo", description: "Con decoración incluida", href: "/catalogo/set-picnic-completo/" },
      { title: "Paquete Estándar", description: "6 bancas + sombrillas", href: "/paquetes/estandar/" },
    ]}
    sidebarTitle="Mobiliario para fiestas temáticas"
  />
</section>

<section class="section section-alt" id="tematicas">
  <SectionHeader
    badge="Nuestras temáticas"
    tag="h2"
    title="Temáticas que Montamos Cada Semana"
    paragraph1="Estas no son ideas sacadas de Pinterest — son fiestas reales que montamos regularmente. Conocemos la logística de cada una porque las hacemos una y otra vez."
    paragraph2="Si tu temática no está aquí, dinos cuál es y te decimos cómo la resolvemos. La madera se adapta a todo."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Fiesta Mexicana" description="Papel picado, cempasúchil, cazuelas de barro, manteles de colores. La madera de pino contrasta con los colores vivos de una fiesta mexicana sin competir. Funciona para Grito, Día de Muertos y fiestas patrias." image="/img/mesa-picnic-fiesta-tematica-20.avif" href="/catalogo/mesa-picnic-rustica/" btnLabel="Mesa rústica" />
      <ServiceCard title="XV Años" description="Centros de mesa altos, manteles en rosa o dorado, sillas decoradas y un montaje que se siente especial. Las bancas grandes funcionan como mesa de honor para la quinceañera y su chambelanes." image="/img/mesa-picnic-fiesta-tematica-20.avif" href="/catalogo/mesa-picnic-grande/" btnLabel="Mesa grande" />
      <ServiceCard title="Garden Party" description="Flores blancas, mantelería de lino, vajilla clara y mucha vegetación. La madera al natural complementa la estética de jardín inglés sin agregar ruido visual. El estilo que mejor funciona en jardines con pasto." image="/img/mesa-picnic-fiesta-tematica-20.avif" href="/catalogo/mesa-picnic-estandar/" btnLabel="Mesa estándar" />
      <ServiceCard title="Brunch Temático" description="Fruta, pasteles, café y champagne sobre madera de pino a media mañana. El brunch al aire libre es el formato que más está creciendo en CDMX. Funciona en terrazas, jardines y rooftops con vista." image="/img/mesa-picnic-fiesta-tematica-20.avif" href="/catalogo/set-picnic-completo/" btnLabel="Set completo" />
    </div>
  </div>
</section>

<section class="section" id="por-que-madera">
  <SectionHeader
    badge="Por qué elegirnos"
    tag="h2"
    title="Por Qué la Madera Funciona para Cualquier Temática"
    paragraph1="Un mantel rojo convierte la banca en fiesta mexicana. Uno blanco la convierte en garden party. Uno dorado en XV años. La madera no tiene identidad propia — toma la de tu decoración."
    paragraph2="Esa neutralidad es lo que la hace más versátil que cualquier otro tipo de mobiliario para fiestas temáticas."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Base Neutra" description="El tono natural del pino no compite con ningún color. Acepta paletas vivas (mexicana, tropical), neutras (garden, provenzal) y dramáticas (XV años, halloween) con la misma naturalidad." />
      <FeatureCard title="Textura que Aporta" description="La veta de la madera agrega profundidad visual que las mesas de plástico no tienen. En fotos se nota la diferencia: la madera se ve real, cálida, no genérica." />
      <FeatureCard title="Sin Forrar ni Ocultar" description="No necesitas fundas, forros ni telas para cubrir el mobiliario. La madera ya aporta estética. Eso ahorra tiempo de montaje y dinero en textiles." />
      <FeatureCard title="Resistencia para Todo" description="Cazuelas de barro caliente, hielo seco para centros de mesa, velas encendidas, cubetas de hielo con champagne. La madera tratada lo aguanta todo sin mancharse ni dañarse." />
    </div>
  </div>
</section>

<section class="section section-alt" id="incluye">
  <SectionHeader
    badge="Servicio incluido"
    tag="h2"
    title="Qué Incluye"
    paragraph1="Entrega, montaje y recolección. El servicio es el mismo para cualquier temática — lo que cambia es la distribución que hacemos según tu concepto."
    paragraph2="Coordinamos con tu decorador o empresa de eventos para que el montaje del mobiliario encaje con la producción completa."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Asesoría de Distribución" description="No solo ponemos bancas — las distribuimos según la temática. Una fiesta mexicana se monta en herradura. Un brunch en mesas largas. Un XV años con mesa de honor separada." />
      <FeatureCard title="Adaptación al Espacio" description="Nos adaptamos a jardines, terrazas, haciendas, salones con patio, estacionamientos decorados y cualquier espacio que tu temática requiera." />
      <FeatureCard title="Combinación de Modelos" description="Puedes mezclar estándar, grandes y rústicas en el mismo evento. Mesa grande como centro, estándar para invitados, rústica para la barra de bebidas." />
      <FeatureCard title="Montaje con Anticipación" description="Llegamos con el tiempo que tu decorador necesite. Si la producción requiere 5 horas de montaje, nosotros llegamos primero para que el mobiliario esté listo cuando empiece la decoración." />
    </div>
  </div>
</section>

<section class="section" id="referencias">
  <SectionHeader
    badge="Guía de cantidades"
    tag="h2"
    title="Referencia de Cantidad por Evento"
    paragraph1="Cada temática tiene su propia distribución. Aquí tienes referencias rápidas para los formatos más comunes."
    paragraph2="Mándanos tu temática, número de invitados y medidas del espacio. Te regresamos un plano con la distribución sugerida."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Fiesta Mexicana 50 Personas" description="7-8 bancas estándar en distribución herradura o filas enfrentadas. Mesa grande para la comida y 1 extra como barra de bebidas. Total: 9-10 bancas." />
      <FeatureCard title="XV Años 80 Personas" description="11-14 bancas estándar para invitados + 1 mesa grande de honor. Si hay pista de baile, dejar 4×4 m libres en el centro. Total: 12-15 bancas." />
      <FeatureCard title="Garden Party 30 Personas" description="4-5 bancas estándar distribuidas con espacio entre ellas. El garden party necesita aire — no aprietes las bancas. Espacio: 60+ m²." />
      <FeatureCard title="Brunch 20 Personas" description="3 bancas estándar + 1 grande como mesa de buffet. Distribución abierta. Si es en terraza, agrega mesa premium con sombrilla. Total: 4-5 bancas." />
    </div>
  </div>
</section>


<!-- Proceso paso a paso — Template L3: proceso-cards -->
<section class="section section" id="proceso">
  <SectionHeader
    badge="Cómo trabajamos"
    tag="h2"
    title="De Tu Concepto al Montaje Final"
    paragraph1="La madera no compite con tu decoración — es la base sobre la que se construye el concepto visual. Por eso dedicamos tiempo real a entender tu temática antes de proponer cualquier pieza de mobiliario."
    paragraph2="Trabajamos con decoradoras y coordinadoras de eventos en CDMX que ya conocen nuestro mobiliario. Si tienes equipo de decoración contratado, los conectamos directamente para que coordinen sin intermediarios."
  />
  <div class="container">
    <div class="proceso-cards">
      <div class="paso-card">
        <span class="paso-card__num">01</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Cuéntanos tu concepto y paleta de colores</h3>
          <p class="paso-card__text">XV años, garden party, mexicana, vintage, minimalista, tropical, boho — dinos el estilo y la paleta de colores que tienen en mente. Cuanta más información nos des sobre la inspiración visual del evento, más precisa será nuestra recomendación de modelo y acabado.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">02</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Asesoría de mobiliario sin costo</h3>
          <p class="paso-card__text">Antes de cotizar, te decimos qué modelo funciona mejor para tu temática específica. No es lo mismo la mesa rústica para un evento mexicano que la mesa estándar barnizada para un garden party formal. Te orientamos sin compromiso para que elijas con criterio.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">03</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Cotización clara y fecha bloqueada</h3>
          <p class="paso-card__text">Propuesta detallada con piezas, costo de traslado y condiciones del servicio. Con el anticipo nadie más puede reservar ese inventario para tu fecha — tu evento queda protegido. Si necesitas factura o comprobante para la sede del evento, lo gestionamos.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">04</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Medidas exactas para tu decoradora</h3>
          <p class="paso-card__text">Enviamos las dimensiones de cada pieza con suficiente anticipación para que tu decoradora o coordinadora planifique centros de mesa, manteles y accesorios al milímetro. También coordinamos el horario de entrega para llegar antes del equipo de decoración y no pisarnos.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">05</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Tu espacio, listo para que empiece la magia</h3>
          <p class="paso-card__text">El día del evento llegamos primero. Colocamos cada pieza en su posición exacta y dejamos el espacio listo para que tu equipo de decoración trabaje directamente sobre el mobiliario. Al terminar la fiesta, recogemos todo sin interrumpir la celebración ni el desmontaje de decoración.</p>
        </div>
      </div>
    </div>
  </div>
</section>
<section class="section section-alt" id="faq">
  <SectionHeader
    badge="Preguntas frecuentes"
    tag="h2"
    title="Preguntas sobre Fiestas Temáticas"
    paragraph1="Dudas de personas que están organizando fiestas con concepto específico y quieren saber si el mobiliario de madera funciona para su idea."
    paragraph2="La respuesta corta: sí funciona. La larga está en cada pregunta."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿La madera funciona para una fiesta mexicana?", answer: "Perfecto. El pino natural contrasta con los colores vivos del papel picado, las cazuelas de barro y el cempasúchil. Es uno de los montajes que mejor se ven en fotos." },
      { question: "¿Puedo poner cosas calientes sobre la madera?", answer: "Sí. Cazuelas de barro, ollas calientes y platos de servicio se pueden poner directamente. El barniz protege la superficie. Recomendamos usar individuales de tela debajo de ollas muy calientes por precaución." },
      { question: "¿Las bancas funcionan para XV años?", answer: "Sí. Hemos montado XV años con mesas de honor de 2.40 m para la quinceañera y estándar para invitados. Acepta manteles, centros de mesa altos y decoración formal sin problema." },
      { question: "¿Tienen bancas de colores?", answer: "No, todas son de pino natural barnizado. Pero eso es una ventaja: un mantel rojo las hace mexicanas, uno blanco las hace garden, uno dorado las hace XV años. Los colores los pone tu decoración, no el mobiliario." },
      { question: "¿Cuánto tiempo antes debo reservar para diciembre?", answer: "Diciembre es el mes más demandado por posadas, cierres de año y fiestas temáticas. Reserva en octubre para asegurar tu fecha. Noviembre ya suele estar complicado." },
      { question: "¿Pueden montar en un estacionamiento decorado?", answer: "Sí. Hemos montado en estacionamientos de oficinas convertidos en venue con carpas, iluminación y decoración. Solo necesitamos piso plano y acceso vehicular." }
    ]}
  />
</section>

<CtaBarFinal
  headline="¿Tienes un concepto en mente?"
  subtext="Dinos tu temática y te decimos cómo la montamos."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero cotizar mesas para una fiesta temática."
  cotizarHref="/cotizar/"
/>

<WaBubble whatsapp="5564328954" message="Hola, quiero cotizar mesas para una fiesta temática." />

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "Service",
    "name": "Renta de Mesas para Fiestas Temáticas y XV Años",
    "provider": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-3128-1706" },
    "areaServed": [{ "@type": "City", "name": "Ciudad de México" }, { "@type": "State", "name": "Estado de México" }],
    "description": "Renta de bancas de madera para fiestas temáticas, XV años, garden party, brunch y celebraciones con concepto en CDMX y Edomex."
  })} />
</Fragment>

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     Template L3 — proceso-cards
     Layout: 3 tarjetas fila 1 + 2 tarjetas fila 2
     ═══════════════════════════════════════════ */
  .proceso-cards {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }
  .paso-card:nth-child(1),
  .paso-card:nth-child(2),
  .paso-card:nth-child(3) { grid-column: span 2; }
  .paso-card:nth-child(4),
  .paso-card:nth-child(5) { grid-column: span 3; }
  .paso-card {
    background: #fff;
    border: 1px solid var(--c-border, #E7E0D8);
    border-top: 3px solid var(--c-accent, #C8956C);
    border-radius: var(--radius-md, 12px);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }
  .paso-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(44, 85, 48, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }
  .paso-card__num {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--c-primary, #2C5530);
    opacity: 0.12;
    line-height: 1;
    letter-spacing: -0.03em;
    align-self: flex-start;
  }
  .paso-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }
  .paso-card__title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--c-text, #1C1917);
    line-height: 1.3;
    margin: 0;
  }
  .paso-card__text {
    font-size: 0.875rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.7;
    margin: 0;
  }
  @media (max-width: 1024px) {
    .proceso-cards { grid-template-columns: repeat(2, 1fr); }
    .paso-card:nth-child(1),.paso-card:nth-child(2),
    .paso-card:nth-child(3),.paso-card:nth-child(4),
    .paso-card:nth-child(5) { grid-column: span 1; }
  }
  @media (max-width: 640px) {
    .proceso-cards { grid-template-columns: 1fr; }
  }

  :global(.hero) { padding-top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2.5rem + 3rem); }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }
</style>
