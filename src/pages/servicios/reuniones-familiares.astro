---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import FaqSection from '../../components/FaqSection.astro';
import NextStep from '../../components/NextStep.astro';
import CtaBarFinal from '../../components/CtaBarFinal.astro';
---

<BaseLayout
  title="Mesas para Reuniones Familiares al Aire Libre | MESPIC — CDMX"
  description="Bancas de madera para reuniones familiares: cumpleaños, Día de las Madres y posadas. Donde caben abuelos, papás y nietos juntos."
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios", href: "/servicios/" },
    { label: "Reuniones Familiares" }
  ]} />
</Fragment>

<Hero
  badge="Para familias"
  title="Bancas de Madera donde Cabe Toda la Familia"
  description="Hay mesas de restaurante donde alguien siempre queda en la esquina. En una banca de 2.40 metros, los abuelos, los papás, los primos y los niños comen juntos sin que nadie sobre."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="Las reuniones familiares tienen algo que los eventos corporativos y las bodas no: nadie quiere estar sentado lejos de los demás. Una banca de madera de 2.40 metros sienta a 10 personas cara a cara. Los abuelos platican con los nietos, los primos se pasan los platos sin levantarse, y nadie necesita gritar de un extremo al otro de la mesa. Esa es la diferencia entre un comedor extensible y una banca al aire libre."
  seoParagraph2="Montamos reuniones familiares en patios, jardines residenciales, parques con permiso, terrazas de casa y hasta en estacionamientos que se convierten en comedor para la posada de diciembre. No hace falta un venue — tu espacio funciona. Cubrimos toda la Ciudad de México y municipios del Estado de México como Naucalpan, Satélite, Tlalnepantla y Coacalco."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<section class="section" id="montajes">
  <SectionHeader
    badge="Por qué elegirnos"
    tag="h2"
    title="Reuniones que se Sienten como Antes"
    paragraph1="Cuando éramos niños, las reuniones familiares eran en el patio de los abuelos con una mesa larga donde cabían todos. Eso se perdió con los comedores de departamento. Las bancas lo devuelven."
    paragraph2="Montajes para 10 hasta 80 personas en espacios familiares. Explora el mobiliario en la barra lateral."
  />
  <ProductGallery
    images={[
      { src: "/img/reunion-familiar-mesas-picnic-coyoacan-01.avif", alt: "Familia completa comiendo al aire libre en bancas de madera" },
      { src: "/img/reunion-familiar-mesas-picnic-coyoacan-02.avif", alt: "Abuelos y nietos en banca grande para Día de las Madres" },
      { src: "/img/reunion-familiar-mesas-picnic-coyoacan-03.avif", alt: "Posada familiar en patio con 6 bancas decoradas" },
      { src: "/img/reunion-familiar-mesas-picnic-coyoacan-04.avif", alt: "Cumpleaños de adulto al aire libre con pastel sobre madera" },
      { src: "/img/reunion-familiar-mesas-picnic-coyoacan-05.avif", alt: "Reunión dominical con tacos y cerveza sobre bancas de pino" },
      { src: "/img/mesa-picnic-reunion-familiar-comida.avif", alt: "Niños jugando entre las bancas después de comer" },
      { src: "/img/mesa-picnic-reunion-familiar-mexicana.avif", alt: "Familia grande de 40 personas en 6 bancas en jardín" },
      { src: "/img/gastronomia-mexicana-picnic-gourmet-ingredientes-01.avif", alt: "Aniversario de bodas de oro en banca decorada con flores" },
      { src: "/img/gastronomia-mexicana-picnic-gourmet-ingredientes-02.avif", alt: "Desayuno familiar del domingo en terraza con bancas" },
    ]}
    recommended={[
      { title: "Mesa Grande", description: "10-12 personas, toda la familia junta", href: "/catalogo/mesa-picnic-grande/" },
      { title: "Mesa Estándar", description: "6-8 personas por banca", href: "/catalogo/mesa-picnic-estandar/" },
      { title: "Mesa Infantil", description: "Mesa de niños separada", href: "/catalogo/mesa-picnic-infantil/" },
      { title: "Paquete Básico", description: "4 bancas, 24 personas", href: "/paquetes/basico/" },
      { title: "Paquete Estándar", description: "6 bancas, 36 personas", href: "/paquetes/estandar/" },
    ]}
    sidebarTitle="Mobiliario para familias"
  />
</section>

<section class="section section-alt" id="ocasiones">
  <SectionHeader
    badge="Por qué elegirnos"
    tag="h2"
    title="Cada Familia Tiene sus Fechas"
    paragraph1="No necesitas un motivo elaborado para juntar a la familia. Pero cuando lo hay, el mobiliario de madera al aire libre convierte un patio normal en algo que se siente especial — sin la producción de un salón de fiestas."
    paragraph2="Estas son las ocasiones más comunes. Y sí, también vale el clásico 'es que mi mamá quiere hacer una comida'."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Cumpleaños de Adulto" description="Los 30, 40, 50 o 60 del papá, la mamá o los abuelos. 20-50 personas con comida casera, pastel y brindis. Las bancas de madera le dan otro nivel al patio de siempre." image="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" href="/catalogo/mesa-picnic-estandar/" btnLabel="Mesa estándar" />
      <ServiceCard title="Día de las Madres" description="La comida del 10 de mayo con toda la familia. Cada banca grande sienta a una rama de la familia: abuelos con sus hijos y nietos. Si la familia es grande, 4-6 bancas resuelven todo." image="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" href="/catalogo/mesa-picnic-grande/" btnLabel="Mesa grande" />
      <ServiceCard title="Posada Familiar" description="Diciembre con tamales, ponche, piñata y villancicos. Las bancas en el patio con series de luces se sienten como las posadas de antes. Reserva en octubre — diciembre se satura rápido." image="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" href="/paquetes/estandar/" btnLabel="Paquete estándar" />
      <ServiceCard title="Domingos y Fin de Semana" description="No hay fecha especial — solo la familia que quiere comer junta. Tacos, carne asada, arroz y frijoles sobre madera de pino en el jardín. Así de simple y así de bueno." image="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" href="/paquetes/basico/" btnLabel="Paquete básico" />
    </div>
  </div>
</section>

<section class="section" id="por-que">
  <SectionHeader
    badge="Por qué elegirnos"
    tag="h2"
    title="Por Qué la Banca Funciona Mejor que el Comedor"
    paragraph1="Un comedor extensible sienta a 8. Una banca grande sienta a 12. Dos bancas sientan a 20. No hay comedor de casa que compita con eso — y el patio tiene más aire que el comedor."
    paragraph2="La banca no es elegante ni pretenciosa. Es práctica, resistente y cómoda. Exactamente lo que necesita una reunión familiar."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Todos en una Mesa" description="La banca grande de 2.40 m sienta a 10-12 personas cara a cara. Los abuelos, los papás, los hijos y los primos. Sin mesas separadas, sin que alguien coma en el sillón." />
      <FeatureCard title="Los Niños Tienen su Espacio" description="Banca infantil separada para los niños. Comen, juegan y se ensucian en su propia mesa — sin estorbar a los adultos y sin que los adultos estén cuidando que no tiren algo." />
      <FeatureCard title="Aguanta Comida Real" description="Cazuelas de mole, ollas de tamales, charolas de carnitas, cubetas de cerveza con hielo. La madera tratada soporta el peso y el calor. No se mancha, no se tambalea." />
      <FeatureCard title="Se Monta en tu Patio" description="No necesitas rentar un salón. Tu patio, tu jardín, tu estacionamiento o la terraza del edificio. Montamos en cualquier espacio plano con acceso vehicular." />
    </div>
  </div>
</section>

<section class="section section-alt" id="configuraciones">
  <SectionHeader
    badge="Guía de cantidades"
    tag="h2"
    title="¿Cuántas Bancas para tu Familia?"
    paragraph1="Depende de cuántos sean — y de si tu familia es de las que dice '20 personas' y llegan 35. Aquí tienes las referencias."
    paragraph2="Consejo: siempre pide 1-2 bancas extra. En las familias mexicanas, siempre llega alguien que no confirmó."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Familia Chica — 15 Personas" description="2 bancas estándar para adultos + 1 infantil para niños. Cabe en un patio de 30 m². El formato más común para domingos y cumpleaños pequeños." />
      <FeatureCard title="Familia Mediana — 30 Personas" description="4 bancas estándar + 1 infantil. Patio o jardín de 50+ m². Para Día de las Madres, cumpleaños de los papás y reuniones de fin de año." />
      <FeatureCard title="Familia Grande — 50 Personas" description="7-8 bancas estándar + 2 infantiles. Necesitas un jardín de 80+ m². Para posadas, aniversarios y las reuniones donde se junta toda la familia extendida." />
      <FeatureCard title="Familia Enorme — 80+ Personas" description="11-14 bancas estándar + 2-3 infantiles. Esto ya es un evento. Jardín de 120+ m² o parque con permiso. Reserva con 2 semanas mínimo." />
    </div>
  </div>
</section>


<!-- Proceso paso a paso — Template L3: proceso-cards -->
<section class="section section-alt" id="proceso">
  <SectionHeader
    badge="Cómo trabajamos"
    tag="h2"
    title="Así de Fácil Es Rentarnos para tu Reunión"
    paragraph1="Sin formularios en línea, sin visitas de diagnóstico, sin correos de confirmación interminables. Un mensaje de WhatsApp es suficiente para poner en marcha todo lo que sigue — de principio a fin."
    paragraph2="Nueve de cada diez familias que nos escriben confirman su reserva el mismo día. El proceso más común: WhatsApp a las 10 am, bancas separadas antes del mediodía."
  />
  <div class="container">
    <div class="proceso-cards">
      <div class="paso-card">
        <span class="paso-card__num">01</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Un mensaje con lo básico es suficiente</h3>
          <p class="paso-card__text">Fecha, número aproximado de personas y tipo de espacio — patio de casa, jardín, terraza, parque o salón. No necesitas tener todo definido: con datos aproximados ya podemos darte un estimado de bancas y un rango de precio real en minutos.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">02</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Precio transparente, sin letra chica</h3>
          <p class="paso-card__text">Cantidad de bancas recomendada, costo de traslado incluido y cualquier extra que quieras agregar. Sin cargos ocultos ni sorpresas al final. Si el espacio es pequeño, te decimos cuántas bancas caben realmente — nunca te ofrecemos más de lo que tu espacio soporta.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">03</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Reserva en dos pasos, sin trámites</h3>
          <p class="paso-card__text">Un anticipo separa las bancas para tu fecha. El saldo lo cierras antes del evento o el mismo día. Sin contratos de varias páginas, sin formularios extensos, sin validaciones de semanas. El proceso es tan simple como debe ser para una reunión familiar.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">04</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Verificamos el acceso el día anterior</h3>
          <p class="paso-card__text">Te llamamos o escribimos un día antes para confirmar dirección, horario de entrega y el acceso para nuestra camioneta. Cochera angosta, escalón en la entrada, reja con código o condominio con permisos especiales — nos lo dices y llegamos preparados para no perder tiempo.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">05</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Llegan, ponen las bancas y se van</h3>
          <p class="paso-card__text">El día de la reunión colocamos el mobiliario donde lo necesites. Tú te concentras en recibir a la familia, nosotros nos hacemos cargo de lo demás. Al terminar regresamos a recoger todo. No cargas, no doblas, no buscas dónde apilar nada — solo disfrutas a los tuyos.</p>
        </div>
      </div>
    </div>
  </div>
</section>
<section class="section" id="faq">
  <SectionHeader
    badge="Preguntas frecuentes"
    tag="h2"
    title="Preguntas de Familias"
    paragraph1="Las dudas que nos mandan por WhatsApp antes de una reunión familiar. Sin formalidades — como habla la gente normal."
    paragraph2="Si tienes otra duda, escríbenos. Respondemos como si fueras de la familia."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿Caben en el patio de mi casa?", answer: "Cada banca estándar ocupa 1.80 × 1.50 m. Si tu patio tiene 4 × 6 m, caben 2 bancas cómodamente con espacio de circulación. Mándanos las medidas de tu patio por WhatsApp y te decimos exactamente cuántas caben." },
      { question: "¿Puedo poner cazuelas calientes directo sobre la madera?", answer: "Sí. La madera barnizada resiste calor moderado. Para ollas muy calientes recomendamos poner un trapo debajo. Pero la realidad es que en las reuniones familiares todo va directo a la mesa y no pasa nada." },
      { question: "¿Los abuelos se pueden sentar cómodos?", answer: "La banca integrada tiene asiento a 45 cm del piso, similar a una silla de comedor. Si algún familiar tiene movilidad reducida, puede usar su propia silla al lado de la banca." },
      { question: "¿Llegan a tiempo para la comida?", answer: "Entregamos con 2-3 horas de anticipación. Si la comida es a las 3 pm, las bancas están listas a la 1 pm. Llegamos puntuales — sabemos que la familia no espera." },
      { question: "¿Cuánto cuesta para 30 personas?", answer: "Depende de la combinación de bancas. Cotizamos por WhatsApp en minutos. Mándanos cuántos adultos, cuántos niños y dónde es — te damos precio el mismo día." },
      { question: "¿En diciembre tienen disponibilidad?", answer: "Diciembre es el mes más demandado. Reserva tu fecha de posada en octubre o primera semana de noviembre. Las últimas semanas del año se saturan rápido." }
    ]}
  />
</section>


<!-- Siguiente paso: Ver catálogo -->
<NextStep
  titulo="¿Ya encontraste tu servicio?"
  subtitulo="Explora el catálogo completo con 20 modelos de mobiliario. Hay una opción ideal para tu evento."
  href="/catalogo/"
  btnLabel="Ver catálogo completo →"
  step={1}
  secondBtn={{ label: 'Ver paquetes', href: '/paquetes/' }}
/>

<CtaBarFinal
  headline="¿Juntando a la familia?"
  subtext="Cotiza las bancas para tu reunión. Te respondemos hoy."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero cotizar mesas para una reunión familiar."
  cotizarHref="/cotizar/"
/>


<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "Service",
    "name": "Renta de Mesas para Reuniones Familiares",
    "provider": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-3128-1706" },
    "areaServed": [{ "@type": "City", "name": "Ciudad de México" }, { "@type": "State", "name": "Estado de México" }],
    "description": "Renta de bancas de madera para cumpleaños, Día de las Madres, posadas y reuniones familiares al aire libre en CDMX y Edomex."
  })} />
</Fragment>

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     Template L3 — proceso-cards
     Layout: 3 tarjetas fila 1 + 2 tarjetas fila 2
     ═══════════════════════════════════════════ */
  .proceso-cards {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }
  .paso-card:nth-child(1),
  .paso-card:nth-child(2),
  .paso-card:nth-child(3) { grid-column: span 2; }
  .paso-card:nth-child(4),
  .paso-card:nth-child(5) { grid-column: span 3; }
  .paso-card {
    background: #fff;
    border: 1px solid var(--c-border, #E7E0D8);
    border-top: 3px solid var(--c-accent, #C8956C);
    border-radius: var(--radius-md, 12px);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }
  .paso-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(44, 85, 48, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }
  .paso-card__num {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--c-primary, #2C5530);
    opacity: 0.12;
    line-height: 1;
    letter-spacing: -0.03em;
    align-self: flex-start;
  }
  .paso-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }
  .paso-card__title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--c-text, #1C1917);
    line-height: 1.3;
    margin: 0;
  }
  .paso-card__text {
    font-size: 0.875rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.7;
    margin: 0;
  }
  @media (max-width: 1024px) {
    .proceso-cards { grid-template-columns: repeat(2, 1fr); }
    .paso-card:nth-child(1),.paso-card:nth-child(2),
    .paso-card:nth-child(3),.paso-card:nth-child(4),
    .paso-card:nth-child(5) { grid-column: span 1; }
  }
  @media (max-width: 640px) {
    .proceso-cards { grid-template-columns: 1fr; }
  }

  :global(.hero) { padding-top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2.5rem + 3rem); }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }
</style>
