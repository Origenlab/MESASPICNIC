---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import FaqSection from '../../components/FaqSection.astro';
import CtaBarFinal from '../../components/CtaBarFinal.astro';
import WaBubble from '../../components/WaBubble.astro';
---

<BaseLayout
  title="Mesas Picnic para Fiestas Infantiles en CDMX | MESPIC"
  description="Bancas infantiles de madera para cumpleaños y baby showers. Lijadas sin astillas, altura adaptada para niños. Montaje en CDMX y Edomex."
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios", href: "/servicios/" },
    { label: "Fiestas Infantiles" }
  ]} />
</Fragment>

<Hero
  badge="Servicio infantil"
  title="Bancas de Madera para Fiestas Infantiles"
  description="Modelo infantil con altura adaptada para niños de 3 a 10 años. Madera lijada a grano fino, sin astillas ni bordes filosos. Para cumpleaños, baby showers y reuniones familiares."
  ctaPrimary={{ label: "Ver mesa infantil →", href: "/catalogo/mesa-picnic-infantil/" }}
  ctaSecondary={{ label: "Ver paquetes", href: "/paquetes/" }}
  seoParagraph1="Los niños pasan la fiesta entera sentados comiendo, pintando, jugando y abriendo regalos. Por eso nuestras bancas infantiles están lijadas a grano fino — sin astillas, sin bordes filosos, sin clavos expuestos. El modelo infantil mide 1.20 × 1.00 m con altura proporcionada para niños de 3 a 10 años. Caben 8 a 10 niños cómodamente."
  seoParagraph2="Hemos montado más de 150 fiestas infantiles en jardines, parques, salones con terraza y patios residenciales en la Ciudad de México y Estado de México. También combinamos bancas infantiles con estándar para eventos donde hay niños y adultos — los papás comen en las grandes mientras los niños tienen su propia zona."
/>

<section class="section" id="montajes">
  <SectionHeader
    tag="h2"
    title="Así se Ve en Fiestas de Niños"
    paragraph1="Cumpleaños, baby showers y reuniones familiares con bancas infantiles de madera. Jardines, parques y patios residenciales en CDMX y Edomex."
    paragraph2="Explora los modelos recomendados en la barra lateral."
  />
  <ProductGallery
    images={[
      { src: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif", alt: "Bancas infantiles decoradas con globos para cumpleaños" },
      { src: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif", alt: "Niños comiendo pastel sentados en bancas de madera" },
      { src: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif", alt: "Taller de arte infantil sobre mesa de pino" },
      { src: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif", alt: "Baby shower al aire libre con bancas decoradas" },
      { src: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif", alt: "Zona infantil con bancas pequeñas y zona adultos con estándar" },
      { src: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif", alt: "Niños abriendo regalos en bancas de madera en jardín" },
      { src: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif", alt: "Fiesta temática infantil con decoración sobre madera" },
      { src: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif", alt: "Tea party infantil con vajilla miniatura" },
      { src: "/img/mesa-picnic-fiesta-infantil-globos-colores.avif", alt: "Cumpleaños en parque con 4 bancas infantiles" },
    ]}
    recommended={[
      { title: "Mesa Infantil", description: "8-10 niños, 1.20 × 1.00 m", href: "/catalogo/mesa-picnic-infantil/" },
      { title: "Mesa Estándar", description: "6-8 adultos, zona papás", href: "/catalogo/mesa-picnic-estandar/" },
      { title: "Set Completo", description: "Con decoración incluida", href: "/catalogo/set-picnic-completo/" },
      { title: "Paquete Básico", description: "4 bancas, 24 personas", href: "/paquetes/basico/" },
    ]}
    sidebarTitle="Mobiliario para fiestas infantiles"
  />
</section>

<section class="section section-alt" id="tipos">
  <SectionHeader
    tag="h2"
    title="Tipos de Fiesta Infantil"
    paragraph1="Cada celebración tiene sus propias necesidades. No es lo mismo un cumpleaños de 15 niños en un jardín que un baby shower para 40 personas con zona de adultos y niños."
    paragraph2="Dinos qué tipo de fiesta estás organizando y te recomendamos la configuración ideal."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Cumpleaños Infantil" description="Bancas infantiles para la mesa del pastel, la comida y las actividades. De 8 a 30 niños. El formato más solicitado para patios y jardines residenciales." image="/img/mesa-picnic-fiesta-infantil-globos-colores.avif" href="/catalogo/mesa-picnic-infantil/" btnLabel="Mesa infantil" />
      <ServiceCard title="Baby Shower" description="Combinación de bancas estándar para adultos y mesa de exhibición para regalos. La madera complementa decoraciones en tonos pastel, florales y naturales." image="/img/mesa-picnic-fiesta-infantil-globos-colores.avif" href="/catalogo/mesa-picnic-estandar/" btnLabel="Mesa estándar" />
      <ServiceCard title="Fiesta con Zona Mixta" description="Bancas infantiles para niños + estándar para papás en el mismo espacio. Cada grupo tiene su zona y su tamaño de mobiliario. Para reuniones familiares de 30-60 personas." image="/img/mesa-picnic-fiesta-infantil-globos-colores.avif" href="/paquetes/basico/" btnLabel="Paquete básico" />
      <ServiceCard title="Taller o Actividad" description="Bancas como estaciones de actividad: pintura, manualidades, decoración de cupcakes. Cada banca agrupa 8-10 niños con espacio para materiales." image="/img/mesa-picnic-fiesta-infantil-globos-colores.avif" href="/catalogo/mesa-picnic-infantil/" btnLabel="Mesa para talleres" />
    </div>
  </div>
</section>

<section class="section" id="incluye">
  <SectionHeader
    tag="h2"
    title="Qué Incluye el Servicio Infantil"
    paragraph1="El mismo servicio que para bodas y corporativos: entrega, montaje y recolección. La diferencia es que las bancas infantiles están especialmente preparadas para niños."
    paragraph2="Todas las piezas se revisan antes de cada evento: sin astillas, sin clavos, sin bordes afilados."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Madera Lijada a Grano Fino" description="Cada pieza se lija antes del evento para eliminar cualquier aspereza. Los niños pueden tocar, sentarse y jugar sin riesgo de astillas." />
      <FeatureCard title="Altura Adaptada" description="El modelo infantil tiene asiento a 30 cm del piso y mesa a 50 cm. Proporcionado para niños de 3 a 10 años. Los pies tocan el suelo." />
      <FeatureCard title="Sin Bordes Filosos" description="Las esquinas están redondeadas y los cantos lijados. No hay clavos ni tornillos expuestos. Seguridad revisada pieza por pieza." />
      <FeatureCard title="Fácil de Limpiar" description="La superficie barnizada se limpia con un trapo húmedo. Resiste derrames de jugo, migajas de pastel y pintura de manualidades." />
    </div>
  </div>
</section>

<section class="section section-alt" id="datos">
  <SectionHeader
    tag="h2"
    title="Referencia de Cantidad"
    paragraph1="Estas son las combinaciones más comunes para fiestas infantiles. La cantidad final depende de si hay zona mixta (niños + adultos) o solo niños."
    paragraph2="Mándanos el número de niños y adultos y te calculamos la configuración exacta."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="10 Niños" description="1-2 bancas infantiles. Cumpleaños pequeño en patio o jardín. Si hay 10 adultos, agrega 2 bancas estándar." />
      <FeatureCard title="20 Niños" description="2-3 bancas infantiles. Cumpleaños mediano. Con 20 adultos: agrega 3 bancas estándar. Total: 5-6 bancas." />
      <FeatureCard title="30 Niños + Adultos" description="3-4 infantiles + 4-5 estándar. Fiesta familiar completa. Espacio recomendado: 80+ m²." />
      <FeatureCard title="Baby Shower 40 Personas" description="5-6 bancas estándar + 1 grande como mesa de regalos. Sin bancas infantiles (los niños van con los papás)." />
    </div>
  </div>
</section>

<section class="section" id="faq">
  <SectionHeader
    tag="h2"
    title="Preguntas sobre Fiestas Infantiles"
    paragraph1="Las dudas más comunes de papás y mamás que organizan cumpleaños y fiestas de niños."
    paragraph2="Si tienes una duda específica, escríbenos por WhatsApp."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿Las bancas son seguras para niños pequeños?", answer: "Sí. Todas las piezas se lijan a grano fino antes de cada evento. Sin astillas, sin clavos expuestos, sin bordes filosos. Las esquinas están redondeadas." },
      { question: "¿Qué edad es la adecuada para la mesa infantil?", answer: "De 3 a 10 años. El asiento está a 30 cm del piso y la mesa a 50 cm. Para niños menores de 3 años recomendamos sillas altas propias." },
      { question: "¿Puedo combinar infantiles con estándar?", answer: "Sí, es lo más común. Zona infantil con bancas pequeñas y zona de papás con estándar. Así cada grupo tiene su tamaño de mobiliario." },
      { question: "¿Resisten pintura y derrames?", answer: "Sí. La superficie barnizada se limpia con trapo húmedo. Resiste jugo, migajas, pintura lavable y pegamento. No se mancha la madera." },
      { question: "¿Cuántas bancas infantiles para 15 niños?", answer: "2 bancas infantiles (8-10 niños cada una). Si quieres más espacio, 3 bancas para que no estén apretados." },
      { question: "¿Entregan en salones de fiestas?", answer: "Sí, si el salón tiene área exterior o patio. También montamos en jardines residenciales, parques (con permiso) y terrazas." }
    ]}
  />
</section>

<CtaBarFinal
  headline="¿Organizando una fiesta infantil?"
  subtext="Cotiza bancas infantiles y estándar. Te respondemos hoy."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero cotizar mesas para una fiesta infantil."
  cotizarHref="/cotizar/"
/>

<WaBubble whatsapp="5564328954" message="Hola, quiero cotizar mesas para una fiesta infantil." />

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "Service",
    "name": "Renta de Mesas Picnic para Fiestas Infantiles",
    "provider": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-3128-1706" },
    "areaServed": [{ "@type": "City", "name": "Ciudad de México" }, { "@type": "State", "name": "Estado de México" }],
    "description": "Renta de bancas de madera infantiles para cumpleaños y fiestas de niños en CDMX. Lijadas sin astillas, altura adaptada."
  })} />
</Fragment>

</BaseLayout>

<style>
  :global(.hero) { padding-top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2.5rem + 3rem); }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }
</style>
