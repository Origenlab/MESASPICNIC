---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import NextStep from '../../components/NextStep.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
---

<BaseLayout
  title="Mesas para Conferencias al Aire Libre | MESPIC — CDMX"
  description="Renta de bancas de madera como estaciones de trabajo para conferencias, seminarios y talleres al aire libre. Espacio para laptop y libreta. CDMX y Edomex."
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[{ label: "Inicio", href: "/" }, { label: "Servicios", href: "/servicios/" }, { label: "Corporativos", href: "/servicios/eventos-corporativos/" }, { label: "Conferencias" }]} />
</Fragment>

<Hero
  badge="Conferencias"
  title="Bancas de Madera para Conferencias al Aire Libre"
  description="Estaciones de trabajo con espacio para laptop, libreta y vaso. Seminarios, talleres y mesas de discusión de hasta 120 personas con luz natural y ventilación."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="Las conferencias al aire libre cambian la dinámica: la luz natural reduce la fatiga, el espacio abierto mejora la concentración y el formato de banca agrupa a los asistentes en mesas de discusión en vez de filas de sillas. Cada banca funciona como estación de trabajo donde cada persona tiene superficie suficiente para laptop, libreta y vaso sin estorbarse."
  seoParagraph2="Hemos montado seminarios de hasta 120 personas en jardines corporativos, parques empresariales y terrazas de oficinas en CDMX. El formato funciona para talleres técnicos, workshops creativos, presentaciones de resultados y mesas redondas. Coordinamos con tu equipo de logística o agencia de eventos."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<section class="section" id="montajes">
  <SectionHeader
    badge="En detalle" tag="h2" title="Conferencias sobre Madera" paragraph1="Seminarios, talleres y mesas de discusión con bancas como estaciones de trabajo. Jardines corporativos y terrazas en CDMX." paragraph2="Cada banca agrupa 6-8 asistentes con espacio personal de trabajo." />
  <ProductGallery
    images={[
      { src: "/img/bancas-picnic-madera-disposicion-u-evento-01.avif", alt: "Conferencia al aire libre con bancas como estaciones de trabajo" },
      { src: "/img/bancas-picnic-madera-disposicion-u-evento-02.avif", alt: "Seminario en jardín corporativo con laptops sobre madera" },
      { src: "/img/bancas-picnic-madera-disposicion-u-evento-03.avif", alt: "Taller creativo al aire libre con 8 bancas" },
      { src: "/img/bancas-picnic-madera-disposicion-u-evento-04.avif", alt: "Mesa de discusión con moderador en banca central" },
      { src: "/img/bancas-picnic-madera-disposicion-u-evento-05.avif", alt: "Presentación de resultados en terraza con mobiliario de madera" },
      { src: "/img/bancas-picnic-madera-disposicion-u-evento-06.avif", alt: "Workshop con materiales de trabajo sobre bancas de pino" },
      { src: "/img/mesa-picnic-conferencia-empresarial-plantas.avif", alt: "Asistentes tomando notas en banca de madera" },
      { src: "/img/corp-desayuno-reunion-1.avif", alt: "Coffee break servido sobre mobiliario del seminario" },
      { src: "/img/corp-taller-1.avif", alt: "Vista general de conferencia para 80 personas" },
    ]}
    recommended={[
      { title: "Mesa Grande", description: "10-12 personas, mesas amplias", href: "/catalogo/mesa-picnic-grande/" },
      { title: "Mesa Estándar", description: "6-8 personas por mesa", href: "/catalogo/mesa-picnic-estandar/" },
      { title: "Mesa Premium", description: "Con sombrilla, eventos de día", href: "/catalogo/mesa-picnic-premium/" },
      { title: "Paquete Premium", description: "10 bancas, 60 personas", href: "/paquetes/premium/" },
    ]}
    sidebarTitle="Mobiliario para conferencias"
  />
</section>

<section class="section section-alt" id="formatos">
  <SectionHeader
    badge="Nuestras opciones" tag="h2" title="Formatos de Conferencia" paragraph1="Cada tipo de conferencia necesita una distribución diferente. Estas son las configuraciones más comunes que montamos." paragraph2="Si tu evento tiene un formato específico, nos adaptamos. Mándanos el programa y proponemos la distribución." />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Seminario con Ponente" description="Bancas en semicírculo o filas con vista al frente. Cada asistente tiene espacio para laptop. Funciona para 30-120 personas con presentación central." />
      <FeatureCard title="Mesas de Discusión" description="Bancas distribuidas como mesas redondas pero rectangulares. 6-8 personas por mesa con moderador. Ideal para workshops y lluvia de ideas." />
      <FeatureCard title="Taller Práctico" description="Bancas como estaciones de trabajo con materiales. Cada grupo trabaja en su proyecto. Espacio para herramientas, muestras o prototipos." />
      <FeatureCard title="Panel con Networking" description="Bancas al frente para panelistas y el resto para audiencia. Al terminar, las mismas bancas funcionan para el networking y café." />
    </div>
  </div>
</section>

<section class="section" id="incluye">
  <SectionHeader
    badge="Servicio incluido" tag="h2" title="Qué Incluye" paragraph1="Montaje profesional según el formato de tu conferencia. Coordinamos tiempos con tu equipo de logística o producción." paragraph2="Facturamos CFDI. Aceptamos orden de compra corporativa." />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Superficie para Laptops" description="Cada persona tiene 60-70 cm lineales de mesa. Espacio suficiente para laptop 15 pulgadas, libreta, vaso y celular sin estorbarse." />
      <FeatureCard title="Sombrillas Opcionales" description="Para conferencias de día al aire libre, agrega la mesa premium con sombrilla incluida. Protege del sol sin necesidad de carpas." />
      <FeatureCard title="Doble Uso: Conferencia + Comida" description="Las mismas bancas sirven para la conferencia y para la comida. Sin necesidad de cambiar el montaje ni contratar mobiliario extra." />
      <FeatureCard title="Montaje según Programa" description="Si tu conferencia tiene breaks, rotaciones o cambios de formato, redistribuimos las bancas entre sesiones. Sin costo extra." />
    </div>
  </div>
</section>

<section class="section section-alt" id="relacionados">
  <SectionHeader
    badge="También te puede interesar" tag="h2" title="Otros Servicios Corporativos" paragraph1="Si tu evento combina conferencia con comida o dinámicas, explora los otros formatos." paragraph2="Puedes combinar: conferencia por la mañana, team building al mediodía y comida de integración en la tarde." />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Team Building" description="Bancas agrupadas en estaciones de 6-8 personas para dinámicas de integración." image="/img/corp-teambuilding-1.avif" href="/servicios/eventos-corporativos/team-building/" btnLabel="Team building" />
      <ServiceCard title="Conferencias" description="Bancas como estaciones de trabajo con espacio para laptop y libreta." image="/img/mesa-picnic-conferencia-empresarial-plantas.avif" href="/servicios/eventos-corporativos/conferencias/" btnLabel="Conferencias" />
      <ServiceCard title="Comidas de Integración" description="Montaje para comidas de fin de año, celebraciones y convivios." image="/img/corp-almuerzo-1.avif" href="/servicios/eventos-corporativos/comidas/" btnLabel="Comidas empresariales" />
      <ServiceCard title="Activaciones de Marca" description="Mobiliario para lanzamientos, ferias internas y employer branding." image="/img/corp-lanzamiento-1.avif" href="/servicios/eventos-corporativos/activaciones/" btnLabel="Activaciones de marca" />
    </div>
  </div>
</section>

<section class="section" id="faq">
  <SectionHeader
    badge="Preguntas frecuentes" tag="h2" title="Preguntas sobre Conferencias" paragraph1="Dudas de organizadores de eventos corporativos y agencias de producción." paragraph2="Si necesitas cotización formal, escríbenos y te la enviamos por correo." />
  <FaqSection phone="55 6432 8954" whatsapp="5564328954" schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿Cabe una laptop en cada lugar?", answer: "Sí. Cada persona tiene 60-70 cm lineales. Cabe laptop de 15 pulgadas, libreta, vaso y celular. La mesa estándar acomoda 6 personas con laptop, la grande 10." },
      { question: "¿Funcionan para conferencias de todo el día?", answer: "Sí. Las bancas son cómodas para sesiones de 4-8 horas. Recomendamos breaks cada 90 minutos. Las mismas bancas sirven para el coffee break y la comida." },
      { question: "¿Tienen sombrillas para eventos al sol?", answer: "Sí, la mesa premium incluye sombrilla. Para conferencias de día al aire libre, recomendamos combinar mesas estándar con premium según la distribución." },
      { question: "¿Pueden montar tipo auditorio?", answer: "Sí, alineamos las bancas en filas con vista al frente. Para 80 personas en formato auditorio necesitas 11-14 bancas estándar." },
      { question: "¿Hay conexiones eléctricas?", answer: "No incluimos electricidad. Recomendamos coordinar con tu venue para extensiones o plantas de luz. Las bancas no tienen puertos eléctricos integrados." },
      { question: "¿Facturan?", answer: "Sí, emitimos CFDI. Aceptamos transferencia, tarjeta y orden de compra con pago a 15 días." }
    ]}
  />
</section>


<!-- Siguiente paso: Ver catálogo -->
<NextStep
  titulo="¿Ya encontraste tu servicio?"
  subtitulo="Explora el catálogo completo con 20 modelos de mobiliario. Hay una opción ideal para tu evento."
  href="/catalogo/"
  btnLabel="Ver catálogo completo →"
  step={1}
  secondBtn={{ label: 'Ver paquetes', href: '/paquetes/' }}
/>

<CtaBarFinal headline="¿Organizando una conferencia?" subtext="Cotiza el mobiliario según tu formato. Factura CFDI." phone="55 6432 8954" whatsapp="5564328954" waMessage="Hola, necesito cotizar mesas para una conferencia al aire libre." cotizarHref="/cotizar/" />

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@type": "Service", "name": "Renta de Mesas para Conferencias al Aire Libre", "provider": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-3128-1706" }, "areaServed": [{ "@type": "City", "name": "Ciudad de México" }, { "@type": "State", "name": "Estado de México" }], "description": "Renta de bancas de madera como estaciones de trabajo para conferencias y seminarios al aire libre en CDMX." })} />
</Fragment>
</BaseLayout>

<style>
  :global(.hero) { padding-top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2.5rem + 3rem); }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }
</style>
