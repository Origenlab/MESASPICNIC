---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import WaBubble from '../../../components/WaBubble.astro';

---

<BaseLayout
  title="Mesas Picnic para Eventos Corporativos en CDMX | MESPIC"
  description="Bancas de madera para team buildings, conferencias y comidas empresariales. Facturamos CFDI. Montaje incluido en CDMX."
>

<!-- Breadcrumbs -->
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios", href: "/servicios/" },
    { label: "Eventos Corporativos" }
  ]} />
</Fragment>

<!-- Hero -->
<Hero
  badge="Servicio corporativo"
  title="Mobiliario de Madera para Eventos Corporativos"
  description="Bancas y mesas para team buildings, conferencias al aire libre, comidas de integración y activaciones de marca. De 10 a 500+ asistentes con factura CFDI."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="Desde 2017, MESPIC trabaja con empresas en la Ciudad de México y zona metropolitana montando mobiliario para eventos corporativos al aire libre. Team buildings en parques, conferencias en jardines, comidas de cierre anual y activaciones de marca en espacios abiertos. Cada banca sienta de 6 a 8 personas frente a frente, lo que rompe jerarquías y facilita la conversación entre áreas."
  seoParagraph2="Facturamos CFDI con los datos fiscales que tu empresa necesite. Manejamos flotilla propia de transporte y coordinamos directamente con tu equipo de logística o agencia de eventos. Entrega, montaje según plano y recolección incluidos en el precio."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<!-- Galería + Sidebar -->
<section class="section" id="montajes">
  <SectionHeader
    badge="Galería de montajes"
    tag="h2"
    title="Así se Ve en Eventos de Empresa"
    paragraph1="Montajes de mobiliario de madera en team buildings, conferencias y comidas corporativas. Terrazas, jardines, parques y espacios abiertos en la Ciudad de México."
    paragraph2="Explora los modelos recomendados en la barra lateral para cotizar según tu número de asistentes."
  />
  <ProductGallery
    images={[
      { src: "/img/mesa-picnic-evento-corporativo-networking.avif", alt: "Grupo de empleados en team building con bancas de madera al aire libre" },
      { src: "/img/mesa-picnic-evento-corporativo-networking.avif", alt: "Conferencia empresarial en jardín con bancas como estaciones de trabajo" },
      { src: "/img/mesa-picnic-evento-corporativo-networking.avif", alt: "Comida de integración con 20 bancas en terraza corporativa" },
      { src: "/img/mesa-picnic-evento-corporativo-networking.avif", alt: "Activación de marca al aire libre con mobiliario de pino natural" },
      { src: "/img/mesa-picnic-evento-corporativo-networking.avif", alt: "Almuerzo empresarial servido sobre bancas de madera en jardín" },
      { src: "/img/mesa-picnic-evento-corporativo-networking.avif", alt: "Networking corporativo en mesas de madera con vista a la ciudad" },
      { src: "/img/mesa-picnic-evento-corporativo-networking.avif", alt: "Seminario al aire libre con laptops sobre mobiliario rústico" },
      { src: "/img/mesa-picnic-evento-corporativo-networking.avif", alt: "Evento masivo corporativo con 30+ bancas alineadas" },
      { src: "/img/mesa-picnic-evento-corporativo-networking.avif", alt: "Cierre anual de empresa con decoración navideña sobre madera" },
    ]}
    recommended={[
      { title: "Mesa Estándar", description: "6-8 personas, la más versátil", href: "/catalogo/mesa-picnic-estandar/" },
      { title: "Mesa Grande", description: "10-12 personas, reuniones amplias", href: "/catalogo/mesa-picnic-grande/" },
      { title: "Paquete Estándar", description: "6 bancas, 36 personas", href: "/paquetes/estandar/" },
      { title: "Paquete Premium", description: "10 bancas, 60 personas", href: "/paquetes/premium/" },
      { title: "Mesa Premium", description: "Con sombrilla incluida", href: "/catalogo/mesa-picnic-premium/" },
    ]}
    sidebarTitle="Mobiliario para empresas"
  />
</section>

<!-- Tipos de evento corporativo -->
<section class="section section-alt" id="tipos">
  <SectionHeader
    badge="Nuestras opciones"
    tag="h2"
    title="Tipos de Evento que Montamos"
    paragraph1="No es lo mismo un team building para 30 personas que una comida de cierre anual para 300. Cada formato tiene su propia configuración de mobiliario."
    paragraph2="Dinos qué tipo de evento estás organizando y te proponemos la distribución ideal según tu espacio y presupuesto."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Team Building" description="Bancas agrupadas en estaciones de 6-8 personas para dinámicas de integración. Ideal para parques, jardines y espacios deportivos. El formato rompe la formalidad de oficina." image="/img/mesa-picnic-evento-corporativo-networking.avif" href="/servicios/eventos-corporativos/team-building/" btnLabel="Team building" />
      <ServiceCard title="Conferencias al Aire Libre" description="Bancas como estaciones de trabajo con espacio para laptop, libreta y vaso. Seminarios de hasta 120 personas en jardines corporativos. Luz natural y ventilación que mejoran la atención." image="/img/mesa-picnic-evento-corporativo-networking.avif" href="/servicios/eventos-corporativos/conferencias/" btnLabel="Conferencias" />
      <ServiceCard title="Comidas de Integración" description="Montaje para comidas de fin de año, celebraciones de resultados y convivios entre sucursales. De 50 a 300 personas con bancas de madera en vez de mesas redondas de hotel." image="/img/mesa-picnic-evento-corporativo-networking.avif" href="/servicios/eventos-corporativos/comidas/" btnLabel="Comidas empresariales" />
      <ServiceCard title="Activaciones de Marca" description="Mobiliario para lanzamientos de producto, ferias internas, bazares corporativos y eventos de employer branding. La madera aporta una estética natural que funciona en fotos y redes." image="/img/mesa-picnic-evento-corporativo-networking.avif" href="/servicios/eventos-corporativos/activaciones/" btnLabel="Activaciones de marca" />
    </div>
  </div>
</section>

<!-- Qué incluye -->
<section class="section" id="incluye">
  <SectionHeader
    badge="Servicio incluido"
    tag="h2"
    title="Qué Incluye el Servicio Corporativo"
    paragraph1="Todo el servicio viene resuelto para que tu equipo de logística no tenga que preocuparse por el mobiliario. Coordinamos directo con tu agencia de eventos si la tienes."
    paragraph2="Facturamos CFDI con los datos fiscales de tu empresa. Solo necesitamos RFC, razón social y uso de CFDI al momento de la cotización."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Factura CFDI" description="Emitimos factura fiscal con los datos que necesite tu departamento de compras. RFC, razón social, uso de CFDI y método de pago configurables." />
      <FeatureCard title="Montaje según Plano" description="Coordinamos con tu equipo o agencia de eventos. Llegamos 3-4 horas antes para montar según la distribución aprobada. Ajustamos en sitio si hay cambios de último momento." />
      <FeatureCard title="Volumen para 500+ Personas" description="Tenemos inventario para eventos masivos. Para más de 200 asistentes, reserva con 2 semanas de anticipación para garantizar disponibilidad." />
      <FeatureCard title="Contacto Directo el Día del Evento" description="Tu coordinador tiene línea directa de WhatsApp con nuestro equipo de montaje. Cualquier ajuste se resuelve en tiempo real, sin intermediarios." />
    </div>
  </div>
</section>

<!-- Datos para cotizar -->
<section class="section section-alt" id="datos">
  <SectionHeader
    badge="Guía de cantidades"
    tag="h2"
    title="Referencia de Cantidad por Asistentes"
    paragraph1="Usa esta tabla como referencia rápida para estimar cuántas bancas necesitas. El número final depende de la distribución del espacio y el formato del evento."
    paragraph2="Si nos mandas el número de asistentes y las medidas del espacio, te calculamos la cantidad exacta con un plano de distribución."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="30 Personas" description="5-6 bancas estándar. Ideal para team buildings pequeños y almuerzos de equipo. Cabe en un jardín de 60 m²." />
      <FeatureCard title="80 Personas" description="11-14 bancas estándar. Para conferencias medianas y comidas de área. Necesitas un espacio de aproximadamente 100 m²." />
      <FeatureCard title="200 Personas" description="28-34 bancas estándar. Comidas de fin de año y eventos inter-sucursales. Espacio recomendado: 200+ m²." />
      <FeatureCard title="500+ Personas" description="70+ bancas. Eventos masivos, festivales corporativos y activaciones de marca. Requiere reserva anticipada de 2 semanas mínimo." />
    </div>
  </div>
</section>

<!-- FAQ -->

<!-- Proceso paso a paso — Template L3: proceso-cards -->
<section class="section section-alt" id="proceso">
  <SectionHeader
    badge="Cómo trabajamos"
    tag="h2"
    title="Nuestro Proceso de Servicio Corporativo"
    paragraph1="Operamos con el mismo nivel de exigencia que cualquier proveedor corporativo profesional: confirmaciones por escrito, horarios cumplidos y un responsable disponible durante todo el evento. Sin improvisaciones."
    paragraph2="Trabajamos con áreas de compras, agencias de producción y coordinadoras de eventos. Emitimos factura con RFC, orden de servicio y cualquier documentación que tu proceso interno requiera."
  />
  <div class="container">
    <div class="proceso-cards">
      <div class="paso-card">
        <span class="paso-card__num">01</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Compártenos el brief de tu evento</h3>
          <p class="paso-card__text">Fecha, aforo, tipo de evento y espacio disponible. Si tienes brief o concepto visual de la marca, compártelo — nos ayuda a proponer el mobiliario más alineado con la imagen corporativa que quieren proyectar y a evitar propuestas que no encajan con el concepto.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">02</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Propuesta formal en el mismo día</h3>
          <p class="paso-card__text">Cantidad de piezas, distribución por zonas, costo de traslado y servicios adicionales. Todo por escrito. Podemos enviar la cotización en PDF con membrete para procesos de aprobación interna, validación de presupuesto o alta de proveedor.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">03</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Orden de servicio y confirmación</h3>
          <p class="paso-card__text">Con el anticipo bloqueamos el inventario y emitimos orden de servicio. Para empresas que requieren proceso de compras formal, alta de proveedor o factura anticipada, nos adaptamos al flujo administrativo de cada organización sin demoras.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">04</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Coordinación técnica con producción</h3>
          <p class="paso-card__text">Compartimos planos de distribución y dimensiones exactas con el coordinador o agencia de producción. Acordamos horarios de entrega para no interferir con el catering, AV ni otros proveedores. Todo documentado antes del evento.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">05</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Montaje impecable, recolección sin rastros</h3>
          <p class="paso-card__text">Llegamos en el horario acordado, colocamos cada pieza según el plano aprobado y dejamos el espacio listo. Al finalizar el evento, retiramos el mobiliario de forma ordenada y sin generar interrupciones. Tu equipo no coordina ningún aspecto logístico del mobiliario.</p>
        </div>
      </div>
    </div>
  </div>
</section>
<section class="section" id="faq">
  <SectionHeader
    badge="Preguntas frecuentes"
    tag="h2"
    title="Preguntas sobre Eventos Corporativos"
    paragraph1="Las dudas más comunes que recibimos de departamentos de logística, agencias de eventos y coordinadores de recursos humanos."
    paragraph2="Si necesitas una cotización formal para presentar a tu empresa, escríbenos y te la enviamos por correo."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿Emiten factura fiscal?", answer: "Sí, emitimos CFDI con los datos fiscales de tu empresa. Solicítala al momento de la cotización con RFC, razón social y uso de CFDI." },
      { question: "¿Cuántas bancas para 200 personas?", answer: "Entre 28 y 34 bancas estándar (6-8 personas cada una), dependiendo de la distribución. Te enviamos un plano de distribución si nos mandas las medidas del espacio." },
      { question: "¿Entregan en oficinas y parques corporativos?", answer: "Sí, entregamos en oficinas con área exterior, parques corporativos, jardines, terrazas, centros de convenciones y cualquier espacio con acceso vehicular en CDMX y Edomex." },
      { question: "¿Pueden coordinarse con nuestra agencia de eventos?", answer: "Sí, trabajamos directamente con agencias, wedding planners y coordinadores de logística. Les enviamos medidas del mobiliario y coordinamos tiempos de montaje." },
      { question: "¿Tienen disponibilidad entre semana?", answer: "Sí, operamos los 7 días. Los eventos corporativos generalmente son entre semana y tenemos más disponibilidad que los fines de semana." },
      { question: "¿Qué formas de pago aceptan?", answer: "Transferencia bancaria, depósito en efectivo y pago con tarjeta. Para empresas, aceptamos orden de compra con pago a 15 días contra factura." }
    ]}
  />
</section>

<!-- CTA Final -->
<CtaBarFinal
  headline="¿Organizando un evento de empresa?"
  subtext="Cotiza con factura CFDI. Te respondemos el mismo día."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, necesito cotizar mobiliario para un evento corporativo."
  cotizarHref="/cotizar/"
/>

<!-- WA Bubble -->
<WaBubble whatsapp="5564328954" message="Hola, necesito cotizar mesas para un evento corporativo." />

<!-- Schema -->
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Mesas Picnic para Eventos Corporativos",
    "provider": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-3128-1706" },
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "description": "Renta de mobiliario de madera para team buildings, conferencias, comidas empresariales y activaciones de marca en CDMX y Edomex. Facturamos CFDI."
  })} />
</Fragment>

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     Template L3 — proceso-cards
     Layout: 3 tarjetas fila 1 + 2 tarjetas fila 2
     ═══════════════════════════════════════════ */
  .proceso-cards {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }
  .paso-card:nth-child(1),
  .paso-card:nth-child(2),
  .paso-card:nth-child(3) { grid-column: span 2; }
  .paso-card:nth-child(4),
  .paso-card:nth-child(5) { grid-column: span 3; }
  .paso-card {
    background: #fff;
    border: 1px solid var(--c-border, #E7E0D8);
    border-top: 3px solid var(--c-accent, #C8956C);
    border-radius: var(--radius-md, 12px);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }
  .paso-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(44, 85, 48, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }
  .paso-card__num {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--c-primary, #2C5530);
    opacity: 0.12;
    line-height: 1;
    letter-spacing: -0.03em;
    align-self: flex-start;
  }
  .paso-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }
  .paso-card__title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--c-text, #1C1917);
    line-height: 1.3;
    margin: 0;
  }
  .paso-card__text {
    font-size: 0.875rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.7;
    margin: 0;
  }
  @media (max-width: 1024px) {
    .proceso-cards { grid-template-columns: repeat(2, 1fr); }
    .paso-card:nth-child(1),.paso-card:nth-child(2),
    .paso-card:nth-child(3),.paso-card:nth-child(4),
    .paso-card:nth-child(5) { grid-column: span 1; }
  }
  @media (max-width: 640px) {
    .proceso-cards { grid-template-columns: 1fr; }
  }

  :global(.hero) {
    padding-top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2.5rem + 3rem);
  }

  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 1024px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .grid-4 { grid-template-columns: 1fr; }
  }
</style>
