---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import FaqSection from '../../components/FaqSection.astro';
import NextStep from '../../components/NextStep.astro';
import CtaBarFinal from '../../components/CtaBarFinal.astro';
---

<BaseLayout
  title="Picnic Romántico en CDMX — Montaje con Mobiliario de Madera | MESPIC"
  description="Picnic romántico para parejas en CDMX. Banca decorada con mantelería, cojines y ambientación. Montamos todo, tú solo llegas."
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios", href: "/servicios/" },
    { label: "Picnic Romántico" }
  ]} />
</Fragment>

<Hero
  badge="Para parejas"
  title="Picnic Romántico en la Ciudad de México"
  description="Un montaje íntimo con banca de madera decorada, mantelería, cojines y ambientación. Para pedidas de mano, aniversarios, cumpleaños en pareja o una tarde que no se olvida."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="El picnic romántico se convirtió en una de las experiencias más buscadas en la Ciudad de México. No es solo comer al aire libre — es un montaje completo sobre una banca de madera natural con mantelería, cojines, flores y ambientación que transforma un parque o un jardín en un espacio privado para dos personas. En MESPIC lo montamos todo: tú solo llegas y disfrutas."
  seoParagraph2="Hacemos picnics románticos en Chapultepec, Viveros de Coyoacán, jardines privados de San Ángel, terrazas en Polanco y Condesa, parques de Naucalpan y cualquier espacio al aire libre que elijas. El montaje toma 30 minutos y lo dejamos listo antes de que llegues. Al terminar, recogemos todo. Sin logística, sin estrés, sin que tengas que cargar nada."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<section class="section" id="montajes">
  <SectionHeader
    badge="El estilo en detalle"
    tag="h2"
    title="Montajes Románticos con Madera Natural"
    paragraph1="Cada picnic romántico es un montaje a medida. No usamos kits genéricos — armamos la ambientación según la ocasión, el espacio y lo que quieras sorprender."
    paragraph2="Explora los productos que usamos para estos montajes en la barra lateral."
  />
  <ProductGallery
    images={[
      { src: "/img/picnic-romantico-bridal-shower-mesas-pino-01.avif", alt: "Picnic romántico para dos personas en jardín con velas y flores" },
      { src: "/img/picnic-romantico-bridal-shower-mesas-pino-02.avif", alt: "Banca decorada con mantelería blanca y pétalos de rosa" },
      { src: "/img/picnic-romantico-bridal-shower-mesas-pino-03.avif", alt: "Montaje de pedida de mano con banca y arco floral" },
      { src: "/img/picnic-romantico-bridal-shower-mesas-pino-04.avif", alt: "Picnic al atardecer en Chapultepec con cojines y canasta" },
      { src: "/img/picnic-romantico-bridal-shower-mesas-pino-05.avif", alt: "Detalle de copa de vino sobre madera con flores" },
      { src: "/img/picnic-romantico-bridal-shower-mesas-pino-06.avif", alt: "Pareja disfrutando picnic romántico en terraza privada" },
      { src: "/img/picnic-romantico-bridal-shower-mesas-pino-07.avif", alt: "Montaje nocturno con velas y luces sobre banca" },
      { src: "/img/picnic-romantico-bridal-shower-mesas-pino-08.avif", alt: "Picnic romántico en jardín de San Ángel con bugambilias" },
      { src: "/img/boda-playa-1.avif", alt: "Banca de madera con cojines terracota y flores secas" },
    ]}
    recommended={[
      { title: "Set Completo", description: "Mesa + decoración + menaje", href: "/catalogo/set-picnic-completo/" },
      { title: "Mesa Estándar", description: "6-8 personas, si van amigos", href: "/catalogo/mesa-picnic-estandar/" },
      { title: "Mesa Rústica", description: "Acabado campestre natural", href: "/catalogo/mesa-picnic-rustica/" },
      { title: "Paquete Básico", description: "Si llevas grupo pequeño", href: "/paquetes/basico/" },
    ]}
    sidebarTitle="Mobiliario para picnic romántico"
  />
</section>

<section class="section section-alt" id="ocasiones">
  <SectionHeader
    badge="Cuándo contratarnos"
    tag="h2"
    title="Ocasiones para un Picnic Romántico"
    paragraph1="No necesitas una fecha especial para organizar un picnic. Pero si la tienes, el montaje hace que el momento se sienta a la altura. Estas son las ocasiones más comunes."
    paragraph2="Cada montaje se adapta a la ocasión: no es lo mismo una pedida de mano que un aniversario tranquilo."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Pedida de Mano" description="El momento más importante merece un escenario especial. Banca decorada con flores, velas, una botella de champagne y el espacio despejado para que todo salga como lo planeaste. Coordinamos el timing contigo." />
      <FeatureCard title="Aniversario" description="Un año, cinco, diez — da igual el número. El montaje sobre madera con mantelería y ambientación convierte un parque que ya conocen en un lugar que se siente nuevo." />
      <FeatureCard title="Cumpleaños en Pareja" description="Si tu pareja prefiere algo íntimo en vez de un restaurante, un picnic con banca decorada en su parque favorito es la sorpresa que no espera." />
      <FeatureCard title="Sin Ocasión Especial" description="A veces el mejor plan es simplemente una tarde al aire libre con la persona correcta. Una banca, una canasta, una copa de vino y el atardecer de la ciudad. Eso es todo." />
    </div>
  </div>
</section>

<section class="section" id="incluye">
  <SectionHeader
    badge="Servicio incluido"
    tag="h2"
    title="Qué Incluye el Montaje"
    paragraph1="El picnic romántico no es solo una banca — es una experiencia completa. Nosotros montamos, tú llegas y disfrutas. Al terminar, recogemos todo."
    paragraph2="Si quieres agregar algo especial (flores frescas, comida, botella), nos coordinamos contigo o con tu proveedor."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Banca de Madera Decorada" description="Pino natural barnizado con mantelería, camino de mesa y ambientación según la ocasión. La banca es el centro del montaje — todo gira alrededor de ella." />
      <FeatureCard title="Cojines y Textiles" description="Cojines de algodón sobre las bancas para mayor comodidad. Mantel, servilletas y camino de mesa en tonos neutros que combinan con cualquier espacio." />
      <FeatureCard title="Ambientación Básica" description="Velas en portavelas de vidrio, flores secas o frescas (según disponibilidad) y detalles decorativos. Creamos el ambiente sin que parezca un set de fotos armado." />
      <FeatureCard title="Montaje y Recolección" description="Llegamos 30 minutos antes al punto que elijas. Armamos todo y nos retiramos. Al terminar nos avisas por WhatsApp y recogemos. Sin logística de tu parte." />
    </div>
  </div>
</section>

<section class="section section-alt" id="lugares">
  <SectionHeader
    badge="Dónde montamos"
    tag="h2"
    title="Dónde Hacemos Picnics Románticos"
    paragraph1="Montamos en cualquier espacio al aire libre de la Ciudad de México y zona metropolitana. Estos son los lugares más populares que nuestros clientes eligen."
    paragraph2="Si tienes un lugar en mente que no está en la lista, mándanos la ubicación y confirmamos si podemos montar ahí."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Chapultepec" description="El parque más grande de la ciudad. Zonas con pasto, árboles maduros y vistas al castillo. Necesitas llegar temprano para apartarte un buen spot. Nosotros llegamos antes." />
      <FeatureCard title="Viveros de Coyoacán" description="Ambiente tranquilo rodeado de árboles. Menos concurrido que Chapultepec entre semana. Funciona perfecto para atardeceres con picnic entre semana." />
      <FeatureCard title="Jardines Privados" description="Si tienes acceso a un jardín (tuyo o de un familiar), el montaje se siente más íntimo que en un parque público. Sin gente alrededor, sin ruido." />
      <FeatureCard title="Terrazas y Azoteas" description="Rooftops en Polanco, Roma, Condesa o Del Valle. Con vista a la ciudad y privacidad. Verificamos acceso para la entrega antes de confirmar." />
    </div>
  </div>
</section>

<section class="section" id="datos">
  <SectionHeader
    badge="Antes de reservar"
    tag="h2"
    title="Lo que Necesitas Saber Antes de Reservar"
    paragraph1="Datos prácticos para que tu picnic salga como lo imaginaste. Sin sorpresas, sin costos ocultos, sin complicaciones."
    paragraph2="Si tienes dudas específicas sobre tu montaje, escríbenos. Cada picnic es diferente y lo adaptamos a tu plan."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Reserva con 3-4 Días" description="No necesitas semanas de anticipación. Con 3-4 días de aviso confirmamos disponibilidad. En temporada de San Valentín y aniversarios, reserva con 1 semana." />
      <FeatureCard title="Duración Libre" description="El montaje queda el tiempo que necesites. No cobramos por hora. Si quieres 2 horas o toda la tarde, el precio es el mismo." />
      <FeatureCard title="Tú Pones la Comida" description="El montaje incluye banca, decoración y ambientación. La comida y bebida las llevas tú o coordinamos con un servicio de canastas que recomendamos." />
      <FeatureCard title="Clima" description="Si llueve, reagendamos sin costo. Si hay llovizna leve y tu espacio tiene techo parcial o palapa, montamos sin problema. La madera tratada resiste humedad moderada." />
    </div>
  </div>
</section>


<!-- Proceso paso a paso — Template L3: proceso-cards -->
<section class="section section" id="proceso">
  <SectionHeader
    badge="Cómo trabajamos"
    tag="h2"
    title="Cómo Preparamos Tu Picnic Perfecto"
    paragraph1="El montaje perfecto no improvisa — se planea con cuidado. Nos encargamos de que cada detalle del escenario esté listo antes de que llegues, para que tú te concentres únicamente en la persona que importa."
    paragraph2="Montamos experiencias en parques, jardines privados, terrazas y espacios especiales de toda la CDMX. Los fines de semana en fechas clave — 14 de febrero, aniversarios, Día de las Madres — se reservan con semanas de anticipación."
  />
  <div class="container">
    <div class="proceso-cards">
      <div class="paso-card">
        <span class="paso-card__num">01</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Cuéntanos qué están celebrando</h3>
          <p class="paso-card__text">¿Pedida de mano, aniversario, cumpleaños, primer mes o simplemente un momento para dos? Mientras más nos cuentes sobre la ocasión y sobre la persona, mejor podemos asesorarte sobre el estilo de montaje que va a crear el impacto que buscas.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">02</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Propuesta personalizada con detalle completo</h3>
          <p class="paso-card__text">Te mandamos la cotización con todo lo que incluye el montaje: mobiliario, mantelería, flores disponibles, velas y accesorios decorativos. Ajustamos los elementos y el nivel de personalización según tu presupuesto — hay opciones para distintos rangos.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">03</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Tu fecha queda asegurada con el anticipo</h3>
          <p class="paso-card__text">Con el pago parcial reservamos la fecha y empezamos a organizar cada detalle del montaje. Los elementos más específicos — flores en particular, colores, accesorios personalizados — los cerramos en los días previos para que todo llegue fresco y en perfectas condiciones.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">04</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Verificamos el espacio y gestionamos el acceso</h3>
          <p class="paso-card__text">Confirmamos el acceso al parque, jardín privado o terraza. En espacios públicos que requieren permiso o reserva, te asesoramos sobre los pasos necesarios. Verificamos las condiciones del terreno para que la distribución del mobiliario sea estable y segura.</p>
        </div>
      </div>
      <div class="paso-card">
        <span class="paso-card__num">05</span>
        <div class="paso-card__body">
          <h3 class="paso-card__title">Montamos en silencio, recogemos en discreción</h3>
          <p class="paso-card__text">Llegamos con suficiente tiempo, instalamos cada elemento según lo acordado y nos retiramos antes de que empieces la experiencia. Cuando terminen, nos avisas y volvemos a recoger todo discretamente — sin prisas, sin interrupciones. Tú solo disfrutas el momento.</p>
        </div>
      </div>
    </div>
  </div>
</section>
<section class="section section-alt" id="faq">
  <SectionHeader
    badge="Preguntas frecuentes"
    tag="h2"
    title="Preguntas sobre Picnic Romántico"
    paragraph1="Las dudas más comunes de personas que quieren organizar un picnic romántico por primera vez."
    paragraph2="Si estás planeando una sorpresa, podemos coordinarnos contigo por WhatsApp sin que tu pareja se entere."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿El montaje incluye comida?", answer: "No, el montaje incluye banca decorada, cojines, mantelería y ambientación. La comida la llevas tú. Si quieres, te recomendamos un servicio de canastas gourmet que trabaja con nosotros." },
      { question: "¿Puedo hacer el picnic en un parque público?", answer: "Sí. Chapultepec, Viveros, Parque Lincoln, Parque España y otros. No necesitas permiso especial para poner una banca con comida. Nosotros montamos, tú comes, nosotros recogemos." },
      { question: "¿Cuánto tiempo dura el montaje?", answer: "Armamos en 30 minutos. Llegamos antes que tú al punto que elijas. Cuando termines, nos avisas por WhatsApp y recogemos en 20 minutos." },
      { question: "¿Puedo agregar flores frescas?", answer: "Sí. Si quieres rosas, peonías o algo específico, coordinamos con una florista. Tiene costo adicional según el arreglo. También puedes llevar tus propias flores." },
      { question: "¿Funciona para una pedida de mano?", answer: "Sí, hemos montado más de 30 pedidas de mano. Coordinamos el timing contigo: montamos antes, te avisamos cuando está listo, tú llegas con tu pareja. Discreción total." },
      { question: "¿Qué pasa si mi pareja llega antes que el montaje?", answer: "Coordinamos por WhatsApp en tiempo real. Tú nos dices cuándo van a llegar y nosotros tenemos todo listo con margen. Si hay un cambio de planes, nos adaptamos." }
    ]}
  />
</section>


<!-- Siguiente paso: Ver catálogo -->
<NextStep
  titulo="¿Ya encontraste tu servicio?"
  subtitulo="Explora el catálogo completo con 20 modelos de mobiliario. Hay una opción ideal para tu evento."
  href="/catalogo/"
  btnLabel="Ver catálogo completo →"
  step={1}
  secondBtn={{ label: 'Ver paquetes', href: '/paquetes/' }}
/>

<CtaBarFinal
  headline="¿Planeando algo especial?"
  subtext="Reserva tu picnic romántico. Lo montamos nosotros."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero reservar un picnic romántico."
  cotizarHref="/cotizar/"
/>


<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "Service",
    "name": "Picnic Romántico en CDMX",
    "provider": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-3128-1706" },
    "areaServed": [{ "@type": "City", "name": "Ciudad de México" }, { "@type": "State", "name": "Estado de México" }],
    "description": "Montaje de picnic romántico para parejas en parques, jardines y terrazas de la Ciudad de México. Banca decorada con mantelería, cojines y ambientación."
  })} />
</Fragment>

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     Template L3 — proceso-cards
     Layout: 3 tarjetas fila 1 + 2 tarjetas fila 2
     ═══════════════════════════════════════════ */
  .proceso-cards {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }
  .paso-card:nth-child(1),
  .paso-card:nth-child(2),
  .paso-card:nth-child(3) { grid-column: span 2; }
  .paso-card:nth-child(4),
  .paso-card:nth-child(5) { grid-column: span 3; }
  .paso-card {
    background: #fff;
    border: 1px solid var(--c-border, #E7E0D8);
    border-top: 3px solid var(--c-accent, #C8956C);
    border-radius: var(--radius-md, 12px);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }
  .paso-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(44, 85, 48, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }
  .paso-card__num {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--c-primary, #2C5530);
    opacity: 0.12;
    line-height: 1;
    letter-spacing: -0.03em;
    align-self: flex-start;
  }
  .paso-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }
  .paso-card__title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--c-text, #1C1917);
    line-height: 1.3;
    margin: 0;
  }
  .paso-card__text {
    font-size: 0.875rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.7;
    margin: 0;
  }
  @media (max-width: 1024px) {
    .proceso-cards { grid-template-columns: repeat(2, 1fr); }
    .paso-card:nth-child(1),.paso-card:nth-child(2),
    .paso-card:nth-child(3),.paso-card:nth-child(4),
    .paso-card:nth-child(5) { grid-column: span 1; }
  }
  @media (max-width: 640px) {
    .proceso-cards { grid-template-columns: 1fr; }
  }

  :global(.hero) { padding-top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2.5rem + 3rem); }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }
</style>
