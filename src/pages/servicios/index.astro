---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Hero from '../../components/Hero.astro';
import CtaBar from '../../components/CtaBar.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import GallerySection from '../../components/GallerySection.astro';
import FaqSection from '../../components/FaqSection.astro';
import NextStep from '../../components/NextStep.astro';
import ExploreMore from '../../components/ExploreMore.astro';

const galeriaServicios = [
  { src: "/img/boda-hacienda-1.avif",            alt: "Mesas picnic elegantes en boda de hacienda mexicana con decoración floral" },
  { src: "/img/corp-teambuilding-1.avif", alt: "Mobiliario de madera para evento corporativo networking al aire libre" },
  { src: "/img/baby-shower-mesas-picnic-madera-cdmx-01.avif",           alt: "Mesa infantil decorada con globos y cupcakes para cumpleaños en jardín" },
  { src: "/img/picnic-romantico-bridal-shower-mesas-pino-02.avif", alt: "Montaje romántico de picnic para pedida de mano con flores y velas" },
  { src: "/img/tema-mexicana-1.avif",             alt: "Mesa temática con decoración mexicana, papel picado y talavera" },
  { src: "/img/eventos-corporativos-ejecutivos-renta-mesas-picnic-02.avif",         alt: "Bancas de madera distribuidas en parque verde para team building empresarial" },
  { src: "/img/cine-aire-libre-mesas-picnic-festival-04.avif", alt: "Gran montaje de mesas picnic para feria gastronómica con múltiples asistentes" },
  { src: "/img/equipo-trabajo-mesas-picnic-showroom.avif", alt: "Mesa picnic con iluminación de luces cálidas para boda nocturna en jardín" },
];
---

<BaseLayout
  title="Servicios de Renta de Mesas Picnic para Eventos | MESPIC — CDMX"
  description="8 servicios especializados de renta de mobiliario de madera: bodas, corporativos, infantiles, picnic romántico, temáticas, festivales y más. Entrega y montaje incluidos en CDMX y Edomex."
  ogImage="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif"
>

<!-- Breadcrumbs -->
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios" }
  ]} />
</Fragment>

<!-- Hero -->
<Hero
  badge="8 tipos de servicio"
  title="Mobiliario de Madera para Cada Tipo de Evento"
  description="Desde una boda para 200 personas hasta un picnic romántico para dos. Tenemos la configuración exacta para tu evento, con entrega, montaje y recolección incluidos en CDMX y Edomex."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="MESPIC ofrece 8 servicios especializados de renta de mobiliario de madera para eventos al aire libre en la Ciudad de México y Estado de México. Cada servicio tiene su propia logística y configuración: no es lo mismo preparar bancas para una boda íntima en Coyoacán que montar 30 mesas para un festival gastronómico en Roma Norte. Por eso adaptamos cada entrega al tipo de evento, no al revés."
  seoParagraph2="Todos los servicios incluyen transporte a tu ubicación, montaje profesional por nuestro equipo y recolección al terminar. No subcontratamos ni cobramos cargos extra por maniobras o tiempo. Operamos los 7 días de la semana con tiempo de respuesta inferior a 3 horas en toda la Ciudad de México y municipios del Estado de México como Naucalpan, Huixquilucan y Atizapán."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<!-- ═══════════════════════════════════════════════════════
     8 SERVICIOS
═══════════════════════════════════════════════════════ -->
<section class="section" id="todos-los-servicios">
  <SectionHeader
    tag="h2"
    badge="Nuestros Servicios"
    title="Todos Nuestros Servicios"
    paragraph1="Cada tipo de evento requiere una logística distinta: cantidad de bancas, distribución del espacio, tiempo de montaje y tipo de asesoría. Explora cada servicio en detalle y encuentra el que se ajusta a tu ocasión."
    paragraph2="Si no estás seguro de cuál necesitas, cotiza por WhatsApp y te asesoramos según tu fecha, ubicación y número de invitados. Respondemos en minutos."
    stats={[
      { value: '8',        label: 'servicios especializados' },
      { value: '500+',     label: 'eventos realizados' },
      { value: 'CDMX+Edomex', label: 'zona de cobertura' },
    ]}
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard
        title="Bodas al Aire Libre"
        description="Bancas de pino barnizadas a mano para bodas en jardines, haciendas y terrazas. Combinan con cualquier estilo de decoración: rústico, boho, clásico o minimalista. Montaje incluido en tu ubicación."
        image="/img/boda-hacienda-1.avif"
        href="/servicios/bodas/"
        btnLabel="Mesas para bodas"
        badge="Bodas"
        icon="💍"
      />
      <ServiceCard
        title="Eventos Corporativos"
        description="Mobiliario para team buildings, conferencias y comidas empresariales al aire libre. Configuramos el montaje según la cantidad de asistentes y el formato de tu evento."
        image="/img/corp-teambuilding-1.avif"
        href="/servicios/eventos-corporativos/"
        btnLabel="Mobiliario corporativo"
        badge="Corporativo"
        icon="🏢"
      />
      <ServiceCard
        title="Fiestas Infantiles"
        description="Bancas lijadas a grano fino, sin astillas ni bordes filosos. Modelo infantil con altura adaptada para niños de 3 a 10 años. Ideal para cumpleaños, baby showers y reuniones familiares."
        image="/img/infantil-cumple-1.avif"
        href="/servicios/fiestas-infantiles/"
        btnLabel="Mesas para niños"
        badge="Infantil"
        icon="🎈"
      />
      <ServiceCard
        title="Picnic Romántico"
        description="Montaje íntimo para dos personas con banca decorada, mantelería y ambientación personalizada. Ideal para pedidas de mano, aniversarios o una tarde especial en parques y jardines de la ciudad."
        image="/img/picnic-romantico-bridal-shower-mesas-pino-01.avif"
        href="/servicios/picnic-romantico/"
        btnLabel="Picnic para parejas"
        badge="Romántico"
        icon="❤️"
      />
      <ServiceCard
        title="Fiestas Temáticas"
        description="Montajes para fiestas mexicanas, XV años, ferias gastronómicas y celebraciones temáticas. La madera natural se adapta visualmente a cualquier ambientación que tengas en mente."
        image="/img/tema-mexicana-1.avif"
        href="/servicios/fiestas-tematicas/"
        btnLabel="Mesas para fiestas"
        badge="Temático"
        icon="🎉"
      />
      <ServiceCard
        title="Reuniones Familiares"
        description="Mobiliario para cumpleaños de adultos, día de las madres, posadas y reuniones de fin de semana. Bancas amplias donde caben abuelos, papás y niños cómodamente."
        image="/img/reunion-familiar-mesas-picnic-coyoacan-01.avif"
        href="/servicios/reuniones-familiares/"
        btnLabel="Mesas para familia"
        badge="Familiar"
        icon="🏡"
      />
      <ServiceCard
        title="Festivales y Ferias"
        description="Bancas resistentes de alta capacidad para ferias gastronómicas, bazares, festivales culturales y eventos masivos al aire libre. Disponibles en volumen para 100+ personas."
        image="/img/cine-aire-libre-mesas-picnic-festival-01.avif"
        href="/servicios/festivales/"
        btnLabel="Mobiliario para festivales"
        badge="Masivo"
        icon="🎪"
      />
      <ServiceCard
        title="Sesiones Fotográficas"
        description="Bancas de madera como escenografía para sesiones de fotos profesionales, contenido para redes sociales, catálogos y producciones audiovisuales. Montaje por hora disponible."
        image="/img/equipo-trabajo-mesas-picnic-showroom.avif"
        href="/servicios/sesiones-fotograficas/"
        btnLabel="Renta para fotos"
        badge="Foto & Video"
        icon="📷"
      />
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     QUÉ INCLUYE CADA SERVICIO
═══════════════════════════════════════════════════════ -->
<section class="section section-alt" id="incluye">
  <SectionHeader
    tag="h2"
    badge="Servicio completo"
    title="Qué Incluye Cada Servicio"
    paragraph1="Sin importar el tipo de evento que elijas, todos los servicios vienen con el mismo paquete integral: entrega, montaje, uso ilimitado y recolección. Sin cargos extra, sin letra chica, sin sorpresas."
    paragraph2="La diferencia entre servicios está en el tipo de montaje, la cantidad de piezas recomendadas y la asesoría que te damos según el formato específico de tu evento."
    stats={[
      { value: '100%',     label: 'precio final sin cargos extra' },
      { value: 'sin límite', label: 'de tiempo en tu evento' },
      { value: '7 días',   label: 'de la semana, 8–20 hrs' },
    ]}
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard
        index={0}
        title="Entrega en tu Ubicación"
        description="Llevamos el mobiliario a donde sea tu evento: jardín, terraza, parque, hacienda o salón exterior. Cubrimos todas las alcaldías de CDMX y municipios del Edomex en un promedio de 2 a 3 horas."
      />
      <FeatureCard
        index={1}
        title="Montaje Profesional"
        description="Nuestro equipo arma y distribuye las bancas según el espacio disponible y el número de invitados. Llegamos con tiempo para que todo esté listo antes de que comience tu evento."
      />
      <FeatureCard
        index={2}
        title="Uso sin Límite de Tiempo"
        description="Las bancas quedan en tu evento hasta que termine. No cobramos por hora ni por tiempo extra. Si tu boda termina a las 3 am, recogemos a las 3 am, sin cargo adicional."
      />
      <FeatureCard
        index={3}
        title="Recolección Incluida"
        description="Al terminar tu evento, nuestro equipo recoge todo el mobiliario. Tú no tienes que hacer absolutamente nada. El precio que cotizamos ya incluye este servicio desde el inicio."
      />
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     LINK A CATÁLOGO
═══════════════════════════════════════════════════════ -->
<section class="section" id="catalogo-relacionado">
  <SectionHeader
    tag="h2"
    badge="Catálogo de mobiliario"
    title="Elige el Modelo que Mejor se Adapta a tu Evento"
    paragraph1="Además de tipo de servicio, puedes elegir el modelo específico de mesa picnic. Tenemos 6 modelos distintos, cada uno diseñado para una capacidad y un uso particular."
    paragraph2="Revisa las fichas técnicas de cada producto con medidas, capacidad, acabado y fotos reales en eventos. También puedes ver la tabla comparativa para decidir cuál combina mejor con tu ocasión."
    stats={[
      { value: '6',        label: 'modelos de mesa picnic' },
      { value: '1.20–2.40 m', label: 'rango de medidas' },
      { value: 'pino nacional', label: 'madera natural premium' },
    ]}
  />
  <div class="container">
    <div class="grid-3">
      <ServiceCard
        title="Mesa Picnic Estándar"
        description="1.80 × 1.50 m · 6 personas. Pino lijado y barnizado a mano. El modelo más solicitado para bodas, reuniones familiares y corporativos."
        image="/img/renta-mesa-picnic-madera-pino-cdmx-03.avif"
        href="/catalogo/mesa-picnic-estandar/"
        btnLabel="Ver ficha técnica →"
        badge="6 personas"
        icon="🪵"
      />
      <ServiceCard
        title="Mesa Picnic Grande"
        description="2.40 × 1.50 m · 10-12 personas. Ideal para festivales, corporativos y mesa principal de boda. Estructura reforzada."
        image="/img/mesa-picnic-grande-evento-16.avif"
        href="/catalogo/mesa-picnic-grande/"
        btnLabel="Ver ficha técnica →"
        badge="10-12 personas"
        icon="🌳"
      />
      <ServiceCard
        title="Mesa Picnic Infantil"
        description="1.20 × 1.00 m · 8-10 niños. Altura reducida, bordes redondeados y lijado ultrafino sin astillas. Seguridad para los pequeños."
        image="/img/infantil-cumple-1.avif"
        href="/catalogo/mesa-picnic-infantil/"
        btnLabel="Ver ficha técnica →"
        badge="3-10 años"
        icon="🧸"
      />
      <ServiceCard
        title="Mesa Picnic Premium"
        description="Pino sin nudos + 4 manos de barniz. Acabado de lujo para bodas VIP, eventos de alto perfil y sesiones fotográficas profesionales."
        image="/img/mesa-picnic-lujo-madera-exterior-renta-01.avif"
        href="/catalogo/mesa-picnic-premium/"
        btnLabel="Ver ficha técnica →"
        badge="Lujo"
        icon="✨"
      />
      <ServiceCard
        title="Set Picnic Completo"
        description="Mesa + mantelería + cojines + centro de mesa. Paquete llave en mano para picnics románticos, aniversarios y pedidas de mano."
        image="/img/picnic-romantico-bridal-shower-mesas-pino-01.avif"
        href="/catalogo/set-picnic-completo/"
        btnLabel="Ver ficha técnica →"
        badge="Todo incluido"
        icon="🎁"
      />
      <ServiceCard
        title="Mesa Picnic Rústica"
        description="Barniz que resalta veta y nudos naturales. Estilo boho, vintage y campestre-chic. Perfecta para bodas en bosques y haciendas."
        image="/img/boda-rustica-intima-1.avif"
        href="/catalogo/mesa-picnic-rustica/"
        btnLabel="Ver ficha técnica →"
        badge="Boho & Vintage"
        icon="🌿"
      />
    </div>
    <div class="catalog-cta-wrap">
      <a href="/catalogo/" class="btn btn-secondary">Ver catálogo completo con tabla comparativa →</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     ¿POR QUÉ MESPIC?
═══════════════════════════════════════════════════════ -->
<section class="section" id="por-que">
  <SectionHeader
    tag="h2"
    badge="Por qué elegirnos"
    title="¿Por qué elegir MESPIC?"
    paragraph1="Después de 8 años y más de 500 eventos, hay cosas que solo se aprenden con experiencia: cómo proteger la madera del clima, cuántas bancas necesitas según tus invitados, o cómo distribuir el mobiliario para que todos estén cómodos."
    paragraph2="Trabajamos con pino nacional seleccionado, lijado a grano fino y barnizado a mano. No subcontratamos: nuestro equipo se encarga desde la carga hasta el último detalle del montaje."
    stats={[
      { value: '8 años',     label: 'de experiencia operativa' },
      { value: '100%',       label: 'madera de pino natural' },
      { value: 'equipo propio', label: 'sin subcontratistas' },
    ]}
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard index={0} title="Madera 100% Natural" description="Pino nacional seleccionado, lijado a grano fino y barnizado a mano. Sin plásticos ni materiales sintéticos. La textura y el color de la madera real no se pueden imitar con ningún sustituto." />
      <FeatureCard index={1} title="Precio Final sin Sorpresas" description="El precio que cotizamos incluye entrega, montaje y recolección. Sin cargos por traslado, maniobras extra ni tiempo adicional. Lo que ves en la cotización es lo que pagas." />
      <FeatureCard index={2} title="Equipo Propio, Sin Subcontratistas" description="Todo el personal que atiende tu evento es de MESPIC: desde la carga en bodega hasta el montaje en tu locación. Eso nos permite controlar la calidad en cada entrega." />
      <FeatureCard index={3} title="+500 Eventos desde 2017" description="Bodas, corporativos, cumpleaños, posadas, XV años, festivales y bazares. Ocho años de operación nos han dado la logística y la experiencia para anticipar lo que cada evento necesita." />
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════
     GALERÍA
═══════════════════════════════════════════════════════ -->
<section class="section" id="galeria">
  <SectionHeader
    tag="h2"
    badge="Galería de eventos"
    title="Nuestro Mobiliario en Acción"
    paragraph1="Bodas, corporativos, fiestas infantiles, eventos temáticos y festivales — la madera natural se adapta a cualquier estilo y tipo de celebración."
    stats={[
      { value: '3 modelos',    label: 'estándar, grande e infantil' },
      { value: 'pino natural', label: 'lijado y barnizado a mano' },
      { value: 'cualquier estilo', label: 'rústico, boho, minimalista…' },
    ]}
  />
  <GallerySection images={galeriaServicios} id="galeria-servicios" />
</section>

<!-- ═══════════════════════════════════════════════════════
     FAQ
═══════════════════════════════════════════════════════ -->
<section class="section section-alt" id="faq-servicios">
  <SectionHeader
    tag="h2"
    badge="Preguntas frecuentes"
    title="Preguntas sobre los Servicios"
    paragraph1="Dudas comunes que recibimos antes de que los clientes elijan su servicio. Cada pregunta tiene una respuesta directa y sin rodeos."
    paragraph2="Cada servicio tiene su propia página con información detallada, fotos de referencia y especificaciones del mobiliario."
    stats={[
      { value: '6',      label: 'dudas resueltas al vuelo' },
      { value: 'hábil',  label: 'cotización el mismo día' },
      { value: 'lun–dom', label: '8:00 a 20:00 hrs' },
    ]}
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      {
        question: "¿Cuál es la diferencia entre los servicios?",
        answer: "La diferencia está en el tipo de montaje y la asesoría. Para una boda te ayudamos con la distribución en el jardín y el estilo del armado. Para un corporativo configuramos según el formato del evento. Para un festival preparamos volumen de bancas con resistencia para todo el día. El mobiliario es el mismo; la logística y el acompañamiento cambian."
      },
      {
        question: "¿Puedo combinar varios servicios en un mismo evento?",
        answer: "Sí. Si tu evento tiene zona de niños y zona de adultos, llevamos bancas estándar e infantiles. Si quieres un rincón de fotos además del mobiliario principal del evento, lo incluimos en la misma cotización y entrega."
      },
      {
        question: "¿Cuántas bancas necesito para mi evento?",
        answer: "Depende del número de invitados. La banca estándar (1.80 × 1.50 m) acomoda 6 personas; la grande (2.40 × 1.50 m) acomoda 10-12. Para 50 invitados necesitas aproximadamente 8-9 bancas estándar. Cotiza por WhatsApp y te calculamos la cantidad exacta sin costo."
      },
      {
        question: "¿Tienen disponibilidad para fines de semana?",
        answer: "Operamos los 7 días de la semana. Los sábados y domingos son los más solicitados, así que recomendamos reservar con al menos 1 semana de anticipación, especialmente en temporada alta de noviembre a febrero."
      },
      {
        question: "¿Pueden montar en cualquier ubicación de CDMX?",
        answer: "Sí, siempre que haya acceso vehicular para la entrega. Montamos en jardines, terrazas, parques públicos (con permiso), haciendas, salones con área exterior y azoteas. Si no estás seguro, mándanos la ubicación por WhatsApp y te confirmamos sin compromiso."
      },
      {
        question: "¿El servicio de picnic romántico incluye decoración?",
        answer: "Sí. El picnic romántico incluye banca decorada, mantelería, cojines y ambientación básica. Si quieres agregar flores, velas, menaje especial o una cesta de picnic, lo cotizamos por separado según tus preferencias."
      }
    ]}
  />
</section>

<!-- CTA Final -->

<!-- Sigue explorando -->
<ExploreMore
  title="Sigue explorando MESPIC"
  subtitle="Todo lo que necesitas para tu evento en un solo lugar"
  items={[
    { href: '/servicios/', label: 'Todos los servicios', sub: 'Bodas, corporativos, infantiles y más', badge: 'Paso 1', isEmoji: true, icon: '🎪' },
    { href: '/catalogo/', label: 'Catálogo completo', sub: '20 modelos con fichas técnicas y fotos', badge: 'Paso 2', isEmoji: true, icon: '🪵' },
    { href: '/paquetes/', label: 'Nuestros paquetes', sub: 'Básico · Estándar · Premium', badge: 'Paso 3', isEmoji: true, icon: '📦' },
  ]}
/>

<!-- Siguiente paso -->
<NextStep
  titulo="¿Ya sabes qué tipo de evento tienes?"
  subtitulo="Explora todos nuestros servicios especializados: bodas, corporativos, fiestas infantiles, picnics románticos y más."
  href="/servicios/"
  btnLabel="Explorar servicios →"
  secondBtn={{ label: 'Ver catálogo', href: '/catalogo/' }}
/>

