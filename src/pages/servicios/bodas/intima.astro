---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import NextStep from '../../../components/NextStep.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
---

<BaseLayout
  title="Boda Íntima con Mesas de Madera | MESPIC — CDMX"
  description="Renta de 2 a 5 bancas de madera para bodas íntimas de 10 a 30 personas. Ceremonias civiles en jardines privados, terrazas y restaurantes. CDMX y Edomex."
>

<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios", href: "/servicios/" },
    { label: "Bodas", href: "/servicios/bodas/" },
    { label: "Boda Íntima" }
  ]} />
</Fragment>

<Hero
  badge="Boda íntima"
  title="Mobiliario para Bodas Íntimas de 10 a 30 Personas"
  description="Montaje pequeño con 2 a 5 bancas de madera para ceremonias civiles, cenas de compromiso y celebraciones familiares cercanas. Sin mínimo de piezas."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="No todas las bodas son para 200 personas. Muchas parejas prefieren una ceremonia civil con familia cercana y amigos íntimos — 10, 15 o 30 personas máximo. Para esos eventos tenemos montajes pequeños con 2 a 5 bancas de pino natural que transforman un jardín privado, una terraza o un restaurante en un espacio especial sin la producción de una boda grande."
  seoParagraph2="El servicio es el mismo que para bodas grandes: entrega, montaje según tu distribución y recolección al terminar. La diferencia es el volumen — menos piezas, logística más ágil, y la posibilidad de reservar con menos anticipación. Operamos en toda la CDMX y Edomex, incluso para montajes de solo 2 bancas."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<section class="section" id="montajes">
  <SectionHeader
    badge="Galería de montajes"
    tag="h2"
    title="Montajes para Pocos Invitados"
    paragraph1="Bodas íntimas con 2 a 5 bancas. Una mesa larga para todos o varias distribuidas en un jardín. La madera hace que un espacio pequeño se sienta especial."
    paragraph2="Explora los modelos ideales para bodas íntimas en la barra lateral."
  />
  <ProductGallery
    images={[
      { src: "/img/boda-rustica-intima-1.avif", alt: "Boda íntima de 10 personas en una sola banca grande decorada" },
      { src: "/img/boda-playa-1.avif", alt: "Tres bancas para cena de boda en terraza privada" },
      { src: "/img/boda-detalle-1.avif", alt: "Ceremonia civil al aire libre con 2 bancas y arco floral" },
      { src: "/img/boda-mesa-postres-1.avif", alt: "Mesa decorada para cena de compromiso entre árboles" },
      { src: "/img/boda-boho-1.avif", alt: "Boda familiar con 5 bancas en jardín residencial" },
      { src: "/img/boda-bosque-encantado-1.avif", alt: "Montaje nocturno con velas para boda de 20 personas" },
      { src: "/img/boda-minimalista-1.avif", alt: "Detalle de decoración íntima con flores y velas" },
      { src: "/img/mesa-picnic-boda-invitados-atardecer.avif", alt: "Pareja cenando sola en banca decorada" },
      { src: "/img/boda-vinedo-elegante-1.avif", alt: "Brindis en boda íntima sobre mobiliario de pino" },
    ]}
    recommended={[
      { title: "Mesa Grande", description: "10-12 personas, una sola mesa", href: "/catalogo/mesa-picnic-grande/" },
      { title: "Mesa Estándar", description: "6-8 personas por banca", href: "/catalogo/mesa-picnic-estandar/" },
      { title: "Set Completo", description: "Con decoración incluida", href: "/catalogo/set-picnic-completo/" },
      { title: "Paquete Básico", description: "4 bancas, 24 personas", href: "/paquetes/basico/" },
    ]}
    sidebarTitle="Mobiliario para boda íntima"
  />
</section>

<section class="section section-alt" id="espacios">
  <SectionHeader
    badge="Dónde montamos"
    tag="h2"
    title="Espacios Ideales para Bodas Íntimas"
    paragraph1="Una boda de 10-30 personas no necesita una hacienda ni un jardín de eventos. Estos son los espacios donde mejor funcionan los montajes pequeños."
    paragraph2="Lo bueno de una boda íntima: cabe en más lugares y se puede organizar con menos anticipación."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Jardines Privados" description="Tu casa o la de un familiar con patio o jardín. Con 2-3 bancas y buena decoración, un jardín residencial se transforma en un venue íntimo." />
      <FeatureCard title="Terrazas y Azoteas" description="Rooftops en Polanco, Roma, Condesa o Del Valle. Espacio reducido pero con vista. 2-4 bancas bastan para 20 personas." />
      <FeatureCard title="Restaurantes con Exterior" description="Reserva el área exterior de un restaurante y complementa con nuestras bancas. Ideal para cenas de compromiso y firmas civiles." />
      <FeatureCard title="Parques con Permiso" description="Chapultepec, Viveros de Coyoacán, Parque Lincoln. Con el permiso del parque y 2-3 bancas, tienes una ceremonia al aire libre memorable." />
    </div>
  </div>
</section>

<section class="section" id="incluye">
  <SectionHeader
    badge="Servicio incluido"
    tag="h2"
    title="Qué Incluye el Servicio"
    paragraph1="El servicio para bodas íntimas es el mismo que para bodas grandes — la diferencia es el volumen. Entrega, montaje y recolección incluidos incluso para 2 bancas."
    paragraph2="No tenemos mínimo de piezas. Si necesitas una sola banca grande para 10 personas, la rentamos."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Sin Mínimo de Piezas" description="Rentamos desde 1 banca. No necesitas contratar un paquete completo si tu evento es para 10-15 personas." />
      <FeatureCard title="Entrega Rápida" description="Para montajes pequeños, la entrega toma 1-2 horas. Menos piezas = logística más ágil. Puedes reservar con 3-4 días de anticipación." />
      <FeatureCard title="Montaje en 30 Minutos" description="2-5 bancas se montan en menos de media hora. Nuestro equipo coloca, nivela y se retira para que tengas privacidad." />
      <FeatureCard title="Precio por Pieza" description="En bodas íntimas cotizamos por pieza, no por paquete. Así pagas exactamente lo que necesitas, sin extras innecesarios." />
    </div>
  </div>
</section>

<section class="section section-alt" id="configuraciones">
  <SectionHeader
    badge="Configuraciones populares"
    tag="h2"
    title="Configuraciones Populares"
    paragraph1="Estas son las combinaciones más comunes para bodas íntimas. La elección depende del número de invitados y si quieres una mesa larga o varias separadas."
    paragraph2="Si no estás segura, dinos cuántas personas van y te recomendamos la configuración."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="1 Mesa Grande" description="Para 10-12 personas. Todos juntos en una sola mesa larga. Ideal para cenas de compromiso y firmas civiles donde quieres cercanía." image="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" href="/catalogo/mesa-picnic-grande/" btnLabel="Mesa grande" />
      <ServiceCard title="2 Bancas Estándar" description="Para 12-16 personas. Dos mesas separadas o juntas formando una mesa doble. Funciona en terrazas y jardines pequeños." image="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" href="/catalogo/mesa-picnic-estandar/" btnLabel="Mesa estándar" />
      <ServiceCard title="4 Bancas Mixtas" description="Para 24-30 personas. Combina 3 estándar + 1 grande como mesa de novios. El paquete básico cubre exactamente esta configuración." image="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" href="/paquetes/basico/" btnLabel="Paquete básico" />
      <ServiceCard title="Set Completo" description="1 mesa con decoración, mantelería y menaje incluido. Si no quieres coordinar nada, este set te resuelve todo para 6-8 personas." image="/img/picnic-romantico-bridal-shower-mesas-pino-01.avif" href="/catalogo/set-picnic-completo/" btnLabel="Set completo" />
    </div>
  </div>
</section>

<!-- Estilos relacionados -->
<section class="section section-alt" id="relacionados">
  <SectionHeader
    badge="Estilos de boda"
    tag="h2"
    title="Otros Estilos de Boda"
    paragraph1="Si quieres una boda íntima pero con un estilo decorativo definido, explora estas opciones. Todas funcionan con montajes pequeños de 2 a 5 bancas."
    paragraph2="La misma madera se adapta a cualquier concepto — solo cambia la decoración."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Boda Rústica" description="Madera al natural con flores silvestres, velas y caminos de yute. El estilo más popular para jardines y haciendas. Combina con iluminación cálida de serie de luces." image="/img/boda-bosque-encantado-1.avif" href="/servicios/bodas/rustica/" btnLabel="Boda rústica" />
      <ServiceCard title="Boda Boho" description="Pampas, macramé y telas naturales sobre las bancas. Ideal para bosques, viñedos y espacios con vegetación. Las bancas de pino complementan la estética orgánica." image="/img/boda-boho-1.avif" href="/servicios/bodas/boho/" btnLabel="Boda boho" />
      <ServiceCard title="Boda Clásica" description="Manteles de lino, vajilla de porcelana y centros de mesa con rosas. La superficie lisa de la banca soporta montajes formales sin problema. Para 50 a 300 invitados." image="/img/boda-hacienda-banquete-1.avif" href="/servicios/bodas/clasica/" btnLabel="Boda clásica" />
      <ServiceCard title="Boda Íntima" description="Montaje para 10 a 30 personas con 2 a 5 bancas. Perfecto para ceremonias civiles en jardines privados, terrazas o restaurantes con área exterior." image="/img/boda-rustica-intima-1.avif" href="/servicios/bodas/intima/" btnLabel="Boda íntima" />
    </div>
  </div>
</section>

<section class="section" id="faq">
  <SectionHeader
    badge="Preguntas frecuentes"
    tag="h2"
    title="Preguntas sobre Bodas Íntimas"
    paragraph1="Dudas de parejas que quieren una ceremonia pequeña sin la producción de una boda grande."
    paragraph2="Para bodas íntimas la comunicación suele ser más directa — escríbenos y resolvemos rápido."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿Puedo rentar solo 1 o 2 bancas?", answer: "Sí. No tenemos mínimo de piezas. Si tu evento es para 10 personas, una mesa grande es suficiente. La entrega y montaje están incluidos." },
      { question: "¿Cuánto cuesta para una boda de 15 personas?", answer: "Depende del modelo. Cotizamos por pieza: mándanos tu número de invitados y el tipo de espacio por WhatsApp y te damos precio el mismo día." },
      { question: "¿Puedo reservar con poca anticipación?", answer: "Para montajes pequeños (1-5 bancas), generalmente tenemos disponibilidad con 3-4 días de anticipación. En temporada alta (nov-feb), recomendamos 1 semana." },
      { question: "¿Funcionan en un departamento con terraza?", answer: "Sí, si la terraza tiene acceso para subir las bancas (elevador de carga o escaleras amplias). Las piezas se desarman para transporte. Mándanos fotos del espacio y confirmamos." },
      { question: "¿El montaje tarda mucho?", answer: "Para 2-5 bancas, el montaje toma 20-30 minutos. Nuestro equipo llega, coloca, nivela y se retira para darte privacidad." },
      { question: "¿Puedo agregar decoración al momento?", answer: "El mobiliario se entrega limpio y listo. Tú o tu decoradora agregan lo que quieran: flores, velas, manteles, centros de mesa. También puedes contratar nuestro Set Completo que incluye ambientación." }
    ]}
  />
</section>


<!-- Siguiente paso: Ver catálogo -->
<NextStep
  titulo="¿Ya encontraste tu servicio?"
  subtitulo="Explora el catálogo completo con 20 modelos de mobiliario. Hay una opción ideal para tu evento."
  href="/catalogo/"
  btnLabel="Ver catálogo completo →"
  step={1}
  secondBtn={{ label: 'Ver paquetes', href: '/paquetes/' }}
/>

<CtaBarFinal headline="¿Planeando una boda íntima?" subtext="Cotiza desde 1 banca. Sin mínimo de piezas." phone="55 6432 8954" whatsapp="5564328954" waMessage="Hola, quiero cotizar mesas de madera para una boda íntima." cotizarHref="/cotizar/" />

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "Service",
    "name": "Renta de Mesas para Bodas Íntimas",
    "provider": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-3128-1706" },
    "areaServed": [{ "@type": "City", "name": "Ciudad de México" }, { "@type": "State", "name": "Estado de México" }],
    "description": "Renta de bancas de madera para bodas íntimas de 10 a 30 personas en CDMX y Edomex. Sin mínimo de piezas."
  })} />
</Fragment>

</BaseLayout>

<style>
  :global(.hero) { padding-top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2.5rem + 3rem); }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid-4 { grid-template-columns: 1fr; } }
</style>
