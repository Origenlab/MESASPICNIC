---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import WaBubble from '../../../components/WaBubble.astro';
---

<BaseLayout
  title="Mesas Picnic para Bodas al Aire Libre en CDMX | MESPIC"
  description="Renta de bancas de pino para bodas al aire libre. 4 estilos: rústica, boho, clásica e íntima. Entrega y montaje en CDMX y Edomex."
>

<!-- Breadcrumbs -->
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Servicios", href: "/servicios/" },
    { label: "Bodas" }
  ]} />
</Fragment>

<!-- Hero -->
<Hero
  badge="Servicio para bodas"
  title="Bancas de Madera para Bodas al Aire Libre"
  description="Mobiliario de pino natural barnizado a mano para ceremonias y recepciones en jardines, haciendas y terrazas. De 10 a 300 invitados, con montaje incluido."
  ctaPrimary={{ label: "Ver catálogo de mesas →", href: "/catalogo/" }}
  ctaSecondary={{ label: "Ver paquetes", href: "/paquetes/" }}
  seoParagraph1="En más de 200 bodas al aire libre hemos trabajado junto a wedding planners y parejas en la Ciudad de México y Estado de México. Desde ceremonias íntimas de 10 personas en jardines privados de Coyoacán hasta recepciones de 300 invitados en haciendas de Edomex. Cada banca mide 2.4 metros de largo, acomoda de 6 a 8 personas y se entrega lijada y barnizada a tres manos."
  seoParagraph2="La madera de pino tratado combina naturalmente con decoración rústica, boho, provenzal, minimalista o clásica — no necesitas forrar ni ocultar la estructura. Las bancas integradas eliminan la necesidad de rentar sillas por separado, lo que reduce costos y simplifica la logística de tu boda."
/>

<!-- Galería + Sidebar -->
<section class="section" id="montajes">
  <SectionHeader
    tag="h2"
    title="Así se Ve en Bodas Reales"
    paragraph1="Montajes con bancas de pino natural en jardines, haciendas y terrazas. Cada imagen es de un evento real o referencia para que visualices cómo queda en tu espacio."
    paragraph2="Explora los modelos recomendados en la barra lateral para cotizar según tu número de invitados."
  />
  <ProductGallery
    images={[
      { src: "/img/mesa-picnic-boda-elegante-decoracion.avif", alt: "Bancas de madera con flores y velas para boda en jardín" },
      { src: "/img/mesa-picnic-boda-elegante-decoracion.avif", alt: "Montaje rústico con eucalipto en hacienda" },
      { src: "/img/mesa-picnic-boda-elegante-decoracion.avif", alt: "Boda boho con pampas y macramé sobre bancas de pino" },
      { src: "/img/mesa-picnic-boda-elegante-decoracion.avif", alt: "Mesa principal de novios decorada con lino y rosas" },
      { src: "/img/mesa-picnic-boda-elegante-decoracion.avif", alt: "Vista general con 15 bancas en jardín al atardecer" },
      { src: "/img/mesa-picnic-boda-elegante-decoracion.avif", alt: "Boda íntima con 4 bancas entre árboles maduros" },
      { src: "/img/mesa-picnic-boda-elegante-decoracion.avif", alt: "Montaje nocturno con series de luces cálidas" },
      { src: "/img/mesa-picnic-boda-elegante-decoracion.avif", alt: "Bancas con cojines de algodón para ceremonia civil" },
      { src: "/img/mesa-picnic-boda-elegante-decoracion.avif", alt: "Detalle de centro de mesa con lavanda sobre pino natural" },
    ]}
    recommended={[
      { title: "Mesa Rústica", description: "Acabado campestre, 8 personas", href: "/catalogo/mesa-picnic-rustica/" },
      { title: "Mesa Estándar", description: "Versátil, 6-8 personas", href: "/catalogo/mesa-picnic-estandar/" },
      { title: "Mesa Grande", description: "Mesa principal, 10-12 personas", href: "/catalogo/mesa-picnic-grande/" },
      { title: "Set Completo", description: "Con decoración incluida", href: "/catalogo/set-picnic-completo/" },
      { title: "Paquete Estándar", description: "6 bancas + sombrillas", href: "/paquetes/estandar/" },
    ]}
    sidebarTitle="Mobiliario para bodas"
  />
</section>

<!-- Estilos de boda (nivel 3) -->
<section class="section section-alt" id="estilos">
  <SectionHeader
    tag="h2"
    title="Estilos de Boda que Montamos"
    paragraph1="La madera natural funciona como base neutra que se adapta a cualquier concepto. Cada estilo tiene su propia página con detalles, venues recomendados y mobiliario específico."
    paragraph2="Coordinamos directamente con tu wedding planner o decoradora para definir la distribución de las bancas según el estilo que elijas."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard title="Boda Rústica" description="Madera al natural con flores silvestres, velas y caminos de yute. El estilo más popular para jardines y haciendas. Combina con iluminación cálida de serie de luces." image="/img/mesa-picnic-boda-elegante-decoracion.avif" href="/servicios/bodas/rustica/" btnLabel="Boda rústica" />
      <ServiceCard title="Boda Boho" description="Pampas, macramé y telas naturales sobre las bancas. Ideal para bosques, viñedos y espacios con vegetación. Las bancas de pino complementan la estética orgánica." image="/img/mesa-picnic-boda-elegante-decoracion.avif" href="/servicios/bodas/boho/" btnLabel="Boda boho" />
      <ServiceCard title="Boda Clásica" description="Manteles de lino, vajilla de porcelana y centros de mesa con rosas. La superficie lisa de la banca soporta montajes formales sin problema. Para 50 a 300 invitados." image="/img/mesa-picnic-boda-elegante-decoracion.avif" href="/servicios/bodas/clasica/" btnLabel="Boda clásica" />
      <ServiceCard title="Boda Íntima" description="Montaje para 10 a 30 personas con 2 a 5 bancas. Perfecto para ceremonias civiles en jardines privados, terrazas o restaurantes con área exterior." image="/img/mesa-picnic-boda-elegante-decoracion.avif" href="/servicios/bodas/intima/" btnLabel="Boda íntima" />
    </div>
  </div>
</section>

<!-- Qué incluye -->
<section class="section" id="incluye">
  <SectionHeader
    tag="h2"
    title="Qué Incluye el Servicio para Bodas"
    paragraph1="Todo lo que necesitas para que el mobiliario de tu boda esté listo sin que tú ni tu familia muevan una sola pieza. Nuestro equipo se encarga de la logística completa."
    paragraph2="Coordinamos directamente con tu wedding planner o decoradora para definir la disposición de las bancas, los pasillos de circulación y los puntos de iluminación."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="Entrega en tu Venue" description="Llegamos al jardín, hacienda o terraza entre 3 y 4 horas antes de la ceremonia. Cubrimos todas las alcaldías de CDMX y municipios del Edomex." />
      <FeatureCard title="Montaje según Plano" description="Colocamos cada banca según el plano acordado con tu planner. Definimos pasillos de circulación, zona de banquete, área de ceremonia y rincones de foto." />
      <FeatureCard title="Sin Límite de Hora" description="Las bancas quedan en tu boda hasta que termine. Si la fiesta acaba a las 3 am, recogemos a las 3 am. No cobramos tiempo extra." />
      <FeatureCard title="Recolección al Terminar" description="Al día siguiente o al finalizar el evento, nuestro equipo recoge todo el mobiliario. El precio incluye este servicio — sin cargos adicionales." />
    </div>
  </div>
</section>

<!-- Referencia cantidad -->
<section class="section section-alt" id="datos">
  <SectionHeader
    tag="h2"
    title="Referencia de Cantidad por Invitados"
    paragraph1="Usa estos números como referencia rápida. La cantidad final depende del layout del venue y si quieres bancas estándar, grandes o combinadas."
    paragraph2="Mándanos tu número de invitados y las medidas de tu venue por WhatsApp y te calculamos todo con un plano de distribución."
  />
  <div class="container">
    <div class="grid-4">
      <FeatureCard title="30 Invitados" description="4-5 bancas estándar. Boda íntima en jardín privado o terraza. Cabe en un espacio de 50 m²." />
      <FeatureCard title="80 Invitados" description="11-14 bancas estándar. Boda mediana en jardín o hacienda. Espacio recomendado: 100 m²." />
      <FeatureCard title="150 Invitados" description="20-22 bancas estándar. Boda grande con banquete completo. Espacio recomendado: 150+ m²." />
      <FeatureCard title="300 Invitados" description="40-50 bancas. Boda masiva en hacienda o finca. Reserva con 2 semanas de anticipación mínimo." />
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section" id="faq">
  <SectionHeader
    tag="h2"
    title="Preguntas sobre Bodas"
    paragraph1="Las dudas más comunes que recibimos de parejas y wedding planners antes de reservar el mobiliario para su boda."
    paragraph2="Si tu pregunta no está aquí, escríbenos por WhatsApp y te respondemos en minutos."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    items={[
      { question: "¿Cuántas bancas necesito para mi boda?", answer: "Cada banca estándar sienta 6-8 personas. Para 100 invitados necesitas 14-16 unidades, para 150 necesitas 20-22, para 200 necesitas 28-30. Mándanos tu número de invitados y te calculamos la cantidad exacta." },
      { question: "¿Combinan con decoración elegante?", answer: "Sí. La madera de pino acepta manteles de lino, vajilla de porcelana, candelabros y centros de mesa con flores sin desentonar." },
      { question: "¿Entregan en haciendas fuera de la ciudad?", answer: "Cubrimos toda la zona metropolitana y municipios del Estado de México. Para haciendas más lejanas, escríbenos la ubicación y confirmamos disponibilidad y costo de traslado." },
      { question: "¿Pueden coordinarse con mi wedding planner?", answer: "Sí, trabajamos directo con tu planner o decoradora. Les enviamos las medidas de cada pieza y coordinamos el plano de distribución antes del evento." },
      { question: "¿Qué pasa si llueve el día de mi boda?", answer: "La madera está tratada y resiste humedad moderada. Recomendamos contar con carpas o toldos como plan B. Si cancelas por clima, puedes reagendar sin costo adicional." },
      { question: "¿Puedo ver las bancas antes de reservar?", answer: "Sí, puedes agendar una visita a nuestro almacén para ver el mobiliario en persona. También te mandamos fotos y video del estado actual de las piezas por WhatsApp." }
    ]}
  />
</section>

<!-- CTA Final -->
<CtaBarFinal
  headline="¿Lista para tu boda?"
  subtext="Cotiza el mobiliario para tu fecha. Te respondemos el mismo día."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero cotizar mesas picnic para mi boda."
  cotizarHref="/cotizar/"
/>

<!-- WA Bubble -->
<WaBubble whatsapp="5564328954" message="Hola, quiero cotizar mesas de madera para mi boda." />

<!-- Schema -->
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Renta de Mesas Picnic para Bodas",
    "provider": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-3128-1706" },
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "State", "name": "Estado de México" }
    ],
    "description": "Renta de bancas de madera de pino para bodas al aire libre en CDMX y Edomex. Incluye entrega, montaje y recolección."
  })} />
</Fragment>

</BaseLayout>

<style>
  :global(.hero) {
    padding-top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2.5rem + 3rem);
  }

  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 1024px) {
    .grid-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .grid-4 { grid-template-columns: 1fr; }
  }
</style>
