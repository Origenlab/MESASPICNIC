---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Cotizar Mesas Picnic — MESPIC | Cotización Gratis"
  description="Solicita tu cotización gratuita de renta de mesas picnic para eventos en CDMX y Edomex. Respuesta inmediata por WhatsApp."
>

<Hero
  title="Cotiza tu Evento"
  description="Recibe una cotización personalizada en minutos. Sin compromiso, sin costos ocultos. Cuéntanos sobre tu evento y te hacemos la mejor propuesta."
  ctaPrimary={{ label: "WhatsApp directo →", href: "https://wa.me/5215512345678?text=Hola%2C%20quiero%20cotizar%20mesas%20picnic" }}
  ctaSecondary={{ label: "Ver servicios", href: "/servicios/" }}
  seoParagraph1="Cotizar mesas picnic con MESPIC es fácil y rápido. Solo necesitas decirnos la fecha de tu evento, el número de invitados, la ubicación y el tipo de evento. Con esa información te enviamos una cotización detallada al momento."
  seoParagraph2="Todas nuestras cotizaciones incluyen entrega, montaje profesional y recolección sin costos adicionales. No hay sorpresas ni cargos ocultos. El precio que te damos es el precio final. Aceptamos efectivo, transferencia y tarjeta."
/>

<section class="section">
  <div class="container">
    <div class="cotizar-grid">
      <div class="cotizar-form-wrap">
        <h2>Solicitar cotización</h2>
        <form class="cotizar-form" id="cotizarForm">
          <div class="form-row">
            <div class="form-group">
              <label for="nombre">Nombre completo *</label>
              <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
            </div>
            <div class="form-group">
              <label for="telefono">Teléfono / WhatsApp *</label>
              <input type="tel" id="telefono" name="telefono" required placeholder="55 1234 5678" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Correo electrónico</label>
              <input type="email" id="email" name="email" placeholder="tu@email.com" />
            </div>
            <div class="form-group">
              <label for="tipo-evento">Tipo de evento *</label>
              <select id="tipo-evento" name="tipo-evento" required>
                <option value="">Selecciona...</option>
                <option value="boda">Boda</option>
                <option value="corporativo">Evento corporativo</option>
                <option value="infantil">Fiesta infantil</option>
                <option value="tematica">Fiesta temática</option>
                <option value="otro">Otro</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="fecha">Fecha del evento *</label>
              <input type="date" id="fecha" name="fecha" required />
            </div>
            <div class="form-group">
              <label for="invitados">Número de invitados *</label>
              <input type="number" id="invitados" name="invitados" required placeholder="Ej: 50" min="1" />
            </div>
          </div>
          <div class="form-group">
            <label for="ubicacion">Ubicación del evento *</label>
            <input type="text" id="ubicacion" name="ubicacion" required placeholder="Colonia, alcaldía/municipio" />
          </div>
          <div class="form-group">
            <label for="detalles">Detalles adicionales</label>
            <textarea id="detalles" name="detalles" rows="3" placeholder="Cuéntanos más sobre tu evento..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Enviar solicitud de cotización</button>
        </form>
      </div>

      <div class="cotizar-info">
        <div class="info-card">
          <h3>¿Qué incluye nuestra cotización?</h3>
          <ul class="check-list">
            <li>Renta de mesas picnic de madera natural</li>
            <li>Entrega en tu ubicación</li>
            <li>Montaje profesional</li>
            <li>Uso sin límite de tiempo</li>
            <li>Recolección al finalizar</li>
            <li>Sin costos ocultos</li>
          </ul>
        </div>

        <div class="info-card">
          <h3>¿Prefieres WhatsApp?</h3>
          <p>Si prefieres atención inmediata, escríbenos directamente por WhatsApp y te respondemos al instante.</p>
          <a href="https://wa.me/5215512345678?text=Hola%2C%20quiero%20cotizar%20mesas%20picnic%20para%20mi%20evento" class="btn btn-wa" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp directo
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .cotizar-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 3rem;
    align-items: start;
  }

  .cotizar-form-wrap h2 {
    font-size: 1.5rem;
    color: var(--c-primary);
    margin-bottom: 2rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--c-text);
  }

  .form-group input, .form-group textarea, .form-group select {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.2s;
    background: #fff;
  }

  .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
    outline: none;
    border-color: var(--c-primary);
  }

  .info-card {
    background: var(--c-bg-alt);
    border-radius: var(--radius-md);
    padding: 2rem;
    margin-bottom: 1.5rem;
  }

  .info-card h3 {
    font-size: 1.125rem;
    color: var(--c-primary);
    margin-bottom: 1rem;
  }

  .info-card p {
    color: var(--c-text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .check-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .check-list li {
    padding-left: 1.75rem;
    position: relative;
    color: var(--c-text);
    line-height: 1.6;
  }

  .check-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--c-primary);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .cotizar-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
