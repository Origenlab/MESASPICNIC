---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import WaBubble from '../../../components/WaBubble.astro';
---

<BaseLayout
  title="Paquete Básico de Mesas Picnic — 24 Personas | MESPIC CDMX"
  description="Paquete Básico de MESPIC: 4 bancas de pino natural para eventos de hasta 24 personas en CDMX y Edomex. Precio final con traslado, montaje y recolección incluidos. Ideal para reuniones familiares y corporativos pequeños."
  ogImage="/img/reunion-familiar-mesas-picnic-coyoacan-03.avif"
>

<!-- Breadcrumbs -->
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Paquetes", href: "/paquetes/" },
    { label: "Paquete Básico" }
  ]} />
</Fragment>

<!-- Hero -->
<Hero
  badge="Paquete Básico"
  title="Paquete Básico — 4 Bancas para Hasta 24 Personas"
  description="El paquete de entrada de MESPIC. Cuatro bancas de pino natural (1.80 × 1.50 m), con capacidad total de 24 personas. Precio final que incluye traslado, montaje y recolección en CDMX y Edomex."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="El Paquete Básico está pensado para eventos íntimos y reuniones de escala pequeña donde no se necesita mucho mobiliario pero sí se quiere la experiencia completa de servicio: entrega puntual, montaje profesional y recolección al terminar. Las 4 bancas estándar cubren cómodamente desde una reunión familiar de 15 personas hasta un cumpleaños íntimo de 24 invitados."
  seoParagraph2="La composición base incluye 4 bancas estándar de pino nacional (1.80 × 1.50 m, 6 personas por banca). Si necesitas ajustar el modelo de banca — por ejemplo, cambiar alguna por bancas grandes o agregar una infantil para niños — lo cotizamos sin costo adicional de asesoría. El precio final es siempre el mismo que aparece en la cotización: sin sorpresas el día del evento."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<!-- GALERÍA + SIDEBAR -->
<section class="section" id="galeria">
  <SectionHeader
    tag="h2"
    badge="Paquete Básico en eventos"
    title="El Paquete Básico en Reuniones, Cumpleaños y Eventos Íntimos"
    paragraph1="4 bancas bien distribuidas crean un espacio acogedor para grupos pequeños. Así se ve el Paquete Básico en diferentes tipos de eventos."
    paragraph2="¿Tienes entre 20 y 30 invitados? El Básico cubre perfectamente hasta 24. Si son más, el Paquete Estándar (6 bancas, 36 personas) es el siguiente paso."
  />
  <ProductGallery
    images={[
      { src: "/img/reunion-familiar-mesas-picnic-coyoacan-03.avif",        alt: "Paquete básico de 4 mesas picnic para reunión familiar con comida en jardín privado" },
      { src: "/img/baby-shower-mesas-picnic-madera-cdmx-01.avif",                          alt: "4 bancas picnic distribuidas para cumpleaños íntimo de niños con decoración temática" },
      { src: "/img/picnic-romantico-bridal-shower-mesas-pino-02.avif",          alt: "Paquete básico montado para celebración íntima de pareja en jardín exterior CDMX" },
      { src: "/img/eventos-corporativos-ejecutivos-renta-mesas-picnic-02.avif",                        alt: "4 bancas de pino natural para reunión corporativa pequeña de equipo al aire libre" },
      { src: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif",       alt: "Paquete básico para boda íntima con 20 invitados en jardín privado" },
      { src: "/img/mesa-picnic-madera-renta-cdmx-05.avif",                            alt: "4 bancas con decoración temática para posada o reunión familiar navideña en jardín" },
    ]}
    recommended={[
      { title: "Paquete Estándar",  description: "6 bancas · 36 personas",      href: "/paquetes/estandar/",             image: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" },
      { title: "Paquete Premium",   description: "10 bancas · 60 personas",     href: "/paquetes/premium/",              image: "/img/cine-aire-libre-mesas-picnic-festival-04.avif" },
      { title: "Mesa Estándar",     description: "Pieza individual · 6 pax",    href: "/catalogo/mesa-picnic-estandar/", image: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" },
      { title: "Set Picnic",        description: "Mesa + decoración incluida",  href: "/catalogo/set-picnic-completo/",  image: "/img/picnic-romantico-bridal-shower-mesas-pino-02.avif" },
      { title: "Cotizar volumen",   description: "+60 personas",                href: "/cotizar/",                       image: "/img/cine-aire-libre-mesas-picnic-festival-04.avif" },
    ]}
    sidebarTitle="Otros paquetes disponibles"
  />
</section>

<!-- COMPOSICIÓN DEL PAQUETE -->
<section class="section section-alt" id="composicion">
  <SectionHeader
    tag="h2"
    badge="Composición del paquete"
    title="Qué Incluye el Paquete Básico"
    paragraph1="La composición base y todo lo que está cubierto en el precio. Sin letra chica, sin cargos que se descubren el día del evento."
    stats={[
      { value: '4',          label: 'bancas incluidas' },
      { value: '24',         label: 'personas cubiertas' },
      { value: 'precio final', label: 'todo incluido' },
    ]}
  />
  <div class="container">
    <div class="spec-grid">
      <div class="spec-card">
        <h3 class="spec-card__title">Composición Base</h3>
        <ul class="spec-list" role="list">
          <li class="spec-list__item">
            <span class="spec-list__label">Bancas incluidas</span>
            <span class="spec-list__value">4 bancas estándar</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Modelo base</span>
            <span class="spec-list__value">Mesa estándar 1.80 × 1.50 m</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Capacidad total</span>
            <span class="spec-list__value">24 personas</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Traslado</span>
            <span class="spec-list__value spec-list__value--ok">Incluido</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Montaje</span>
            <span class="spec-list__value spec-list__value--ok">Incluido</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Tiempo de uso</span>
            <span class="spec-list__value spec-list__value--ok">Sin límite</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Recolección</span>
            <span class="spec-list__value spec-list__value--ok">Incluida</span>
          </li>
        </ul>
        <a href="/cotizar/" class="spec-card__cta">Cotizar Paquete Básico →</a>
      </div>

      <div class="spec-features">
        <FeatureCard
          index={0}
          title="4 Bancas Estándar de Pino"
          description="Cuatro bancas de 1.80 × 1.50 m, cada una con capacidad para 6 personas. Pino nacional lijado y barnizado a mano, inspeccionado antes de cada entrega. El mismo mobiliario que va a bodas y corporativos."
        />
        <FeatureCard
          index={1}
          title="Composición Personalizable"
          description="La composición base es 4 estándar, pero puede ajustarse. Si prefieres combinar 2 estándar con 1 grande y 1 infantil para un evento con niños, lo cotizamos como paquete personalizado sin costo adicional."
        />
        <FeatureCard
          index={2}
          title="Espacio Requerido: ~40 m²"
          description="4 bancas bien distribuidas ocupan aproximadamente 40 m² de espacio útil, incluyendo circulación entre mesas. Ideal para jardines medianos, terrazas y áreas exteriores de casas."
        />
        <FeatureCard
          index={3}
          title="Tiempo de Montaje: 20–30 min"
          description="4 bancas se montan en 20 a 30 minutos. Nuestro equipo llega con suficiente anticipación para que todo esté listo antes de que comiencen a llegar tus invitados."
        />
      </div>
    </div>
  </div>
</section>

<!-- IDEAL PARA -->
<section class="section" id="usos">
  <SectionHeader
    tag="h2"
    badge="Ideal para"
    title="Para Qué Tipo de Evento es el Paquete Básico"
    paragraph1="El Paquete Básico es la elección correcta para celebraciones íntimas donde la escala pequeña es parte del concepto del evento, no una limitación."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard
        title="Reuniones Familiares"
        description="Comidas dominicales, cumpleaños de adultos, posadas pequeñas y reuniones de fin de año con la familia cercana. Las 4 bancas crean un espacio íntimo y cómodo para 15 a 24 personas."
        image="/img/reunion-familiar-mesas-picnic-coyoacan-03.avif"
        href="/servicios/reuniones-familiares/"
        btnLabel="Reuniones familiares"
        badge="Familiar"
      />
      <ServiceCard
        title="Fiestas Infantiles"
        description="Cumpleaños de niños con zona de actividades, pastel y refrigerios para 20 a 24 pequeños. Si combinas 2 estándar para adultos y 2 infantiles para niños, cubre perfectamente una fiesta familiar completa."
        image="/img/baby-shower-mesas-picnic-madera-cdmx-01.avif"
        href="/servicios/fiestas-infantiles/"
        btnLabel="Fiestas infantiles"
        badge="Infantil"
      />
      <ServiceCard
        title="Eventos Corporativos Pequeños"
        description="Almuerzos ejecutivos de equipo, dinámicas de integración de área o reuniones de trabajo en formato outdoor para grupos de 12 a 24 personas."
        image="/img/eventos-corporativos-ejecutivos-renta-mesas-picnic-02.avif"
        href="/servicios/eventos-corporativos/"
        btnLabel="Corporativos"
        badge="Corporativo"
      />
      <ServiceCard
        title="Baby Showers"
        description="4 bancas son suficientes para un baby shower íntimo de 20 a 24 invitadas. El mobiliario de madera natural encaja con la estética pastel, boho y floral que caracteriza a estos eventos."
        image="/img/picnic-romantico-bridal-shower-mesas-pino-02.avif"
        href="/servicios/reuniones-familiares/"
        btnLabel="Baby showers"
        badge="Baby shower"
      />
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section section-alt" id="faq">
  <SectionHeader
    tag="h2"
    badge="Preguntas frecuentes"
    title="Preguntas sobre el Paquete Básico"
    paragraph1="Todo lo que necesitas saber antes de reservar el Paquete Básico para tu evento."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    waMessage="Hola, quiero cotizar el Paquete Básico de mesas picnic para mi evento."
    items={[
      {
        question: "¿Qué pasa si mis invitados son 26 o 28, no exactamente 24?",
        answer: "El Paquete Básico cubre cómodamente hasta 24 personas (6 por banca). Para 26 a 28 invitados, puedes agregar 1 banca extra al paquete o pasar al Paquete Estándar (6 bancas, 36 personas). Te recomendamos el estándar si esperas 25 o más invitados para que nadie esté apretado."
      },
      {
        question: "¿Puedo cambiar las bancas estándar por bancas grandes en el Paquete Básico?",
        answer: "Sí. Si prefieres 2 bancas grandes (10–12 personas) en lugar de 4 estándar, lo ajustamos. La capacidad total cambia, así que te asesoramos según el número real de invitados para garantizar que el mobiliario sea suficiente."
      },
      {
        question: "¿Cuánto espacio necesito para 4 bancas?",
        answer: "Las 4 bancas ocupan aproximadamente 40 m² considerando el espacio de circulación. Para un jardín doméstico mediano o una terraza amplia es más que suficiente. Si quieres verificar si tu espacio es adecuado, mándanos las medidas aproximadas por WhatsApp."
      },
      {
        question: "¿El Paquete Básico está disponible en temporada alta (diciembre, enero)?",
        answer: "Sí, pero en temporada alta los fines de semana se reservan rápido. Para fechas de noviembre a febrero recomendamos reservar con al menos 2 semanas de anticipación para garantizar disponibilidad."
      },
      {
        question: "¿Puedo subir de Básico a Estándar o Premium después de reservar?",
        answer: "Sí, siempre que haya disponibilidad de las bancas adicionales en tu fecha. Notifícanos el cambio con al menos 48 horas de anticipación. Si el inventario lo permite, ajustamos el paquete y la cotización sin penalización."
      }
    ]}
  />
</section>

<CtaBarFinal
  headline="¿Tu evento es para hasta 24 personas?"
  subtext="El Paquete Básico es el que necesitas. Cotiza sin compromiso y te confirmamos el mismo día."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero cotizar el Paquete Básico de mesas picnic para mi evento."
  cotizarHref="/cotizar/"
/>

<WaBubble whatsapp="5564328954" message="Hola, quiero cotizar el Paquete Básico de mesas picnic." />

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paquete Básico — Renta de Mesas Picnic MESPIC",
    "description": "4 bancas de pino natural para eventos de hasta 24 personas en CDMX y Edomex. Incluye traslado, montaje, uso sin límite y recolección. Precio final sin extras.",
    "brand": { "@type": "Brand", "name": "MESPIC" },
    "offers": {
      "@type": "Offer",
      "priceCurrency": "MXN",
      "availability": "https://schema.org/InStock",
      "seller": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-6432-8954", "url": "https://mesaspicnic.com" }
    }
  })} />
</Fragment>

</BaseLayout>

<style>
  .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .grid-4 { grid-template-columns: 1fr; } }

  .spec-grid { display: grid; grid-template-columns: 320px 1fr; gap: 2rem; align-items: start; }
  .spec-card { background: #fff; border: 1px solid var(--c-border, #E7E0D8); border-radius: var(--radius-md, 12px); padding: 1.75rem; position: sticky; top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2rem); }
  .spec-card__title { font-size: 1rem; font-weight: 700; color: var(--c-text, #1C1917); margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 2px solid var(--c-primary, #2C5530); }
  .spec-list { list-style: none; display: flex; flex-direction: column; margin-bottom: 1.5rem; }
  .spec-list__item { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.625rem 0; border-bottom: 1px solid var(--c-border, #E7E0D8); }
  .spec-list__item:last-child { border-bottom: none; }
  .spec-list__label { font-size: 0.8125rem; color: var(--c-text-muted, #78716C); font-weight: 500; flex-shrink: 0; }
  .spec-list__value { font-size: 0.8125rem; color: var(--c-text, #1C1917); font-weight: 600; text-align: right; }
  .spec-list__value--ok { color: var(--c-primary, #2C5530); }
  .spec-card__cta { display: flex; align-items: center; justify-content: center; background: var(--c-primary, #2C5530); color: #fff; padding: 0.75rem 1.25rem; border-radius: 8px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.18s ease; }
  .spec-card__cta:hover { background: #224228; }
  .spec-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  @media (max-width: 1024px) { .spec-grid { grid-template-columns: 1fr; } .spec-card { position: static; } }
  @media (max-width: 640px)  { .spec-features { grid-template-columns: 1fr; } }
</style>
