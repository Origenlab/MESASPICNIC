---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import NextStep from '../../../components/NextStep.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import WaBubble from '../../../components/WaBubble.astro';
---

<BaseLayout
  title="Paquete Estándar de Mesas Picnic — 36 Personas | MESPIC CDMX"
  description="Paquete Estándar de MESPIC: 6 bancas de pino natural para eventos de hasta 36 personas en CDMX y Edomex. El paquete más solicitado. Precio final con traslado, montaje y recolección incluidos."
  ogImage="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif"
>

<!-- Breadcrumbs -->
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Paquetes", href: "/paquetes/" },
    { label: "Paquete Estándar" }
  ]} />
</Fragment>

<!-- Hero -->
<Hero
  badge="Paquete Estándar — El más solicitado"
  title="Paquete Estándar — 6 Bancas para Hasta 36 Personas"
  description="El paquete más reservado de MESPIC. Seis bancas de pino natural que cubren cómodamente eventos de hasta 36 personas. Precio final con traslado, montaje y recolección incluidos en CDMX y Edomex."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="El Paquete Estándar es el más reservado del catálogo de MESPIC porque cubre el rango de invitados más frecuente en eventos familiares y corporativos medianos: entre 25 y 36 personas. Las 6 bancas de pino natural se distribuyen en aproximadamente 60 m² de espacio útil y crean un ambiente cómodo donde todos los invitados tienen lugar sin estar apretados."
  seoParagraph2="La composición base incluye 6 bancas estándar de 1.80 × 1.50 m. Como en todos los paquetes, la composición es ajustable: si prefieres combinar estándar con grandes, o agregar una banca infantil para la zona de niños, lo cotizamos sin costo adicional. El precio incluye traslado al evento, montaje profesional, uso sin límite de horas y recolección al terminar — todo en una sola cotización sin sorpresas."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<!-- GALERÍA + SIDEBAR -->
<section class="section" id="galeria">
  <SectionHeader
    tag="h2"
    badge="El Estándar en eventos"
    title="6 Bancas en Cumpleaños, Posadas, Bodas Íntimas y Corporativos"
    paragraph1="El rango de 25 a 36 personas es el más común en eventos privados. Así se ve el Paquete Estándar distribuido en diferentes tipos de celebración."
    paragraph2="¿Tus invitados son más de 36? El Paquete Premium (10 bancas, 60 personas) es el siguiente paso. También podemos cotizar combinaciones personalizadas."
  />
  <ProductGallery
    images={[
      { src: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif",       alt: "6 bancas picnic estándar para boda íntima de 30 personas en jardín CDMX" },
      { src: "/img/eventos-corporativos-ejecutivos-renta-mesas-picnic-02.avif",                        alt: "Paquete estándar distribuido en parque para team building corporativo de 36 personas" },
      { src: "/img/mesa-picnic-madera-renta-cdmx-05.avif",                            alt: "6 mesas picnic con decoración para posada navideña familiar de 30 invitados" },
      { src: "/img/baby-shower-mesas-picnic-madera-cdmx-01.avif",                          alt: "Paquete estándar para cumpleaños familiar con zona de adultos y zona de niños" },
      { src: "/img/mesa-picnic-lujo-madera-exterior-renta-01.avif",            alt: "6 bancas estándar con iluminación cálida para evento nocturno de 36 personas" },
      { src: "/img/reunion-familiar-mesas-picnic-coyoacan-03.avif",        alt: "Paquete estándar en comida familiar de fin de año con 30 invitados en terraza" },
    ]}
    recommended={[
      { title: "Paquete Básico",    description: "4 bancas · 24 personas",      href: "/paquetes/basico/",               image: "/img/reunion-familiar-mesas-picnic-coyoacan-03.avif" },
      { title: "Paquete Premium",   description: "10 bancas · 60 personas",     href: "/paquetes/premium/",              image: "/img/cine-aire-libre-mesas-picnic-festival-04.avif" },
      { title: "Mesa Estándar",     description: "Pieza individual · 6 pax",    href: "/catalogo/mesa-picnic-estandar/", image: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" },
      { title: "Mesa Grande",       description: "Pieza individual · 10–12 pax", href: "/catalogo/mesa-picnic-grande/",  image: "/img/mesas-picnic-madera-renta-evento-cdmx-05.avif" },
      { title: "Cotizar volumen",   description: "+60 personas",                href: "/cotizar/",                       image: "/img/cine-aire-libre-mesas-picnic-festival-04.avif" },
    ]}
    sidebarTitle="Otros paquetes disponibles"
  />
</section>

<!-- COMPOSICIÓN -->
<section class="section section-alt" id="composicion">
  <SectionHeader
    tag="h2"
    badge="Composición del paquete"
    title="Qué Incluye el Paquete Estándar"
    paragraph1="Todo lo que viene incluido en el precio. Sin costos adicionales el día del evento."
    stats={[
      { value: '6',          label: 'bancas incluidas' },
      { value: '36',         label: 'personas cubiertas' },
      { value: '~60 m²',     label: 'espacio requerido' },
    ]}
  />
  <div class="container">
    <div class="spec-grid">
      <div class="spec-card">
        <h3 class="spec-card__title">Composición Base</h3>
        <ul class="spec-list" role="list">
          <li class="spec-list__item">
            <span class="spec-list__label">Bancas incluidas</span>
            <span class="spec-list__value">6 bancas estándar</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Modelo base</span>
            <span class="spec-list__value">Mesa estándar 1.80 × 1.50 m</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Capacidad total</span>
            <span class="spec-list__value">36 personas</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Traslado</span>
            <span class="spec-list__value spec-list__value--ok">Incluido</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Montaje</span>
            <span class="spec-list__value spec-list__value--ok">Incluido</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Tiempo de uso</span>
            <span class="spec-list__value spec-list__value--ok">Sin límite</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Recolección</span>
            <span class="spec-list__value spec-list__value--ok">Incluida</span>
          </li>
        </ul>
        <a href="/cotizar/" class="spec-card__cta">Cotizar Paquete Estándar →</a>
      </div>

      <div class="spec-features">
        <FeatureCard
          index={0}
          title="El Paquete Más Solicitado"
          description="El Estándar cubre el rango de invitados más frecuente: entre 25 y 36 personas. Es el punto de equilibrio entre escala y costo que funciona para la mayoría de los eventos privados y corporativos medianos."
        />
        <FeatureCard
          index={1}
          title="6 Bancas — Distribución Flexible"
          description="6 bancas permiten configuraciones variadas: 2 filas de 3, distribución en herradura, 6 islas independientes o combinación con zona de pie. La distribución se define en coordinación con el cliente antes del evento."
        />
        <FeatureCard
          index={2}
          title="~60 m² de Espacio Útil"
          description="6 bancas bien distribuidas ocupan aproximadamente 60 m² incluyendo circulación. Para un jardín de tamaño medio, terraza grande o salón con área exterior es la medida ideal."
        />
        <FeatureCard
          index={3}
          title="Montaje en 30–45 Minutos"
          description="6 bancas requieren entre 30 y 45 minutos de montaje. El equipo llega al menos 1 hora antes del inicio del evento para garantizar que todo esté listo con margen suficiente."
        />
      </div>
    </div>
  </div>
</section>

<!-- IDEAL PARA -->
<section class="section" id="usos">
  <SectionHeader
    tag="h2"
    badge="Ideal para"
    title="Para Qué Tipo de Evento es el Paquete Estándar"
    paragraph1="El rango de 25 a 36 personas cubre la gran mayoría de los eventos privados en CDMX. Aquí los tipos de evento que más frecuentemente reservan el Paquete Estándar."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard
        title="Cumpleaños y Reuniones"
        description="Cumpleaños de adultos de 30 personas, reuniones familiares de fin de año o posadas con 30 a 36 invitados. El paquete más común para celebraciones familiares de escala media."
        image="/img/reunion-familiar-mesas-picnic-coyoacan-03.avif"
        href="/servicios/reuniones-familiares/"
        btnLabel="Reuniones"
        badge="Familiar"
      />
      <ServiceCard
        title="Bodas Íntimas"
        description="Para bodas civiles o ceremonias íntimas de 25 a 36 personas. 6 bancas crean un espacio ceremonial cálido sin la logística de un evento masivo. Ideal para haciendas y jardines privados."
        image="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif"
        href="/servicios/bodas/"
        btnLabel="Bodas íntimas"
        badge="Bodas"
      />
      <ServiceCard
        title="Team Building Corporativo"
        description="Dinámicas de integración para equipos de trabajo de 24 a 36 personas. Las 6 bancas permiten separar al grupo en subequipos o reunirlos todos en un espacio cohesionado."
        image="/img/eventos-corporativos-ejecutivos-renta-mesas-picnic-02.avif"
        href="/servicios/eventos-corporativos/"
        btnLabel="Team building"
        badge="Corporativo"
      />
      <ServiceCard
        title="XV Años y Graduaciones"
        description="Celebraciones de XV años íntimas o graduaciones escolares con familiares cercanos. El paquete estándar da el mobiliario suficiente para el banquete sin sobredimensionar el espacio."
        image="/img/mesa-picnic-madera-renta-cdmx-05.avif"
        href="/servicios/fiestas-tematicas/"
        btnLabel="XV años"
        badge="Celebraciones"
      />
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section section-alt" id="faq">
  <SectionHeader
    tag="h2"
    badge="Preguntas frecuentes"
    title="Preguntas sobre el Paquete Estándar"
    paragraph1="Las dudas más comunes sobre el paquete más reservado de MESPIC."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    waMessage="Hola, quiero cotizar el Paquete Estándar de mesas picnic para mi evento."
    items={[
      {
        question: "¿Por qué el Estándar es el más solicitado?",
        answer: "Porque el rango de 25 a 36 personas cubre la mayoría de los eventos privados en CDMX: cumpleaños familiares, posadas, graduaciones, baby showers medianos y convivencias corporativas de área. Es el punto donde el número de invitados ya requiere mobiliario dedicado, pero la escala todavía es manejable logísticamente."
      },
      {
        question: "¿Puedo agregar una 7ª banca para tener un poco más de espacio?",
        answer: "Sí. Puedes agregar bancas sueltas al paquete base. La cotización se ajusta proporcionalmente. Si necesitas entre 37 y 48 personas, agregar 1 o 2 bancas al Estándar puede ser más conveniente que pasar al Premium completo."
      },
      {
        question: "¿El Paquete Estándar incluye decoración o mantelería?",
        answer: "No. Los paquetes incluyen el mobiliario de madera (bancas), el servicio completo de traslado, montaje y recolección. La decoración, mantelería y centros de mesa no están incluidos. Si quieres decoración integrada, el Set Picnic Completo del catálogo sí la incluye para eventos más pequeños."
      },
      {
        question: "¿Puedo mezclar bancas estándar con bancas grandes en el mismo paquete?",
        answer: "Sí. Por ejemplo, 4 estándar + 1 grande cubre más invitados que 6 estándar. Si tienes una mesa principal que necesitas más larga, combinar modelos es la solución. Cotizamos la combinación exacta que necesites."
      },
      {
        question: "¿Atienden en días entre semana o solo fines de semana?",
        answer: "Operamos los 7 días de la semana, de 8:00 a 20:00 hrs. Los eventos entre semana (miércoles o jueves corporativos, por ejemplo) tienen más disponibilidad y generalmente se pueden confirmar con menos anticipación que los fines de semana."
      }
    ]}
  />
</section>


<!-- Siguiente paso: Cotizar -->
<NextStep
  titulo="¿Ya elegiste tu paquete?"
  subtitulo="Solicita tu cotización sin compromiso. Te confirmamos disponibilidad y precio el mismo día."
  href="/cotizar/"
  btnLabel="Solicitar cotización →"
  step={3}
/>

<CtaBarFinal
  headline="¿Tu evento es para 25 a 36 personas?"
  subtext="El Paquete Estándar es el más solicitado por una razón. Cotiza y confirma tu fecha hoy."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero cotizar el Paquete Estándar de mesas picnic para mi evento."
  cotizarHref="/cotizar/"
/>

<WaBubble whatsapp="5564328954" message="Hola, quiero cotizar el Paquete Estándar de mesas picnic." />

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paquete Estándar — Renta de Mesas Picnic MESPIC",
    "description": "6 bancas de pino natural para eventos de hasta 36 personas en CDMX y Edomex. El paquete más solicitado de MESPIC. Incluye traslado, montaje, uso sin límite y recolección. Precio final.",
    "brand": { "@type": "Brand", "name": "MESPIC" },
    "offers": {
      "@type": "Offer",
      "priceCurrency": "MXN",
      "availability": "https://schema.org/InStock",
      "seller": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-6432-8954" }
    }
  })} />
</Fragment>

</BaseLayout>

<style>
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .grid-4 { grid-template-columns: 1fr; } }

  .spec-grid { display: grid; grid-template-columns: 320px 1fr; gap: 2rem; align-items: start; }
  .spec-card { background: #fff; border: 1px solid var(--c-border, #E7E0D8); border-radius: var(--radius-md, 12px); padding: 1.75rem; position: sticky; top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2rem); }
  .spec-card__title { font-size: 1rem; font-weight: 700; color: var(--c-text, #1C1917); margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 2px solid var(--c-primary, #2C5530); }
  .spec-list { list-style: none; display: flex; flex-direction: column; margin-bottom: 1.5rem; }
  .spec-list__item { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.625rem 0; border-bottom: 1px solid var(--c-border, #E7E0D8); }
  .spec-list__item:last-child { border-bottom: none; }
  .spec-list__label { font-size: 0.8125rem; color: var(--c-text-muted, #78716C); font-weight: 500; flex-shrink: 0; }
  .spec-list__value { font-size: 0.8125rem; color: var(--c-text, #1C1917); font-weight: 600; text-align: right; }
  .spec-list__value--ok { color: var(--c-primary, #2C5530); }
  .spec-card__cta { display: flex; align-items: center; justify-content: center; background: var(--c-primary, #2C5530); color: #fff; padding: 0.75rem 1.25rem; border-radius: 8px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.18s ease; }
  .spec-card__cta:hover { background: #224228; }
  .spec-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  @media (max-width: 1024px) { .spec-grid { grid-template-columns: 1fr; } .spec-card { position: static; } }
  @media (max-width: 640px)  { .spec-features { grid-template-columns: 1fr; } }
</style>
