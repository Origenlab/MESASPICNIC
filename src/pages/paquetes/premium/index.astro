---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Hero from '../../../components/Hero.astro';
import CtaBar from '../../../components/CtaBar.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import ProductGallery from '../../../components/ProductGallery.astro';
import FaqSection from '../../../components/FaqSection.astro';
import CtaBarFinal from '../../../components/CtaBarFinal.astro';
import WaBubble from '../../../components/WaBubble.astro';
---

<BaseLayout
  title="Paquete Premium de Mesas Picnic — 60 Personas | MESPIC CDMX"
  description="Paquete Premium de MESPIC: 10 bancas de pino natural para eventos de hasta 60 personas en CDMX y Edomex. Combinación de modelos según el evento. Precio final con traslado, montaje y recolección incluidos."
  ogImage="/img/cine-aire-libre-mesas-picnic-festival-04.avif"
>

<!-- Breadcrumbs -->
<Fragment slot="breadcrumbs">
  <Breadcrumbs items={[
    { label: "Inicio", href: "/" },
    { label: "Paquetes", href: "/paquetes/" },
    { label: "Paquete Premium" }
  ]} />
</Fragment>

<!-- Hero -->
<Hero
  badge="Paquete Premium"
  title="Paquete Premium — 10 Bancas para Hasta 60 Personas"
  description="El paquete de mayor escala del catálogo. Diez bancas en combinación de modelos estándar y/o grande, según el layout y el tipo de evento. Para bodas medianas, corporativos de grupo y festivales de escala completa."
  ctaPrimary={null}
  ctaSecondary={null}
  seoParagraph1="El Paquete Premium está diseñado para eventos donde el número de invitados supera la capacidad del Estándar pero donde el cliente quiere seguir trabajando con un paquete predefinido en lugar de cotizar por volumen. Las 10 bancas cubren cómodamente hasta 60 personas y se distribuyen en aproximadamente 90 m² de espacio útil."
  seoParagraph2="La composición del Paquete Premium es la más flexible de los tres: la combinación de bancas estándar y grandes se define según el tipo de evento y el layout del espacio. Para una boda, típicamente incluimos una proporción mayor de bancas estándar con 1 o 2 grandes para la mesa principal. Para un corporativo o festival, la combinación puede ser distinta. Esto se acuerda en la cotización sin costo adicional. El precio final incluye traslado, montaje, uso ilimitado y recolección."
  dark={true}
/>

<!-- CtaBar -->
<CtaBar />

<!-- GALERÍA + SIDEBAR -->
<section class="section" id="galeria">
  <SectionHeader
    tag="h2"
    badge="El Premium en eventos"
    title="10 Bancas en Bodas Medianas, Corporativos y Festivales"
    paragraph1="60 personas es el umbral donde el evento deja de ser íntimo y se convierte en una celebración de escala completa. Así se ve el Paquete Premium distribuido en diferentes eventos."
    paragraph2="¿Tus invitados son más de 60? Cotizamos por volumen con capacidad para 100 o más personas. Escríbenos con tu número de invitados y fecha."
  />
  <ProductGallery
    images={[
      { src: "/img/cine-aire-libre-mesas-picnic-festival-04.avif",    alt: "Paquete premium con 10 bancas picnic para festival gastronómico de 60 personas CDMX" },
      { src: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif",       alt: "10 bancas estándar distribuidas para boda mediana de 55 personas en jardín" },
      { src: "/img/eventos-corporativos-ejecutivos-renta-mesas-picnic-02.avif",                        alt: "Paquete premium corporativo con 10 mesas picnic para team building de empresa" },
      { src: "/img/mesas-picnic-madera-renta-evento-cdmx-05.avif",  alt: "10 mesas picnic para convivencia corporativa de área completa al aire libre" },
      { src: "/img/mesa-picnic-lujo-madera-exterior-renta-01.avif",            alt: "Paquete premium con iluminación para boda de 60 personas en jardín nocturno" },
      { src: "/img/mesa-picnic-madera-renta-cdmx-05.avif",                            alt: "10 bancas con decoración para fiesta de XV años o graduación de 60 invitados" },
    ]}
    recommended={[
      { title: "Paquete Básico",    description: "4 bancas · 24 personas",      href: "/paquetes/basico/",               image: "/img/reunion-familiar-mesas-picnic-coyoacan-03.avif" },
      { title: "Paquete Estándar",  description: "6 bancas · 36 personas",      href: "/paquetes/estandar/",             image: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" },
      { title: "Mesa Grande",       description: "Pieza individual · 10–12 pax", href: "/catalogo/mesa-picnic-grande/",  image: "/img/mesas-picnic-madera-renta-evento-cdmx-05.avif" },
      { title: "Mesa Estándar",     description: "Pieza individual · 6 pax",    href: "/catalogo/mesa-picnic-estandar/", image: "/img/renta-mesa-picnic-madera-pino-cdmx-01.avif" },
      { title: "Cotizar volumen",   description: "+60 personas",                href: "/cotizar/",                       image: "/img/cine-aire-libre-mesas-picnic-festival-04.avif" },
    ]}
    sidebarTitle="Otros paquetes disponibles"
  />
</section>

<!-- COMPOSICIÓN -->
<section class="section section-alt" id="composicion">
  <SectionHeader
    tag="h2"
    badge="Composición del paquete"
    title="Qué Incluye el Paquete Premium"
    paragraph1="El Premium es el paquete con mayor flexibilidad en composición. La combinación de modelos se define según el formato del evento y el layout del espacio."
    stats={[
      { value: '10',         label: 'bancas incluidas' },
      { value: '60',         label: 'personas cubiertas' },
      { value: '~90 m²',     label: 'espacio requerido' },
    ]}
  />
  <div class="container">
    <div class="spec-grid">
      <div class="spec-card">
        <h3 class="spec-card__title">Composición Base</h3>
        <ul class="spec-list" role="list">
          <li class="spec-list__item">
            <span class="spec-list__label">Bancas incluidas</span>
            <span class="spec-list__value">10 bancas</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Composición</span>
            <span class="spec-list__value">Combinación de modelos</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Capacidad total</span>
            <span class="spec-list__value">Hasta 60 personas</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Traslado</span>
            <span class="spec-list__value spec-list__value--ok">Incluido</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Montaje</span>
            <span class="spec-list__value spec-list__value--ok">Incluido</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Tiempo de uso</span>
            <span class="spec-list__value spec-list__value--ok">Sin límite</span>
          </li>
          <li class="spec-list__item">
            <span class="spec-list__label">Recolección</span>
            <span class="spec-list__value spec-list__value--ok">Incluida</span>
          </li>
        </ul>
        <a href="/cotizar/" class="spec-card__cta">Cotizar Paquete Premium →</a>
      </div>

      <div class="spec-features">
        <FeatureCard
          index={0}
          title="Composición Flexible por Evento"
          description="El Premium es el único paquete donde la combinación de bancas estándar y grandes se define según el evento. Para una boda, más estándar con 1–2 grandes para mesa principal. Para un festival, más grandes para maximizar capacidad por pieza."
        />
        <FeatureCard
          index={1}
          title="Escala Completa — 60 Personas"
          description="60 personas es el umbral donde un evento requiere una operación logística más coordinada. El equipo de MESPIC llega con tiempo suficiente para distribuir 10 bancas según el plano acordado antes de que lleguen los invitados."
        />
        <FeatureCard
          index={2}
          title="~90 m² de Espacio Útil"
          description="10 bancas requieren aproximadamente 90 m² de espacio útil incluyendo circulación. Jardines de hacienda, terrazas amplias, parques y espacios exteriores de salones son los venues más frecuentes para este paquete."
        />
        <FeatureCard
          index={3}
          title="Reserva con Anticipación"
          description="El Paquete Premium mueve más inventario y requiere coordinación logística mayor. Recomendamos reservar con al menos 2 semanas de anticipación, especialmente en temporada alta (noviembre a febrero)."
        />
      </div>
    </div>
  </div>
</section>

<!-- IDEAL PARA -->
<section class="section" id="usos">
  <SectionHeader
    tag="h2"
    badge="Ideal para"
    title="Para Qué Tipo de Evento es el Paquete Premium"
    paragraph1="El Paquete Premium está pensado para eventos de escala completa donde el número de invitados justifica la logística de 10 piezas y la coordinación de un montaje de mayor alcance."
  />
  <div class="container">
    <div class="grid-4">
      <ServiceCard
        title="Bodas Medianas"
        description="Para bodas de 40 a 60 invitados con banquete completo al aire libre. Las 10 bancas permiten una distribución clara entre zona de ceremonia y zona de recepción, con espacio para circulación y fotografía."
        image="/img/renta-mesa-picnic-madera-pino-cdmx-01.avif"
        href="/servicios/bodas/"
        btnLabel="Bodas"
        badge="Bodas"
      />
      <ServiceCard
        title="Corporativos de Área"
        description="Convivencias anuales, celebraciones de cierre de año o team buildings de área completa para 40 a 60 colaboradores. El mobiliario crea un espacio informal y funcional que favorece la integración."
        image="/img/mesas-picnic-madera-renta-evento-cdmx-05.avif"
        href="/servicios/eventos-corporativos/"
        btnLabel="Corporativos"
        badge="Corporativo"
      />
      <ServiceCard
        title="Festivales y Ferias"
        description="Food markets, bazares y ferias gastronómicas con aforo de 50 a 60 personas simultáneas. Las 10 bancas crean zonas de comida definidas que organizan el flujo de asistentes."
        image="/img/cine-aire-libre-mesas-picnic-festival-04.avif"
        href="/servicios/festivales/"
        btnLabel="Festivales"
        badge="Festivales"
      />
      <ServiceCard
        title="XV Años y Graduaciones"
        description="Celebraciones familiares amplias donde los 60 invitados incluyen familia extendida, compañeros y amigos. El Premium da el espacio suficiente para un banquete completo con área de baile o actividades."
        image="/img/mesa-picnic-madera-renta-cdmx-05.avif"
        href="/servicios/fiestas-tematicas/"
        btnLabel="XV años"
        badge="Celebraciones"
      />
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section section-alt" id="faq">
  <SectionHeader
    tag="h2"
    badge="Preguntas frecuentes"
    title="Preguntas sobre el Paquete Premium"
    paragraph1="Las dudas más comunes sobre el paquete de mayor escala del catálogo."
  />
  <FaqSection
    phone="55 6432 8954"
    whatsapp="5564328954"
    schedule="Lun–Dom 8:00–20:00"
    waMessage="Hola, quiero cotizar el Paquete Premium de mesas picnic para mi evento."
    items={[
      {
        question: "¿Cómo se decide la combinación de bancas estándar y grandes?",
        answer: "Lo definimos en la cotización según el tipo de evento y el layout del espacio. Para bodas, solemos usar 7–8 estándar y 1–2 grandes para la mesa principal de novios y padrinos. Para festivales, más grandes para maximizar la capacidad por pieza. Para corporativos, según si necesitan agrupación en equipos o un solo espacio abierto."
      },
      {
        question: "¿El Paquete Premium puede cubrir más de 60 personas?",
        answer: "La composición base cubre hasta 60 personas. Si tus invitados son entre 60 y 70, podemos agregar bancas sueltas al paquete. Para más de 70 personas, recomendamos cotizar por volumen: te enviamos una propuesta personalizada con la cantidad exacta de bancas según el número de invitados y el espacio disponible."
      },
      {
        question: "¿Cuánto tiempo toma montar 10 bancas?",
        answer: "El montaje de 10 bancas toma entre 45 y 60 minutos. El equipo llega con al menos 1 hora y media de anticipación al inicio del evento para garantizar que todo esté distribuido, nivelado y listo antes de que lleguen los primeros invitados."
      },
      {
        question: "¿Necesito contratar coordinación adicional para eventos de 60 personas?",
        answer: "No. Nuestro equipo maneja el montaje de forma autónoma. Si tienes wedding planner, decoradora o coordinador de evento, trabajamos directo con ellos para coordinar la distribución del mobiliario según el plano del evento. No necesitas un punto de contacto adicional de nuestra parte."
      },
      {
        question: "¿Con cuánto tiempo de anticipación debo reservar el Paquete Premium?",
        answer: "Recomendamos al menos 2 semanas para el Paquete Premium. En temporada alta (octubre a febrero), los fines de semana con eventos de esta escala se agotan rápido — reservar con 3 o 4 semanas de anticipación garantiza disponibilidad de los modelos específicos que necesitas."
      }
    ]}
  />
</section>

<CtaBarFinal
  headline="¿Tu evento es para 40 a 60 personas?"
  subtext="El Paquete Premium tiene la escala que necesitas. Cotiza y confirma tu fecha."
  phone="55 6432 8954"
  whatsapp="5564328954"
  waMessage="Hola, quiero cotizar el Paquete Premium de mesas picnic para mi evento."
  cotizarHref="/cotizar/"
/>

<WaBubble whatsapp="5564328954" message="Hola, quiero cotizar el Paquete Premium de mesas picnic." />

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Paquete Premium — Renta de Mesas Picnic MESPIC",
    "description": "10 bancas de pino natural en combinación de modelos para eventos de hasta 60 personas en CDMX y Edomex. Incluye traslado, montaje, uso sin límite y recolección. Precio final.",
    "brand": { "@type": "Brand", "name": "MESPIC" },
    "offers": {
      "@type": "Offer",
      "priceCurrency": "MXN",
      "availability": "https://schema.org/InStock",
      "seller": { "@type": "LocalBusiness", "name": "MESPIC", "telephone": "+52-55-6432-8954" }
    }
  })} />
</Fragment>

</BaseLayout>

<style>
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .grid-4 { grid-template-columns: 1fr; } }

  .spec-grid { display: grid; grid-template-columns: 320px 1fr; gap: 2rem; align-items: start; }
  .spec-card { background: #fff; border: 1px solid var(--c-border, #E7E0D8); border-radius: var(--radius-md, 12px); padding: 1.75rem; position: sticky; top: calc(var(--topbar-height, 36px) + var(--header-height, 70px) + 2rem); }
  .spec-card__title { font-size: 1rem; font-weight: 700; color: var(--c-text, #1C1917); margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 2px solid var(--c-accent, #D4A574); }
  .spec-list { list-style: none; display: flex; flex-direction: column; margin-bottom: 1.5rem; }
  .spec-list__item { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.625rem 0; border-bottom: 1px solid var(--c-border, #E7E0D8); }
  .spec-list__item:last-child { border-bottom: none; }
  .spec-list__label { font-size: 0.8125rem; color: var(--c-text-muted, #78716C); font-weight: 500; flex-shrink: 0; }
  .spec-list__value { font-size: 0.8125rem; color: var(--c-text, #1C1917); font-weight: 600; text-align: right; }
  .spec-list__value--ok { color: var(--c-primary, #2C5530); }
  .spec-card__cta { display: flex; align-items: center; justify-content: center; background: var(--c-accent, #D4A574); color: #fff; padding: 0.75rem 1.25rem; border-radius: 8px; font-size: 0.9375rem; font-weight: 600; text-decoration: none; transition: background 0.18s ease; }
  .spec-card__cta:hover { background: #b8834c; }
  .spec-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  @media (max-width: 1024px) { .spec-grid { grid-template-columns: 1fr; } .spec-card { position: static; } }
  @media (max-width: 640px)  { .spec-features { grid-template-columns: 1fr; } }
</style>
