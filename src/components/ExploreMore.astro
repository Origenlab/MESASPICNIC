---
/**
 * ExploreMore — MESPIC Navigation Funnel
 * ────────────────────────────────────────
 * Sección "Sigue explorando" con cards de navegación
 * relacionada. Mantiene al usuario navegando por el sitio.
 *
 * Props:
 *  - title  : Título de la sección (default: "Sigue explorando")
 *  - items  : Array de cards de navegación
 */
interface ExploreItem {
  href: string;
  label: string;
  sub: string;
  icon: string;        // SVG string o emoji
  badge?: string;      // Etiqueta pequeña (opcional)
  isEmoji?: boolean;   // true si icon es emoji
}

interface Props {
  title?: string;
  subtitle?: string;
  items: ExploreItem[];
}

const {
  title = 'Sigue explorando',
  subtitle,
  items,
} = Astro.props;
---

<section class="explore-more" aria-labelledby="explore-heading">
  <div class="container">
    <div class="explore-more__head">
      <div class="explore-more__title-wrap">
        <span class="explore-more__chip" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <h2 id="explore-heading" class="explore-more__title">{title}</h2>
      </div>
      {subtitle && <p class="explore-more__subtitle">{subtitle}</p>}
    </div>

    <div class="explore-more__grid" style={`--cols: ${Math.min(items.length, 3)}`}>
      {items.map((item) => (
        <a href={item.href} class="explore-card" aria-label={item.label}>
          <div class="explore-card__icon" aria-hidden="true">
            {item.isEmoji ? (
              <span class="explore-card__emoji">{item.icon}</span>
            ) : (
              <span class="explore-card__svg" set:html={item.icon} />
            )}
          </div>
          <div class="explore-card__body">
            {item.badge && (
              <span class="explore-card__badge">{item.badge}</span>
            )}
            <p class="explore-card__label">{item.label}</p>
            <p class="explore-card__sub">{item.sub}</p>
          </div>
          <svg class="explore-card__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .explore-more {
    background: #fff;
    padding: 2.5rem 0;
    border-top: 1px solid var(--c-border, #E7E0D8);
    border-bottom: 1px solid var(--c-border, #E7E0D8);
  }

  /* ─── Header ─── */
  .explore-more__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .explore-more__title-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .explore-more__chip {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(44, 85, 48, 0.08);
    border-radius: 50%;
    color: var(--c-primary, #2C5530);
  }

  .explore-more__title {
    font-size: 1rem;
    font-weight: 750;
    color: var(--c-text, #1C1917);
    margin: 0;
  }

  .explore-more__subtitle {
    font-size: 0.875rem;
    color: var(--c-text-muted, #78716C);
    margin: 0;
  }

  /* ─── Grid ─── */
  .explore-more__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: 1rem;
  }

  /* ─── Card ─── */
  .explore-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.125rem 1.25rem;
    background: var(--c-bg-alt, #FAF8F5);
    border: 1.5px solid var(--c-border, #E7E0D8);
    border-radius: var(--radius-md, 12px);
    text-decoration: none;
    transition: border-color 0.18s ease, background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    position: relative;
  }

  .explore-card:hover {
    border-color: var(--c-primary, #2C5530);
    background: #fff;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(44, 85, 48, 0.1);
  }

  /* Icon */
  .explore-card__icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(44, 85, 48, 0.08);
    border-radius: 10px;
    flex-shrink: 0;
    color: var(--c-primary, #2C5530);
    transition: background 0.18s ease;
  }

  .explore-card:hover .explore-card__icon {
    background: rgba(44, 85, 48, 0.14);
  }

  .explore-card__emoji {
    font-size: 1.25rem;
    line-height: 1;
  }

  .explore-card__svg svg {
    width: 20px;
    height: 20px;
  }

  /* Body */
  .explore-card__body {
    flex: 1;
    min-width: 0;
  }

  .explore-card__badge {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--c-primary, #2C5530);
    background: rgba(44, 85, 48, 0.08);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    margin-bottom: 0.25rem;
  }

  .explore-card__label {
    font-size: 0.9375rem;
    font-weight: 650;
    color: var(--c-text, #1C1917);
    margin: 0 0 0.2rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .explore-card__sub {
    font-size: 0.8125rem;
    color: var(--c-text-muted, #78716C);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Arrow */
  .explore-card__arrow {
    flex-shrink: 0;
    color: rgba(44, 85, 48, 0.3);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.18s ease, transform 0.18s ease, color 0.18s ease;
  }

  .explore-card:hover .explore-card__arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--c-primary, #2C5530);
  }

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .explore-more__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .explore-more__grid {
      grid-template-columns: 1fr;
    }
    .explore-more__head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
