---
/**
 * CtaBar — NavRápida post-hero · OrigenLab Standard v4
 * ─────────────────────────────────────────────────────
 * Strip horizontal oscuro (#111) — contraste total con el hero verde.
 * Patrón homologado con MESECI: ícono + label + subtítulo + flecha.
 * Último ítem = CTA con acento terracota.
 * Scrollable en móvil. Sin animaciones pesadas. Código limpio.
 */
interface NavItem {
  href: string;
  label: string;
  sub: string;
  icon: string;
  cta?: boolean;
}

interface Props {
  items?: NavItem[];
}

const defaultItems: NavItem[] = [
  {
    href: '/servicios/bodas/',
    label: 'Bodas',
    sub: 'Jardines · Haciendas · Terrazas',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`,
  },
  {
    href: '/servicios/eventos-corporativos/',
    label: 'Corporativo',
    sub: 'Team building · Conferencias',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>`,
  },
  {
    href: '/servicios/fiestas-infantiles/',
    label: 'Fiestas infantiles',
    sub: 'Cumpleaños · Baby shower',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
  },
  {
    href: '/servicios/picnic-romantico/',
    label: 'Picnic romántico',
    sub: 'Parejas · Aniversarios',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
  },
  {
    href: '/cotizar/',
    label: 'Cotizar ahora',
    sub: 'Respuesta en minutos',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    cta: true,
  },
];

const { items = defaultItems } = Astro.props;
---

<nav class="nav-rapida" aria-label="Acceso rápido a servicios">
  <div class="nav-rapida__inner">
    {items.map((item) => (
      <a
        href={item.href}
        class:list={['nav-item', item.cta && 'nav-item--cta']}
        aria-label={item.label}
      >
        <span class="nav-item__icon" aria-hidden="true" set:html={item.icon} />
        <span class="nav-item__text">
          <span class="nav-item__label">{item.label}</span>
          <span class="nav-item__sub">{item.sub}</span>
        </span>
        <svg class="nav-item__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </a>
    ))}
  </div>
</nav>

<style>
  /* ══════════════════════════════════════
     Wrapper
     ══════════════════════════════════════ */
  .nav-rapida {
    background: #111;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .nav-rapida::-webkit-scrollbar { display: none; }

  /* ══════════════════════════════════════
     Inner — flex horizontal
     ══════════════════════════════════════ */
  .nav-rapida__inner {
    display: flex;
    align-items: stretch;
    max-width: var(--container, 1400px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ══════════════════════════════════════
     Ítem individual
     ══════════════════════════════════════ */
  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
    padding: 1.125rem 1.25rem;
    color: rgba(255, 255, 255, 0.6);
    border-right: 1px solid rgba(255, 255, 255, 0.07);
    position: relative;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .nav-item:first-child { border-left: none; }
  .nav-item:last-child  { border-right: none; }

  /* línea acento inferior en hover */
  .nav-item::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--c-accent, #C8956C);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s ease;
  }

  .nav-item:hover {
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
  }
  .nav-item:hover::after { transform: scaleX(1); }

  /* ══════════════════════════════════════
     Ícono
     ══════════════════════════════════════ */
  .nav-item__icon {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(200, 149, 108, 0.1);
    border: 1px solid rgba(200, 149, 108, 0.2);
    border-radius: 8px;
    color: var(--c-accent, #C8956C);
    transition: background 0.18s ease, border-color 0.18s ease;
  }
  .nav-item__icon svg {
    width: 18px;
    height: 18px;
  }
  .nav-item:hover .nav-item__icon {
    background: rgba(200, 149, 108, 0.18);
    border-color: rgba(200, 149, 108, 0.4);
  }

  /* ══════════════════════════════════════
     Texto
     ══════════════════════════════════════ */
  .nav-item__text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
    flex: 1;
  }

  .nav-item__label {
    font-size: 0.8125rem;
    font-weight: 650;
    color: rgba(255, 255, 255, 0.85);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.2;
    transition: color 0.18s ease;
  }
  .nav-item:hover .nav-item__label { color: #fff; }

  .nav-item__sub {
    font-size: 0.6875rem;
    color: rgba(255, 255, 255, 0.32);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.01em;
    transition: color 0.18s ease;
  }
  .nav-item:hover .nav-item__sub { color: rgba(255, 255, 255, 0.52); }

  /* ══════════════════════════════════════
     Flecha
     ══════════════════════════════════════ */
  .nav-item__arrow {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    opacity: 0;
    transform: translateX(-4px);
    color: rgba(255, 255, 255, 0.35);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }
  .nav-item:hover .nav-item__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ══════════════════════════════════════
     Variante CTA — último ítem
     ══════════════════════════════════════ */
  .nav-item--cta {
    background: rgba(200, 149, 108, 0.07);
    border-left: 1px solid rgba(200, 149, 108, 0.18);
  }
  .nav-item--cta .nav-item__label {
    color: var(--c-accent, #C8956C);
  }
  .nav-item--cta .nav-item__icon {
    background: rgba(200, 149, 108, 0.15);
    border-color: rgba(200, 149, 108, 0.3);
  }
  .nav-item--cta:hover {
    background: rgba(200, 149, 108, 0.13);
  }
  .nav-item--cta:hover .nav-item__label {
    color: #dba87a;
  }
  .nav-item--cta::after {
    background: var(--c-accent, #C8956C);
  }

  /* ══════════════════════════════════════
     Responsive
     ══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .nav-rapida__inner { padding: 0 1rem; }
    .nav-item { padding: 1rem 0.875rem; gap: 0.625rem; }
    .nav-item__arrow { display: none; }
  }

  @media (max-width: 768px) {
    .nav-rapida__inner {
      padding: 0;
      width: max-content;
      min-width: 100%;
    }
    .nav-item {
      flex: 0 0 auto;
      width: 150px;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      padding: 1rem 1rem;
    }
    .nav-item__icon { width: 32px; height: 32px; }
    .nav-item__icon svg { width: 16px; height: 16px; }
  }
</style>
