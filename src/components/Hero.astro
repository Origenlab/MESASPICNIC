---
/**
 * Hero Component — OrigenLab Standard v3
 * ────────────────────────────────────────
 * 2 columnas obligatorias:
 *   Col 1: Badge + H1 + descripción + CTAs + métricas opcionales
 *   Col 2: 2 párrafos SEO (SOLO TEXTO, sin imágenes)
 * Variante oscura: prop dark={true} activa gradiente forestal
 * Métricas opcionales debajo de los CTAs
 * Sin animaciones. Código limpio.
 */
interface Props {
  badge?: string;
  title: string;
  description: string;
  ctaPrimary?: { label: string; href: string } | null;
  ctaSecondary?: { label: string; href: string } | null;
  seoParagraph1: string;
  seoParagraph2: string;
  dark?: boolean;
  metrics?: Array<{ value: string; label: string }>;
}

const {
  badge = "Renta de Mobiliario",
  title,
  description,
  ctaPrimary = { label: "Cotizar ahora →", href: "/cotizar/" },
  ctaSecondary = { label: "Ver servicios", href: "/servicios/" },
  seoParagraph1,
  seoParagraph2,
  dark = false,
  metrics,
} = Astro.props;
---

<section class:list={["hero", { "hero--dark": dark }]} aria-label="Sección principal">
  <div class="container hero__grid">
    <!-- ═══ COLUMNA 1: Título + CTAs ═══ -->
    <div class="hero__col1">
      {badge && (
        <span class="hero__badge">
          {badge}
        </span>
      )}

      <h1 class="hero__title">{title}</h1>

      <p class="hero__desc">{description}</p>

      {(ctaPrimary || ctaSecondary) && (
        <div class="hero__ctas">
          {ctaPrimary && (
            <a href={ctaPrimary.href} class="hero__cta-primary">
              {ctaPrimary.label}
            </a>
          )}
          {ctaSecondary && (
            <a href={ctaSecondary.href} class="hero__cta-secondary">
              {ctaSecondary.label}
            </a>
          )}
        </div>
      )}

      {metrics && metrics.length > 0 && (
        <div class="hero__metrics">
          {metrics.map((m) => (
            <div class="hero__metric">
              <span class="hero__metric-value">{m.value}</span>
              <span class="hero__metric-label">{m.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- ═══ COLUMNA 2: Párrafos SEO (SOLO TEXTO) ═══ -->
    <div class="hero__col2">
      <p class="hero__seo-text">{seoParagraph1}</p>
      <p class="hero__seo-text">{seoParagraph2}</p>
    </div>
  </div>
</section>

<style>
  /* ══════════════════════════════════════
     Hero — Base (variante clara)
     ══════════════════════════════════════ */
  .hero {
    padding-top: calc(var(--topbar-height, 0px) + var(--header-height, 70px) + 5rem);
    padding-bottom: 5rem;
    background: var(--c-bg-hero, #F2EDE7);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* ══════════════════════════════════════
     Variante oscura — gradiente forestal
     ══════════════════════════════════════ */
  .hero--dark {
    background: linear-gradient(155deg, #1B3B20 0%, #2C5530 50%, #1D4A25 100%);
  }

  /* ══════════════════════════════════════
     Columna 1 — Título + CTAs
     ══════════════════════════════════════ */
  .hero__col1 {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-primary);
    background: rgba(44, 85, 48, 0.08);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    width: fit-content;
    margin-bottom: 1.5rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .hero--dark .hero__badge {
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .hero__title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    color: var(--c-primary-dark, #1B3B20);
    margin-bottom: 1.25rem;
    line-height: 1.08;
    letter-spacing: -0.03em;
    max-width: 520px;
  }

  .hero--dark .hero__title {
    color: #ffffff;
  }

  .hero__desc {
    font-size: 1.0625rem;
    color: var(--c-text-muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 480px;
  }

  .hero--dark .hero__desc {
    color: rgba(255, 255, 255, 0.8);
  }

  .hero__ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  /* ── CTA primario ── */
  .hero__cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2.25rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-lg, 20px);
    text-decoration: none;
    transition: background 0.2s, opacity 0.2s;
    /* variante clara (default) */
    background: var(--c-primary, #2C5530);
    color: #fff;
    border: 2px solid transparent;
  }

  .hero__cta-primary:hover {
    background: var(--c-primary-light, #3D7A45);
  }

  .hero--dark .hero__cta-primary {
    background: #ffffff;
    color: var(--c-primary-dark, #1B3B20);
  }

  .hero--dark .hero__cta-primary:hover {
    background: rgba(255, 255, 255, 0.9);
  }

  /* ── CTA secundario ── */
  .hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-lg, 20px);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
    /* variante clara (default) */
    background: transparent;
    color: var(--c-text, #1C1917);
    border: 2px solid var(--c-border, #E7E0D8);
  }

  .hero__cta-secondary:hover {
    border-color: var(--c-primary, #2C5530);
    color: var(--c-primary, #2C5530);
  }

  .hero--dark .hero__cta-secondary {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.4);
    color: #ffffff;
  }

  .hero--dark .hero__cta-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.7);
  }

  /* ══════════════════════════════════════
     Métricas
     ══════════════════════════════════════ */
  .hero__metrics {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--c-border, #E7E0D8);
  }

  .hero--dark .hero__metrics {
    border-top-color: rgba(255, 255, 255, 0.15);
  }

  .hero__metric {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .hero__metric-value {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--c-primary-dark, #1B3B20);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .hero--dark .hero__metric-value {
    color: #ffffff;
  }

  .hero__metric-label {
    font-size: 0.8125rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.3;
  }

  .hero--dark .hero__metric-label {
    color: rgba(255, 255, 255, 0.65);
  }

  /* ══════════════════════════════════════
     Columna 2 — Párrafos SEO
     ══════════════════════════════════════ */
  .hero__col2 {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero__seo-text {
    font-size: 0.9375rem;
    color: var(--c-text);
    line-height: 1.75;
  }

  .hero--dark .hero__seo-text {
    color: rgba(255, 255, 255, 0.75);
  }

  /* ══════════════════════════════════════
     Responsive
     ══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .hero__grid {
      gap: 3rem;
    }

    .hero__title {
      font-size: clamp(2rem, 4.5vw, 2.75rem);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: calc(var(--topbar-height, 0px) + var(--header-height, 70px) + 3rem);
      padding-bottom: 3rem;
    }

    .hero__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero__title {
      max-width: none;
    }

    .hero__desc {
      max-width: none;
    }

    .hero__ctas {
      flex-direction: column;
    }

    .hero__cta-primary,
    .hero__cta-secondary {
      width: 100%;
      justify-content: center;
    }

    .hero__seo-text {
      padding: 1.25rem 1.5rem;
    }

    .hero__metrics {
      gap: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .hero__badge {
      font-size: 0.75rem;
    }

    .hero__seo-text {
      font-size: 0.875rem;
    }

    .hero__metrics {
      gap: 1rem;
    }

    .hero__metric-value {
      font-size: 1.125rem;
    }
  }
</style>
