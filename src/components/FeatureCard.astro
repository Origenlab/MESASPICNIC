---
/**
 * FeatureCard — OrigenLab Standard v2
 * Card de diferenciador tipo "trust item": borde sutil, ícono/número,
 * título H3 y descripción. Sin sección de imagen ni placeholder.
 * Código limpio. Sin animaciones.
 */
interface Props {
  title: string;
  description: string;
  index?: number;
}

const {
  title,
  description,
  index,
} = Astro.props;

const num = index !== undefined ? String(index + 1).padStart(2, '0') : null;
---

<div class="fc">
  {num && <span class="fc__num" aria-hidden="true">{num}</span>}
  <div class="fc__body">
    <h3 class="fc__title">{title}</h3>
    <p class="fc__desc">{description}</p>
  </div>
</div>

<style>
  .fc {
    background: #fff;
    border: 1px solid var(--c-border, #E7E0D8);
    border-radius: var(--radius-md, 12px);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }

  .fc::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md, 12px);
    background: linear-gradient(135deg, rgba(44, 85, 48, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .fc__num {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--c-primary, #2C5530);
    opacity: 0.12;
    line-height: 1;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    align-self: flex-start;
  }

  .fc__body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .fc__title {
    font-size: 1.125rem;
    color: var(--c-text, #1C1917);
    line-height: 1.3;
    font-weight: 600;
  }

  .fc__desc {
    font-size: 0.875rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.7;
  }
</style>
