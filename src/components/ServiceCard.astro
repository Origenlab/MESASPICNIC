---
/**
 * ServiceCard — rediseño v3
 * ─────────────────────────
 * Card limpia: sin ícono, sin animaciones de hover,
 * botón CTA sólido y diseño mejorado.
 */
interface Props {
  title: string;
  description: string;
  image: string;
  href: string;
  btnLabel?: string;
  badge?: string;
  icon?: string;
}

const {
  title,
  description,
  image,
  href,
  btnLabel = "Ver detalles",
  badge,
} = Astro.props;
---

<div class="sc">
  <div class="sc__img">
    <img src={image} alt={title} loading="lazy" width="400" height="300" />
    {badge && <span class="sc__badge">{badge}</span>}
  </div>
  <div class="sc__body">
    <h3 class="sc__title">{title}</h3>
    <p class="sc__desc">{description}</p>
    <a href={href} class="sc__btn">{btnLabel}</a>
  </div>
</div>

<style>
  .sc {
    background: #fff;
    border: 1px solid var(--c-border, #E0D9D0);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .sc__img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    position: relative;
  }
  .sc__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sc__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 50px;
    padding: 4px 13px;
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--c-primary, #2C5530);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    pointer-events: none;
  }

  .sc__body {
    padding: 1.375rem 1.5rem 1.625rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    border-top: 3px solid var(--c-primary, #2C5530);
  }

  .sc__title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--c-text, #1C1917);
    margin-bottom: 0.625rem;
    line-height: 1.3;
  }

  .sc__desc {
    font-size: 0.84rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.72;
    flex: 1;
    margin-bottom: 1.375rem;
  }

  .sc__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--c-primary, #2C5530);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    padding: 0.65rem 1.25rem;
    border-radius: 8px;
    width: 100%;
    transition: background 0.18s ease;
  }
  .sc__btn:hover {
    background: var(--c-primary-dark, #224228);
  }
</style>
