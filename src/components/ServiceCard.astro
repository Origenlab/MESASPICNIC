---
interface Props {
  title: string;
  description: string;
  image: string;
  href: string;
}

const { title, description, image, href } = Astro.props;
---

<a href={href} class="service-card">
  <div class="service-card-img">
    <img src={image} alt={title} loading="lazy" width="400" height="300" />
  </div>
  <div class="service-card-body">
    <h3 class="service-card-title">{title}</h3>
    <p class="service-card-desc">{description}</p>
    <span class="service-card-link">Ver más →</span>
  </div>
</a>

<style>
  .service-card {
    display: block;
    background: #fff;
    border-radius: var(--radius-md, 12px);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transition: transform 0.3s var(--ease, ease), box-shadow 0.3s var(--ease, ease);
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .service-card-img {
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .service-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease, ease);
  }

  .service-card:hover .service-card-img img {
    transform: scale(1.05);
  }

  .service-card-body {
    padding: 1.5rem;
  }

  .service-card-title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--c-primary, #2D5016);
  }

  .service-card-desc {
    color: var(--c-text-muted, #6b7280);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .service-card-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-accent, #D4A574);
    transition: color 0.2s;
  }

  .service-card:hover .service-card-link {
    color: var(--c-primary, #2D5016);
  }
</style>
