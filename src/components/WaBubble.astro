---
/**
 * WaBubble — MESPIC
 * Burbuja flotante de WhatsApp, presente en TODO el sitio (incluida en BaseLayout).
 * Enlace DIRECTO a WhatsApp con mensaje precargado. Sin intermediarios.
 *
 * Desktop: círculo que despliega una etiqueta al pasar el cursor.
 * Mobile: solo el ícono (toca y abre WhatsApp). Respeta safe-area de iOS.
 * Pulso sutil para llamar la atención (se desactiva con prefers-reduced-motion).
 */
interface Props {
  whatsapp?: string;
  message?: string;
  label?: string;
}

const {
  whatsapp = "5530682988",
  message = "Hola, quiero cotizar mesas picnic para mi evento.",
  label = "Cotiza por WhatsApp",
} = Astro.props;

const waHref = `https://wa.me/52${whatsapp}?text=${encodeURIComponent(message)}`;
---

<a
  href={waHref}
  class="wa-float"
  target="_blank"
  rel="noopener"
  aria-label="Escríbenos por WhatsApp"
>
  <span class="wa-float__label">{label}</span>
  <span class="wa-float__icon">
    <svg width="30" height="30" viewBox="0 0 24 24" fill="#fff" aria-hidden="true" focusable="false">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </span>
</a>

<style>
  .wa-float {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    right: max(1.25rem, env(safe-area-inset-right));
    bottom: max(1.25rem, env(safe-area-inset-bottom));
    z-index: 900;
    display: flex;
    align-items: center;
    padding: 6px;
    background: #25D366;
    border-radius: 999px;
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.36), 0 2px 6px rgba(0, 0, 0, 0.14);
    text-decoration: none;
    color: #fff;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .wa-float:hover {
    background: #1eb858;
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(37, 211, 102, 0.45), 0 3px 8px rgba(0, 0, 0, 0.18);
  }

  .wa-float:focus-visible {
    outline: 3px solid #1B3B20;
    outline-offset: 3px;
  }

  .wa-float__icon {
    position: relative;
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  /* Anillo de pulso sutil */
  .wa-float__icon::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5);
    animation: wa-pulse 2.4s ease-out infinite;
  }

  @keyframes wa-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5); }
    70%  { box-shadow: 0 0 0 16px rgba(37, 211, 102, 0); }
    100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0); }
  }

  .wa-float__label {
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    white-space: nowrap;
    font-family: inherit;
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1;
    color: #fff;
    transition: max-width 0.35s ease, opacity 0.25s ease, padding 0.35s ease;
  }

  .wa-float:hover .wa-float__label,
  .wa-float:focus-visible .wa-float__label {
    max-width: 240px;
    opacity: 1;
    padding: 0 0.5rem 0 1rem;
  }

  /* Sin etiqueta en táctil / mobile: solo el ícono */
  @media (hover: none), (max-width: 768px) {
    .wa-float__label { display: none; }
  }

  @media (max-width: 640px) {
    .wa-float {
      right: max(1rem, env(safe-area-inset-right));
      bottom: max(1rem, env(safe-area-inset-bottom));
      padding: 5px;
    }
    .wa-float__icon { width: 48px; height: 48px; }
    .wa-float__icon svg { width: 26px; height: 26px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-float,
    .wa-float__label { transition: none; }
    .wa-float__icon::before { animation: none; }
  }
</style>
