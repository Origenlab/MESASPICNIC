---
/**
 * FunnelProgress — MESPIC Navigation Funnel v2
 * ─────────────────────────────────────────────
 * Stepper horizontal premium con línea de progreso.
 * Fondo cálido que contrasta con el CtaBar oscuro.
 * Auto-detecta la etapa desde Astro.url.pathname.
 */

const path = Astro.url.pathname;

let activeStep = 0;
if (path === '/' || path === '') activeStep = 0;
else if (path.startsWith('/servicios')) activeStep = 1;
else if (path.startsWith('/catalogo'))  activeStep = 2;
else if (path.startsWith('/paquetes'))  activeStep = 3;
else if (path.startsWith('/cotizar') || path.startsWith('/contacto')) activeStep = 4;

const displayStep = activeStep === 0 ? 1 : activeStep;

const steps = [
  {
    num: 1,
    label: 'Servicios',
    sub: 'Elige tu tipo de evento',
    href: '/servicios/',
  },
  {
    num: 2,
    label: 'Catálogo',
    sub: 'Explora el mobiliario',
    href: '/catalogo/',
  },
  {
    num: 3,
    label: 'Paquetes',
    sub: 'Selecciona tu paquete',
    href: '/paquetes/',
  },
  {
    num: 4,
    label: 'Cotizar',
    sub: 'Obtén tu precio final',
    href: '/cotizar/',
  },
];
---

<div class="fp" role="navigation" aria-label="Pasos para contratar MESPIC">
  <div class="fp__inner">

    <!-- Etiqueta lateral -->
    <div class="fp__lead" aria-hidden="true">
      <svg class="fp__leaf" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 8C8 10 5.9 16.17 3.82 19.25c-.87 1.29.98 2.45 1.91 1.26C7.27 18.35 12 16 12 16s-1 3 2 4c5 0 8-5 8-10a7 7 0 00-5-7z"/>
      </svg>
      <span class="fp__lead-text">Tu recorrido</span>
    </div>

    <!-- Stepper -->
    <ol class="fp__steps" role="list">
      {steps.map((step, i) => {
        const isDone    = step.num < displayStep;
        const isCurrent = step.num === displayStep;
        const isFuture  = step.num > displayStep;
        return (
          <li
            class:list={[
              'fp__step',
              isDone    && 'fp__step--done',
              isCurrent && 'fp__step--current',
              isFuture  && 'fp__step--future',
            ]}
          >
            {/* Línea conectora izquierda */}
            {i > 0 && (
              <span
                class:list={[
                  'fp__line',
                  (isDone || isCurrent) && 'fp__line--filled',
                ]}
                aria-hidden="true"
              />
            )}

            <a href={step.href} class="fp__step-link" aria-current={isCurrent ? 'step' : undefined}>
              {/* Círculo indicador */}
              <span class="fp__circle" aria-hidden="true">
                {isDone ? (
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                ) : (
                  <span class="fp__num">{step.num}</span>
                )}
              </span>

              {/* Texto */}
              <span class="fp__text">
                <span class="fp__name">{step.label}</span>
                <span class="fp__sub">{step.sub}</span>
              </span>
            </a>
          </li>
        );
      })}
    </ol>

    <!-- CTA derecha: siguiente paso -->
    <a href={steps[Math.min(displayStep, 3)].href} class="fp__cta" aria-label="Ir al siguiente paso">
      <span class="fp__cta-text">Siguiente</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </a>

  </div>
</div>

<style>
  /* ══════════════════════════════════════════════
     WRAPPER — fondo cálido parchment / madera
  ══════════════════════════════════════════════ */
  .fp {
    background: linear-gradient(135deg, #FAF3E8 0%, #F5EAD8 60%, #F0E4CE 100%);
    border-top: 1px solid #E2C9A8;
    border-bottom: 2px solid #D4B896;
    padding: 0.9rem 0;
    position: relative;
    overflow: hidden;
  }

  /* Línea decorativa de madera */
  .fp::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent,
      transparent 120px,
      rgba(180, 130, 80, 0.04) 120px,
      rgba(180, 130, 80, 0.04) 121px
    );
    pointer-events: none;
  }

  /* ── Layout interior ── */
  .fp__inner {
    max-width: var(--container, 1400px);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  /* ══════════════════════════════════════════════
     ETIQUETA LATERAL
  ══════════════════════════════════════════════ */
  .fp__lead {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    flex-shrink: 0;
    padding-right: 1.25rem;
    border-right: 1.5px solid #D4B896;
    min-width: 72px;
  }

  .fp__leaf {
    color: #7A5C3A;
    opacity: 0.7;
  }

  .fp__lead-text {
    font-size: 0.5625rem;
    font-weight: 750;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #7A5C3A;
    white-space: nowrap;
  }

  /* ══════════════════════════════════════════════
     STEPPER — lista de pasos
  ══════════════════════════════════════════════ */
  .fp__steps {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .fp__steps::-webkit-scrollbar { display: none; }

  /* ── Paso individual ── */
  .fp__step {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
    position: relative;
  }

  /* ── Línea de conexión ── */
  .fp__line {
    flex: 1;
    height: 2px;
    background: #D4B896;
    border-radius: 999px;
    transition: background 0.3s ease;
    min-width: 20px;
  }

  .fp__line--filled {
    background: linear-gradient(90deg, #C8956C 0%, #B07A4E 100%);
  }

  /* ── Link del paso ── */
  .fp__step-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    padding: 0.25rem 0.625rem;
    border-radius: 10px;
    text-decoration: none;
    flex-shrink: 0;
    transition: background 0.18s ease;
  }

  .fp__step-link:hover {
    background: rgba(180, 120, 60, 0.08);
  }

  /* ── Círculo indicador ── */
  .fp__circle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    flex-shrink: 0;
    transition: all 0.25s ease;
    position: relative;
  }

  .fp__num {
    font-size: 0.8125rem;
    font-weight: 800;
    line-height: 1;
  }

  /* ── Texto ── */
  .fp__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.05rem;
    line-height: 1.15;
  }

  .fp__name {
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .fp__sub {
    font-size: 0.5875rem;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  /* ══════════════════════════════════════════════
     ESTADOS
  ══════════════════════════════════════════════ */

  /* DONE — completado */
  .fp__step--done .fp__circle {
    background: #C8956C;
    color: #fff;
    box-shadow: 0 2px 8px rgba(200, 149, 108, 0.4);
  }
  .fp__step--done .fp__name { color: #8B6240; }
  .fp__step--done .fp__sub  { color: #B8956A; }

  /* CURRENT — paso activo */
  .fp__step--current .fp__circle {
    background: #2C5530;
    color: #fff;
    box-shadow:
      0 0 0 4px rgba(44, 85, 48, 0.15),
      0 3px 10px rgba(44, 85, 48, 0.3);
    transform: scale(1.12);
  }
  .fp__step--current .fp__name {
    color: #1E3D21;
    font-weight: 800;
    font-size: 0.8125rem;
  }
  .fp__step--current .fp__sub { color: #4A7050; }
  .fp__step--current .fp__step-link {
    background: rgba(44, 85, 48, 0.07);
  }

  /* FUTURE — próximos pasos */
  .fp__step--future .fp__circle {
    background: #fff;
    color: #C4A882;
    border: 2px solid #D4B896;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }
  .fp__step--future .fp__name { color: #B09070; }
  .fp__step--future .fp__sub  { color: #C8A880; }

  /* ══════════════════════════════════════════════
     BOTÓN CTA DERECHO
  ══════════════════════════════════════════════ */
  .fp__cta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 1rem;
    background: #2C5530;
    color: #fff;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    flex-shrink: 0;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(44, 85, 48, 0.3);
    transition: background 0.18s ease, transform 0.18s ease;
    margin-left: 0.5rem;
  }

  .fp__cta:hover {
    background: #234425;
    transform: translateX(2px);
  }

  .fp__cta-text {
    font-size: 0.6875rem;
  }

  /* ══════════════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .fp__cta-text { display: none; }
    .fp__cta { padding: 0.45rem 0.65rem; }
  }

  @media (max-width: 768px) {
    .fp__lead { display: none; }
    .fp__inner { padding: 0 0.75rem; gap: 0; }
    .fp__step-link { padding: 0.2rem 0.375rem; }
    .fp__sub { display: none; }
    .fp__circle { width: 28px; height: 28px; }
    .fp__cta { display: none; }
    .fp__line { min-width: 10px; }
  }

  @media (max-width: 480px) {
    .fp__name { font-size: 0.6875rem; }
    .fp__circle { width: 24px; height: 24px; }
    .fp__num { font-size: 0.6875rem; }
  }
</style>
