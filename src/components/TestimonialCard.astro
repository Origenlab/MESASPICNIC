---
/**
 * TestimonialCard — OrigenLab Standard
 * Card de reseña con avatar, estrellas variables, cita y datos del evento.
 * Sin animaciones. Código limpio.
 */
interface Props {
  name: string;
  event: string;
  quote: string;
  stars?: number;
  image?: string;
  date?: string;
}

const {
  name,
  event,
  quote,
  stars = 5,
  image,
  date,
} = Astro.props;

const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();
const filledStars = Math.min(Math.max(Math.round(stars), 1), 5);
---

<div class="tc">
  <div class="tc__top">
    <div class="tc__stars" aria-label={`${filledStars} de 5 estrellas`}>
      {Array.from({ length: 5 }).map((_, i) => (
        <span class:list={['tc__star', { 'tc__star--empty': i >= filledStars }]}>★</span>
      ))}
    </div>
    {date && <span class="tc__date">{date}</span>}
  </div>

  <blockquote class="tc__quote">{quote}</blockquote>

  <div class="tc__author">
    {image ? (
      <img src={image} alt={name} class="tc__avatar" width="44" height="44" loading="lazy" />
    ) : (
      <div class="tc__avatar tc__avatar--placeholder" aria-hidden="true">{initials}</div>
    )}
    <div class="tc__info">
      <span class="tc__name">{name}</span>
      <span class="tc__event">{event}</span>
    </div>
  </div>
</div>

<style>
  .tc {
    background: #fff;
    border: 1px solid var(--c-border, #E7E0D8);
    border-radius: var(--radius-md, 12px);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tc__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .tc__stars {
    display: flex;
    gap: 1px;
  }

  .tc__star {
    color: var(--c-star, #F59E0B);
    font-size: 1rem;
  }

  .tc__star--empty {
    color: var(--c-border, #E7E0D8);
  }

  .tc__date {
    font-size: 0.75rem;
    color: var(--c-text-muted, #78716C);
  }

  .tc__quote {
    font-size: 0.9375rem;
    color: var(--c-text, #1C1917);
    line-height: 1.7;
    flex: 1;
  }

  .tc__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--c-border, #E7E0D8);
  }

  .tc__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .tc__avatar--placeholder {
    background: var(--c-bg-alt, #F7F4F0);
    color: var(--c-text-muted, #78716C);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .tc__info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .tc__name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--c-text, #1C1917);
  }

  .tc__event {
    font-size: 0.8125rem;
    color: var(--c-text-muted, #78716C);
  }
</style>
