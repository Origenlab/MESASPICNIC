---
interface Props {
  name: string;
  event: string;
  quote: string;
}

const { name, event, quote } = Astro.props;
---

<div class="testimonial-card">
  <div class="testimonial-stars" aria-label="5 estrellas">★★★★★</div>
  <blockquote class="testimonial-quote">{quote}</blockquote>
  <div class="testimonial-author">
    <span class="testimonial-name">{name}</span>
    <span class="testimonial-event">{event}</span>
  </div>
</div>

<style>
  .testimonial-card {
    background: #fff;
    border-radius: var(--radius-md, 12px);
    padding: 2rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .testimonial-stars {
    color: #F59E0B;
    font-size: 1.25rem;
    letter-spacing: 2px;
  }

  .testimonial-quote {
    font-size: 1rem;
    color: var(--c-text, #1a1a1a);
    line-height: 1.7;
    font-style: italic;
    flex: 1;
  }

  .testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--c-border, #e5e7eb);
  }

  .testimonial-name {
    font-weight: 600;
    color: var(--c-text, #1a1a1a);
  }

  .testimonial-event {
    font-size: 0.875rem;
    color: var(--c-text-muted, #6b7280);
  }
</style>
