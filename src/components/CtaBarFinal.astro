---
/**
 * CtaBarFinal — OrigenLab Standard
 * Barra de conversión al final de la página.
 * El usuario ya navegó — aquí sí puede contactar.
 * Sin animaciones. Código limpio.
 */
interface Props {
  headline?: string;
  subtext?: string;
  phone?: string;
  whatsapp?: string;
  waMessage?: string;
  cotizarHref?: string;
}

const {
  headline = "¿Listo para tu evento?",
  subtext = "Cuéntanos fecha y número de invitados — cotización con precio y disponibilidad el mismo día hábil.",
  phone = "55 6432 8954",
  whatsapp = "5564328954",
  waMessage = "Hola, quiero cotizar mesas picnic para mi evento.",
  cotizarHref = "/cotizar/",
} = Astro.props;

const waHref = `https://wa.me/${whatsapp}?text=${encodeURIComponent(waMessage)}`;
---

<section class="ctaf" aria-label="Contacto">
  <div class="container ctaf__inner">
    <div class="ctaf__text">
      <h2 class="ctaf__headline">{headline}</h2>
      <p class="ctaf__sub">{subtext}</p>
    </div>
    <div class="ctaf__actions">
      <!-- Abre DMChamp widget interno, no WhatsApp directo -->
      <button
        type="button"
        class="ctaf__btn ctaf__btn--wa"
        onclick="if(window.openMespicChat){openMespicChat()}else{window.open('https://wa.me/5564328954','_blank','noopener')}"
        aria-label="Abrir chat de WhatsApp"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </button>
      <a href={`tel:+52${whatsapp}`} class="ctaf__btn ctaf__btn--phone">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        {phone}
      </a>
      <a href={cotizarHref} class="ctaf__btn ctaf__btn--cotizar">
        Cotizar en línea →
      </a>
    </div>
  </div>
</section>

<style>
  .ctaf {
    background: linear-gradient(135deg, #1B3B20 0%, var(--c-primary, #2C5530) 55%, #1D4A25 100%);
    padding: 3.5rem 0;
  }

  .ctaf__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .ctaf__headline {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: #fff;
    margin-bottom: 0.375rem;
    line-height: 1.2;
  }

  .ctaf__sub {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9375rem;
  }

  .ctaf__actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .ctaf__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    border-radius: var(--radius-sm, 8px);
    font-size: 0.9375rem;
    font-weight: 600;
    white-space: nowrap;
    transition: background 0.2s var(--ease, ease);
    border: none;
    cursor: pointer;
    font-family: inherit;
    text-decoration: none;
  }

  .ctaf__btn--wa {
    background: #25D366;
    color: #fff;
  }

  .ctaf__btn--wa:hover {
    background: #1fb855;
  }

  .ctaf__btn--phone {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .ctaf__btn--phone:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .ctaf__btn--cotizar {
    background: #fff;
    color: var(--c-primary, #2C5530);
  }

  .ctaf__btn--cotizar:hover {
    background: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 1024px) {
    .ctaf__inner {
      flex-direction: column;
      text-align: center;
    }

    .ctaf__actions {
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .ctaf__actions {
      flex-direction: column;
      width: 100%;
    }

    .ctaf__btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
