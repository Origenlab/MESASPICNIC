<style>
  /* ══════════════════════════════════════════════════
     PRE-FOOTER CTA STRIP
     ══════════════════════════════════════════════════ */
  .ft-cta {
    background: linear-gradient(135deg, #1a0f08 0%, #2d1a0e 50%, #1a0f08 100%);
    border-top: 1px solid rgba(200, 149, 108, 0.2);
    padding: 3.5rem 0;
  }

  .ft-cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .ft-cta__eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-accent, #C8956C);
    margin-bottom: 0.5rem;
  }

