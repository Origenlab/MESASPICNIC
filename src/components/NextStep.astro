---
/**
 * NextStep — MESPIC Navigation Funnel
 * ─────────────────────────────────────
 * Sección "Tu siguiente paso" que guía al usuario
 * al próximo punto del embudo. Va ANTES de CtaBarFinal.
 *
 * Props:
 *  - titulo     : Título del siguiente paso
 *  - subtitulo  : Texto de apoyo (opcional)
 *  - href       : URL del siguiente paso
 *  - btnLabel   : Texto del botón
 *  - step       : Número del paso actual (1-4) para contexto visual
 *  - secondBtn  : { label, href } — botón secundario opcional
 */
interface SecondBtn {
  label: string;
  href: string;
}

interface Props {
  titulo: string;
  subtitulo?: string;
  href: string;
  btnLabel: string;
  step?: 1 | 2 | 3 | 4;
  secondBtn?: SecondBtn;
}

const {
  titulo,
  subtitulo,
  href,
  btnLabel,
  step,
  secondBtn,
} = Astro.props;

const stepLabels: Record<number, { from: string; to: string }> = {
  1: { from: 'Servicios', to: 'Catálogo' },
  2: { from: 'Catálogo',  to: 'Paquetes' },
  3: { from: 'Paquetes',  to: 'Cotizar'  },
};

const context = step ? stepLabels[step] : null;
---

<section class="next-step" aria-label="Siguiente paso">
  <div class="container next-step__inner">

    <!-- Icono de flecha + contexto de paso -->
    <div class="next-step__meta">
      {context && (
        <p class="next-step__breadcrumb" aria-label={`Pasando de ${context.from} a ${context.to}`}>
          <span class="ns-crumb">{context.from}</span>
          <svg class="ns-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          <span class="ns-crumb ns-crumb--next">{context.to}</span>
        </p>
      )}
      <div class="next-step__icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 16 16 12 12 8"/>
          <line x1="8" y1="12" x2="16" y2="12"/>
        </svg>
      </div>
    </div>

    <!-- Texto principal -->
    <div class="next-step__text">
      <h2 class="next-step__titulo">{titulo}</h2>
      {subtitulo && <p class="next-step__sub">{subtitulo}</p>}
    </div>

    <!-- CTA -->
    <div class="next-step__actions">
      <a href={href} class="next-step__btn next-step__btn--primary">
        {btnLabel}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
      {secondBtn && (
        <a href={secondBtn.href} class="next-step__btn next-step__btn--secondary">
          {secondBtn.label}
        </a>
      )}
    </div>

  </div>
</section>

<style>
  .next-step {
    background: linear-gradient(135deg, #FAF6F0 0%, #F5EFE6 100%);
    border-top: 1px solid #E8DDD3;
    border-bottom: 1px solid #E8DDD3;
    padding: 2rem 0;
  }

  .next-step__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem 2rem;
  }

  /* ─── Meta (ícono + breadcrumb) ─── */
  .next-step__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .next-step__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .ns-crumb {
    color: rgba(44, 85, 48, 0.5);
  }

  .ns-crumb--next {
    color: var(--c-primary, #2C5530);
    font-weight: 750;
  }

  .ns-arrow {
    color: rgba(44, 85, 48, 0.4);
  }

  .next-step__icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--c-primary, #2C5530);
    color: #fff;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(44, 85, 48, 0.25);
  }

  /* ─── Text ─── */
  .next-step__titulo {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 750;
    color: var(--c-text, #1C1917);
    margin-bottom: 0.375rem;
    line-height: 1.2;
  }

  .next-step__sub {
    font-size: 0.9375rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.5;
    max-width: 52ch;
  }

  /* ─── Actions ─── */
  .next-step__actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
    align-items: center;
  }

  .next-step__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    border-radius: var(--radius-sm, 8px);
    font-size: 0.9375rem;
    font-weight: 650;
    white-space: nowrap;
    text-decoration: none;
    transition: background 0.18s ease, transform 0.18s ease;
  }

  .next-step__btn--primary {
    background: var(--c-primary, #2C5530);
    color: #fff;
    box-shadow: 0 2px 8px rgba(44, 85, 48, 0.2);
  }

  .next-step__btn--primary:hover {
    background: #244826;
    transform: translateX(2px);
  }

  .next-step__btn--secondary {
    background: transparent;
    color: var(--c-primary, #2C5530);
    border: 1.5px solid var(--c-primary, #2C5530);
  }

  .next-step__btn--secondary:hover {
    background: rgba(44, 85, 48, 0.06);
  }

  /* ─── Responsive ─── */
  @media (max-width: 1024px) {
    .next-step__inner {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
    }
    .next-step__actions {
      grid-column: 1 / -1;
      justify-content: flex-start;
    }
  }

  @media (max-width: 640px) {
    .next-step__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .next-step__meta {
      align-items: center;
    }
    .next-step__actions {
      justify-content: center;
      flex-wrap: wrap;
    }
    .next-step__sub {
      max-width: none;
    }
  }
</style>
