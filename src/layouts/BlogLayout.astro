---
/**
 * BlogLayout — MESPIC
 * Layout completo para artículos de blog.
 * Patrón idéntico al resto del sitio:
 *   BaseLayout → Hero(dark) → CtaBar → contenido + sidebar → CtaBarFinal
 * Breadcrumbs en slot="breadcrumbs" → dentro del hdr-stack fijo, debajo del header.
 */
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBar from '../components/CtaBar.astro';
import CtaBarFinal from '../components/CtaBarFinal.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  heroTitle: string;
  heroBadge?: string;
  heroDescription: string;
  heroSeo1: string;
  heroSeo2: string;
  heroMetrics?: Array<{ value: string; label: string }>;
  heroCta?: { label: string; href: string };
  heroCtaSecondary?: { label: string; href: string };
  breadcrumbs?: Array<{ label: string; href?: string }>;
}

const {
  title,
  description,
  canonical,
  ogImage,
  heroTitle,
  heroBadge = "Blog · Guías de eventos",
  heroDescription,
  heroSeo1,
  heroSeo2,
  heroMetrics,
  heroCta = { label: "Cotizar sin compromiso →", href: "/cotizar/" },
  heroCtaSecondary = { label: "Ver catálogo", href: "/catalogo/" },
  breadcrumbs = [],
} = Astro.props;

const defaultBreadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Blog", href: "/blog/" },
  { label: title.replace(/ \| MESPIC$/, "").substring(0, 50) },
];

const crumbs = breadcrumbs.length > 0 ? breadcrumbs : defaultBreadcrumbs;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
>

  <!-- ── Breadcrumbs: slot fijo dentro del hdr-stack, debajo del header ── -->
  <Fragment slot="breadcrumbs">
    <Breadcrumbs items={crumbs} />
  </Fragment>

  <!-- ── Hero — mismo componente que el resto del sitio ── -->
  <Hero
    badge={heroBadge}
    title={heroTitle}
    description={heroDescription}
    seoParagraph1={heroSeo1}
    seoParagraph2={heroSeo2}
    dark={true}
    metrics={heroMetrics}
    ctaPrimary={heroCta}
    ctaSecondary={heroCtaSecondary}
  />

  <!-- ── Barra de navegación rápida (misma que el sitio) ── -->
  <CtaBar />

  <!-- ── Layout de dos columnas: Artículo + Sidebar ── -->
  <div class="blog-wrapper">
    <div class="container blog-layout">

      <!-- ── Columna principal: contenido del artículo ── -->
      <article class="blog-content" itemscope itemtype="https://schema.org/Article">
        <slot />
      </article>

      <!-- ── Sidebar ── -->
      <aside class="blog-sidebar" aria-label="Contenido relacionado">

        <!-- Widget: CTA cotizar -->
        <div class="sidebar-widget sidebar-widget--cta">
          <div class="sw-cta__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3 class="sw-cta__title">¿Planeas una boda?</h3>
          <p class="sw-cta__text">Cotiza sin compromiso. Te respondemos en menos de 30 minutos vía WhatsApp.</p>
          <a href="https://wa.me/5564328954?text=Hola%2C+quiero+cotizar+mesas+picnic+para+mi+boda." target="_blank" rel="noopener" class="sw-cta__btn sw-cta__btn--wa">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Cotizar por WhatsApp
          </a>
          <a href="/cotizar/" class="sw-cta__btn sw-cta__btn--cotizar">Formulario de cotización →</a>
        </div>

        <!-- Widget: Servicios relacionados -->
        <div class="sidebar-widget">
          <h3 class="sidebar-widget__title">Servicios para bodas</h3>
          <ul class="sw-links">
            <li>
              <a href="/servicios/bodas/" class="sw-link">
                <span class="sw-link__text">
                  <strong>Bodas al Aire Libre</strong>
                  <small>Jardines · Haciendas · Terrazas</small>
                </span>
                <svg class="sw-link__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              </a>
            </li>
            <li>
              <a href="/servicios/picnic-romantico/" class="sw-link">
                <span class="sw-link__text">
                  <strong>Picnic Romántico</strong>
                  <small>Pedidas · Aniversarios</small>
                </span>
                <svg class="sw-link__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              </a>
            </li>
            <li>
              <a href="/servicios/eventos-corporativos/" class="sw-link">
                <span class="sw-link__text">
                  <strong>Eventos Corporativos</strong>
                  <small>Team building · Conferencias</small>
                </span>
                <svg class="sw-link__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              </a>
            </li>
            <li>
              <a href="/servicios/fiestas-infantiles/" class="sw-link">
                <span class="sw-link__text">
                  <strong>Fiestas Infantiles</strong>
                  <small>Cumpleaños · Baby shower</small>
                </span>
                <svg class="sw-link__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
              </a>
            </li>
          </ul>
        </div>

        <!-- Widget: Catálogo de productos -->
        <div class="sidebar-widget">
          <h3 class="sidebar-widget__title">Catálogo de productos</h3>
          <div class="sw-products">
            <a href="/catalogo/" class="sw-product">
              <div class="sw-product__img-wrap">
                <img src="/img/mesa-picnic-boda-elegante-decoracion.avif" alt="Mesa Picnic Estándar 2.4 m" loading="lazy" width="280" height="160" />
              </div>
              <div class="sw-product__info">
                <span class="sw-product__name">Mesa Estándar 2.4 m</span>
                <span class="sw-product__cap">6–8 personas</span>
              </div>
            </a>
            <a href="/catalogo/" class="sw-product">
              <div class="sw-product__img-wrap">
                <img src="/img/mesa-picnic-boda-elegante-luces.avif" alt="Mesa Picnic Premium con decoración" loading="lazy" width="280" height="160" />
              </div>
              <div class="sw-product__info">
                <span class="sw-product__name">Mesa Premium con Set</span>
                <span class="sw-product__cap">Decoración incluida</span>
              </div>
            </a>
            <a href="/catalogo/" class="sw-product-cta">Ver catálogo completo →</a>
          </div>
        </div>

        <!-- Widget: Artículos relacionados -->
        <div class="sidebar-widget">
          <h3 class="sidebar-widget__title">Artículos relacionados</h3>
          <ul class="sw-articles">
            <li>
              <a href="/blog/cuantas-mesas-picnic-necesitas-segun-invitados/" class="sw-article">
                <div class="sw-article__img">
                  <img src="/img/mesa-picnic-boda-invitados-atardecer.avif" alt="¿Cuántas mesas picnic necesitas?" loading="lazy" width="80" height="80" />
                </div>
                <div class="sw-article__text">
                  <span class="sw-article__title">¿Cuántas mesas necesitas según tus invitados?</span>
                  <span class="sw-article__meta">Guía de cálculo · 5 min</span>
                </div>
              </a>
            </li>
            <li>
              <a href="/blog/decoracion-mesas-picnic-fiestas-infantiles/" class="sw-article">
                <div class="sw-article__img">
                  <img src="/img/mesa-picnic-fiesta-infantil-globos-colores.avif" alt="Decoración para fiestas infantiles" loading="lazy" width="80" height="80" />
                </div>
                <div class="sw-article__text">
                  <span class="sw-article__title">Ideas de decoración para fiestas infantiles</span>
                  <span class="sw-article__meta">Decoración · 6 min</span>
                </div>
              </a>
            </li>
            <li>
              <a href="/blog/mesas-picnic-eventos-corporativos/" class="sw-article">
                <div class="sw-article__img">
                  <img src="/img/mesa-picnic-evento-corporativo-networking.avif" alt="Mesas picnic para eventos corporativos" loading="lazy" width="80" height="80" />
                </div>
                <div class="sw-article__text">
                  <span class="sw-article__title">Mesas picnic para eventos corporativos</span>
                  <span class="sw-article__meta">Corporativo · 7 min</span>
                </div>
              </a>
            </li>
          </ul>
        </div>

        <!-- Widget: Zonas de cobertura -->
        <div class="sidebar-widget sidebar-widget--coverage">
          <h3 class="sidebar-widget__title">Cobertura</h3>
          <p class="sw-coverage__text">Entregamos en toda la CDMX y zona metropolitana del Estado de México.</p>
          <ul class="sw-coverage__list">
            <li>Ciudad de México (todas las alcaldías)</li>
            <li>Naucalpan · Huixquilucan</li>
            <li>Tlalnepantla · Atizapán</li>
            <li>Metepec · Cuernavaca</li>
          </ul>
          <a href="/cotizar/" class="sw-coverage__link">¿Tu zona? Consúltanos →</a>
        </div>

      </aside>
    </div>
  </div>

  <!-- ── Barra final de conversión ── -->
  <CtaBarFinal
    headline="¿Lista para reservar el mobiliario de tu boda?"
    subtext="Cotiza sin compromiso. Te respondemos en menos de 30 minutos."
    waMessage="Hola, quiero cotizar mesas picnic para mi boda en CDMX."
  />

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     LAYOUT PRINCIPAL — dos columnas
     ═══════════════════════════════════════════ */
  .blog-wrapper {
    background: var(--c-bg, #FEFDFB);
    padding: 3.5rem 0 5rem;
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: start;
  }

  /* ═══════════════════════════════════════════
     SIDEBAR — widgets
     ═══════════════════════════════════════════ */
  .blog-sidebar {
    position: sticky;
    top: calc(var(--topbar-height,36px) + var(--header-height,92px) + var(--bc-height,40px) + 1.5rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-widget {
    background: var(--c-bg, #FEFDFB);
    border: 1px solid var(--c-border, #E7E0D8);
    border-radius: var(--radius-md, 12px);
    padding: 1.5rem;
  }

  .sidebar-widget__title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--c-text, #1C1917);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 1.125rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--c-border, #E7E0D8);
  }

  /* Widget CTA */
  .sidebar-widget--cta {
    background: linear-gradient(145deg, #1B3B20, #2C5530);
    border-color: transparent;
    text-align: center;
  }

  .sw-cta__icon {
    width: 52px;
    height: 52px;
    background: rgba(255,255,255,0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    color: rgba(255,255,255,0.9);
  }

  .sw-cta__title {
    font-size: 1.0625rem;
    color: #ffffff;
    margin-bottom: 0.625rem;
    font-weight: 700;
  }

  .sw-cta__text {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .sw-cta__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-sm, 8px);
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.625rem;
    transition: background 0.2s ease;
  }

  .sw-cta__btn--wa {
    background: #25D366;
    color: #fff;
  }

  .sw-cta__btn--wa:hover { background: #1fb855; }

  .sw-cta__btn--cotizar {
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
    border: 1px solid rgba(255,255,255,0.25);
    margin-bottom: 0;
  }

  .sw-cta__btn--cotizar:hover { background: rgba(255,255,255,0.22); }

  /* Links de servicios */
  .sw-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sw-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.875rem;
    border-radius: var(--radius-sm, 8px);
    transition: background 0.15s ease;
  }

  .sw-link:hover { background: var(--c-bg-alt, #F7F4F0); }

  .sw-link__icon {
    font-size: 1.125rem;
    flex-shrink: 0;
  }

  .sw-link__text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
  }

  .sw-link__text strong {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-text, #1C1917);
    line-height: 1.3;
  }

  .sw-link__text small {
    font-size: 0.75rem;
    color: var(--c-text-muted, #78716C);
  }

  .sw-link__arrow {
    flex-shrink: 0;
    color: var(--c-border, #E7E0D8);
    transition: color 0.15s, transform 0.15s;
  }

  .sw-link:hover .sw-link__arrow {
    color: var(--c-primary, #2C5530);
    transform: translateX(3px);
  }

  /* Productos */
  .sw-products {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .sw-product {
    display: flex;
    gap: 0.875rem;
    align-items: center;
    padding: 0.625rem;
    border-radius: var(--radius-sm, 8px);
    border: 1px solid var(--c-border, #E7E0D8);
    transition: border-color 0.15s, background 0.15s;
  }

  .sw-product:hover {
    border-color: var(--c-primary, #2C5530);
    background: rgba(44,85,48,0.03);
  }

  .sw-product__img-wrap {
    width: 72px;
    height: 60px;
    flex-shrink: 0;
    border-radius: 6px;
    overflow: hidden;
  }

  .sw-product__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sw-product__info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .sw-product__name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-text, #1C1917);
    line-height: 1.3;
  }

  .sw-product__cap {
    font-size: 0.75rem;
    color: var(--c-text-muted, #78716C);
  }

  .sw-product-cta {
    display: block;
    text-align: center;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-primary, #2C5530);
    padding: 0.625rem;
    border: 1px dashed var(--c-primary, #2C5530);
    border-radius: var(--radius-sm, 8px);
    transition: background 0.15s;
    opacity: 0.8;
  }

  .sw-product-cta:hover {
    background: rgba(44,85,48,0.05);
    opacity: 1;
  }

  /* Artículos relacionados */
  .sw-articles {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sw-article {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    padding: 0.75rem 0.5rem;
    border-radius: var(--radius-sm, 8px);
    transition: background 0.15s;
  }

  .sw-article:hover { background: var(--c-bg-alt, #F7F4F0); }

  .sw-article__img {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .sw-article__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sw-article__text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sw-article__title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-text, #1C1917);
    line-height: 1.4;
  }

  .sw-article__meta {
    font-size: 0.75rem;
    color: var(--c-text-muted, #78716C);
  }

  /* Cobertura */
  .sidebar-widget--coverage {
    background: var(--c-bg-alt, #F7F4F0);
    border-color: transparent;
  }

  .sw-coverage__text {
    font-size: 0.875rem;
    color: var(--c-text-muted, #78716C);
    line-height: 1.6;
    margin-bottom: 0.875rem;
  }

  .sw-coverage__list {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 1rem;
  }

  .sw-coverage__list li {
    font-size: 0.8125rem;
    color: var(--c-text, #1C1917);
    padding-left: 1rem;
    position: relative;
  }

  .sw-coverage__list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--c-primary, #2C5530);
    font-weight: 700;
    font-size: 0.75rem;
  }

  .sw-coverage__link {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-primary, #2C5530);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ═══════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════ */
  @media (max-width: 1100px) {
    .blog-layout {
      grid-template-columns: 1fr 300px;
      gap: 2.5rem;
    }
  }

  @media (max-width: 900px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }

    .blog-sidebar {
      position: static;
    }
  }

  @media (max-width: 600px) {
    .blog-wrapper {
      padding: 2.5rem 0 3.5rem;
    }
  }
</style>
