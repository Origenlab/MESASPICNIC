      "status": "aprobado",
      "description": "Patrón de sección para procesos paso a paso. Grid 6 cols — fila 1: 3 tarjetas (span 2 c/u), fila 2: 2 tarjetas (span 3 c/u). Tarjetas blancas con borde terracota superior, número fantasma verde y gradiente sutil. Responsive: 2 cols en tablet, 1 col en móvil.",
      "file_referencia": "src/pages/servicios/bodas/index.astro#proceso",
      "obsidian_doc": "obsidian-vault/MESPIC/Template L3 — Proceso Cards.md",
      "spec": {
        "clases_css": [
          ".proceso-cards",
          ".paso-card",
          ".paso-card__num",
          ".paso-card__body",
          ".paso-card__title",
          ".paso-card__text"
        ],
        "tokens": {
          "border": "var(--c-border, #E7E0D8)",
          "acento_top": "var(--c-accent, #C8956C)",
          "numero_color": "var(--c-primary, #2C5530)",
          "numero_opacity": "0.12",
          "border_radius": "var(--radius-md, 12px)",
          "padding": "1.75rem",
          "gap": "1.25rem"
        },
        "grid": {
          "desktop": "repeat(6, 1fr) — pasos 1-3: span 2, pasos 4-5: span 3",
          "tablet_1024": "repeat(2, 1fr) — todos span 1",
          "mobile_640": "1fr"
        },
        "pasos_optimos": 5,
        "variantes_validas": [3, 4, 5, 6],
        "seccion_padre_recomendada": "section.section.section-alt",
        "requiere_section_header": true,
        "badge_section_header": "Cómo trabajamos",
        "sin_animaciones": true
      },
